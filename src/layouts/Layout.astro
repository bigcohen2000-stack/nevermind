---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { ClientRouter } from "astro:transitions";
import { Search } from "lucide-react";
import A11yWidget from "../components/A11yWidget.astro";
import SearchModal from "../components/SearchModal";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import WhisperBanner from "../components/WhisperBanner.astro";
import appConfig from "../config/appConfig.json";
import { disclaimerLong } from "../lib/services";

const {
  title,
  description,
  frontmatter,
  hasInquirySection,
  faqItems,
  image,
  noIndex = false,
  waArticleSlug = "",
} = Astro.props;

const waTags = Array.isArray(frontmatter?.tags) ? frontmatter.tags : [];
const waArticleTitle = typeof title === "string" ? title : "";
const waSlug = typeof waArticleSlug === "string" ? waArticleSlug.trim() : "";

const siteTitle = appConfig.site.name;
const siteDescription = "מרחב חקירה שקט לבהירות, דיוק רגשי והבנה בגובה העיניים.";
const siteUrl = appConfig.site.url;
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const pageDescription = description ?? frontmatter?.description ?? siteDescription;
const pageUrl = Astro.url ? new URL(Astro.url.pathname, siteUrl).toString() : siteUrl;
const ogImage = image || (frontmatter?.image ? new URL(frontmatter.image, siteUrl).toString() : `${siteUrl}/og.jpg`);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteTitle,
  url: siteUrl,
  description: siteDescription,
  inLanguage: "he-IL",
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteTitle,
  url: siteUrl,
  inLanguage: "he-IL",
  publisher: {
    "@type": "Organization",
    name: siteTitle,
    url: siteUrl,
  },
};

const normalizeSegment = (segment: string) => {
  const map: Record<string, string> = {
    articles: "מאמרים",
    topics: "נושאים",
    now: "מה המצב עכשיו",
    training: "הכשרות",
    admin: "ניהול",
    services: "שירותים",
    glossary: "הגדרות מחדש",
    questions: "שאלות קצרות",
    intake: "טופס הכנה לשיחה",
    "personal-consultation": "ייעוץ אישי",
    "premium-access": "גישת פרימיום",
    journey: "מסלולי בהירות",
    "root-problem-tree": "עץ שורש הבעיה",
    "forbidden-library": "הספרייה האסורה",
    accessibility: "הצהרת נגישות",
  };

  return map[segment] ?? segment;
};

const pathName = Astro.url?.pathname ?? "/";
const shouldNoIndexByPath = pathName.startsWith("/admin/");
const effectiveNoIndex = noIndex || shouldNoIndexByPath;
const pathSegments = pathName.split("/").filter(Boolean);
const breadcrumbItems = [{ name: "בית", item: siteUrl }];
let runningUrl = siteUrl.replace(/\/$/, "");

pathSegments.forEach((segment: string, index: number) => {
  runningUrl = `${runningUrl}/${segment}`;
  const isLast = index === pathSegments.length - 1;
  const label = isLast && frontmatter?.title ? frontmatter.title : normalizeSegment(segment);
  breadcrumbItems.push({ name: label, item: runningUrl });
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: item.item,
  })),
};

const toIso = (value: string | Date | undefined) => {
  if (!value) return undefined;
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? undefined : date.toISOString();
};

const articleSchema = frontmatter
  ? {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: frontmatter.title ?? pageTitle,
      description: frontmatter.description ?? pageDescription,
      author: {
        "@type": "Person",
        name: frontmatter.author ?? "השם לא משנה",
      },
      datePublished: toIso(frontmatter.pubDate),
      dateModified: toIso(frontmatter.updatedDate) ?? toIso(frontmatter.pubDate),
      image: ogImage,
      inLanguage: "he-IL",
      mainEntityOfPage: pageUrl,
      publisher: {
        "@type": "Organization",
        name: siteTitle,
        url: siteUrl,
      },
    }
  : null;

const normalizedFaqItems = Array.isArray(faqItems) ? faqItems : [];
const fallbackFaqItems =
  hasInquirySection && normalizedFaqItems.length === 0 && frontmatter?.description
    ? [
        {
          question: `מה בודקים במאמר "${frontmatter.title ?? pageTitle}"?`,
          answer: frontmatter.description,
        },
      ]
    : [];
const faqItemsForSchema = normalizedFaqItems.length > 0 ? normalizedFaqItems : fallbackFaqItems;
const faqSchema =
  faqItemsForSchema.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqItemsForSchema.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }
    : null;

const youtubeIdRaw = typeof frontmatter?.youtubeId === "string" ? frontmatter.youtubeId.trim() : "";
const videoSummaryPointsForSchema = Array.isArray(frontmatter?.videoSummaryPoints)
  ? frontmatter.videoSummaryPoints.map((p: string) => String(p).trim()).filter(Boolean)
  : [];

const videoObjectSchema =
  youtubeIdRaw.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "VideoObject",
        name: frontmatter?.title ?? pageTitle,
        description: frontmatter?.description ?? pageDescription,
        thumbnailUrl: [`https://i.ytimg.com/vi/${youtubeIdRaw}/hqdefault.jpg`],
        uploadDate: toIso(frontmatter?.pubDate),
        contentUrl: `https://www.youtube.com/watch?v=${youtubeIdRaw}`,
        embedUrl: `https://www.youtube-nocookie.com/embed/${youtubeIdRaw}`,
        ...(videoSummaryPointsForSchema.length > 0
          ? {
              keywords: videoSummaryPointsForSchema.join(", "),
              transcript: videoSummaryPointsForSchema.map((line: string) => `• ${line}`).join("\n"),
            }
          : {}),
        publisher: {
          "@type": "Organization",
          name: siteTitle,
          url: siteUrl,
        },
        inLanguage: "he-IL",
      }
    : null;

const schemas = [organizationSchema, websiteSchema, breadcrumbSchema, articleSchema, videoObjectSchema, faqSchema].filter(Boolean);
const randomArticlePaths = (await getCollection("articles", ({ data }) => data.draft !== true)).map((entry) => `/articles/${entry.slug}`);

const socialLinks = [
  { label: "פייסבוק", href: "https://www.facebook.com/nevermindyakir", mark: "f" },
  { label: "אינסטגרם", href: "https://www.instagram.com/nevermind.co.il/", mark: "IG" },
  { label: "טיקטוק", href: "https://www.tiktok.com/@nevermind.co.il", mark: "♪" },
  { label: "X", href: "https://x.com/nevermindyakir", mark: "X" },
];

const navItems = [
  { href: "/", label: "בית" },
  { href: "/articles/", label: "מאמרים" },
  { href: "/glossary/", label: "הגדרות מחדש" },
  { href: "/services/", label: "שירותים" },
  { href: "/questions/", label: "שאלות קצרות" },
  { href: "/now/", label: "מה המצב עכשיו" },
];
---
<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {effectiveNoIndex && <meta name="robots" content="noindex,nofollow,noarchive" />}
    <link rel="canonical" href={pageUrl} />

    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="he_IL" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preload" href="/fonts/assistant-hebrew-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/assistant-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemas)}></script>
    <ClientRouter />

  </head>
  <body data-whisper-banner-state="hidden" class="min-h-screen antialiased selection:bg-[color-mix(in_srgb,var(--nm-accent)_18%,var(--nm-bg))] selection:text-[var(--nm-fg)]">
    <a
      href="#main-content"
      class="sr-only transition-colors duration-200 focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-md focus:bg-[var(--nm-bg-canvas)] focus:px-4 focus:py-2 focus:text-[var(--nm-fg)] focus:ring-2 focus:ring-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)] shadow-xl"
    >
      דלג לתוכן הראשי
    </a>

    <WhisperBanner />

    <nav data-nav class="fixed inset-x-0 top-[var(--nm-nav-top,1.5rem)] z-50 flex justify-center px-4 transition-[top] duration-300">
      <div class="flex flex-wrap items-center justify-center gap-3 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)]/92 px-5 py-3 shadow-[0_14px_34px_color-mix(in_srgb,var(--nm-fg)_8%,transparent)] backdrop-blur-md">
        {navItems.map((item) => (
          <a href={item.href} class="text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_82%,var(--nm-bg))] transition-colors duration-200 hover:text-[var(--nm-accent)]">{item.label}</a>
        ))}
        <button
          type="button"
          data-random-article-trigger
          class="rounded-full bg-[var(--nm-accent)] px-4 py-2 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
        >
          הפתע אותי
        </button>
        <button
          id="search-trigger"
          data-search-trigger
          aria-label="חיפוש במרכז הידע | מה מעסיק אותך כרגע?"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition-colors duration-200 hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] hover:text-[var(--nm-accent)]"
        >
          <Search className="h-4 w-4" />
        </button>
      </div>
    </nav>

    <main id="main-content" class="relative z-10 mx-auto w-full max-w-6xl px-6 pb-20 pt-32">
      <slot />
    </main>

    <footer data-footer class="mt-20 border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-6 py-12">
      <div class="mx-auto flex max-w-6xl flex-col gap-6">
        <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
          <div class="space-y-2 text-center md:text-right">
            <p class="text-sm text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">
              © {new Date().getFullYear()} NeverMind | הכל מתחיל ונגמר בראש.
            </p>
            <p class="text-xs text-[color-mix(in_srgb,var(--nm-fg)_45%,var(--nm-bg))]">האתר מאובטח SSL | סליקה מאושרת דרך Grow</p>
            <p class="max-w-3xl whitespace-pre-line text-xs leading-relaxed text-[color-mix(in_srgb,var(--nm-fg)_48%,var(--nm-bg))]">
              {disclaimerLong}
            </p>
          </div>
          <div class="flex items-center gap-3">
            {socialLinks.map(({ label, href, mark }) => (
              <a
                href={href}
                target="_blank"
                rel="noreferrer"
                aria-label={label}
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)]/75 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] hover:text-[var(--nm-accent)]"
              >
                <span aria-hidden="true">{mark}</span>
              </a>
            ))}
            <a href="https://tally.so/r/3N0x0q" class="text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))] transition-colors duration-200 hover:text-[var(--nm-accent)]">יצירת קשר</a>
          </div>
        </div>
        <div class="flex flex-wrap items-center justify-center gap-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))] md:justify-end">
          <span class="text-[color-mix(in_srgb,var(--nm-fg)_50%,var(--nm-bg))]">כלים וחקירה:</span>
          <a
            href="/forbidden-library/"
            class="transition-colors duration-200 hover:text-[var(--nm-accent)]"
            title="הספרייה האסורה | תוכן לחקירה"
          >
            הספרייה האסורה
          </a>
          <a
            href="/root-problem-tree/"
            class="transition-colors duration-200 hover:text-[var(--nm-accent)]"
            title="עץ שורש הבעיה | כלי חשיבה"
          >
            עץ שורש הבעיה
          </a>
          <a
            href="/accessibility/"
            class="transition-colors duration-200 hover:text-[var(--nm-accent)]"
            title="הצהרת נגישות | השם לא משנה"
          >
            הצהרת נגישות
          </a>
        </div>
      </div>
    </footer>

    <WhatsAppButton
      phone={appConfig.contact.whatsAppNumber}
      tags={waTags}
      articleTitle={waArticleTitle}
      articleSlug={waSlug}
      meetingIntent={Boolean(waSlug && waArticleTitle)}
    />
    <SearchModal client:idle />
    <A11yWidget />

    <script is:inline define:vars={{ randomArticlePaths }}>
      document.addEventListener("astro:page-load", () => {
        if (window.__nmLayoutCleanup) {
          window.__nmLayoutCleanup();
        }

        const searchTriggers = Array.from(document.querySelectorAll("[data-search-trigger]"));
        const randomTriggers = Array.from(document.querySelectorAll("[data-random-article-trigger]"));

        const onSearchClick = (event) => {
          event.preventDefault();
          window.dispatchEvent(new CustomEvent("open-search"));
        };

        const onRandomClick = (event) => {
          event.preventDefault();
          const paths = Array.isArray(randomArticlePaths) ? randomArticlePaths : [];
          if (!paths.length) return;

          const currentPath = window.location.pathname.replace(/\/$/, "");
          const pool = paths.filter((path) => path.replace(/\/$/, "") !== currentPath);
          const source = pool.length ? pool : paths;
          const target = source[Math.floor(Math.random() * source.length)];
          if (target) window.location.href = target;
        };

        const formatAvailabilityDateHebrew = (isoString) => {
          const date = new Date(isoString);
          if (Number.isNaN(date.getTime())) return "";
          const days = ["ראשון", "שני", "שלישי", "רביעי", "חמישי", "שישי", "שבת"];
          const day = date.getDay();
          const prefix = day === 6 ? 'מוצ"ש' : `יום ${days[day]}`;
          const hours = date.getHours().toString().padStart(2, "0");
          const minutes = date.getMinutes().toString().padStart(2, "0");
          return `עודכן ${prefix} ${hours}:${minutes}`;
        };

        const refreshAvailabilityLines = () => {
          document.querySelectorAll("[data-nm-availability]").forEach((el) => {
            const spotsRaw = el.getAttribute("data-spots");
            const updatedAt = el.getAttribute("data-updated-at")?.trim();
            const label = (el.getAttribute("data-label") || "נותרו").trim();
            const spots = spotsRaw != null ? Number(spotsRaw) : NaN;
            if (!Number.isFinite(spots) || !updatedAt) return;
            const unit = spots === 1 ? "מקום" : "מקומות";
            const datePart = formatAvailabilityDateHebrew(updatedAt);
            el.textContent = datePart ? `${label} ${spots} ${unit} · ${datePart}` : `${label} ${spots} ${unit}`;
          });
        };

        searchTriggers.forEach((trigger) => trigger.addEventListener("click", onSearchClick));
        randomTriggers.forEach((trigger) => trigger.addEventListener("click", onRandomClick));
        refreshAvailabilityLines();

        window.__nmLayoutCleanup = () => {
          searchTriggers.forEach((trigger) => trigger.removeEventListener("click", onSearchClick));
          randomTriggers.forEach((trigger) => trigger.removeEventListener("click", onRandomClick));
        };
      });
    </script>
  </body>
</html>
