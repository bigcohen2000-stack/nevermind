          if (path.startsWith("/admin")) return () => {};

          const forms = Array.from(document.querySelectorAll("main form")).filter(
            (form) => form instanceof HTMLFormElement
          );
          if (!forms.length) return () => {};

          const cleanups = [];

          forms.forEach((form, index) => {
            if (!(form instanceof HTMLFormElement)) return;

            const fields = Array.from(form.querySelectorAll("input, textarea, select")).filter((field) => {
              if (!(field instanceof HTMLElement)) return false;
              const input = field instanceof HTMLInputElement ? field : null;
              if (input && ["password", "file", "hidden", "submit", "button", "reset"].includes(input.type)) {
                return false;
              }
              return Boolean(field.id || field.getAttribute("name"));
            });
            if (!fields.length) return;

            const storageKey = `nm-form-draft:${path}:${form.id || index}`;

            const restoreDraft = () => {
              try {
                const raw = window.localStorage.getItem(storageKey);
                if (!raw) return;
                const draft = JSON.parse(raw);
                fields.forEach((field) => {
                  const key = field.getAttribute("name") || field.id;
                  if (!key || !(key in draft)) return;
                  if (field instanceof HTMLInputElement && (field.type === "checkbox" || field.type === "radio")) {
                    field.checked = Boolean(draft[key]);
                    return;
                  }
                  field.value = String(draft[key] ?? "");
                });
              } catch {
                /* ignore */
              }
            };

            const persistDraft = () => {
              const snapshot = {};
              fields.forEach((field) => {
                const key = field.getAttribute("name") || field.id;
                if (!key) return;
                if (field instanceof HTMLInputElement && (field.type === "checkbox" || field.type === "radio")) {
                  snapshot[key] = field.checked;
                  return;
                }
                snapshot[key] = field.value;
              });
              try {
                window.localStorage.setItem(storageKey, JSON.stringify(snapshot));
              } catch {
                /* ignore */
              }
            };

            const clearDraft = () => {
              try {
                window.localStorage.removeItem(storageKey);
              } catch {
                /* ignore */
              }
            };

            restoreDraft();
            fields.forEach((field) => {
              field.addEventListener("input", persistDraft);
              field.addEventListener("change", persistDraft);
              field.addEventListener("blur", persistDraft);
            });
            form.addEventListener("submit", clearDraft);

            cleanups.push(() => {
              fields.forEach((field) => {
                field.removeEventListener("input", persistDraft);
                field.removeEventListener("change", persistDraft);
                field.removeEventListener("blur", persistDraft);
              });
              form.removeEventListener("submit", clearDraft);
            });
          });

          return () => {
            cleanups.forEach((cleanup) => cleanup());
          };
        };
        const cleanupFormPersistence = setupFormPersistence();

        emailTriggers.forEach((trigger) => trigger.addEventListener("click", onEmailClick));
        phoneTriggers.forEach((trigger) => trigger.addEventListener("click", onPhoneClick));

        window.addEventListener("nm:focus-target", (event) => {
          const selector = event?.detail?.selector;
          if (!selector) return;
          const target = document.querySelector(selector);
          if (!(target instanceof HTMLElement)) return;
          target.setAttribute("tabindex", "-1");
          target.focus({ preventScroll: true });
          target.scrollIntoView({ behavior: "smooth", block: "start" });
          window.__nmAnnounce?.("התוכן עודכן");
        });

        window.__nmLayoutCleanup = () => {
          searchTriggers.forEach((trigger) => trigger.removeEventListener("click", onSearchClick));
          randomTriggers.forEach((trigger) => trigger.removeEventListener("click", onRandomClick));
          emailTriggers.forEach((trigger) => trigger.removeEventListener("click", onEmailClick));
          phoneTriggers.forEach((trigger) => trigger.removeEventListener("click", onPhoneClick));
          document.removeEventListener("click", onCopyClick);
          document.removeEventListener("click", onInteractiveFeedbackClick, true);
          document.removeEventListener("click", onFavoriteToggleClick);
          document.removeEventListener("click", onHeaderLogoutClick);
          document.removeEventListener("astro:before-preparation", onBeforePreparation);
          document.removeEventListener("astro:after-swap", onAfterSwap);
          document.removeEventListener("astro:page-load", onAfterSwap);
          document.removeEventListener("astro:page-load", onNmPageLoadSync);
          clearRouteProgressTimer();
          clearTransientLoading();
          cleanupFormPersistence();
          window.removeEventListener("scroll", persistScroll);
          window.removeEventListener("beforeunload", persistScroll);
          window.removeEventListener("scroll", onBackToTopScroll);
          window.removeEventListener("scroll", onHeaderScroll);
          window.removeEventListener("storage", onNmClubStorage);
          window.removeEventListener("nm-club-session-changed", nmSyncPremiumUi);
          window.removeEventListener("nm-admin-session-changed", nmSyncPremiumUi);
          window.removeEventListener("nm-club-session-changed", syncFavoriteButtons);
          if (backBtn instanceof HTMLElement) {
            backBtn.removeEventListener("click", onBackToTopClick);
          }
        };
      });
    </script>

    <script is:inline defer define:vars={{ clubWebhookUrl }}>
      (() => {
        const webhook = typeof clubWebhookUrl === "string" ? clubWebhookUrl.trim() : "";
        if (!webhook) return;
        let beaconUrl = "";
        try {
          const u = new URL(webhook);
          beaconUrl = `${u.origin}/log/club-page`;
        } catch {
          return;
        }
        const sendPageBeacon = () => {
          try {
            const path = typeof location !== "undefined" ? location.pathname : "";
            if (!path.startsWith("/articles/")) return;
            const sess = typeof window.__nmReadClubSession === "function" ? window.__nmReadClubSession() : null;
            if (!sess) return;
            const key = `nm_deep_beacon:${path}`;
            if (sessionStorage.getItem(key)) return;
            sessionStorage.setItem(key, "1");
            fetch(beaconUrl, {
              method: "POST",
              mode: "cors",
              credentials: "omit",
              headers: { "Content-Type": "application/json", Accept: "application/json" },
              body: JSON.stringify({ path }),
              keepalive: true,
            }).catch(() => {});
          } catch {
            /* ignore */
          }
        };
        document.addEventListener("astro:page-load", sendPageBeacon);
        sendPageBeacon();
      })();
    </script>

    <script is:inline defer define:vars={{ clientLogUrl }}>
      (() => {
        const url = typeof clientLogUrl === "string" ? clientLogUrl.trim() : "";
        if (!url) return;
        const send = (payload) => {
          try {
            fetch(url, {
              method: "POST",
              mode: "cors",
              credentials: "omit",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
              keepalive: true,
            }).catch(() => {});
          } catch {
            /* ignore */
          }
        };
        window.addEventListener("error", (event) => {
          send({
            k: "error",
            m: String(event.message || "").slice(0, 500),
            f: String(event.filename || "").split("/").pop() || "",
            l: event.lineno ?? null,
            c: event.colno ?? null,
            p: typeof location !== "undefined" ? location.pathname : "",
          });
        });
        window.addEventListener("unhandledrejection", (event) => {
          const reason = event.reason;
          const text =
            typeof reason === "string"
              ? reason
              : reason && typeof reason.message === "string"
                ? reason.message
                : "unhandledrejection";
          send({
            k: "rejection",
            m: String(text).slice(0, 500),
            p: typeof location !== "undefined" ? location.pathname : "",
          });
        });
      })();
    </script>

    <script is:inline>
      (function () {
        if (window.__nmHcaptchaGlobalsRegistered) return;
        window.__nmHcaptchaGlobalsRegistered = true;
        window.__nmHcaptchaApiPromise = null;
        window.__nmLoadHcaptchaApi = function () {
          if (window.hcaptcha) return Promise.resolve();
          if (!window.__nmHcaptchaApiPromise) {
            window.__nmHcaptchaApiPromise = new Promise(function (resolve, reject) {
              var s = document.createElement("script");
              s.src = "https://js.hcaptcha.com/1/api.js";
              s.async = true;
              s.onload = function () {
                resolve();
              };
              s.onerror = function () {
                reject(new Error("hcaptcha"));
              };
              document.head.appendChild(s);
            });
          }
          return window.__nmHcaptchaApiPromise;
        };
        window.__nmMountHcaptcha = function (form) {
          if (!(form instanceof HTMLFormElement)) return function () {};
          var wrap = form.querySelector("[data-nm-hcaptcha-wrap]");
          if (!wrap) return function () {};
          var container = wrap.querySelector(".nm-hcaptcha-container");
          var tokenInput = wrap.querySelector('input[name="h-captcha-response"]');
          if (!container || !tokenInput) return function () {};
          var sitekey = container.getAttribute("data-sitekey") || "";
          if (!sitekey) return function () {};
          var disposed = false;
          var widgetId = null;
          window.__nmLoadHcaptchaApi().then(function () {
            if (disposed) return;
            if (!container.isConnected) return;
            widgetId = window.hcaptcha.render(container, {
              sitekey: sitekey,
              callback: function (t) {
                tokenInput.value = t || "";
              },
              "expired-callback": function () {
                tokenInput.value = "";
              },
              "error-callback": function () {
                tokenInput.value = "";
              },
            });
          });
          return function unmount() {
            disposed = true;
            if (widgetId !== null && window.hcaptcha) {
              try {
                window.hcaptcha.remove(widgetId);
              } catch (e) {}
            }
            widgetId = null;
            tokenInput.value = "";
            if (container) container.innerHTML = "";
          };
        };
        window.__nmHcaptchaOk = function (form) {
          if (!(form instanceof HTMLFormElement)) return true;
          var wrap = form.querySelector("[data-nm-hcaptcha-wrap]");
          if (!wrap) return true;
          var tokenInput = wrap.querySelector('input[name="h-captcha-response"]');
          if (!tokenInput) return true;
          return String(tokenInput.value || "").trim().length > 0;
        };
      })();
    </script>
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("/sw.js", { scope: "/" }).catch(function () {});
        });
      }
    </script>
      <script is:inline>
      (() => {
        if (window.__nmConnectivityBooted) return;
        window.__nmConnectivityBooted = true;

        let timer = null;
        let root = null;

        const ensureUi = () => {
          if (root) return root;
          const style = document.createElement("style");
          style.id = "nm-connectivity-style";
          style.textContent = `
            .nm-connectivity-banner {
              position: fixed;
              left: 50%;
              bottom: 1rem;
              transform: translateX(-50%) translateY(10px);
              z-index: 90;
              display: inline-flex;
              align-items: center;
              gap: 0.65rem;
              min-height: 46px;
              max-width: min(32rem, calc(100vw - 1.5rem));
              padding: 0.7rem 1rem;
              border-radius: 999px;
              border: 0.5px solid rgba(26, 26, 26, 0.1);
              background: rgba(250, 250, 248, 0.96);
              color: #1A1A1A;
              box-shadow: 0 16px 40px rgba(26, 26, 26, 0.12);
              backdrop-filter: blur(16px);
              opacity: 0;
              pointer-events: none;
              transition: opacity 180ms ease, transform 180ms ease;
            }
            .nm-connectivity-banner.is-visible {
              opacity: 1;
              transform: translateX(-50%) translateY(0);
            }
            .nm-connectivity-dot {
              width: 0.6rem;
              height: 0.6rem;
              border-radius: 999px;
              flex: 0 0 auto;
              background: #D42B2B;
              box-shadow: 0 0 0 6px rgba(212, 43, 43, 0.08);
            }
            .nm-connectivity-banner[data-kind="online"] .nm-connectivity-dot {
              background: #4B6055;
              box-shadow: 0 0 0 6px rgba(75, 96, 85, 0.08);
            }
            .nm-connectivity-copy {
              font-size: 0.84rem;
              line-height: 1.55;
            }
          `;
          document.head.appendChild(style);

          root = document.createElement("div");
          root.className = "nm-connectivity-banner";
          root.setAttribute("role", "status");
          root.setAttribute("aria-live", "polite");
          root.innerHTML = '<span class="nm-connectivity-dot" aria-hidden="true"></span><span class="nm-connectivity-copy"></span>';
          document.body.appendChild(root);
          return root;
        };

        const show = (message, kind = "issue", timeout = kind === "online" ? 2200 : 4200) => {
          const el = ensureUi();
          const copy = el.querySelector(".nm-connectivity-copy");
          if (copy) copy.textContent = String(message || "");
          el.dataset.kind = kind;
          el.classList.add("is-visible");
          window.clearTimeout(timer);
          if (timeout > 0) {
            timer = window.setTimeout(() => {
              el.classList.remove("is-visible");
            }, timeout);
          }
        };

        window.__nmReportConnectivityIssue = (message) => {
          show(message || "יש עיכוב קטן בחיבור. אפשר לנסות שוב בעוד רגע.", "issue", 4200);
        };
        window.__nmClearConnectivityIssue = () => {
          if (root) root.classList.remove("is-visible");
          window.clearTimeout(timer);
        };

        const syncOnlineState = () => {
          if (navigator.onLine === false) {
            show("נראה שהחיבור לרשת התנתק. אפשר להמשיך לקרוא, ונחזור כשיש חיבור.", "issue", 0);
            return;
          }
          show("החיבור חזר. אפשר להמשיך כרגיל.", "online", 2200);
        };

        window.addEventListener("offline", syncOnlineState);
        window.addEventListener("online", syncOnlineState);
      })();
    </script>
  </body>
