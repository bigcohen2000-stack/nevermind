---
import "@fontsource-variable/assistant/wght.css";
import "@fontsource/heebo/index.css";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import A11yWidget from "../components/A11yWidget.astro";
import Analytics from "../components/Analytics.astro";
import IntegrityReporter from "../components/IntegrityReporter.astro";
import PwaInstallPrompt from "../components/PwaInstallPrompt.astro";
import SearchModal from "../components/SearchModal";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import WhisperBanner from "../components/WhisperBanner.astro";
import appConfig from "../config/appConfig.json";
import siteSettings from "../config/siteSettings.json";
import { jsonLdForInlineScript } from "../lib/json-ld-inline";
import { disclaimerLong } from "../lib/services";
import SiteBreadcrumbs from "../components/SiteBreadcrumbs.astro";
import FooterPaymentIcons from "../components/FooterPaymentIcons.astro";
import {
  buildSiteBreadcrumbTrail,
  parseBreadcrumbOverride,
  breadcrumbTrailToJsonLd,
} from "../lib/site-breadcrumbs";
import { GOOGLE_SITE_VERIFICATION } from "../data/migration-map";

type StagingBannerCfg = { enabled?: boolean; message?: string };
type BrandCfg = {
  logoPath?: string;
  defaultOgImagePath?: string;
  themeColor?: string;
  backgroundColor?: string;
  wordmarkHe?: string;
};
type ContactCfg = {
  whatsAppNumber?: string;
  email?: string;
  phoneDisplay?: string;
  phoneTel?: string;
};

const stagingCfg = (siteSettings as { stagingBanner?: StagingBannerCfg }).stagingBanner;
const brandCfg = (siteSettings as { brand?: BrandCfg }).brand ?? {};
const stagingEnabled = Boolean(stagingCfg?.enabled);
const stagingMessage =
  typeof stagingCfg?.message === "string" && stagingCfg.message.trim().length > 0
    ? stagingCfg.message.trim()
    : "עדכון אתר";
const navTopClass = stagingEnabled
  ? "top-[calc(var(--nm-staging-banner-height)+var(--nm-nav-top,1.5rem))]"
  : "top-[var(--nm-nav-top,1.5rem)]";
const mainPadTopClass = stagingEnabled
  ? "pt-[calc(var(--nm-staging-banner-height)+var(--nm-nav-top,1.5rem)+6.25rem)]"
  : "pt-32";

const {
  title,
  description,
  frontmatter,
  hasInquirySection,
  faqItems,
  image,
  noIndex = false,
  waArticleSlug = "",
  seoArticleBody = "",
  articlePaywalled = false,
  breadcrumbCurrentLabel,
  breadcrumbItems: breadcrumbItemsProp,
  skipToContentHref = "#main-content",
} = Astro.props;

const waTags = Array.isArray(frontmatter?.tags) ? frontmatter.tags : [];
const waArticleTitle = typeof title === "string" ? title : "";
const waSlug = typeof waArticleSlug === "string" ? waArticleSlug.trim() : "";

const siteBrandEn = appConfig.site.name;
const siteWordmark =
  typeof brandCfg.wordmarkHe === "string" && brandCfg.wordmarkHe.trim().length > 0
    ? brandCfg.wordmarkHe.trim()
    : "השם לא משנה";
const siteTitle = `${siteWordmark} | ${siteBrandEn}`;
const trimMetaDescription = (value: string) => {
  const normalized = String(value || "").trim().replace(/\s+/g, " ");
  if (normalized.length <= 155) return normalized;
  return `${normalized.slice(0, 152).trimEnd()}...`;
};
/** מטא ברירת מחדל: מילות מפתח SEO + בלי משפטי "ש…" */
const siteDescription = trimMetaDescription(
  "השם לא משנה הוא הבית של NeverMind: שקט נפשי, בהירות, חשיבה צלולה והפרדה בין עובדה, פירוש ותגובה."
);
const seoKeywords =
  "השם לא משנה, NeverMind, שקט נפשי, חשיבה צלולה, עובדה מול פירוש, הבנה לפני תגובה, בהירות";
const siteUrl = appConfig.site.url;
const siteUrlSlash = siteUrl.endsWith("/") ? siteUrl : `${siteUrl}/`;
const logoPath =
  typeof brandCfg.logoPath === "string" && brandCfg.logoPath.startsWith("/")
    ? brandCfg.logoPath
    : "/images/logo.svg";
const iconPath = "/images/logo.svg";
const defaultOgPath =
  typeof brandCfg.defaultOgImagePath === "string" && brandCfg.defaultOgImagePath.startsWith("/")
    ? brandCfg.defaultOgImagePath
    : "/images/logo.svg";
const pwaThemeColor = typeof brandCfg.themeColor === "string" ? brandCfg.themeColor : "#1A1A1A";
const contact = appConfig.contact as ContactCfg;
const waDigits = String(contact.whatsAppNumber ?? "").replace(/\D/g, "");
const emailStr = typeof contact.email === "string" ? contact.email.trim() : "";
const [emailUserRaw = "", emailDomainRaw = ""] = emailStr.includes("@") ? emailStr.split("@") : ["", ""];
const emailUser = emailUserRaw.trim();
const emailDomain = emailDomainRaw.trim();
const normalizeTitle = (value: unknown) => String(value ?? "").trim();
const rawPageTitle = normalizeTitle(title);
const pageTitle = !rawPageTitle
  ? siteTitle
  : rawPageTitle.includes(siteWordmark)
    ? rawPageTitle
    : rawPageTitle.toLowerCase().includes(siteBrandEn.toLowerCase())
      ? `${rawPageTitle} | ${siteWordmark}`
      : `${rawPageTitle} | ${siteTitle}`;
const pageDescription = trimMetaDescription(description ?? frontmatter?.description ?? siteDescription);
const pageUrl = Astro.url ? new URL(Astro.url.pathname, siteUrl).toString() : siteUrl;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : pageUrl;
const defaultOgAbsolute = new URL(defaultOgPath.replace(/^\//, ""), siteUrlSlash).toString();
const resolveOgImage = (): string => {
  if (typeof image === "string" && image.trim().length > 0) {
    const t = image.trim();
    if (t.startsWith("http://") || t.startsWith("https://")) return t;
    return new URL(t.replace(/^\//, ""), siteUrlSlash).toString();
  }
  if (frontmatter?.image) {
    return new URL(String(frontmatter.image).replace(/^\//, ""), siteUrlSlash).toString();
  }
  return defaultOgAbsolute;
};
const ogImage = resolveOgImage();
const showOgRasterDimensions =
  ogImage === defaultOgAbsolute && /\.(jpe?g|png|webp)$/i.test(defaultOgPath);
const ogImageAlt =
  typeof frontmatter?.imageAlt === "string" && frontmatter.imageAlt.trim().length > 0
    ? frontmatter.imageAlt.trim()
    : frontmatter?.title
      ? String(frontmatter.title)
      : pageTitle;
const clientLogUrl = (import.meta.env.PUBLIC_CLIENT_LOG_URL ?? "").trim();
const clubWebhookUrl = String(import.meta.env.PUBLIC_NM_CLUB_WEBHOOK_URL ?? "").trim();
const logoAbsolute = new URL(logoPath.replace(/^\//, ""), siteUrlSlash).toString();
const wordmarkHe = siteWordmark;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteTitle,
  url: siteUrl,
  logo: logoAbsolute,
  image: logoAbsolute,
  description: siteDescription,
  inLanguage: "he-IL",
  sameAs: [
    "https://www.facebook.com/nevermindyakir",
    "https://www.instagram.com/nevermind.co.il/",
    "https://www.tiktok.com/@nevermind.co.il",
    "https://x.com/nevermindyakir",
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteTitle,
  url: siteUrl,
  inLanguage: "he-IL",
  potentialAction: {
    "@type": "SearchAction",
    target: new URL("archive/?q={search_term_string}", siteUrlSlash).toString(),
    "query-input": "required name=search_term_string",
  },
  publisher: {
    "@type": "Organization",
    name: siteTitle,
    url: siteUrl,
  },
};

const professionalServiceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: siteTitle,
  url: new URL("services/", siteUrlSlash).toString(),
  image: logoAbsolute,
  description: siteDescription,
  inLanguage: "he-IL",
  areaServed: { "@type": "Country", name: "IL" },
  provider: {
    "@type": "Organization",
    name: siteTitle,
    url: siteUrl,
  },
};

const pathName = Astro.url?.pathname ?? "/";
const normalizeNavPath = (raw: string) => {
  const trimmed = String(raw || "").trim();
  if (!trimmed || trimmed === "/") return "/";
  return trimmed.replace(/\/+$/, "") || "/";
};
const currentNavPath = normalizeNavPath(pathName);

const intentNavItems: { href: string; label: string; activePrefixes: string[] }[] = [
  {
    href: "/blog/",
    label: "אני רוצה להעמיק",
    activePrefixes: ["/blog", "/archive", "/articles", "/journey/mental-health"],
  },
  {
    href: "/studio/",
    label: "אני רוצה לדבר",
    activePrefixes: ["/studio", "/services", "/intake", "/personal-consultation", "/contact", "/book"],
  },
  { href: "/glossary/", label: "הגדרות מחדש", activePrefixes: ["/glossary"] },
  { href: "/about/", label: "אודות NeverMind", activePrefixes: ["/about"] },
];

const intentNavItemIsCurrent = (prefixes: string[]) => {
  const p = currentNavPath;
  return prefixes.some((pre) => {
    const norm = normalizeNavPath(pre);
    if (norm === "/") return p === "/";
    return p === norm || p.startsWith(`${norm}/`);
  });
};

/** קישורי פוטר: onlyMd מסתיר קישור עד md כדי לרוקן מובייל */
const footerLinkColumns: {
  title: string;
  links: { href: string; label: string }[];
}[] = [
  {
    title: "תוכן",
    links: [
      { href: "/library/", label: "ספרייה" },
      { href: "/articles/", label: "מאמרים" },
      { href: "/topics/clarity/", label: "בהירות" },
      { href: "/topics/freedom/", label: "חופש" },
      { href: "/forbidden-library/", label: "הספרייה האסורה" },
      { href: "/root-problem-tree/", label: "עץ שורש הבעיה" },
    ],
  },
  {
    title: "שירות",
    links: [
      { href: "/personal-consultation/", label: "שיחה אישית" },
      { href: "/services/", label: "מחירון" },
      { href: "/contact/", label: "יצירת קשר" },
    ],
  },
  {
    title: "מערכת",
    links: [
      { href: "/privacy/", label: "פרטיות" },
      { href: "/terms/", label: "תנאים" },
      { href: "/accessibility/", label: "נגישות" },
      { href: "/faq/", label: "שאלות נפוצות" },
    ],
  },
];
const isNoIndex =
  Boolean(frontmatter?.noIndex || noIndex) ||
  pathName.startsWith("/admin") ||
  pathName.startsWith("/api");
const robotsContent = isNoIndex ? "noindex, nofollow" : "index, follow";
const breadcrumbOverride = parseBreadcrumbOverride(breadcrumbItemsProp);
const bcLabelProp =
  typeof breadcrumbCurrentLabel === "string" ? breadcrumbCurrentLabel.trim() : "";
const fmTitleForCrumb =
  typeof frontmatter?.title === "string" ? String(frontmatter.title).trim() : "";
const currentPageTitleForCrumb = bcLabelProp || fmTitleForCrumb || null;
const breadcrumbCrumbs = pathName.startsWith("/admin")
  ? []
  : (breadcrumbOverride ?? buildSiteBreadcrumbTrail(pathName, { currentPageTitle: currentPageTitleForCrumb }));

const breadcrumbJsonLdItems =
  breadcrumbCrumbs.length > 0
    ? breadcrumbTrailToJsonLd(breadcrumbCrumbs, canonicalURL, siteUrlSlash)
    : [];

const breadcrumbSchema =
  breadcrumbJsonLdItems.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbJsonLdItems.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.name,
          item: item.item,
        })),
      }
    : null;

const toIso = (value: string | Date | undefined) => {
  if (!value) return undefined;
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? undefined : date.toISOString();
};

const seoBodyTrimmed = typeof seoArticleBody === "string" ? seoArticleBody.trim() : "";
const articleSchema = frontmatter
  ? {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: frontmatter.title ?? pageTitle,
      description: frontmatter.description ?? pageDescription,
      author: {
        "@type": "Person",
        name: frontmatter.author ?? "השם לא משנה",
        jobTitle: "כותב וחוקר מנגנוני חשיבה ומציאות",
        description:
          "תוכן אנליטי: עובדות, מנגנונים, והפרדה בין סיפור למציאות. ללא טשטוש שיווקי.",
      },
      datePublished: toIso(frontmatter.pubDate),
      dateModified: toIso(frontmatter.updatedDate) ?? toIso(frontmatter.pubDate),
      image: ogImage,
      inLanguage: "he-IL",
      mainEntityOfPage: pageUrl,
      publisher: {
        "@type": "Organization",
        name: siteTitle,
        url: siteUrl,
      },
      ...(articlePaywalled ? { isAccessibleForFree: false } : {}),
      ...(seoBodyTrimmed.length > 0 ? { articleBody: seoBodyTrimmed } : {}),
    }
  : null;

const hasArticleDates = Boolean(frontmatter?.pubDate);
const ogType = hasArticleDates ? "article" : "website";
const articlePublishedMeta = hasArticleDates ? toIso(frontmatter?.pubDate) : undefined;
const articleModifiedMeta = hasArticleDates
  ? toIso(frontmatter?.updatedDate) ?? toIso(frontmatter?.pubDate)
  : undefined;

const normalizedFaqItems = Array.isArray(faqItems) ? faqItems : [];
const qSchemaRaw = typeof frontmatter?.questionForSchema === "string" ? frontmatter.questionForSchema.trim() : "";
const descForFaqAnswer =
  typeof frontmatter?.description === "string" && frontmatter.description.trim().length > 0
    ? frontmatter.description.trim()
    : pageDescription;

const fromQuestionSchema =
  qSchemaRaw.length > 0
    ? [{ question: qSchemaRaw, answer: descForFaqAnswer }]
    : [];

type FaqPair = { question: string; answer: string };
const mergedFaqItems: FaqPair[] = [...fromQuestionSchema];
for (const item of normalizedFaqItems) {
  const q = typeof (item as FaqPair)?.question === "string" ? String((item as FaqPair).question).trim() : "";
  const a = typeof (item as FaqPair)?.answer === "string" ? String((item as FaqPair).answer).trim() : "";
  if (!q || !a) continue;
  if (!mergedFaqItems.some((x) => x.question === q)) mergedFaqItems.push({ question: q, answer: a });
}

const fallbackFaqItems: FaqPair[] =
  mergedFaqItems.length === 0 && hasInquirySection && frontmatter?.description
    ? [
        {
          question: `מה בודקים במאמר "${frontmatter.title ?? pageTitle}"?`,
          answer: String(frontmatter.description),
        },
      ]
    : [];

const faqItemsForSchema: FaqPair[] = mergedFaqItems.length > 0 ? mergedFaqItems : fallbackFaqItems;
const faqSchema =
  faqItemsForSchema.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqItemsForSchema.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }
    : null;

const youtubeIdRaw = typeof frontmatter?.youtubeId === "string" ? frontmatter.youtubeId.trim() : "";
const videoSummaryPointsForSchema = Array.isArray(frontmatter?.videoSummaryPoints)
  ? frontmatter.videoSummaryPoints.map((p: string) => String(p).trim()).filter(Boolean)
  : [];

const videoObjectSchema =
  youtubeIdRaw.length > 0
    ? articlePaywalled
      ? {
          "@context": "https://schema.org",
          "@type": "VideoObject",
          name: frontmatter?.title ?? pageTitle,
          description: frontmatter?.description ?? pageDescription,
          thumbnailUrl: [`https://i.ytimg.com/vi/${youtubeIdRaw}/hqdefault.jpg`],
          uploadDate: toIso(frontmatter?.pubDate),
          isAccessibleForFree: false,
          ...(videoSummaryPointsForSchema.length > 0
            ? {
                keywords: videoSummaryPointsForSchema.join(", "),
                transcript: videoSummaryPointsForSchema.map((line: string) => `• ${line}`).join("\n"),
              }
            : {}),
          publisher: {
            "@type": "Organization",
            name: siteTitle,
            url: siteUrl,
          },
          inLanguage: "he-IL",
        }
      : {
          "@context": "https://schema.org",
          "@type": "VideoObject",
          name: frontmatter?.title ?? pageTitle,
          description: frontmatter?.description ?? pageDescription,
          thumbnailUrl: [`https://i.ytimg.com/vi/${youtubeIdRaw}/hqdefault.jpg`],
          uploadDate: toIso(frontmatter?.pubDate),
          contentUrl: `https://www.youtube.com/watch?v=${youtubeIdRaw}`,
          embedUrl: `https://www.youtube-nocookie.com/embed/${youtubeIdRaw}`,
          ...(videoSummaryPointsForSchema.length > 0
            ? {
                keywords: videoSummaryPointsForSchema.join(", "),
                transcript: videoSummaryPointsForSchema.map((line: string) => `• ${line}`).join("\n"),
              }
            : {}),
          publisher: {
            "@type": "Organization",
            name: siteTitle,
            url: siteUrl,
          },
          inLanguage: "he-IL",
        }
    : null;

const servicesPageUrl = new URL("services/", siteUrlSlash).toString();

const podcastSessionProductsSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "סשן אולפן פודקאסט - עד חצי שעה",
    description: "הקלטה באולפן פודקאסט, עד 30 דקות.",
    brand: { "@type": "Brand", name: siteTitle },
    sku: "nm-podcast-30",
    url: servicesPageUrl,
    offers: {
      "@type": "Offer",
      price: "650.00",
      priceCurrency: "ILS",
      availability: "https://schema.org/InStock",
      url: servicesPageUrl,
      seller: { "@type": "Organization", name: siteTitle, url: siteUrl },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "סשן אולפן פודקאסט - עד שעה",
    description: "הקלטה באולפן פודקאסט, עד 60 דקות.",
    brand: { "@type": "Brand", name: siteTitle },
    sku: "nm-podcast-60",
    url: servicesPageUrl,
    offers: {
      "@type": "Offer",
      price: "1180.00",
      priceCurrency: "ILS",
      availability: "https://schema.org/InStock",
      url: servicesPageUrl,
      seller: { "@type": "Organization", name: siteTitle, url: siteUrl },
    },
  },
];

const coreStructuredData = [
  organizationSchema,
  websiteSchema,
  professionalServiceSchema,
  ...podcastSessionProductsSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  articleSchema,
  videoObjectSchema,
].filter(Boolean);

const socialLinks = [
  { label: "פייסבוק", href: "https://www.facebook.com/nevermindyakir", mark: "f" },
  { label: "אינסטגרם", href: "https://www.instagram.com/nevermind.co.il/", mark: "IG" },
  { label: "טיקטוק", href: "https://www.tiktok.com/@nevermind.co.il", mark: "♪" },
  { label: "X", href: "https://x.com/nevermindyakir", mark: "X" },
];

---
<!doctype html>
<html lang="he" dir="rtl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token":"7f4a6c326cc14178bba8457078baf381"}'></script>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={seoKeywords} />
    <meta
      name="robots"
      content={robotsContent}
    />
    {GOOGLE_SITE_VERIFICATION ? (
      <meta name="google-site-verification" content={GOOGLE_SITE_VERIFICATION} />
    ) : null}
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="he-IL" href={canonicalURL} />
    <link rel="alternate" hreflang="he" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    <link rel="dns-prefetch" href="https://api.web3forms.com" />

    <link rel="icon" href={iconPath} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={iconPath} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content={pwaThemeColor} />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={ogType} />
    {articlePublishedMeta ? <meta property="article:published_time" content={articlePublishedMeta} /> : null}
    {articleModifiedMeta ? <meta property="article:modified_time" content={articleModifiedMeta} /> : null}
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    {showOgRasterDimensions ? (
      <>
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    ) : null}
    <meta property="og:locale" content="he_IL" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline type="application/ld+json" set:html={jsonLdForInlineScript(coreStructuredData)}></script>
    {faqSchema ? <script is:inline type="application/ld+json" set:html={jsonLdForInlineScript(faqSchema)} /> : null}
    <ClientRouter />
    <script>
      import "../scripts/form-antispam-bootstrap.ts";
      import "../scripts/site-search-bootstrap.ts";
      import "../scripts/glossary-tooltip-bootstrap.ts";
      import "../scripts/nm-auto-term-tooltips.ts";
    </script>

  </head>
  <body
    data-whisper-banner-state="hidden"
    data-staging={stagingEnabled ? "true" : "false"}
    class={`min-h-screen overflow-x-hidden bg-[var(--nm-bg)] text-[var(--nm-fg)] antialiased selection:bg-[color-mix(in_srgb,var(--nm-accent)_18%,var(--nm-bg))] selection:text-[var(--nm-fg)]`}
  >
    <div id="nm-route-progress" aria-hidden="true"></div>
    <a
      href={skipToContentHref}
      class="sr-only transition-colors duration-200 focus:not-sr-only focus:fixed focus:top-4 focus:z-[110] focus:rounded-md focus:bg-[var(--nm-bg-canvas)] focus:px-4 focus:py-2 focus:text-[var(--nm-fg)] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[var(--color-red)] shadow-xl focus:start-4"
    >
      דלג לתוכן הראשי
    </a>

    {stagingEnabled ? (
      <div
        role="status"
        aria-live="polite"
        data-nm-staging
        class="fixed inset-x-0 top-0 z-[100] flex min-h-[var(--nm-staging-banner-height)] items-center justify-center gap-3 bg-[var(--nm-accent)] px-4 py-3 text-center shadow-[0_4px_24px_color-mix(in_srgb,var(--nm-fg)_12%,transparent)]"
      >
        <span
          class="size-3 shrink-0 rounded-full bg-[var(--nm-on-accent)] ring-2 ring-[color-mix(in_srgb,var(--nm-on-accent)_55%,transparent)]"
          aria-hidden="true"
        />
        <p class="text-[clamp(1.2rem,1.05rem+1vw,1.85rem)] font-bold leading-tight text-[var(--nm-on-accent)]">
          {stagingMessage}
        </p>
      </div>
    ) : null}

    <WhisperBanner />

    <div
