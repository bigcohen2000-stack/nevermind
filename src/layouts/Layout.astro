      meetingIntent={Boolean(waSlug && waArticleTitle)}
    />
    <SearchModal client:idle />
    <A11yWidget />

    <script is:inline defer define:vars={{ randomArticlePaths }}>
      document.addEventListener("astro:page-load", () => {
        if (window.__nmLayoutCleanup) {
          window.__nmLayoutCleanup();
        }

        const titleNode = document.querySelector("title");
        const titleText = titleNode?.textContent?.trim();
        if (titleText) {
          document.title = titleText;
        }

        const nmNavTrackKeyCurrent = "nm-nav-current";
        const nmNavTrackKeyPrevious = "nm-nav-previous";
        const nmShouldTrackPathname = (pathname) => {
          if (!pathname) return false;
          if (pathname.startsWith("/admin")) return false;
          if (pathname.startsWith("/thank-you")) return false;
          if (pathname === "/404" || pathname.startsWith("/404/")) return false;
          return true;
        };
        const curFull = `${location.pathname}${location.search}`;
        const curPath = location.pathname;
        if (nmShouldTrackPathname(curPath)) {
          try {
            const last = sessionStorage.getItem(nmNavTrackKeyCurrent);
            if (last && last !== curFull) {
              sessionStorage.setItem(nmNavTrackKeyPrevious, last);
            }
            sessionStorage.setItem(nmNavTrackKeyCurrent, curFull);
          } catch {
            /* ignore */
          }
        }

        window.__nmReturnLabelForPath = (pNorm) => {
          if (pNorm === "/") return "חזור לדף הבית";
          if (pNorm === "/archive" || pNorm.startsWith("/archive/")) return "חזור לארכיון";
          if (pNorm === "/articles") return "חזור לארכיון";
          if (pNorm.startsWith("/articles/")) return "חזור למאמר";
          if (pNorm === "/studio" || pNorm.startsWith("/studio/")) return "חזור לסטודיו";
          if (pNorm === "/about" || pNorm.startsWith("/about/")) return "חזור להבנה";
          if (pNorm.startsWith("/topics/")) return "חזור לנושא";
          if (pNorm.startsWith("/glossary")) return "חזור להגדרות מחדש";
          if (pNorm.startsWith("/services") || pNorm.startsWith("/intake")) return "חזור ללוח הלמידה";
          if (pNorm.startsWith("/questions")) return "חזור לשאלות";
          if (pNorm === "/now" || pNorm.startsWith("/now/")) return "חזור למה המצב עכשיו";
          return "חזור לאן שבאת";
        };

        window.__nmResolveReturnTarget = () => {
          let href = "/archive/";
          let label = "חזור לארכיון";
          const here = `${location.pathname}${location.search}`;
          const hereNorm = location.pathname.replace(/\/+$/, "") || "/";
          try {
            const prev = sessionStorage.getItem(nmNavTrackKeyPrevious);
            if (prev && prev !== here) {
              const pathOnly = prev.split("?")[0];
              const pNorm = pathOnly.replace(/\/+$/, "") || "/";
              href = prev.startsWith("/") ? prev : `/${prev}`;
              label = window.__nmReturnLabelForPath(pNorm);
              return { href, label };
            }
            const ref = document.referrer;
            if (ref && ref.startsWith(location.origin)) {
              const u = new URL(ref);
              const refFull = `${u.pathname}${u.search}`;
              const refNorm = u.pathname.replace(/\/+$/, "") || "/";
              if (refFull !== here && !refNorm.startsWith("/admin")) {
                href = `${u.pathname}${u.search}`;
                label = window.__nmReturnLabelForPath(refNorm);
                return { href, label };
              }
            }
          } catch {
            /* ignore */
          }
          return { href, label };
        };

        window.__nmFillReturnLink = (anchor) => {
          if (!(anchor instanceof HTMLAnchorElement)) return;
          const target = window.__nmResolveReturnTarget();
          anchor.setAttribute("href", target.href);
          anchor.textContent = target.label;
        };

        document.querySelectorAll("[data-nm-return-cta-link]").forEach((node) => {
          window.__nmFillReturnLink(node);
        });

        const searchTriggers = Array.from(document.querySelectorAll("[data-search-trigger]"));
        const randomTriggers = Array.from(document.querySelectorAll("[data-random-article-trigger]"));
        const emailTriggers = Array.from(document.querySelectorAll("[data-email-cta]"));
        const phoneTriggers = Array.from(document.querySelectorAll("[data-phone-cta]"));
        const footerIdentityLine = document.getElementById("nm-footer-identity-line");

        const onSearchClick = (event) => {
          event.preventDefault();
          window.dispatchEvent(new CustomEvent("open-search"));
        };

        const onRandomClick = (event) => {
          event.preventDefault();
          const paths = Array.isArray(randomArticlePaths) ? randomArticlePaths : [];
          if (!paths.length) return;

          const currentPath = window.location.pathname.replace(/\/$/, "");
          const pool = paths.filter((path) => path.replace(/\/$/, "") !== currentPath);
          const source = pool.length ? pool : paths;
          const target = source[Math.floor(Math.random() * source.length)];
          if (target) window.location.href = target;
        };
        const maybeShowIdentityLine = () => {
          if (!(footerIdentityLine instanceof HTMLElement)) return;
          const chance = Math.random();
          if (chance <= 0.35) {
            footerIdentityLine.classList.remove("hidden");
          } else {
            footerIdentityLine.classList.add("hidden");
          }
        };
        const onEmailClick = (event) => {
          const trigger = event.currentTarget;
          if (!(trigger instanceof HTMLElement)) return;
          const user = String(trigger.getAttribute("data-email-user") || "").trim();
          const domain = String(trigger.getAttribute("data-email-domain") || "").trim();
          if (!user || !domain) return;
          const mailto = `mailto:${user}@${domain}`;
          window.location.href = mailto;
        };
        const onPhoneClick = (event) => {
          const trigger = event.currentTarget;
          if (!(trigger instanceof HTMLElement)) return;
          const prefix = String(trigger.getAttribute("data-phone-prefix") || "").trim();
          const rest = String(trigger.getAttribute("data-phone-rest") || "").trim();
          if (!prefix || !rest) return;
          window.location.href = `tel:${prefix}${rest}`.replace(/\s/g, "");
        };

        const saveDataMode = Boolean(navigator.connection && navigator.connection.saveData);
        if (saveDataMode) {
          document.documentElement.setAttribute("data-save-data", "true");
        }

        const formatAvailabilityDateHebrew = (isoString) => {
          const date = new Date(isoString);
          if (Number.isNaN(date.getTime())) return "";
          const days = ["ראשון", "שני", "שלישי", "רביעי", "חמישי", "שישי", "שבת"];
          const day = date.getDay();
          const prefix = day === 6 ? 'מוצ"ש' : `יום ${days[day]}`;
          const hours = date.getHours().toString().padStart(2, "0");
          const minutes = date.getMinutes().toString().padStart(2, "0");
          return `עודכן ${prefix} ${hours}:${minutes}`;
        };

        const refreshAvailabilityLines = () => {
          document.querySelectorAll("[data-nm-availability]").forEach((el) => {
            const spotsRaw = el.getAttribute("data-spots");
            const updatedAt = el.getAttribute("data-updated-at")?.trim();
            const label = (el.getAttribute("data-label") || "נותרו").trim();
            const spots = spotsRaw != null ? Number(spotsRaw) : NaN;
            if (!Number.isFinite(spots) || !updatedAt) return;
            const unit = spots === 1 ? "מקום" : "מקומות";
            const datePart = formatAvailabilityDateHebrew(updatedAt);
            el.textContent = datePart ? `${label} ${spots} ${unit} · ${datePart}` : `${label} ${spots} ${unit}`;
          });
        };

        searchTriggers.forEach((trigger) => trigger.addEventListener("click", onSearchClick));
        randomTriggers.forEach((trigger) => trigger.addEventListener("click", onRandomClick));
        maybeShowIdentityLine();
        refreshAvailabilityLines();

        const scrollStorageKey = `nm-scroll:${window.location.pathname}${window.location.search}`;
        const savedScroll = Number(sessionStorage.getItem(scrollStorageKey));

        const backBtn = document.getElementById("nm-back-to-top");
        const backThreshold = 300;
        const syncBackToTop = () => {
          if (!(backBtn instanceof HTMLElement)) return;
          const y = window.scrollY || document.documentElement.scrollTop || 0;
          const show = y > backThreshold;
          backBtn.classList.toggle("hidden", !show);
          backBtn.toggleAttribute("hidden", !show);
          backBtn.setAttribute("aria-hidden", show ? "false" : "true");
        };
        const onBackToTopScroll = () => syncBackToTop();
        const onBackToTopClick = () => {
          const main = document.getElementById("main-content");
          if (main instanceof HTMLElement) {
            main.scrollIntoView({ behavior: "smooth", block: "start" });
          } else {
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        };
        if (backBtn instanceof HTMLElement) {
          backBtn.addEventListener("click", onBackToTopClick);
        }
        window.addEventListener("scroll", onBackToTopScroll, { passive: true });

        const headerBar = document.querySelector("[data-site-header-bar]");
        const headerScrollThreshold = 50;
        const syncHeaderBarScrolled = () => {
          if (!(headerBar instanceof HTMLElement)) return;
          const y = window.scrollY || document.documentElement.scrollTop || 0;
          headerBar.classList.toggle("nm-header--scrolled", y >= headerScrollThreshold);
        };
        const onHeaderScroll = () => syncHeaderBarScrolled();
        window.addEventListener("scroll", onHeaderScroll, { passive: true });
        syncHeaderBarScrolled();

        const hash = String(window.location.hash || "").replace(/^#/, "");
        if (hash) {
          const target = document.getElementById(hash);
          if (target instanceof HTMLElement) {
            window.requestAnimationFrame(() => {
              target.scrollIntoView({ behavior: "auto", block: "start" });
              syncBackToTop();
              syncHeaderBarScrolled();
            });
          } else {
            syncBackToTop();
          }
        } else if (Number.isFinite(savedScroll) && savedScroll > 0) {
          window.requestAnimationFrame(() => {
            window.scrollTo(0, savedScroll);
            syncBackToTop();
            syncHeaderBarScrolled();
          });
        } else {
          syncBackToTop();
        }

        const persistScroll = () => {
          sessionStorage.setItem(scrollStorageKey, String(window.scrollY || 0));
        };
        window.addEventListener("scroll", persistScroll, { passive: true });
        window.addEventListener("beforeunload", persistScroll);

        const formatIsoDates = () => {
          document.querySelectorAll("[data-iso-date]").forEach((el) => {
            const raw = el.getAttribute("data-iso-date");
            if (!raw) return;
            const date = new Date(raw);
            if (Number.isNaN(date.getTime())) return;
            const formatted = new Intl.DateTimeFormat("he-IL", {
              year: "numeric",
              month: "2-digit",
              day: "2-digit",
              timeZone: Intl.DateTimeFormat().resolvedOptions().timeZone,
            }).format(date);
            el.textContent = formatted;
          });
        };
        formatIsoDates();
        window.__nmAnnounce = (message) => {
          const region = document.getElementById("nm-live-region");
          if (!(region instanceof HTMLElement)) return;
          region.textContent = "";
          window.setTimeout(() => {
            region.textContent = String(message || "");
          }, 20);
        };

        const showCopyFeedback = (trigger) => {
          const original = trigger.textContent || "";
          trigger.textContent = "✓ הועתק";
          window.setTimeout(() => {
            trigger.textContent = original;
          }, 2000);
        };
        const copyToClipboard = async (text) => {
          if (!text) return false;
          try {
            await navigator.clipboard.writeText(text);
            return true;
          } catch {
            return false;
          }
        };
        const onCopyClick = async (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const trigger = target.closest("[data-copy], [data-copy-text]");
          if (!(trigger instanceof HTMLElement)) return;
          const value =
            trigger.getAttribute("data-copy") ||
            trigger.getAttribute("data-copy-text") ||
            trigger.getAttribute("data-copy-value") ||
            "";
          const ok = await copyToClipboard(value);
          if (ok) showCopyFeedback(trigger);
        };
        document.addEventListener("click", onCopyClick);

        const setupFormPersistence = () => {
          const path = window.location.pathname.replace(/\/+$/, "") || "/";
          const isRegistrationPage =
            path === "/intake" ||
            path === "/intake/" ||
            path === "/registration" ||
            path === "/registration/";
          if (!isRegistrationPage) return () => {};

          const form = document.querySelector("main form");
          if (!(form instanceof HTMLFormElement)) return () => {};

          const fields = Array.from(
            form.querySelectorAll("input, textarea, select")
          ).filter((field) => {
            if (!(field instanceof HTMLElement)) return false;
            const input = field instanceof HTMLInputElement ? field : null;
            if (input && ["password", "file", "hidden", "submit", "button", "reset"].includes(input.type)) {
              return false;
            }
            return Boolean(field.id || field.getAttribute("name"));
          });
          if (!fields.length) return () => {};

          const storageKey = `nm-form-draft:${path}`;
          const restoreDraft = () => {
            try {
              const raw = window.localStorage.getItem(storageKey);
              if (!raw) return;
              const draft = JSON.parse(raw);
              fields.forEach((field) => {
                const key = field.getAttribute("name") || field.id;
                if (!key || !(key in draft)) return;
                if (field instanceof HTMLInputElement && (field.type === "checkbox" || field.type === "radio")) {
                  field.checked = Boolean(draft[key]);
                  return;
                }
                field.value = String(draft[key] ?? "");
              });
            } catch {
              /* ignore */
            }
          };

          const persistDraft = () => {
            const snapshot = {};
            fields.forEach((field) => {
              const key = field.getAttribute("name") || field.id;
              if (!key) return;
              if (field instanceof HTMLInputElement && (field.type === "checkbox" || field.type === "radio")) {
                snapshot[key] = field.checked;
                return;
              }
              snapshot[key] = field.value;
            });
            try {
              window.localStorage.setItem(storageKey, JSON.stringify(snapshot));
            } catch {
              /* ignore */
            }
          };

          restoreDraft();
          fields.forEach((field) => field.addEventListener("input", persistDraft));
          form.addEventListener("submit", () => {
            try {
              window.localStorage.removeItem(storageKey);
            } catch {
              /* ignore */
            }
          });

          return () => {
            fields.forEach((field) => field.removeEventListener("input", persistDraft));
          };
        };
        const cleanupFormPersistence = setupFormPersistence();

        emailTriggers.forEach((trigger) => trigger.addEventListener("click", onEmailClick));
        phoneTriggers.forEach((trigger) => trigger.addEventListener("click", onPhoneClick));

        window.addEventListener("nm:focus-target", (event) => {
          const selector = event?.detail?.selector;
          if (!selector) return;
          const target = document.querySelector(selector);
          if (!(target instanceof HTMLElement)) return;
          target.setAttribute("tabindex", "-1");
          target.focus({ preventScroll: true });
          target.scrollIntoView({ behavior: "smooth", block: "start" });
          window.__nmAnnounce?.("התוכן עודכן");
        });

        window.__nmLayoutCleanup = () => {
          searchTriggers.forEach((trigger) => trigger.removeEventListener("click", onSearchClick));
          randomTriggers.forEach((trigger) => trigger.removeEventListener("click", onRandomClick));
          emailTriggers.forEach((trigger) => trigger.removeEventListener("click", onEmailClick));
          phoneTriggers.forEach((trigger) => trigger.removeEventListener("click", onPhoneClick));
          document.removeEventListener("click", onCopyClick);
          cleanupFormPersistence();
          window.removeEventListener("scroll", persistScroll);
          window.removeEventListener("beforeunload", persistScroll);
          window.removeEventListener("scroll", onBackToTopScroll);
          window.removeEventListener("scroll", onHeaderScroll);
          if (backBtn instanceof HTMLElement) {
            backBtn.removeEventListener("click", onBackToTopClick);
          }
        };
      });
    </script>

    <script is:inline defer define:vars={{ clientLogUrl }}>
      (() => {
        const url = typeof clientLogUrl === "string" ? clientLogUrl.trim() : "";
        if (!url) return;
        const send = (payload) => {
          try {
            fetch(url, {
              method: "POST",
              mode: "cors",
              credentials: "omit",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
              keepalive: true,
            }).catch(() => {});
          } catch {
            /* ignore */
          }
        };
        window.addEventListener("error", (event) => {
          send({
            k: "error",
            m: String(event.message || "").slice(0, 500),
            f: String(event.filename || "").split("/").pop() || "",
            l: event.lineno ?? null,
            c: event.colno ?? null,
            p: typeof location !== "undefined" ? location.pathname : "",
          });
        });
        window.addEventListener("unhandledrejection", (event) => {
          const reason = event.reason;
          const text =
            typeof reason === "string"
              ? reason
              : reason && typeof reason.message === "string"
                ? reason.message
                : "unhandledrejection";
          send({
            k: "rejection",
            m: String(text).slice(0, 500),
            p: typeof location !== "undefined" ? location.pathname : "",
          });
        });
      })();
    </script>
  </body>
</html>
