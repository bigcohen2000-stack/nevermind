---
import "@fontsource-variable/assistant/wght.css";
import "../styles/global.css";
import { getCollection } from "astro:content";
import { ClientRouter } from "astro:transitions";
import A11yWidget from "../components/A11yWidget.astro";
import SearchModal from "../components/SearchModal";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import WhisperBanner from "../components/WhisperBanner.astro";
import appConfig from "../config/appConfig.json";
import siteSettings from "../config/siteSettings.json";
import { disclaimerLong } from "../lib/services";

type StagingBannerCfg = { enabled?: boolean; message?: string };
type SeoCfg = { allowIndexing?: boolean };
type BrandCfg = {
  logoPath?: string;
  defaultOgImagePath?: string;
  themeColor?: string;
  backgroundColor?: string;
  wordmarkHe?: string;
};
type ContactCfg = {
  whatsAppNumber?: string;
  email?: string;
  phoneDisplay?: string;
  phoneTel?: string;
};

const stagingCfg = (siteSettings as { stagingBanner?: StagingBannerCfg }).stagingBanner;
const seoCfg = (siteSettings as { seo?: SeoCfg }).seo;
const brandCfg = (siteSettings as { brand?: BrandCfg }).brand ?? {};
const stagingEnabled = Boolean(stagingCfg?.enabled);
const siteAllowsIndexing = seoCfg?.allowIndexing === true;
const stagingMessage =
  typeof stagingCfg?.message === "string" && stagingCfg.message.trim().length > 0
    ? stagingCfg.message.trim()
    : "האתר בהרצה";
const navTopClass = stagingEnabled
  ? "top-[calc(var(--nm-staging-banner-height)+var(--nm-nav-top,1.5rem))]"
  : "top-[var(--nm-nav-top,1.5rem)]";
const mainPadTopClass = stagingEnabled
  ? "pt-[calc(var(--nm-staging-banner-height)+var(--nm-nav-top,1.5rem)+6.25rem)]"
  : "pt-32";

const {
  title,
  description,
  frontmatter,
  hasInquirySection,
  faqItems,
  image,
  noIndex = false,
  robots = "index, follow",
  waArticleSlug = "",
} = Astro.props;

const waTags = Array.isArray(frontmatter?.tags) ? frontmatter.tags : [];
const waArticleTitle = typeof title === "string" ? title : "";
const waSlug = typeof waArticleSlug === "string" ? waArticleSlug.trim() : "";

const siteTitle = appConfig.site.name;
const siteDescription = "מרחב חקירה שקט לבהירות, דיוק רגשי והבנה בגובה העיניים.";
const siteUrl = appConfig.site.url;
const siteUrlSlash = siteUrl.endsWith("/") ? siteUrl : `${siteUrl}/`;
const logoPath =
  typeof brandCfg.logoPath === "string" && brandCfg.logoPath.startsWith("/")
    ? brandCfg.logoPath
    : "/images/logo.svg";
const iconPath = "/images/logo.svg";
const defaultOgPath =
  typeof brandCfg.defaultOgImagePath === "string" && brandCfg.defaultOgImagePath.startsWith("/")
    ? brandCfg.defaultOgImagePath
    : "/images/logo.svg";
const pwaThemeColor = typeof brandCfg.themeColor === "string" ? brandCfg.themeColor : "#092038";
const contact = appConfig.contact as ContactCfg;
const waDigits = String(contact.whatsAppNumber ?? "").replace(/\D/g, "");
const telHref =
  typeof contact.phoneTel === "string" && contact.phoneTel.trim().length > 0
    ? contact.phoneTel.trim()
    : waDigits
      ? `+${waDigits}`
      : "";
const phoneLabel =
  typeof contact.phoneDisplay === "string" && contact.phoneDisplay.trim().length > 0
    ? contact.phoneDisplay.trim()
    : waDigits.length >= 5 && waDigits.startsWith("972")
      ? `+972 ${waDigits.slice(3, 5)}-${waDigits.slice(5)}`
      : telHref;
const emailStr = typeof contact.email === "string" ? contact.email.trim() : "";
const [emailUserRaw = "", emailDomainRaw = ""] = emailStr.includes("@") ? emailStr.split("@") : ["", ""];
const emailUser = emailUserRaw.trim();
const emailDomain = emailDomainRaw.trim();
const [phonePrefixRaw = "", phoneRestRaw = ""] = telHref ? [telHref.slice(0, 4), telHref.slice(4)] : ["", ""];
const phonePrefix = phonePrefixRaw.trim();
const phoneRest = phoneRestRaw.trim();
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const trimMetaDescription = (value: string) => {
  const normalized = String(value || "").trim().replace(/\s+/g, " ");
  if (normalized.length <= 155) return normalized;
  return `${normalized.slice(0, 152).trimEnd()}...`;
};
const pageDescription = trimMetaDescription(description ?? frontmatter?.description ?? siteDescription);
const pageUrl = Astro.url ? new URL(Astro.url.pathname, siteUrl).toString() : siteUrl;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : pageUrl;
const defaultOgAbsolute = new URL(defaultOgPath.replace(/^\//, ""), siteUrlSlash).toString();
const resolveOgImage = (): string => {
  if (typeof image === "string" && image.trim().length > 0) {
    const t = image.trim();
    if (t.startsWith("http://") || t.startsWith("https://")) return t;
    return new URL(t.replace(/^\//, ""), siteUrlSlash).toString();
  }
  if (frontmatter?.image) {
    return new URL(String(frontmatter.image).replace(/^\//, ""), siteUrlSlash).toString();
  }
  return defaultOgAbsolute;
};
const ogImage = resolveOgImage();
const showOgRasterDimensions =
  ogImage === defaultOgAbsolute && /\.(jpe?g|png|webp)$/i.test(defaultOgPath);
const ogImageAlt = frontmatter?.title ? String(frontmatter.title) : pageTitle;
const clientLogUrl = (import.meta.env.PUBLIC_CLIENT_LOG_URL ?? "").trim();
const logoAbsolute = new URL(logoPath.replace(/^\//, ""), siteUrlSlash).toString();
const wordmarkHe =
  typeof brandCfg.wordmarkHe === "string" && brandCfg.wordmarkHe.trim().length > 0
    ? brandCfg.wordmarkHe.trim()
    : "השם לא משנה";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteTitle,
  url: siteUrl,
  logo: logoAbsolute,
  image: logoAbsolute,
  description: siteDescription,
  inLanguage: "he-IL",
  sameAs: [
    "https://www.facebook.com/nevermindyakir",
    "https://www.instagram.com/nevermind.co.il/",
    "https://www.tiktok.com/@nevermind.co.il",
    "https://x.com/nevermindyakir",
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteTitle,
  url: siteUrl,
  inLanguage: "he-IL",
  publisher: {
    "@type": "Organization",
    name: siteTitle,
    url: siteUrl,
  },
};

const professionalServiceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: siteTitle,
  url: new URL("services/", siteUrlSlash).toString(),
  image: logoAbsolute,
  description: siteDescription,
  inLanguage: "he-IL",
  areaServed: { "@type": "Country", name: "IL" },
  provider: {
    "@type": "Organization",
    name: siteTitle,
    url: siteUrl,
  },
};

const normalizeSegment = (segment: string) => {
  const map: Record<string, string> = {
    articles: "מאמרים",
    topics: "נושאים",
    now: "מה המצב עכשיו",
    training: "הכשרות",
    admin: "ניהול",
    services: "שירותים",
    glossary: "הגדרות מחדש",
    questions: "שאלות קצרות",
    intake: "צור קשר (אונליין)",
    archive: "ארכיון",
    studio: "סטודיו",
    about: "להבין",
    "personal-consultation": "שיחה אישית",
    "premium-access": "גישת פרימיום",
    journey: "מסלולי בהירות",
    "root-problem-tree": "עץ שורש הבעיה",
    "forbidden-library": "הספרייה האסורה",
    accessibility: "הצהרת נגישות",
    book: "קביעת שיחה",
    contact: "יצירת קשר",
    privacy: "מדיניות פרטיות",
    faq: "שאלות נפוצות",
    testimonials: "המלצות",
    terms: "תנאי התקשרות",
    library: "ספרייה מובנית",
    search: "חיפוש",
  };

  return map[segment] ?? segment;
};

const pathName = Astro.url?.pathname ?? "/";
const normalizeNavPath = (raw: string) => {
  const trimmed = String(raw || "").trim();
  if (!trimmed || trimmed === "/") return "/";
  return trimmed.replace(/\/+$/, "") || "/";
};
const currentNavPath = normalizeNavPath(pathName);

const intentNavItems: { href: string; label: string; activePrefixes: string[] }[] = [
  { href: "/archive/", label: "אני רוצה להעמיק", activePrefixes: ["/archive", "/articles"] },
  {
    href: "/studio/",
    label: "אני רוצה לדבר",
    activePrefixes: ["/studio", "/services", "/intake", "/personal-consultation", "/contact", "/book"],
  },
  { href: "/glossary/", label: "הגדרות מחדש", activePrefixes: ["/glossary"] },
  { href: "/about/", label: "שיטת NEVERMIND", activePrefixes: ["/about"] },
];

const intentNavItemIsCurrent = (prefixes: string[]) => {
  const p = currentNavPath;
  return prefixes.some((pre) => {
    const norm = normalizeNavPath(pre);
    if (norm === "/") return p === "/";
    return p === norm || p.startsWith(`${norm}/`);
  });
};

/** קישורי פוטר: מסלול, תוכן, נושאים נפוצים, כלים */
const footerLinkColumns: { title: string; links: { href: string; label: string }[] }[] = [
  {
    title: "מסלול",
    links: [
      { href: "/book/", label: "קביעת שיחה" },
      { href: "/services/", label: "שירותים" },
      { href: "/intake/", label: "צור קשר (אונליין)" },
      { href: "/studio/", label: "סטודיו" },
      { href: "/personal-consultation/", label: "שיחה אישית" },
    ],
  },
  {
    title: "תוכן",
    links: [
      { href: "/articles/", label: "ארכיון מאמרים" },
      { href: "/library/", label: "ספרייה מובנית" },
      { href: "/about/", label: "איך זה עובד כאן" },
      { href: "/glossary/", label: "הגדרות מחדש" },
      { href: "/questions/", label: "שאלות קצרות" },
      { href: "/now/", label: "מה המצב עכשיו" },
    ],
  },
  {
    title: "נושאים לדוגמה",
    links: [
      { href: "/topics/clarity/", label: "בהירות" },
      { href: "/topics/freedom/", label: "חופש" },
      { href: "/topics/self/", label: "העצמי" },
      { href: "/topics/thought-mechanics/", label: "מכניקת מחשבה" },
    ],
  },
  {
    title: "כלים",
    links: [
      { href: "/forbidden-library/", label: "הספרייה האסורה" },
      { href: "/root-problem-tree/", label: "עץ שורש הבעיה" },
      { href: "/accessibility/", label: "נגישות" },
    ],
  },
  {
    title: "מערכת",
    links: [
      { href: "/contact/", label: "יצירת קשר" },
      { href: "/faq/", label: "שאלות נפוצות" },
      { href: "/testimonials/", label: "המלצות" },
      { href: "/privacy/", label: "מדיניות פרטיות" },
      { href: "/terms/", label: "תנאי התקשרות" },
    ],
  },
];
const shouldNoIndexByPath = pathName.startsWith("/admin/");
const effectiveNoIndex = noIndex || shouldNoIndexByPath || !siteAllowsIndexing;
const robotsContent =
  typeof robots === "string" && robots.trim().length > 0
    ? robots.trim()
    : effectiveNoIndex
      ? "noindex, nofollow"
      : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const pathSegments = pathName.split("/").filter(Boolean);
const breadcrumbItems = [{ name: "בית", item: siteUrl }];
let runningUrl = siteUrl.replace(/\/$/, "");

pathSegments.forEach((segment: string, index: number) => {
  runningUrl = `${runningUrl}/${segment}`;
  const isLast = index === pathSegments.length - 1;
  const label = isLast && frontmatter?.title ? frontmatter.title : normalizeSegment(segment);
  breadcrumbItems.push({ name: label, item: runningUrl });
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: item.item,
  })),
};

const toIso = (value: string | Date | undefined) => {
  if (!value) return undefined;
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? undefined : date.toISOString();
};

const articleSchema = frontmatter
  ? {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: frontmatter.title ?? pageTitle,
      description: frontmatter.description ?? pageDescription,
      author: {
        "@type": "Person",
        name: frontmatter.author ?? "השם לא משנה",
      },
      datePublished: toIso(frontmatter.pubDate),
      dateModified: toIso(frontmatter.updatedDate) ?? toIso(frontmatter.pubDate),
      image: ogImage,
      inLanguage: "he-IL",
      mainEntityOfPage: pageUrl,
      publisher: {
        "@type": "Organization",
        name: siteTitle,
        url: siteUrl,
      },
    }
  : null;

const hasArticleDates = Boolean(frontmatter?.pubDate);
const ogType = hasArticleDates ? "article" : "website";
const articlePublishedMeta = hasArticleDates ? toIso(frontmatter?.pubDate) : undefined;
const articleModifiedMeta = hasArticleDates
  ? toIso(frontmatter?.updatedDate) ?? toIso(frontmatter?.pubDate)
  : undefined;

const normalizedFaqItems = Array.isArray(faqItems) ? faqItems : [];
const fallbackFaqItems =
  hasInquirySection && normalizedFaqItems.length === 0 && frontmatter?.description
    ? [
        {
          question: `מה בודקים במאמר "${frontmatter.title ?? pageTitle}"?`,
          answer: frontmatter.description,
        },
      ]
    : [];
const faqItemsForSchema = normalizedFaqItems.length > 0 ? normalizedFaqItems : fallbackFaqItems;
const faqSchema =
  faqItemsForSchema.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqItemsForSchema.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }
    : null;

const youtubeIdRaw = typeof frontmatter?.youtubeId === "string" ? frontmatter.youtubeId.trim() : "";
const videoSummaryPointsForSchema = Array.isArray(frontmatter?.videoSummaryPoints)
  ? frontmatter.videoSummaryPoints.map((p: string) => String(p).trim()).filter(Boolean)
  : [];

const videoObjectSchema =
  youtubeIdRaw.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "VideoObject",
        name: frontmatter?.title ?? pageTitle,
        description: frontmatter?.description ?? pageDescription,
        thumbnailUrl: [`https://i.ytimg.com/vi/${youtubeIdRaw}/hqdefault.jpg`],
        uploadDate: toIso(frontmatter?.pubDate),
        contentUrl: `https://www.youtube.com/watch?v=${youtubeIdRaw}`,
        embedUrl: `https://www.youtube-nocookie.com/embed/${youtubeIdRaw}`,
        ...(videoSummaryPointsForSchema.length > 0
          ? {
              keywords: videoSummaryPointsForSchema.join(", "),
              transcript: videoSummaryPointsForSchema.map((line: string) => `• ${line}`).join("\n"),
            }
          : {}),
        publisher: {
          "@type": "Organization",
          name: siteTitle,
          url: siteUrl,
        },
        inLanguage: "he-IL",
      }
    : null;

const schemas = [
  organizationSchema,
  websiteSchema,
  professionalServiceSchema,
  breadcrumbSchema,
  articleSchema,
  videoObjectSchema,
  faqSchema,
].filter(Boolean);
const randomArticlePaths = (await getCollection("articles", ({ data }) => data.draft !== true)).map((entry) => `/articles/${entry.slug}`);

const socialLinks = [
  { label: "פייסבוק", href: "https://www.facebook.com/nevermindyakir", mark: "f" },
  { label: "אינסטגרם", href: "https://www.instagram.com/nevermind.co.il/", mark: "IG" },
  { label: "טיקטוק", href: "https://www.tiktok.com/@nevermind.co.il", mark: "♪" },
  { label: "X", href: "https://x.com/nevermindyakir", mark: "X" },
];

---
<!doctype html>
<html lang="he" dir="rtl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta
      name="robots"
      content={robotsContent}
    />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="he" href={canonicalURL} />
    <link rel="dns-prefetch" href="https://api.web3forms.com" />

    <link rel="icon" href={iconPath} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={iconPath} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content={pwaThemeColor} />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={ogType} />
    {articlePublishedMeta ? <meta property="article:published_time" content={articlePublishedMeta} /> : null}
    {articleModifiedMeta ? <meta property="article:modified_time" content={articleModifiedMeta} /> : null}
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    {showOgRasterDimensions ? (
      <>
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    ) : null}
    <meta property="og:locale" content="he_IL" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemas)}></script>
    <ClientRouter />
    <script>
      import "../scripts/form-antispam-bootstrap.ts";
      import "../scripts/site-search-bootstrap.ts";
    </script>

  </head>
  <body
    data-whisper-banner-state="hidden"
    class={`min-h-screen overflow-x-hidden bg-[var(--nm-bg)] text-[var(--nm-fg)] antialiased selection:bg-[color-mix(in_srgb,var(--nm-accent)_18%,var(--nm-bg))] selection:text-[var(--nm-fg)]`}
  >
    <a
      href="#main-content"
      class="sr-only transition-colors duration-200 focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[110] focus:rounded-md focus:bg-[var(--nm-bg-canvas)] focus:px-4 focus:py-2 focus:text-[var(--nm-fg)] focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-[var(--color-red)] shadow-xl"
    >
      דלג לתוכן הראשי
    </a>

    {stagingEnabled ? (
      <div
        role="status"
        aria-live="polite"
        class="fixed inset-x-0 top-0 z-[100] flex min-h-[var(--nm-staging-banner-height)] items-center justify-center gap-3 bg-[var(--nm-accent)] px-4 py-3 text-center shadow-[0_4px_24px_color-mix(in_srgb,var(--nm-fg)_12%,transparent)]"
      >
        <span
          class="size-3 shrink-0 rounded-full bg-[var(--nm-on-accent)] ring-2 ring-[color-mix(in_srgb,var(--nm-on-accent)_55%,transparent)]"
          aria-hidden="true"
        />
        <p class="text-[clamp(1.2rem,1.05rem+1vw,1.85rem)] font-bold leading-tight text-[var(--nm-on-accent)]">
          {stagingMessage}
        </p>
      </div>
    ) : null}

    <WhisperBanner />

    <header>
      <nav
        data-nav
        class={`fixed inset-x-0 z-50 transition-[top] duration-300 ${navTopClass}`}
        aria-label="ניווט ראשי"
      >
        <div data-site-header-bar class="nm-header-bar w-full px-3 sm:px-4">
          <div class="nm-header-inner mx-auto grid max-w-6xl grid-cols-[1fr_auto] items-center gap-x-3 gap-y-3 py-3 md:grid-cols-[auto_minmax(0,1fr)_auto] md:gap-x-5 md:py-3.5">
            <a
              href="/"
              class="nm-header-brand col-start-1 row-start-1 flex min-w-0 max-w-[min(100%,20rem)] items-center gap-2.5 text-[clamp(1.05rem,1rem+0.35vw,1.25rem)] font-light leading-tight text-[var(--color-black)] no-underline transition-colors duration-200 [transition-timing-function:ease] hover:text-[var(--color-red)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
            >
              <img
                src={logoPath}
                alt="NeverMind"
                width="36"
                height="36"
                class="h-9 w-9 shrink-0 object-contain"
                fetchpriority="high"
                decoding="async"
              />
              <span class="truncate">{wordmarkHe}</span>
            </a>

            <div class="nm-nav-shell col-span-2 row-start-2 min-w-0 md:col-span-1 md:col-start-2 md:row-start-1 md:justify-self-stretch">
              <div class="nm-nav-pill overflow-x-auto nm-nav-scroll-hide">
                <ul class="flex w-max min-w-full flex-nowrap items-stretch justify-center gap-0.5 px-0.5 py-0.5 sm:gap-1" role="list">
                  {intentNavItems.map((item) => {
                    const active = intentNavItemIsCurrent(item.activePrefixes);
                    return (
                      <li class="shrink-0" role="none">
                        <a
                          href={item.href}
                          tabindex={0}
                          class={`nm-nav-link inline-flex min-h-[44px] max-w-[min(100vw-2rem,18rem)] items-center whitespace-nowrap rounded-full px-3 py-2 text-[0.9rem] font-normal no-underline transition-colors duration-200 [transition-timing-function:ease] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)] sm:px-3.5 ${
                            active
                              ? "bg-[color-mix(in_srgb,var(--color-red)_10%,transparent)] font-medium text-[var(--color-red)] shadow-[inset_0_0_0_1px_color-mix(in_srgb,var(--color-red)_22%,transparent)]"
                              : "text-[color-mix(in_srgb,var(--color-black)_65%,transparent)] hover:bg-[color-mix(in_srgb,var(--color-black)_5%,transparent)] hover:text-[var(--color-black)]"
                          }`}
                          {...(active ? ({ "aria-current": "page" } as const) : {})}
                        >
                          {item.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            </div>

            <div class="nm-header-actions col-start-2 row-start-1 flex shrink-0 items-center justify-end gap-2 md:col-start-3 md:row-start-1">
              <a
                href="/services/"
                data-astro-prefetch
