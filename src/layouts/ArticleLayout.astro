---
interface Props {
  frontmatter: {
    inversionQuestion?: string;
    finalQuestion?: string;
  };
}

const { frontmatter } = Astro.props as Props;
const inversionQuestion = String(frontmatter?.inversionQuestion || "").trim();
const finalQuestion = String(frontmatter?.finalQuestion || "").trim();
---

<article class="nm-article">
  <div class="content">
    <slot />
  </div>

  {inversionQuestion ? (
    <section class="inversion-method" aria-label="שאלת היפוך">
      <h2>שאלו את ההפך</h2>
      <p>{inversionQuestion}</p>
    </section>
  ) : null}

  {finalQuestion ? (
    <footer class="reflection" aria-label="שאלת סיום">
      <p class="question">{finalQuestion}</p>
    </footer>
  ) : null}
</article>

<style>
  .nm-article {
    max-width: 700px;
    margin: 0 auto;
    direction: rtl;
    font-family: "Assistant Variable", "Heebo", system-ui, sans-serif;
  }

  .content {
    display: grid;
    gap: 1.35rem;
  }

  .inversion-method {
    margin: 2.5rem 0 0;
    border-radius: 1.5rem;
    border: 0.5px solid color-mix(in srgb, var(--color-accent) 16%, transparent);
    background: #f3f1ed;
    padding: 1.35rem 1.4rem;
  }

  .inversion-method h2 {
    margin: 0 0 0.55rem;
    font-size: 1.1rem;
    line-height: 1.4;
  }

  .inversion-method p,
  .question {
    margin: 0;
    line-height: 1.9;
  }

  .reflection {
    margin-top: 2rem;
    border-top: 0.5px solid color-mix(in srgb, #1a1a1a 12%, transparent);
    padding-top: 1.15rem;
  }

  .question {
    font-weight: 700;
  }
</style>
