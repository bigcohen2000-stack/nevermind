---
import Layout from "../layouts/Layout.astro";
import Gatekeeper from "../components/Gatekeeper.astro";

const pageTitle = "טופס הכנה לשיחה";
const pageDescription = "טופס פרטי וקצר למי ששוקל שיחה או פגישה. הקישור הזה לא מיועד לחיפוש ציבורי.";
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <section class="mx-auto max-w-5xl space-y-10 px-4 pb-16">
    <header class="max-w-3xl space-y-4 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-[#D42B2B]">Private Intake</p>
      <h1 class="text-[clamp(2.2rem,1.5rem+2.2vw,3.6rem)] font-semibold leading-[1.05] text-[#1A1A1A]">לפני שיחה או פגישה, נעבור דרך טופס קצר.</h1>
      <p class="text-[1rem] leading-8 text-[#1A1A1A]/68">
        זה קישור פרטי. המטרה שלו היא לאסוף בהירות בסיסית לפני שיחה, כדי להבין אם נכון לדבר עכשיו, ואם כן, על מה נכון לדבר.
      </p>
    </header>

    <Gatekeeper phone="972555634035" fallbackHref="/articles/" fallbackLabel="לקרוא מאמר פתוח לפני שיחה" />
  </section>
</Layout>
