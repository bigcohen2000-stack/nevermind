---
import { CORE_REDIRECTS } from "../../data/migration-map";

export function getStaticPaths() {
  const slugs = new Set<string>();
  for (const dest of Object.values(CORE_REDIRECTS)) {
    const m = String(dest).match(/^\/products\/(.+)\/$/);
    if (m) slugs.add(m[1]);
  }
  return [...slugs].map((slug) => ({ params: { slug } }));
}

return Astro.redirect("/book/", 302);
---
