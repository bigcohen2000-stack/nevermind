---
import Layout from "../layouts/Layout.astro";
import TruthBlock from "../components/TruthBlock.astro";

const pageTitle = "המבנה של הטעות";
const pageDescription = "בעיה היא לא אירוע שקרה במציאות. היא תוצאה של מחשבה שלא נבדקה. כאן נפרק את המבנה שלה.";
const storageKey = "nm-root-problem-draft";

const dominoes = [
  {
    step: "הנחה",
    title: "משפט שלא נבדק",
    body: "המוח בוחר משפט אחד, ומחזיק בו כאילו הוא עובדה.",
  },
  {
    step: "תגובה",
    title: "ניסיון לשלוט בתוצאה",
    body: "המשפט יוצר לחץ. הלחץ דוחף להתנגדות, דחייה, או הימנעות.",
  },
  {
    step: "סימפטום",
    title: "תקיעות שנראית כמו בעיה",
    body: "הפעולה לא קורית. אחר כך נדמה שהתקיעות היא הבעיה עצמה.",
  },
];

const mechanics = [
  {
    label: "המנגנון",
    text: "אני מרגיש תקוע.",
  },
  {
    label: "העובדה",
    text: "יש פעולה שצריך לעשות והיא לא קורית.",
  },
  {
    label: "הפירוש",
    text: "אם אכשל, זה אומר עלי משהו נורא.",
  },
];

const breakdown = [
  {
    title: "הנחה נסתרת",
    body: 'המחשבה אומרת שהמציאות צריכה להיות אחרת ממה שהיא.',
  },
  {
    title: "התנגדות",
    body: "המוח נלחם בעובדה הקיימת, במקום לבדוק מה באמת קורה.",
  },
  {
    title: "הגדלה",
    body: "פעולה פשוטה נצבעת כאיום על הערך העצמי.",
  },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="problem-shell" dir="rtl">
    <header class="hero-card">
      <p class="hero-label">מפת פירוק</p>
      <h1 class="hero-title">המבנה של הטעות.</h1>
      <p class="hero-subtitle">
        בעיה היא לא אירוע שקרה במציאות. היא תוצאה של מחשבה שלא נבדקה. כאן נפרק את המבנה שלה.
      </p>
    </header>

    <section class="section-block" aria-labelledby="root-sequence-title">
      <div class="section-head">
        <p class="section-kicker">רצף המנגנון</p>
        <h2 id="root-sequence-title" class="section-title">הבעיה נבנית כמו שורת דומינו.</h2>
        <p class="section-copy">הנחה יוצרת תגובה. התגובה יוצרת סימפטום. אחר כך נדמה שהסימפטום הוא השורש.</p>
      </div>

      <div class="domino-grid">
        {dominoes.map((item) => (
          <article class="domino-card">
            <p class="domino-step">{item.step}</p>
            <h3 class="domino-title">{item.title}</h3>
            <p class="domino-body">{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block" aria-labelledby="stage-one-title">
      <div class="section-head">
        <p class="section-kicker">שלב 1</p>
        <h2 id="stage-one-title" class="section-title">הזיהוי</h2>
        <p class="section-copy">במקום לתאר רגש, נבדוק איזה מנגנון פועל עכשיו.</p>
      </div>

      <div class="fact-grid">
        {mechanics.map((item) => (
          <article class="fact-card">
            <p class="fact-label">{item.label}</p>
            <p class="fact-text">{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block" aria-labelledby="stage-two-title">
      <div class="section-head">
        <p class="section-kicker">שלב 2</p>
        <h2 id="stage-two-title" class="section-title">הפירוק</h2>
        <p class="section-copy">מחשבה אחת יכולה להפוך עובדה פשוטה למשבר גדול.</p>
      </div>

      <div class="breakdown-grid">
        {breakdown.map((item) => (
          <article class="fact-card">
            <h3 class="fact-title">{item.title}</h3>
            <p class="fact-text">{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block" aria-labelledby="stage-three-title">
      <div class="section-head">
        <p class="section-kicker">שלב 3</p>
        <h2 id="stage-three-title" class="section-title">השורש</h2>
        <p class="section-copy">
          השורש הוא תמיד מילה אחת או משפט אחד שהמוח לוקח כעובדה מבלי לבדוק אותה.
        </p>
      </div>

      <article class="root-card">
        <p class="root-label">דוגמה</p>
        <p class="root-statement">אני חייב להיות מוצלח כדי להיות קיים.</p>
        <p class="root-copy">כל עוד המשפט הזה נראה אמיתי, כל כישלון ירגיש כמו איום על הקיום.</p>
      </article>
    </section>

    <section class="section-block" aria-labelledby="inversion-title">
      <div class="section-head">
        <p class="section-kicker">היפוך</p>
        <h2 id="inversion-title" class="section-title">פחד מול מציאות</h2>
        <p class="section-copy">הפחד נשמע כמו עובדה. ההיפוך בודק אם באמת יש כאן עובדה.</p>
      </div>

      <TruthBlock label="בדיקת מציאות" questionForSchema="מה קורה כשבודקים את הפחד מול העובדה?">
        <p>הפחד אומר: אם אכשל, זה מוכיח שאני לא שווה.</p>
        <p>המציאות אומרת: יש פעולה, יש תוצאה, ויש מחשבה שמפרשת את התוצאה.</p>
        <p>כשהפירוש נבדק, הכישלון מפסיק להיראות כמו זהות.</p>
      </TruthBlock>
    </section>

    <section class="section-block" aria-labelledby="draft-title">
      <div class="section-head">
        <p class="section-kicker">בדיקה אישית</p>
        <h2 id="draft-title" class="section-title">כתבו כאן את בעיית השורש שלכם</h2>
        <p class="section-copy">נשמור את הניסוח הזה על המכשיר שלכם, כדי שלא ילך לאיבוד.</p>
      </div>

      <div class="draft-card">
        <label class="draft-label" for="root-problem-input">מה המשפט שהמוח מחזיק כעובדה</label>
        <textarea
          id="root-problem-input"
          class="draft-input"
          rows="6"
          placeholder="למשל: אם לא אצליח, זה אומר שאני לא שווה"
          data-root-problem-input
        ></textarea>
        <p class="draft-status" data-root-problem-status aria-live="polite">עדיין לא נכתב כאן דבר.</p>
      </div>
    </section>

    <section class="section-block" aria-labelledby="closing-title">
      <div class="section-head">
        <p class="section-kicker">סיכום</p>
        <h2 id="closing-title" class="section-title">כשהשורש נבדק, הסימפטום מאבד כוח.</h2>
        <p class="section-copy">
          הבעיה לא נפתרת כשמשנים את המציאות. היא נחלשת כשההנחה הנסתרת מתפרקת.
        </p>
      </div>
    </section>

    <script is:inline define:vars={{ storageKey }}>
      const initRootProblemDraft = () => {
        const input = document.querySelector("[data-root-problem-input]");
        const status = document.querySelector("[data-root-problem-status]");
        if (!(input instanceof HTMLTextAreaElement) || !(status instanceof HTMLElement)) {
          return;
        }

        const updateStatus = (value) => {
          const text = String(value || "").trim();
          status.textContent = text ? "נשמר אוטומטית על המכשיר הזה." : "עדיין לא נכתב כאן דבר.";
        };

        try {
          const saved = window.localStorage.getItem(storageKey) || "";
          if (saved) {
            input.value = saved;
          }
          updateStatus(saved);
        } catch {
          updateStatus(input.value);
        }

        const onInput = () => {
          const next = input.value;
          try {
            window.localStorage.setItem(storageKey, next);
          } catch {
            // Keep the field usable even if storage is blocked.
          }
          updateStatus(next);
        };

        input.addEventListener("input", onInput);
      };

      if (!window.__nmRootProblemDraftBound) {
        window.__nmRootProblemDraftBound = true;
        document.addEventListener("astro:page-load", initRootProblemDraft);
      }

      initRootProblemDraft();
    </script>
  </section>
</Layout>

<style>
  .problem-shell {
    inline-size: min(100%, 74rem);
    margin-inline: auto;
    padding-inline: 1.25rem;
    padding-block: 2rem 5rem;
    display: grid;
    gap: 1.5rem;
    color: var(--nm-fg);
  }

  .hero-card,
  .section-block,
  .domino-card,
  .fact-card,
  .root-card,
  .draft-card {
    border: 1px solid color-mix(in srgb, var(--nm-fg) 10%, transparent);
    background: color-mix(in srgb, white 92%, var(--nm-bg-canvas));
    box-shadow: 0 24px 70px rgba(26, 26, 26, 0.06);
  }

  .hero-card,
  .section-block,
  .draft-card,
  .root-card,
  .domino-card,
  .fact-card {
    border-radius: 2rem;
  }

  .hero-card,
  .section-block,
  .draft-card,
  .root-card {
    padding-inline: clamp(1.1rem, 2vw, 2rem);
    padding-block: clamp(1.2rem, 2vw, 2rem);
  }

  .hero-label,
  .section-kicker,
  .domino-step,
  .fact-label,
  .root-label {
    margin: 0;
    color: var(--nm-accent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .hero-title,
  .section-title,
  .domino-title,
  .fact-title,
  .root-statement {
    margin: 0;
    line-height: 1.25;
  }

  .hero-title {
    font-size: clamp(2.2rem, 1.9rem + 1.5vw, 3.7rem);
  }

  .hero-subtitle,
  .section-copy,
  .domino-body,
  .fact-text,
  .root-copy,
  .draft-status {
    margin: 0;
    line-height: 1.6;
    color: color-mix(in srgb, var(--nm-fg) 72%, var(--nm-bg));
  }

  .section-head {
    display: grid;
    gap: 0.55rem;
    margin-block-end: 1rem;
  }

  .domino-grid,
  .fact-grid,
  .breakdown-grid {
    display: grid;
    gap: 1rem;
  }

  .domino-grid,
  .fact-grid,
  .breakdown-grid {
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
  }

  .domino-card,
  .fact-card {
    padding-inline: 1rem;
    padding-block: 1rem;
    display: grid;
    gap: 0.65rem;
  }

  .fact-label,
  .domino-step {
    font-size: 0.82rem;
  }

  .root-card {
    display: grid;
    gap: 0.75rem;
    background: color-mix(in srgb, var(--nm-accent) 6%, white);
  }

  .root-statement {
    font-size: clamp(1.3rem, 1.1rem + 0.6vw, 1.8rem);
    font-weight: 700;
  }

  .draft-card {
    display: grid;
    gap: 0.9rem;
  }

  .draft-label {
    font-weight: 600;
    line-height: 1.5;
  }

  .draft-input {
    inline-size: 100%;
    min-block-size: 12rem;
    border-radius: 1.4rem;
    border: 1px solid color-mix(in srgb, var(--nm-fg) 14%, transparent);
    background: white;
    color: var(--nm-fg);
    padding-inline: 1rem;
    padding-block: 0.95rem;
    resize: vertical;
    line-height: 1.6;
  }

  .draft-input:focus-visible {
    outline: 2px solid var(--nm-accent);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .problem-shell {
      padding-inline: 0.9rem;
      padding-block: 1.25rem 4rem;
    }
  }
</style>
