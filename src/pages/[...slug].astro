---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import siteSettings from "../config/siteSettings.json";
import appConfig from "../config/appConfig.json";
import { glossaryConcepts } from "../data/glossary";
import { buildArticleMeetingWhatsAppMessage, buildWhatsAppHref } from "../lib/services";
import InquiryBox from "../components/InquiryBox.astro";
import InquirySection from "../components/InquirySection.astro";
import SubscribeBanner from "../components/SubscribeBanner.astro";
import VideoPlayer from "../components/VideoPlayer.astro";
import SkepticBox from "../components/SkepticBox.astro";
import ConceptCallout from "../components/ConceptCallout.astro";
import BottomLineSummary from "../components/BottomLineSummary.astro";
import PremiumLock from "../components/PremiumLock.astro";
import PremiumBreak from "../components/PremiumBreak.astro";
import RevealInsight from "../components/RevealInsight.astro";
import ReflectionQuestions from "../components/ReflectionQuestions.astro";
import LogicalQuestionBox from "../components/LogicalQuestionBox.astro";
import PerspectiveToggle from "../components/PerspectiveToggle.astro";
import RefutationBox from "../components/RefutationBox.astro";
import DeepDiveConcepts from "../components/DeepDiveConcepts.astro";
import LogicNote from "../components/LogicNote.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import ThoughtReveal from "../components/ThoughtReveal.astro";
import AudioNarrative from "../components/AudioNarrative.astro";
import { DirectLink } from "../components/ui/DirectLink";
import TruthBlock from "../components/ui/TruthBlock";
import SocialParadoxes from "../components/SocialParadoxes.astro";
import DeepDiveInquiry from "../components/DeepDiveInquiry.astro";
import ClarityAnalogy from "../components/ClarityAnalogy.astro";
import ArticleShareActions from "../components/ArticleShareActions.astro";
import ArticleBenefits from "../components/ArticleBenefits.astro";
import TenSecondExercise from "../components/TenSecondExercise.astro";
import NextNaturalStep from "../components/NextNaturalStep.astro";
import DepthSideNav from "../components/DepthSideNav.astro";
import BookBanner from "../components/ui/BookBanner.astro";

type ArticleEntry = CollectionEntry<"articles">;
type InternalLink = {
  href: string;
  title: string;
  description: string;
  kind: "article" | "topic" | "page";
  score?: number;
};

const difficultyConfig = {
  beginner: {
    label: "מתחילים",
    tone: "bg-[var(--nm-tint)] text-[var(--nm-fg)] border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)]",
  },
  advanced: {
    label: "מתקדמים",
    tone: "bg-[var(--nm-tint-strong)] text-[var(--nm-fg)] border-[color-mix(in_srgb,var(--nm-accent)_26%,transparent)]",
  },
  deep: {
    label: "חקירה עמוקה",
    tone: "bg-[var(--nm-inverse)] text-[var(--nm-inverse-fg)] border-[color-mix(in_srgb,var(--nm-fg)_22%,transparent)]",
  },
} as const;

type DifficultyKey = keyof typeof difficultyConfig;

const toArticleSlug = (entry: ArticleEntry) => entry.id.replace(/\.mdx$/, "");

const topicMap = {
  חופש: {
    href: "/topics/freedom/",
    title: "נושא: חופש",
    description: "ריכוז מאמרים על חופש, אחריות, והמחיר של בחירה אמיתית.",
  },
  "מכניקת מחשבה": {
    href: "/topics/thought-mechanics/",
    title: "נושא: מכניקת מחשבה",
    description: "מקום אחד למאמרים שמפרקים איך מחשבה מנהלת התנגדות.",
  },
  העצמי: {
    href: "/topics/self/",
    title: "נושא: העצמי",
    description: "חקירה של זהות, הזדהות, ודמויות פנימיות שמחזיקות מעמד.",
  },
  בהירות: {
    href: "/topics/clarity/",
    title: "נושא: בהירות",
    description: "מאמרים שמנקים רעש ומכריחים לראות מה באמת קורה.",
  },
  בחירה: {
    href: "/topics/choice/",
    title: "נושא: בחירה",
    description: "מאמרים על רצון, החלטה, ושליטה מודעת.",
  },
} as const;

const kindLabelMap = {
  article: "מאמר קשור",
  topic: "דף נושא",
  page: "עמוד ליבה",
} as const;

export async function getStaticPaths() {
  const entries = await getCollection("articles", ({ data }) => data.draft !== true);
  return entries.map((entry) => ({
    params: { slug: `articles/${entry.id.replace(/\.mdx$/, "")}` },
    props: { entry },
  }));
}

const allEntries = await getCollection("articles", ({ data }) => data.draft !== true);
const { entry } = Astro.props as { entry: ArticleEntry };
const { Content } = await render(entry);
const frontmatter = entry.data;
const rawContent = entry.body ?? "";
const title = frontmatter.title;
const description = frontmatter.description;
const bottomLine = frontmatter.bottomLine ?? frontmatter.description;
const youtubeId = typeof frontmatter.youtubeId === "string" ? frontmatter.youtubeId.trim() : "";
const videoSummaryPoints = Array.isArray(frontmatter.videoSummaryPoints)
  ? frontmatter.videoSummaryPoints.map((point) => String(point).trim()).filter(Boolean)
  : [];
const audioUrl = frontmatter.audioUrl;
const audioFile = typeof frontmatter.audioFile === "string" ? frontmatter.audioFile.trim() : "";
const hasInlineVideoPlayer = /<VideoPlayer\b/i.test(rawContent);
const tags = Array.isArray(frontmatter.tags) ? frontmatter.tags : [];
let faqItems = Array.isArray(frontmatter.faq) ? frontmatter.faq : [];
const hasInquirySection = rawContent.includes("InquirySection") || rawContent.includes("InquiryBox");
const siteUrl = Astro.site?.toString() ?? appConfig.site.url;
const shareUrl = Astro.url ? new URL(Astro.url.pathname, siteUrl).toString() : siteUrl;
const whatsappShareUrl = `https://wa.me/?text=${encodeURIComponent(
  `קראתי את זה וחשבתי עליך, זה בדיוק מה שדיברנו עליו:\n${title}\n${shareUrl}`
)}`;
const web3formsKey = "94b32b6c-7590-4ac6-b8b4-1bc73dd2e5c8";
const currentSlug = `articles/${toArticleSlug(entry)}`;
const plainText = rawContent.replace(/<[^>]*>/g, " ");
const wordCount = plainText.split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 200));
const difficultyKey: DifficultyKey =
  frontmatter.difficultyLevel && frontmatter.difficultyLevel in difficultyConfig
    ? (frontmatter.difficultyLevel as DifficultyKey)
    : wordCount > 1400
      ? "deep"
      : wordCount > 900
        ? "advanced"
        : "beginner";
const difficultyMeta = difficultyConfig[difficultyKey];
const showBottomLine = wordCount >= 900 && Boolean(bottomLine);
const showPremiumBreak = difficultyKey === "deep" || wordCount >= 1400;
const primaryTag = tags[0] ?? "הנקודה הזאת";
const discoveryServicesHref =
  tags.length > 0 ? `/services/?topic=${encodeURIComponent(tags[0])}` : "/services/";
const inversionNote =
  typeof frontmatter.inversionNote === "string" ? frontmatter.inversionNote.trim() : "";
const tagPromptMap: Record<string, string> = {
  חופש: "איפה אתה עדיין מוותר על חופש פנימי כדי לא לשלם מחיר חיצוני?",
  "מכניקת מחשבה": "איזו מחשבה אצלך נשמעת כמו אמת, אבל בפועל מנהלת אותך אוטומטית?",
  העצמי: "איזו דמות פנימית אתה עדיין מנסה להגן עליה גם כשהיא כבר מכבידה עליך?",
  בהירות: "איפה אתה כבר יודע מה נכון, אבל עדיין מעדיף ערפל כי הוא פחות מחייב?",
  בחירה: "באיזה מקום בחיים שלך אתה קורא לזה 'אין לי ברירה', כשבפועל יש ברירה עם מחיר?",
};
const fallbackReflectionQuestions = [
  `מה מתוך "${title}" פוגש בך לא כרעיון, אלא כמשהו שאתה מזהה בעצמך עכשיו?`,
  tagPromptMap[primaryTag] ??
    `איך ${primaryTag} פוגש אותך בחיים האמיתיים, ולא רק ברמת ההסכמה הכללית?`,
  "אם היית צריך לשלוח לי עכשיו תשובה כנה בוואטסאפ במשפט אחד בלבד, מה היית כותב?",
];
const reflectionQuestions =
  Array.isArray(frontmatter.reflectionQuestions) && frontmatter.reflectionQuestions.length === 3
    ? frontmatter.reflectionQuestions
    : fallbackReflectionQuestions;

if (faqItems.length === 0 && reflectionQuestions.length === 3) {
  const baseAnswer = bottomLine || description;
  faqItems = reflectionQuestions.map((question) => ({ question, answer: baseAnswer }));
}

const meetingMessage = buildArticleMeetingWhatsAppMessage({
  title,
  slug: currentSlug,
});
const reflectionWhatsAppUrl = buildWhatsAppHref(meetingMessage);
const originalInsight = typeof frontmatter.originalInsight === "string" ? frontmatter.originalInsight.trim() : "";
const premiumVault = siteSettings.premiumVault;
const premiumAccess = appConfig.premiumAccess;
const manualRelatedConcepts = Array.isArray(frontmatter.relatedConcepts) ? frontmatter.relatedConcepts : [];
const articleSignal = `${title} ${description} ${tags.join(" ")} ${rawContent.slice(0, 1200)}`.toLowerCase();
const relatedConcepts = glossaryConcepts
  .map((concept) => {
    let score = 0;
    if (manualRelatedConcepts.includes(concept.slug) || manualRelatedConcepts.includes(concept.title)) {
      score += 12;
    }
    score += concept.tags.filter((tag) => tags.includes(tag)).length * 3;
    score += concept.keywords.filter((keyword) => articleSignal.includes(keyword.toLowerCase())).length * 2;
    if (articleSignal.includes(concept.title.toLowerCase())) {
      score += 4;
    }
    return { concept, score };
  })
  .filter((item) => item.score > 0)
  .sort((left, right) => right.score - left.score)
  .slice(0, 5)
  .map((item) => item.concept);

const relatedArticles = allEntries
  .filter((item) => `articles/${toArticleSlug(item)}` !== currentSlug)
  .map((item) => {
    const itemTags = Array.isArray(item.data.tags) ? item.data.tags : [];
    const overlap = itemTags.filter((tag) => tags.includes(tag)).length;
    return { item, overlap };
  })
  .filter(({ overlap }) => overlap > 0)
  .sort((left, right) => {
    if (right.overlap !== left.overlap) return right.overlap - left.overlap;
    return right.item.data.pubDate.getTime() - left.item.data.pubDate.getTime();
  })
  .slice(0, 3);

const isRelationshipArticle =
  /zugiyut|zogiyut|relationship/i.test(currentSlug) ||
  tags.some((tag) => ["זוגיות", "מערכות-יחסים", "חברים"].includes(String(tag)));

const resolveDifficultyKeyForEntry = (entry: ArticleEntry): DifficultyKey => {
  const level = entry.data.difficultyLevel;
  if (level && level in difficultyConfig) return level as DifficultyKey;
  const body = entry.body ?? "";
  const wordCount = body.replace(/<[^>]*>/g, " ").split(/\s+/).filter(Boolean).length;
  if (wordCount > 1400) return "deep";
  if (wordCount > 900) return "advanced";
  return "beginner";
};

const nextDifficulty: DifficultyKey | null =
  difficultyKey === "beginner" ? "advanced" : difficultyKey === "advanced" ? "deep" : null;

const overlapRankedArticles = allEntries
  .filter((item) => `articles/${toArticleSlug(item)}` !== currentSlug)
  .map((item) => {
    const itemTags = Array.isArray(item.data.tags) ? item.data.tags : [];
    const overlap = itemTags.filter((tag) => tags.includes(tag)).length;
    return { item, overlap };
  })
  .filter(({ overlap }) => overlap > 0)
  .sort((left, right) => {
    if (right.overlap !== left.overlap) return right.overlap - left.overlap;
    return right.item.data.pubDate.getTime() - left.item.data.pubDate.getTime();
  })
  .slice(0, 10);

const nextArticleEntry =
  nextDifficulty != null
    ? overlapRankedArticles.find(({ item }) => resolveDifficultyKeyForEntry(item) === nextDifficulty)?.item ??
      overlapRankedArticles[0]?.item
    : null;

const nextTarget =
  nextArticleEntry && nextDifficulty
    ? {
        kind: "article" as const,
        href: `/articles/${toArticleSlug(nextArticleEntry)}`,
        title: nextArticleEntry.data.title,
        description: nextArticleEntry.data.description,
        label: difficultyConfig[nextDifficulty].label,
      }
    : {
        kind: "service" as const,
        href: discoveryServicesHref,
        title: "עבודה משותפת",
        description: "אם המאמר פגש נקודה חיה, בוחרים צעד אחד ומתקדמים.",
        label: "שיחה ממוקדת",
      };

const secondaryTargets = overlapRankedArticles
  .filter(({ item }) => {
    if (!nextArticleEntry) return true;
    return toArticleSlug(item) !== toArticleSlug(nextArticleEntry);
  })
  .slice(0, 2)
  .map(({ item }) => ({
    kind: "article" as const,
    href: `/articles/${toArticleSlug(item)}`,
    title: item.data.title,
    description: item.data.description,
  }));

const beginnerEntryForNav = overlapRankedArticles.find(({ item }) => resolveDifficultyKeyForEntry(item) === "beginner")?.item;
const advancedEntryForNav = overlapRankedArticles.find(({ item }) => resolveDifficultyKeyForEntry(item) === "advanced")?.item;

const depthNavItems = [
  {
    key: "beginner" as const,
    label: difficultyConfig.beginner.label,
    tone: difficultyConfig.beginner.tone,
    href: difficultyKey !== "beginner" && beginnerEntryForNav ? `/articles/${toArticleSlug(beginnerEntryForNav)}` : undefined,
  },
  {
    key: "advanced" as const,
    label: difficultyConfig.advanced.label,
    tone: difficultyConfig.advanced.tone,
    href: difficultyKey !== "advanced" && advancedEntryForNav ? `/articles/${toArticleSlug(advancedEntryForNav)}` : undefined,
  },
  {
    key: "deep" as const,
    label: difficultyConfig.deep.label,
    tone: difficultyConfig.deep.tone,
    href: difficultyKey !== "deep" ? discoveryServicesHref : undefined,
  },
];

const sortedChrono = [...allEntries].sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
const chronoIdx = sortedChrono.findIndex((e) => toArticleSlug(e) === toArticleSlug(entry));
const prevChronoArticle = chronoIdx > 0 ? sortedChrono[chronoIdx - 1]! : null;
const nextChronoArticle =
  chronoIdx >= 0 && chronoIdx < sortedChrono.length - 1 ? sortedChrono[chronoIdx + 1]! : null;

const internalLinks: InternalLink[] = [];
const seenLinks = new Set<string>([shareUrl, `/${currentSlug}`]);

const pushInternalLink = (link: InternalLink) => {
  if (seenLinks.has(link.href)) return;
  seenLinks.add(link.href);
  internalLinks.push(link);
};

for (const { item, overlap } of relatedArticles) {
  pushInternalLink({
    href: `/articles/${toArticleSlug(item)}`,
    title: item.data.title,
    description: item.data.description,
    kind: "article",
    score: overlap,
  });
}

for (const tag of tags) {
  const topicLink = topicMap[tag as keyof typeof topicMap];
  if (!topicLink) continue;
  pushInternalLink({ ...topicLink, kind: "topic" });
}

[
  {
    href: "/articles/",
    title: "כל המאמרים",
    description: "ספריית התוכן המלאה, למעבר בין חקירות לפי כיוון ולא לפי רעש.",
    kind: "page" as const,
  },
  {
    href: "/glossary/",
    title: "הגדרות מחדש",
    description:
      "כדי להבין אחד את השני באמת, חייבים להסכים על משמעות המילים. כאן נמצא ההסבר הפשוט והנקי למושגים שאנחנו משתמשים בהם, בלי כוונה נסתרת.",
    kind: "page" as const,
  },
  {
    href: discoveryServicesHref,
    title: "עבודה משותפת",
    description: "אם המאמר פגש נקודה חיה, אפשר להפוך אותה לעבודה ממוקדת ולא לעוד מחשבה.",
    kind: "page" as const,
  },
  {
    href: "/now/",
    title: "מה המצב עכשיו",
    description: "עדכון קצר על הכיוון הנוכחי של NeverMind, בלי מסכות ובלי יחסי ציבור.",
    kind: "page" as const,
  },
].forEach(pushInternalLink);

const curatedInternalLinks = internalLinks.slice(0, 5);
while (curatedInternalLinks.length < 3) {
  const fallbackArticle = allEntries.find(
    (item) =>
      `articles/${toArticleSlug(item)}` !== currentSlug &&
      !curatedInternalLinks.some((link) => link.href === `/articles/${toArticleSlug(item)}`)
  );
  if (!fallbackArticle) break;
  curatedInternalLinks.push({
    href: `/articles/${toArticleSlug(fallbackArticle)}`,
    title: fallbackArticle.data.title,
    description: fallbackArticle.data.description,
    kind: "article",
  });
}

const glossaryTerms = relatedConcepts.map((concept) => ({
  term: concept.title,
  definition: concept.definition,
}));

const components = {
  InquiryBox,
  InquirySection,
  SubscribeBanner,
  SkepticBox,
  ConceptCallout,
  BottomLineSummary,
  PremiumLock,
  RevealInsight,
  ReflectionQuestions,
  RefutationBox,
  DeepDiveConcepts,
  LogicNote,
  WhatsAppButton,
  VideoPlayer,
  PerspectiveToggle,
  ThoughtReveal,
  TruthBlock,
  SocialParadoxes,
  DeepDiveInquiry,
  ClarityAnalogy,
};
---

<Layout
  title={title}
  description={description}
  frontmatter={frontmatter}
  hasInquirySection={hasInquirySection}
  faqItems={faqItems}
  image={frontmatter.image}
  waArticleSlug={currentSlug}
>
  <div aria-hidden="true" class="fixed inset-x-0 top-0 z-40 h-px bg-transparent">
    <span id="reading-progress" class="block h-px w-0 bg-[var(--nm-inverse)]"></span>
  </div>

  <div class="mx-auto max-w-7xl lg:grid lg:grid-cols-[minmax(0,72ch)_minmax(280px,340px)] lg:gap-10">
    <article class="min-w-0 space-y-[clamp(1.75rem,3vw,2.5rem)]">
      <nav aria-label="פירורי לחם" class="text-right">
        <ol class="flex w-full flex-wrap items-center justify-start gap-2 text-sm text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">
          <li>
            <a
              href="/"
              class="transition-colors duration-200 hover:text-[var(--nm-accent)]"
            >
              בית
            </a>
          </li>
          <li aria-hidden="true" class="text-[color-mix(in_srgb,var(--nm-fg)_36%,var(--nm-bg))]">›</li>
          <li>
            <a
              href="/articles/"
              class="transition-colors duration-200 hover:text-[var(--nm-accent)]"
            >
              מאמרים
            </a>
          </li>
          <li aria-hidden="true" class="text-[color-mix(in_srgb,var(--nm-fg)_36%,var(--nm-bg))]">›</li>
          <li class="font-semibold text-[color-mix(in_srgb,var(--nm-fg)_76%,var(--nm-bg))]">{title}</li>
        </ol>
      </nav>

      <header class="space-y-5 text-right">
        <h1 class="text-[clamp(2.1rem,1.65rem+2vw,4rem)] font-semibold leading-[1.04] text-[var(--nm-fg)]">{title}</h1>
        <section
          aria-label="תקציר המאמר"
          class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] border-r-4 border-r-[var(--nm-accent)] bg-[var(--nm-bg-canvas)]/85 px-5 py-4"
        >
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">בשתי שורות:</p>
          <p class="mt-2 text-[clamp(1.08rem,1rem+0.35vw,1.35rem)] font-semibold leading-8 text-[color-mix(in_srgb,var(--nm-fg)_80%,var(--nm-bg))]">{description}</p>
        </section>

        {frontmatter.image && frontmatter.image !== "/images/logo.svg" ? (
          <section
            class="mx-auto max-w-[72ch] overflow-hidden rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/70"
            aria-label="תמונה ראשית"
          >
            <img
              src={frontmatter.image}
              alt={title}
              loading="lazy"
              decoding="async"
              width="1280"
              height="720"
              class="block h-auto w-full"
            />
          </section>
        ) : null}

        <ArticleBenefits reflectionQuestions={reflectionQuestions} bottomLine={bottomLine} />

        {originalInsight && (
          <section class="rounded-[1.35rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-5 py-4">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">תובנת ליבה</p>
              <button
                type="button"
                data-copy-insight
                data-insight={originalInsight}
                data-article-title={title}
                class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-3 py-1.5 text-xs font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_30%,transparent)] hover:text-[var(--nm-accent)]"
              >
                העתק תובנה
              </button>
            </div>
            <p class="mt-3 text-[clamp(1rem,0.95rem+0.25vw,1.15rem)] font-semibold leading-8 text-[var(--nm-fg)]">
              {originalInsight}
            </p>
          </section>
        )}

        <div class="flex flex-wrap items-center justify-end gap-3 text-[clamp(0.85rem,0.82rem+0.2vw,1rem)] text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">
          <span>{readingMinutes} דקות קריאה שיחסכו לך חודשים של התלבטות</span>
          <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${difficultyMeta.tone}`}>
            רמת עומק: {difficultyMeta.label}
          </span>
        </div>

        <p class="flex flex-wrap justify-end gap-x-3 gap-y-1 text-[clamp(0.8rem,0.78rem+0.2vw,0.95rem)] text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">
          <span>
            פורסם:{" "}
            <span data-iso-date={frontmatter.pubDate.toISOString()}>{frontmatter.pubDate.toLocaleDateString("he-IL")}</span>
          </span>
          {frontmatter.updatedDate ? (
            <span>
              עודכן לאחרונה:{" "}
              <span data-iso-date={new Date(frontmatter.updatedDate).toISOString()}>
                {new Date(frontmatter.updatedDate).toLocaleDateString("he-IL")}
              </span>
            </span>
          ) : null}
        </p>

        <div class="flex flex-wrap items-center justify-end gap-3">
