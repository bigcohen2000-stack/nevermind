---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import siteSettings from "../config/siteSettings.json";
import InquiryBox from "../components/InquiryBox.astro";
import InquirySection from "../components/InquirySection.astro";
import SubscribeBanner from "../components/SubscribeBanner.astro";
import LiteYouTubeEmbed from "../components/LiteYouTubeEmbed.astro";
import SkepticBox from "../components/SkepticBox.astro";
import ConceptCallout from "../components/ConceptCallout.astro";
import PremiumLock from "../components/PremiumLock.astro";
import RevealInsight from "../components/RevealInsight.astro";
import appConfig from "../config/appConfig.json";

type ArticleEntry = CollectionEntry<"articles">;
type InternalLink = {
  href: string;
  title: string;
  description: string;
  kind: "article" | "topic" | "page";
  score?: number;
};

const toArticleSlug = (entry: ArticleEntry) => entry.id.replace(/\.mdx$/, "");
const topicMap = {
  "חופש": {
    href: "/topics/freedom/",
    title: "נושא: חופש",
    description: "ריכוז מאמרים על חופש, אחריות, והמחיר של בחירה אמיתית.",
  },
  "מכניקת מחשבה": {
    href: "/topics/thought-mechanics/",
    title: "נושא: מכניקת מחשבה",
    description: "מקום אחד למאמרים שמפרקים איך מחשבה מנהלת התנהגות.",
  },
  "העצמי": {
    href: "/topics/self/",
    title: "נושא: העצמי",
    description: "חקירה של זהות, הזדהות, ודמות פנימית שמתעקשת להחזיק מעמד.",
  },
  "בהירות": {
    href: "/topics/clarity/",
    title: "נושא: בהירות",
    description: "מאמרים שמנקים רעש ומכריחים לראות מה באמת קורה.",
  },
  "בחירה": {
    href: "/topics/choice/",
    title: "נושא: בחירה",
    description: "מאמרים על רצון, החלטה, ושליטה מדומיינת.",
  },
} as const;
const kindLabelMap = {
  article: "מאמר קשור",
  topic: "דף נושא",
  page: "עמוד ליבה",
} as const;

export async function getStaticPaths() {
  const entries = await getCollection("articles", ({ data }) => data.draft !== true);
  return entries.map((entry) => ({
    params: { slug: `articles/${toArticleSlug(entry)}` },
    props: { entry },
  }));
}

const allEntries = await getCollection("articles", ({ data }) => data.draft !== true);
const { entry } = Astro.props as { entry: ArticleEntry };
const { Content } = await render(entry);
const frontmatter = entry.data;
const rawContent = entry.body ?? "";
const title = frontmatter.title;
const description = frontmatter.description;
const youtubeId = frontmatter.youtubeId;
const audioUrl = frontmatter.audioUrl;
const tags = Array.isArray(frontmatter.tags) ? frontmatter.tags : [];
const faqItems = Array.isArray(frontmatter.faq) ? frontmatter.faq : [];
const hasInquirySection = rawContent.includes("InquirySection") || rawContent.includes("InquiryBox");
const siteUrl = Astro.site?.toString() ?? appConfig.site.url;
const shareUrl = Astro.url ? new URL(Astro.url.pathname, siteUrl).toString() : siteUrl;
const whatsappShareUrl = `https://wa.me/?text=${encodeURIComponent(`מצאתי תובנה מעניינת ב-NeverMind: ${title} - ${shareUrl}`)}`;
const web3formsKey = "94b32b6c-7590-4ac6-b8b4-1bc73dd2e5c8";
const currentSlug = `articles/${toArticleSlug(entry)}`;
const wordCount = rawContent.replace(/<[^>]*>/g, " ").split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));
const depth = wordCount > 1400 ? "עמוק מאוד" : wordCount > 900 ? "עמוק" : "נגיש";
const premiumVault = siteSettings.premiumVault;
const premiumAccess = appConfig.premiumAccess;
const relatedArticles = allEntries
  .filter((item) => `articles/${toArticleSlug(item)}` !== currentSlug)
  .map((item) => {
    const itemTags = Array.isArray(item.data.tags) ? item.data.tags : [];
    const overlap = itemTags.filter((tag) => tags.includes(tag)).length;
    return { item, overlap };
  })
  .filter(({ overlap }) => overlap > 0)
  .sort((left, right) => {
    if (right.overlap !== left.overlap) return right.overlap - left.overlap;
    return right.item.data.pubDate.getTime() - left.item.data.pubDate.getTime();
  })
  .slice(0, 3);

const internalLinks: InternalLink[] = [];
const seenLinks = new Set<string>([shareUrl, `/${currentSlug}`]);

const pushInternalLink = (link: InternalLink) => {
  if (seenLinks.has(link.href)) return;
  seenLinks.add(link.href);
  internalLinks.push(link);
};

for (const { item, overlap } of relatedArticles) {
  pushInternalLink({
    href: `/articles/${toArticleSlug(item)}`,
    title: item.data.title,
    description: item.data.description,
    kind: "article",
    score: overlap,
  });
}

for (const tag of tags) {
  const topicLink = topicMap[tag as keyof typeof topicMap];
  if (!topicLink) continue;
  pushInternalLink({
    ...topicLink,
    kind: "topic",
  });
}

[
  {
    href: "/articles/",
    title: "כל המאמרים",
    description: "ספריית התוכן המלאה, למעבר בין חקירות לפי כיוון ולא לפי רעש.",
    kind: "page" as const,
  },
  {
    href: "/services/",
    title: "עבודה משותפת",
    description: "אם המאמר פגש נקודה חיה, אפשר להפוך אותה לעבודה ממוקדת ולא לעוד מחשבה.",
    kind: "page" as const,
  },
  {
    href: "/now/",
    title: "מה המצב עכשיו",
    description: "עדכון קצר על הכיוון הנוכחי של NeverMind, בלי מסכות ובלי יחסי ציבור.",
    kind: "page" as const,
  },
].forEach(pushInternalLink);

const curatedInternalLinks = internalLinks.slice(0, 5);
while (curatedInternalLinks.length < 3) {
  const fallbackArticle = allEntries.find(
    (item) =>
      `articles/${toArticleSlug(item)}` !== currentSlug &&
      !curatedInternalLinks.some((link) => link.href === `/articles/${toArticleSlug(item)}`)
  );
  if (!fallbackArticle) break;
  curatedInternalLinks.push({
    href: `/articles/${toArticleSlug(fallbackArticle)}`,
    title: fallbackArticle.data.title,
    description: fallbackArticle.data.description,
    kind: "article",
  });
}

const components = {
  InquiryBox,
  InquirySection,
  SubscribeBanner,
  SkepticBox,
  ConceptCallout,
  PremiumLock,
  RevealInsight,
};
---

<Layout
  title={title}
  description={description}
  frontmatter={frontmatter}
  hasInquirySection={hasInquirySection}
  faqItems={faqItems}
>
  <div aria-hidden="true" class="fixed inset-x-0 top-0 z-40 h-px bg-transparent">
    <span id="reading-progress" class="block h-px w-0 bg-[#1A1A1A]"></span>
  </div>

  <article class="mx-auto max-w-[72ch] space-y-[clamp(2.5rem,3vw,3.5rem)] leading-[1.8]">
    <header class="space-y-5">
      <h1 class="text-[clamp(2.2rem,1.7rem+2vw,3.2rem)] font-semibold text-[#1A1A1A]">{title}</h1>
      <p class="text-[clamp(1.05rem,1rem+0.35vw,1.4rem)] text-[#1A1A1A]/70">{description}</p>
      <div class="flex flex-wrap items-center gap-3 text-[clamp(0.85rem,0.82rem+0.2vw,1rem)] text-[#1A1A1A]/60">
        <span>זמן קריאה: {readingMinutes} דק׳</span>
        <span>רמת עומק: {depth}</span>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        {tags.length > 0 && (
          <ul class="flex flex-wrap gap-2 text-[clamp(0.85rem,0.82rem+0.2vw,1rem)] text-[#1A1A1A]/60">
            {tags.map((tag) => (
              <li class="rounded-full border border-[#1A1A1A]/10 bg-white/70 px-3 py-1">{tag}</li>
            ))}
          </ul>
        )}
        <button
          type="button"
          data-focus-toggle
          aria-pressed="false"
          class="rounded-full border border-[#1A1A1A]/10 bg-white/70 px-4 py-2 text-[clamp(0.85rem,0.82rem+0.2vw,1rem)] text-[#1A1A1A]/70 transition-colors duration-300 hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#1A1A1A]/20"
        >
          מצב פוקוס
        </button>
      </div>
    </header>

    {audioUrl && (
      <div class="overflow-hidden rounded-2xl border border-[#1A1A1A]/10 bg-white/70 p-4 shadow-sm backdrop-blur-md">
        <audio class="w-full max-w-[400px] accent-[#1A1A1A] text-[#1A1A1A]" controls src={audioUrl}>
          הדפדפן שלך לא תומך בהשמעת אודיו.
        </audio>
      </div>
    )}

    {youtubeId && <LiteYouTubeEmbed youtubeId={youtubeId} title={title} />}

    <div
      data-premium-body
      data-premium-active={frontmatter.isPremium ? "true" : "false"}
      data-premium-marker={premiumVault.cutoffMarker}
      data-premium-title={premiumVault.title}
      data-premium-description={premiumVault.description}
      data-premium-cta-label={premiumVault.ctaLabel}
      data-premium-cta-href={premiumVault.ctaHref}
      data-premium-access-enabled={premiumAccess.enabled ? "true" : "false"}
      data-premium-access-route={premiumAccess.unlockRoute}
      data-premium-access-session-hours={String(premiumAccess.sessionHours || 168)}
      data-premium-access-helper={premiumAccess.helperText}
      class="space-y-6"
    >
      <Content components={components} />
    </div>
  </article>

  <section class="mx-auto mt-[clamp(2.5rem,4vw,3.5rem)] max-w-[72ch] space-y-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
      <a
        href={whatsappShareUrl}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white/70 px-4 py-2 text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] text-[#1A1A1A]/75 transition-colors duration-300 hover:bg-white"
      >
        שתף בוואטסאפ
      </a>
      <button
        type="button"
        data-copy-link
        data-copy-value={shareUrl}
        class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white/70 px-4 py-2 text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] text-[#1A1A1A]/75 transition-colors duration-300 hover:bg-white"
      >
        העתק קישור
      </button>
    </div>
    <div
      data-copy-toast
      class="pointer-events-none fixed bottom-6 right-6 z-50 rounded-full border border-[#1A1A1A]/10 bg-white/90 px-4 py-2 text-[clamp(0.85rem,0.8rem+0.2vw,1rem)] text-[#1A1A1A]/70 opacity-0 transition-opacity duration-300"
    >
      הועתק
    </div>
  </section>

  {curatedInternalLinks.length > 0 && (
    <section class="mx-auto mt-[clamp(3rem,5vw,4rem)] max-w-[72ch] space-y-4">
      <div class="space-y-2">
        <h2 class="text-[clamp(1.4rem,1.15rem+1vw,2rem)] font-semibold text-[#1A1A1A]">ראה גם</h2>
        <p class="text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] text-[#1A1A1A]/65">
          כדי להעמיק בלי לשבור רצף, המשך מכאן ל־3–5 עמודים שמרחיבים את אותה חקירה מכיוון אחר.
        </p>
      </div>
      <div class={`grid gap-4 ${curatedInternalLinks.length > 1 ? "md:grid-cols-2" : ""}`}>
        {curatedInternalLinks.map((link) => (
          <a
            href={link.href}
            class="flex h-full flex-col justify-between gap-3 rounded-3xl border border-[#1A1A1A]/10 bg-white/70 px-5 py-4 text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] text-[#1A1A1A]/80 shadow-sm transition-all duration-500 hover:translate-y-[-2px] hover:bg-white"
          >
            <span class="text-[clamp(0.8rem,0.78rem+0.2vw,0.95rem)] text-[#1A1A1A]/55">{kindLabelMap[link.kind]}</span>
            <span class="font-semibold text-[#1A1A1A]">{link.title}</span>
            <span class="text-[clamp(0.85rem,0.82rem+0.2vw,1rem)] text-[#1A1A1A]/60">{link.description}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mx-auto mt-[clamp(3rem,6vw,5rem)] max-w-2xl space-y-6">
    <h2 class="text-center text-[clamp(1.4rem,1.15rem+1vw,2rem)] font-semibold text-[#1A1A1A]">אפשר להשאיר שאלה או פנייה</h2>
    <form
      data-contact-form
      class="space-y-4 rounded-3xl border border-[#1A1A1A]/10 bg-white/70 p-6"
      action="https://api.web3forms.com/submit"
      method="POST"
    >
      <input type="hidden" name="access_key" value={web3formsKey} />
      <input type="hidden" name="subject" value="פנייה מ-NeverMind" />
      <input type="hidden" name="page" value={title} />
      <input type="text" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="space-y-2 text-right">
        <label class="text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] text-[#1A1A1A]/70" for="name">שם מלא</label>
        <input id="name" name="name" type="text" required class="w-full rounded-2xl border border-[#1A1A1A]/20 bg-white/80 px-4 py-3 text-right text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] text-[#1A1A1A] outline-none focus-visible:ring-2 focus-visible:ring-[#1A1A1A]/20" />
      </div>

      <div class="space-y-2 text-right">
        <label class="text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] text-[#1A1A1A]/70" for="email">אימייל</label>
        <input id="email" name="email" type="email" required class="w-full rounded-2xl border border-[#1A1A1A]/20 bg-white/80 px-4 py-3 text-right text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] text-[#1A1A1A] outline-none focus-visible:ring-2 focus-visible:ring-[#1A1A1A]/20" />
      </div>

      <div class="space-y-2 text-right">
        <label class="text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] text-[#1A1A1A]/70" for="message">הודעה</label>
        <textarea id="message" name="message" rows="4" required class="w-full rounded-2xl border border-[#1A1A1A]/20 bg-white/80 px-4 py-3 text-right text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] text-[#1A1A1A] outline-none focus-visible:ring-2 focus-visible:ring-[#1A1A1A]/20"></textarea>
      </div>

      <button
        type="submit"
        class="w-full rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-[clamp(0.95rem,0.9rem+0.3vw,1.1rem)] text-[#1A1A1A]/80 transition-colors duration-300 hover:bg-white/90"
      >
        שליחה
      </button>
      <p data-form-status aria-live="polite" class="text-center text-[clamp(0.85rem,0.8rem+0.2vw,1rem)] text-[#1A1A1A]/60 opacity-0 transition-opacity duration-300">
        תודה, ההודעה עברה.
      </p>
    </form>
  </section>

  <div class="mx-auto mt-[clamp(3rem,6vw,5rem)] max-w-[72ch]">
    <SubscribeBanner />
  </div>

  <style>
    article :global(h2) {
      font-size: clamp(1.6rem, 1.25rem + 1.2vw, 2.2rem);
      line-height: 1.2;
      margin-top: clamp(2rem, 2vw, 2.8rem);
      margin-bottom: 0.8rem;
    }

    article :global(h3) {
      font-size: clamp(1.3rem, 1.1rem + 0.9vw, 1.8rem);
      line-height: 1.3;
      margin-top: clamp(1.6rem, 1.8vw, 2.2rem);
      margin-bottom: 0.6rem;
    }

    article :global(p),
    article :global(li) {
      font-size: clamp(1rem, 0.95rem + 0.35vw, 1.2rem);
    }

    article :global(ul),
    article :global(ol) {
      padding-inline-start: 1.4rem;
      margin-top: 1rem;
      margin-bottom: 1rem;
    }

    article :global(blockquote) {
      font-size: clamp(1.05rem, 1rem + 0.4vw, 1.3rem);
      border-inline-start: 2px solid rgba(26, 26, 26, 0.2);
      padding-inline-start: 1rem;
      margin: 1.5rem 0;
      color: rgba(26, 26, 26, 0.7);
    }

    article :global(a) {
      color: inherit;
      text-decoration: none;
      border-bottom: 1px solid rgba(26, 26, 26, 0.3);
    }

    article :global(code) {
      font-size: clamp(0.9rem, 0.86rem + 0.2vw, 1.05rem);
      background: rgba(26, 26, 26, 0.06);
      padding: 0.1rem 0.35rem;
      border-radius: 0.4rem;
    }

    [data-premium-body][data-premium-pending="true"] {
      opacity: 0;
    }

    .nm-premium-shell {
      margin-top: 2.5rem;
      display: grid;
      gap: 1rem;
    }

    .nm-premium-card {
      border: 1px solid rgba(26, 26, 26, 0.1);
      border-radius: 2rem;
      background: rgba(255, 255, 255, 0.92);
      padding: 2rem;
      text-align: right;
      box-shadow: 0 24px 70px rgba(26, 26, 26, 0.08);
    }

    .nm-premium-preview {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(26, 26, 26, 0.08);
      border-radius: 2rem;
      background: rgba(255, 255, 255, 0.82);
      padding: 1.5rem;
    }

    .nm-premium-preview__inner {
      max-height: 16rem;
      overflow: hidden;
      filter: blur(10px);
      opacity: 0.72;
      pointer-events: none;
      user-select: none;
    }

    .nm-premium-preview__fade {
      position: absolute;
      inset: auto 0 0 0;
      height: 7rem;
      background: linear-gradient(to top, rgba(250, 250, 248, 0.98), rgba(250, 250, 248, 0));
    }
  </style>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      if (window.__nmArticleCleanup) {
        window.__nmArticleCleanup();
      }

      const progressBar = document.getElementById("reading-progress");
      const focusToggle = document.querySelector("[data-focus-toggle]");
      const copyButton = document.querySelector("[data-copy-link]");
      const toast = document.querySelector("[data-copy-toast]");
      const contactForm = document.querySelector("[data-contact-form]");
      const formStatus = document.querySelector("[data-form-status]");
      const premiumBody = document.querySelector("[data-premium-body]");
      const cleanups = [];
      let ticking = false;
      let toastTimeout;

      const updateProgress = () => {
        const doc = document.documentElement;
        const scrollTop = doc.scrollTop || document.body.scrollTop;
        const scrollHeight = doc.scrollHeight - doc.clientHeight;
        const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
        if (progressBar instanceof HTMLElement) {
          progressBar.style.width = `${progress}%`;
        }
        ticking = false;
      };

      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          window.requestAnimationFrame(updateProgress);
        }
      };

      const setFocusMode = (enabled) => {
        document.body.classList.toggle("is-focus-mode", enabled);
        if (focusToggle instanceof HTMLButtonElement) {
          focusToggle.setAttribute("aria-pressed", String(enabled));
          focusToggle.textContent = enabled ? "יציאה ממצב פוקוס" : "מצב פוקוס";
        }
      };

      const showToast = () => {
        if (!(toast instanceof HTMLElement)) return;
        toast.classList.add("opacity-100");
        window.clearTimeout(toastTimeout);
        toastTimeout = window.setTimeout(() => {
          toast.classList.remove("opacity-100");
        }, 1400);
      };

      const applyPremiumVault = () => {
        if (!(premiumBody instanceof HTMLElement)) return;
        if (premiumBody.dataset.premiumInitialized === "true") return;

        const SETTINGS_STORAGE_KEY = "nm-site-settings-overrides";
        const ACCESS_STORAGE_KEY = "nm-premium-access";
        const readOverrides = () => {
          try {
            return JSON.parse(window.localStorage.getItem(SETTINGS_STORAGE_KEY) || "null");
          } catch {
            return null;
          }
        };

        const hasActivePremiumSession = () => {
          try {
            const raw = window.localStorage.getItem(ACCESS_STORAGE_KEY);
            if (!raw) return false;
            const parsed = JSON.parse(raw);
            const expiresAt = Date.parse(parsed?.expiresAt || "");
            if (!Number.isFinite(expiresAt) || expiresAt <= Date.now()) {
              window.localStorage.removeItem(ACCESS_STORAGE_KEY);
              return false;
            }
            return true;
          } catch {
            window.localStorage.removeItem(ACCESS_STORAGE_KEY);
            return false;
          }
        };

        const normalizeMarker = (marker) => (marker || "premium-break").replace(/<!--|-->/g, "").trim();
        const overrides = readOverrides()?.premiumVault || {};
        const premiumEnabled = overrides.enabled ?? (premiumBody.dataset.premiumActive === "true");
        if (!premiumEnabled) {
          premiumBody.dataset.premiumPending = "false";
          premiumBody.dataset.premiumInitialized = "true";
          return;
        }

        premiumBody.dataset.premiumPending = "true";
        const markerNeedle = normalizeMarker(overrides.cutoffMarker || premiumBody.dataset.premiumMarker || "<!--premium-break-->");
        const walker = document.createTreeWalker(premiumBody, NodeFilter.SHOW_COMMENT);
        let markerNode = null;
        while (walker.nextNode()) {
          const current = walker.currentNode;
          if ((current.nodeValue || "").includes(markerNeedle)) {
            markerNode = current;
            break;
          }
        }

        if (!markerNode) {
          premiumBody.dataset.premiumPending = "false";
          premiumBody.dataset.premiumInitialized = "true";
          return;
        }

        markerNode.parentNode?.removeChild(markerNode);

        if (hasActivePremiumSession()) {
          premiumBody.dataset.premiumPending = "false";
          premiumBody.dataset.premiumInitialized = "true";
          return;
        }

        const title = overrides.title || premiumBody.dataset.premiumTitle || "This professional method is reserved for premium members";
        const description = overrides.description || premiumBody.dataset.premiumDescription || "המשך התוכן המלא שמור כרגע לחברי פרימיום.";
        const fallbackCtaLabel = overrides.ctaLabel || premiumBody.dataset.premiumCtaLabel || "לשירותים ומחירים";
        const fallbackCtaHref = overrides.ctaHref || premiumBody.dataset.premiumCtaHref || "/now";
        const accessEnabled = premiumBody.dataset.premiumAccessEnabled === "true";
        const accessRoute = premiumBody.dataset.premiumAccessRoute || "/premium-access/";
        const helperText = premiumBody.dataset.premiumAccessHelper || "גישה לתוכן פרימיום נפתחת כרגע דרך קוד גישה מתחלף.";
        const returnTo = encodeURIComponent(window.location.pathname);
        const primaryHref = accessEnabled ? `${accessRoute}?returnTo=${returnTo}` : fallbackCtaHref;
        const primaryLabel = accessEnabled ? "להזין קוד גישה" : fallbackCtaLabel;

        const range = document.createRange();
        range.setStartAfter(markerNode);
        range.setEndAfter(premiumBody.lastChild);
        const hiddenContent = range.extractContents();

        const previewShell = document.createElement("section");
        previewShell.className = "nm-premium-shell";

        const card = document.createElement("section");
        card.className = "nm-premium-card";
        card.innerHTML = `
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">Premium Vault</p>
          <h2 class="mt-3 text-[clamp(1.4rem,1.1rem+0.8vw,1.9rem)] font-semibold text-[#1A1A1A]">${title}</h2>
          <p class="mt-3 text-[1rem] leading-8 text-[#1A1A1A]/68">${description}</p>
          <p class="mt-3 text-sm leading-7 text-[#1A1A1A]/56">${helperText}</p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href="${primaryHref}" class="inline-flex items-center rounded-full bg-[#1A1A1A] px-5 py-3 text-sm font-semibold text-[#FAFAF8] no-underline transition hover:bg-black">${primaryLabel}</a>
            <a href="${fallbackCtaHref}" class="inline-flex items-center rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-sm font-semibold text-[#1A1A1A] no-underline transition hover:bg-[#FAFAF8]">${fallbackCtaLabel}</a>
          </div>
        `;

        const preview = document.createElement("div");
        preview.className = "nm-premium-preview";
        const inner = document.createElement("div");
        inner.className = "nm-premium-preview__inner";
        inner.appendChild(hiddenContent);
        const fade = document.createElement("div");
        fade.className = "nm-premium-preview__fade";
        preview.appendChild(inner);
        preview.appendChild(fade);

        previewShell.appendChild(card);
        previewShell.appendChild(preview);
        premiumBody.appendChild(previewShell);

        premiumBody.dataset.premiumPending = "false";
        premiumBody.dataset.premiumInitialized = "true";
      };

      if (copyButton instanceof HTMLElement) {
        const onCopyClick = async () => {
          const value = copyButton.getAttribute("data-copy-value") ?? "";
          if (!value) return;
          try {
            await navigator.clipboard.writeText(value);
            showToast();
          } catch {
            window.prompt("העתק קישור", value);
          }
        };
        copyButton.addEventListener("click", onCopyClick);
        cleanups.push(() => copyButton.removeEventListener("click", onCopyClick));
      }

      if (contactForm instanceof HTMLFormElement) {
        const onSubmit = async (event) => {
          event.preventDefault();
          const formData = new FormData(contactForm);
          try {
            const response = await fetch("https://api.web3forms.com/submit", {
              method: "POST",
              body: formData,
            });
            if (formStatus instanceof HTMLElement) {
              formStatus.textContent = response.ok ? "תודה, ההודעה עברה." : "משהו השתבש, נסה שוב.";
              formStatus.classList.add("opacity-100");
            }
            if (response.ok) {
              contactForm.reset();
            }
          } catch {
            if (formStatus instanceof HTMLElement) {
              formStatus.textContent = "משהו השתבש, נסה שוב.";
              formStatus.classList.add("opacity-100");
            }
          }
        };
        contactForm.addEventListener("submit", onSubmit);
        cleanups.push(() => contactForm.removeEventListener("submit", onSubmit));
      }

      if (focusToggle instanceof HTMLButtonElement) {
        const onFocusClick = () => {
          setFocusMode(!document.body.classList.contains("is-focus-mode"));
        };
        focusToggle.addEventListener("click", onFocusClick);
        cleanups.push(() => focusToggle.removeEventListener("click", onFocusClick));
      }

      document.addEventListener("scroll", onScroll, { passive: true });
      cleanups.push(() => document.removeEventListener("scroll", onScroll));
      updateProgress();
      applyPremiumVault();

      window.__nmArticleCleanup = () => {
        document.body.classList.remove("is-focus-mode");
        cleanups.forEach((cleanup) => cleanup());
      };
    });
  </script>
</Layout>
