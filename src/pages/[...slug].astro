      height: 7rem;
      background: linear-gradient(to top, rgba(250, 250, 248, 0.98), rgba(250, 250, 248, 0));
    }
  </style>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      if (window.__nmArticleCleanup) {
        window.__nmArticleCleanup();
      }

      const progressBar = document.getElementById("reading-progress");
      const focusToggle = document.querySelector("[data-focus-toggle]");
      const copyButton = document.querySelector("[data-copy-link]");
      const insightCopyButton = document.querySelector("[data-copy-insight]");
      const toast = document.querySelector("[data-copy-toast]");
      const premiumBody = document.querySelector("[data-premium-body]");
      const cleanups = [];
      let ticking = false;
      let toastTimeout;

      const updateProgress = () => {
        const doc = document.documentElement;
        const scrollTop = doc.scrollTop || document.body.scrollTop;
        const scrollHeight = doc.scrollHeight - doc.clientHeight;
        const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
        if (progressBar instanceof HTMLElement) {
          progressBar.style.width = `${progress}%`;
        }
        ticking = false;
      };

      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          window.requestAnimationFrame(updateProgress);
        }
      };

      const setFocusMode = (enabled) => {
        document.body.classList.toggle("is-focus-mode", enabled);
        if (focusToggle instanceof HTMLButtonElement) {
          focusToggle.setAttribute("aria-pressed", String(enabled));
          focusToggle.textContent = enabled ? "יציאה ממצב פוקוס" : "מצב פוקוס";
        }
      };

      const showToast = (message = "הועתק") => {
        if (!(toast instanceof HTMLElement)) return;
        const previous = toast.textContent || "הועתק";
        toast.textContent = message;
        toast.classList.add("opacity-100");
        window.clearTimeout(toastTimeout);
        toastTimeout = window.setTimeout(() => {
          toast.classList.remove("opacity-100");
          toast.textContent = previous;
        }, 1400);
      };

      const applyPremiumVault = () => {
        if (!(premiumBody instanceof HTMLElement)) return;
        if (premiumBody.dataset.premiumInitialized === "true") return;

        const SETTINGS_STORAGE_KEY = "nm-site-settings-overrides";
        const ACCESS_STORAGE_KEY = "nm-premium-access";

        const readOverrides = () => {
          try {
            return JSON.parse(window.localStorage.getItem(SETTINGS_STORAGE_KEY) || "null");
          } catch {
            return null;
          }
        };

        const hasActivePremiumSession = () => {
          try {
            const raw = window.localStorage.getItem(ACCESS_STORAGE_KEY);
            if (!raw) return false;
            const parsed = JSON.parse(raw);
            const expiresAt = Date.parse(parsed?.expiresAt || "");
            if (!Number.isFinite(expiresAt) || expiresAt <= Date.now()) {
              window.localStorage.removeItem(ACCESS_STORAGE_KEY);
              return false;
            }
            return true;
          } catch {
            window.localStorage.removeItem(ACCESS_STORAGE_KEY);
            return false;
          }
        };

        const normalizeMarker = (marker) => (marker || "premium-break").replace(/<!--|-->/g, "").trim();
        const overrides = readOverrides()?.premiumVault || {};
        const premiumEnabled = overrides.enabled ?? (premiumBody.dataset.premiumActive === "true");

        if (!premiumEnabled) {
          premiumBody.dataset.premiumPending = "false";
          premiumBody.dataset.premiumInitialized = "true";
          return;
        }

        premiumBody.dataset.premiumPending = "true";
        const markerNeedle = normalizeMarker(
          overrides.cutoffMarker || premiumBody.dataset.premiumMarker || "<!--premium-break-->"
        );

        const walker = document.createTreeWalker(premiumBody, NodeFilter.SHOW_COMMENT);
        let markerNode = null;
        while (walker.nextNode()) {
          const current = walker.currentNode;
          if ((current.nodeValue || "").includes(markerNeedle)) {
            markerNode = current;
            break;
          }
        }

        if (!markerNode) {
          // Fail-closed: without marker, lock all premium content.
          const range = document.createRange();
          range.selectNodeContents(premiumBody);
          range.deleteContents();

          const lockCard = document.createElement("section");
          lockCard.className = "nm-premium-card";
          lockCard.innerHTML = `
            <p style="font-size:11px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--nm-accent)">Premium</p>
            <h2 style="margin-top:12px;font-size:1.4rem;font-weight:600;color:var(--nm-fg)">התוכן שמור לחברי פרימיום</h2>
            <p style="margin-top:12px;font-size:1rem;line-height:1.8;color:color-mix(in srgb,var(--nm-fg) 68%,transparent)">
              המאמר סומן כפרימיום. לגישה מלאה - פנה דרך השירותים.
            </p>
            <div style="margin-top:20px">
              <a href="/services/" style="display:inline-flex;align-items:center;border-radius:9999px;background:var(--nm-accent);padding:12px 20px;font-size:14px;font-weight:600;color:var(--nm-on-accent);text-decoration:none">
                לשירותים ומחירים
              </a>
            </div>
          `;
          premiumBody.appendChild(lockCard);
          premiumBody.dataset.premiumPending = "false";
          premiumBody.dataset.premiumInitialized = "true";
          return;
        }

        const contentStartRef = markerNode.nextSibling;
        markerNode.parentNode?.removeChild(markerNode);

        if (hasActivePremiumSession()) {
          premiumBody.dataset.premiumPending = "false";
          premiumBody.dataset.premiumInitialized = "true";
          return;
        }

        const accessEnabled = premiumBody.dataset.premiumAccessEnabled === "true";
        const title = overrides.title || premiumBody.dataset.premiumTitle || "מכאן הלאה - נכנסים לפרטים";
        const description =
          overrides.description ||
          premiumBody.dataset.premiumDescription ||
          "הבסיס תמיד יהיה פתוח לכולם. ההמשך של המאמר הזה מיועד למי שרוצה לקחת את ההבנה צעד אחד קדימה ולהשקיע בתהליך. הגישה פתוחה לחברי המסלול המלא.";
        const fallbackCtaLabel = overrides.ctaLabel || premiumBody.dataset.premiumCtaLabel || "איך מצטרפים?";
        const fallbackCtaHref = overrides.ctaHref || premiumBody.dataset.premiumCtaHref || "/services/";
        const accessRoute = premiumBody.dataset.premiumAccessRoute || "/dashboard/";
        const helperText =
          premiumBody.dataset.premiumAccessHelper || "גישה לתוכן פרימיום נפתחת כרגע דרך קוד גישה מתחלף.";
        const returnTo = encodeURIComponent(window.location.pathname);
        const primaryHref = accessEnabled ? `${accessRoute}?returnTo=${returnTo}` : fallbackCtaHref;
        const primaryLabel = accessEnabled ? "להזין קוד גישה" : fallbackCtaLabel;

        const actionsHtml = accessEnabled
          ? `<a href="${primaryHref}" class="inline-flex items-center rounded-full bg-[var(--nm-inverse)] px-5 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] no-underline transition hover:bg-[var(--nm-inverse-hover)]">${primaryLabel}</a>
            <a href="${fallbackCtaHref}" class="inline-flex items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[var(--nm-fg)] no-underline transition hover:bg-[var(--nm-surface-muted)]">${fallbackCtaLabel}</a>`
          : `<a href="${primaryHref}" class="inline-flex items-center rounded-full bg-[var(--nm-inverse)] px-5 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] no-underline transition hover:bg-[var(--nm-inverse-hover)]">${primaryLabel}</a>`;

        const range = document.createRange();
        if (contentStartRef) {
          range.setStartBefore(contentStartRef);
        } else {
          range.setStart(premiumBody, premiumBody.childNodes.length);
        }
        range.setEndAfter(premiumBody.lastChild);
        const hiddenContent = range.extractContents();

        const previewShell = document.createElement("section");
        previewShell.className = "nm-premium-shell";

        const card = document.createElement("section");
        card.className = "nm-premium-card";
        card.innerHTML = `
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">Premium Vault</p>
          <h2 class="mt-3 text-[clamp(1.4rem,1.1rem+0.8vw,1.9rem)] font-semibold text-[var(--nm-fg)]">${title}</h2>
          <p class="mt-3 text-[1rem] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">${description}</p>
          <p class="mt-3 text-sm leading-7 text-[var(--nm-fg)]/56">${helperText}</p>
          <div class="mt-5 flex flex-wrap gap-3">
            ${actionsHtml}
          </div>
        `;

        const preview = document.createElement("div");
        preview.className = "nm-premium-preview";
        const inner = document.createElement("div");
        inner.className = "nm-premium-preview__inner";
        inner.appendChild(hiddenContent);
        const fade = document.createElement("div");
        fade.className = "nm-premium-preview__fade";
        preview.appendChild(inner);
        preview.appendChild(fade);

        previewShell.appendChild(card);
        previewShell.appendChild(preview);
        premiumBody.appendChild(previewShell);

        premiumBody.dataset.premiumPending = "false";
        premiumBody.dataset.premiumInitialized = "true";
      };

      if (copyButton instanceof HTMLElement) {
        const onCopyClick = async () => {
          const value = copyButton.getAttribute("data-copy-value") ?? "";
          try {
            await navigator.clipboard.writeText(value);
            showToast();
          } catch {
            window.prompt("העתק קישור", value);
          }
        };

        copyButton.addEventListener("click", onCopyClick);
        cleanups.push(() => copyButton.removeEventListener("click", onCopyClick));
      }

      if (insightCopyButton instanceof HTMLButtonElement) {
        const onInsightCopy = async () => {
          const insight = (insightCopyButton.getAttribute("data-insight") || "").trim();
          const articleTitle = (insightCopyButton.getAttribute("data-article-title") || "").trim();
          if (!insight) return;
          const payload = `"${insight}" - מתוך המאמר: ${articleTitle}. לקריאה המלאה ב-NeverMind: https://milog.co.il/%D7%9E%D7%90%D7%9E%D7%A8`;
          try {
            await navigator.clipboard.writeText(payload);
            showToast("התובנה הועתקה, אפשר להדביק בוואטסאפ!");
          } catch {
            window.prompt("העתק תובנה", payload);
          }
        };

        insightCopyButton.addEventListener("click", onInsightCopy);
        cleanups.push(() => insightCopyButton.removeEventListener("click", onInsightCopy));
      }

      if (focusToggle instanceof HTMLButtonElement) {
        const onFocusClick = () => {
          const isPressed = focusToggle.getAttribute("aria-pressed") === "true";
          setFocusMode(!isPressed);
        };

        focusToggle.addEventListener("click", onFocusClick);
        cleanups.push(() => focusToggle.removeEventListener("click", onFocusClick));
      }

      document.addEventListener("scroll", onScroll, { passive: true });
      cleanups.push(() => document.removeEventListener("scroll", onScroll));
      updateProgress();
      setFocusMode(false);
      applyPremiumVault();

      window.__nmArticleCleanup = () => {
        cleanups.forEach((cleanup) => cleanup());
        window.clearTimeout(toastTimeout);
      };
    });
  </script>
</Layout>
