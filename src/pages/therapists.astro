---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import BookBanner from "../components/ui/BookBanner.astro";
import { findServiceById, type FlatService } from "../lib/services";

const consultation = findServiceById("phone-perspective");
const fallbackConsultation = ({
  id: "phone-perspective",
  title: "שיחת מיקוד למטפלים ומאמנים",
  subtitle: "לוגיקה קלינית לפני עוד טכניקה",
  description: "פגישה ממוקדת שבה אני מחזיר אותך להבחנה בין עובדה לפירוש, כדי שלא תלך לאיבוד בתוך דרמת המקרה.",
  price_full: 650,
  action_type: "whatsapp",
  action_text: "לתיאום שיחת מיקוד",
  visible: true,
  badges: ["דיוק מקצועי"],
  features: ["בהירות לוגית לפני פעולה", "מיפוי צומת קלינית בזמן אמת", "כיוון פרקטי למפגש הבא"],
  stageName: "דיוק קליני",
  targetAudience: "מטפלים ומאמנים שרוצים בהירות בזמן עומס",
} as unknown as FlatService);

const featuredService: FlatService = consultation ?? fallbackConsultation;
---

<Layout
  title="למי המטפל פונה כשאין לו עם מי לדבר?"
  description="דף ייעודי למטפלים ומאמנים שמחפשים לוגיקה, בהירות והבנה בזמן עומס קליני."
  breadcrumbCurrentLabel="למי המטפל פונה כשאין לו עם מי לדבר?"
>
  <section class="mx-auto max-w-6xl space-y-12 px-4 pb-20 text-[var(--nm-fg)]">
    <header class="space-y-5 rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg)] px-6 py-8 text-right">
      <h1 class="text-[clamp(2rem,1.5rem+1.8vw,3rem)] font-semibold leading-tight">למי המטפל פונה כשאין לו עם מי לדבר?</h1>
      <p class="max-w-4xl text-[clamp(1rem,0.95rem+0.25vw,1.1rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_74%,var(--nm-bg))]">
        כמאמן או מטפל, אתה רגיל להיות העוגן. אבל גם העוגן צריך לפעמים קרקע יציבה. בתוך הקליניקה, קל מאוד ללכת לאיבוד בתוך הדרמה של המטופל. אני לא פה כדי לטעון לך עוד מודל סגור. אני פה כדי להחזיר לך את הבהירות הלוגית.
      </p>
    </header>

    <section class="space-y-5 text-right">
      <h2 class="text-[clamp(1.5rem,1.2rem+0.9vw,2rem)] font-semibold">Three Pillars of Professional Clarity</h2>
      <div class="grid gap-4 md:grid-cols-3">
        <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-5">
          <h3 class="text-xl font-semibold">Drama vs Logic</h3>
          <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">אני ממפה איתך איפה אתה נסחף לסיפור של המטופל במקום להחזיק מבנה לוגי נקי.</p>
        </article>
        <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-5">
          <h3 class="text-xl font-semibold">Consciousness Supervision</h3>
          <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">זו לא הדרכה טכנית. זו השגחה על התודעה של המטפל בזמן אמת, כדי לשמור חדות בחדר.</p>
        </article>
        <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-5">
          <h3 class="text-xl font-semibold">Authority Building</h3>
          <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">אני מחזק אצלך סמכות שמבוססת על הבנה, לא על הצגה. זה מורגש מיד גם בקליניקה וגם מחוץ לה.</p>
        </article>
      </div>
    </section>

    <section class="space-y-4 rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg)] px-6 py-7 text-right">
      <h2 class="text-[clamp(1.4rem,1.2rem+0.8vw,1.9rem)] font-semibold">Why most supervision fails</h2>
      <p class="text-[clamp(0.98rem,0.94rem+0.2vw,1.05rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_75%,var(--nm-bg))]">
        ברוב ההדרכות מתעסקים בסימפטומים של המקרה. אני עובד על מערכת ההפעלה של המטפל. כשמערכת ההפעלה מתייצבת, ההחלטות בקליניקה נעשות פשוטות יותר, והעומס יורד בלי משחקים.
      </p>
    </section>

    <BookBanner
      eyebrow="הכלי שחסר לך בקליניקה"
      title="אהבה ב-20 עמודים"
      body="ספר שפורק את הלוגיקה של יחסים. אנשי מקצוע רבים משתמשים בו כבסיס להבנת הדינמיקה בחדר העבודה הקליני."
      digitalHref="/studio/?topic=book-digital"
      physicalHref="/studio/?topic=book-physical"
      questionHref="/studio/?topic=book-question"
    />

    <section class="space-y-5 text-right">
      <h2 class="text-[clamp(1.5rem,1.2rem+0.9vw,2rem)] font-semibold">המשך פעולה</h2>
      <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        אם אתה רוצה לחשוב חד יותר מול מקרים מורכבים, נתחיל בשיחה אחת קצרה ונראה מה נכון לבנות מכאן.
      </p>
      <div class="grid gap-5 lg:grid-cols-1">
        <ServiceCard service={featuredService} />
      </div>
      <button
        id="booking-btn"
        type="button"
        class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded bg-[#1A1A1A] px-6 py-3 text-[#FAFAF8] transition-all hover:bg-[var(--nm-accent)] focus-visible:outline-2 disabled:cursor-not-allowed disabled:opacity-50"
        onclick="handleBooking(this)"
      >
        <span id="btn-text">קביעת שיחה (650&nbsp;₪) • פירוק סיטואציה בזמן אמת</span>
        <span id="btn-spinner" class="mr-2 hidden animate-spin">🔄</span>
      </button>
    </section>
  </section>

  <script is:inline>
    function handleBooking(btn) {
      const text = btn.querySelector("#btn-text");
      const spinner = btn.querySelector("#btn-spinner");
      btn.disabled = true;
      spinner.classList.remove("hidden");
      text.innerText = "מעבד פנייה...";
      setTimeout(() => {}, 2000);
    }
  </script>
</Layout>
