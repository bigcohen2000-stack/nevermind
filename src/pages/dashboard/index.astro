---
import { getCollection } from "astro:content";
import ClubAdminPanel from "../../components/admin/ClubAdminPanel.astro";
import RoleGate from "../../components/admin/RoleGate.astro";
import ContentHealthWidget from "../../components/dashboard/ContentHealthWidget";
import DashboardCommandBar from "../../components/dashboard/DashboardCommandBar";
import DashboardNav from "../../components/dashboard/DashboardNav.astro";
import LiveConnectionsWidget from "../../components/dashboard/LiveConnectionsWidget";
import LiveSecurityFeedWidget from "../../components/dashboard/LiveSecurityFeedWidget";
import SystemHealthWidget from "../../components/dashboard/SystemHealthWidget";
import Layout from "../../layouts/Layout.astro";
import buildReport from "../../generated/admin-build-report.json";
import {
  buildDashboardContentHealth,
  buildDashboardOverviewSummary,
  buildDashboardSearchIndex,
} from "../../lib/dashboard-data";

const articles = await getCollection("articles");
const contentHealthItems = buildDashboardContentHealth(articles);
const overview = buildDashboardOverviewSummary(contentHealthItems);
const searchIndex = buildDashboardSearchIndex(contentHealthItems);

const pageTitle = "דשבורד ניהול";
const pageDescription = "דשבורד ניהול פנימי עם גישה לחברים, בקרה על תוכן ובריאות מערכת.";

const overviewCards = [
  {
    label: "מאמרים פעילים",
    value: String(overview.totalArticles),
    helper: "כל מה שכבר חי באתר",
  },
  {
    label: "דורשים טיפול",
    value: String(overview.criticalArticles),
    helper: "תוכן שדורש החלטה עכשיו",
  },
  {
    label: "במעקב",
    value: String(overview.watchArticles),
    helper: "כדאי לבדוק בקרוב",
  },
  {
    label: "יציבים",
    value: String(overview.healthyArticles),
    helper: "תוכן שמחזיק טוב כרגע",
  },
];

const managerQuickLinks = [
  {
    title: "תצוגת חבר",
    description: "לראות מה חבר רואה בפועל, בלי לצאת למסך אחר.",
    href: "/me/",
    cta: "לפתוח תצוגת חבר",
  },
  {
    title: "מסך הכניסה",
    description: "בדיקה של זרימת האורח והכניסה השקטה לפני שיש גישה פעילה.",
    href: "/me/unlock/",
    cta: "לפתוח את מסך הכניסה",
  },
  {
    title: "מאמר חדש",
    description: "מעבר מהיר למסך היצירה החדש והמקוצר של מאמרים.",
    href: "/admin/generator/",
    cta: "לפתוח את המחולל",
  },
];
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <RoleGate requiredRole="admin">
    <div class="min-h-screen bg-[#FAFAF8] text-[#1A1A1A] dark:bg-[#1A1A1A] dark:text-[#FAFAF8]">
      <main class="mx-auto max-w-7xl px-4 pb-16 pt-8 lg:px-6">
        <DashboardCommandBar client:load index={searchIndex} />

        <div class="grid gap-6 lg:grid-cols-[15rem_minmax(0,1fr)]">
          <DashboardNav />

          <div class="space-y-8">
            <section id="overview" class="space-y-5">
              <div class="rounded-[32px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-[radial-gradient(circle_at_top_left,_rgba(212,43,43,0.14),_transparent_34%),linear-gradient(135deg,#ffffff_0%,#f4f2ed_100%)] p-6 shadow-[0_24px_70px_rgba(26,26,26,0.06)] dark:border-[rgba(250,250,248,0.12)] dark:bg-[radial-gradient(circle_at_top_left,_rgba(212,43,43,0.16),_transparent_30%),linear-gradient(135deg,rgba(255,255,255,0.06)_0%,rgba(255,255,255,0.02)_100%)]">
                <div class="grid gap-5 xl:grid-cols-[minmax(0,1.35fr)_minmax(0,0.95fr)] xl:items-end">
                  <div class="space-y-3 text-right">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#D42B2B] dark:text-[#ff8a8a]">דשבורד</p>
                    <h1 class="nm-title-balance text-[clamp(2rem,1.55rem+1.6vw,3.2rem)] font-semibold leading-tight text-[#1A1A1A] dark:text-[#FAFAF8]">
                      מסך שליטה קצר במקום תיעוד טכני
                    </h1>
                    <p class="nm-copy-balanced max-w-3xl text-sm leading-7 text-[#1A1A1A]/62 dark:text-[#FAFAF8]/64">
                      מכאן מנהלים את שלושת הדברים שבאמת חשובים: מי נכנס, מה דורש עדכון בתוכן, ומה במערכת פתוח או חסר. כל שאר שכבות ההסבר ירדו לאזורים משניים.
                    </p>
                    <div class="flex flex-wrap gap-2 pt-1 text-xs">
                      <span class="inline-flex items-center rounded-full border-[0.5px] border-[rgba(212,43,43,0.18)] bg-[rgba(212,43,43,0.08)] px-3 py-1 font-medium text-[#D42B2B] dark:border-[rgba(212,43,43,0.22)] dark:bg-[rgba(212,43,43,0.12)] dark:text-[#ff8a8a]">מנהל בלבד</span>
                      <span class="inline-flex items-center rounded-full border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/70 px-3 py-1 font-medium text-[#1A1A1A]/72 dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)] dark:text-[#FAFAF8]/72">גישה דרך Cloudflare Access</span>
                      <span class="inline-flex items-center rounded-full border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/70 px-3 py-1 font-medium text-[#1A1A1A]/72 dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)] dark:text-[#FAFAF8]/72">Shared code + שם + טלפון</span>
                    </div>
                  </div>

                  <div class="grid gap-3 sm:grid-cols-2">
                    {overviewCards.map((card) => (
                      <article class="rounded-[24px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/84 p-4 backdrop-blur-sm dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)]">
                        <p class="text-xs text-[#1A1A1A]/45 dark:text-[#FAFAF8]/48">{card.label}</p>
                        <p class="mt-2 text-3xl font-semibold text-[#1A1A1A] dark:text-[#FAFAF8]">{card.value}</p>
                        <p class="mt-1 text-xs text-[#1A1A1A]/42 dark:text-[#FAFAF8]/46">{card.helper}</p>
                      </article>
                    ))}
                  </div>
                </div>
              </div>

              <div class="grid gap-4 lg:grid-cols-3">
                {managerQuickLinks.map((item) => (
                  <article class="rounded-[24px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/84 p-4 shadow-[0_18px_50px_rgba(26,26,26,0.05)] dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)]">
                    <h2 class="nm-title-balance text-base font-semibold text-[#1A1A1A] dark:text-[#FAFAF8]">{item.title}</h2>
                    <p class="nm-copy-balanced mt-2 text-sm leading-7 text-[#1A1A1A]/64 dark:text-[#FAFAF8]/64">{item.description}</p>
                    <a href={item.href} class="mt-4 inline-flex items-center rounded-full border-[0.5px] border-[rgba(26,26,26,0.1)] bg-[#FAFAF8] px-4 py-2 text-sm font-semibold text-[#1A1A1A] transition hover:border-[rgba(212,43,43,0.22)] hover:text-[#D42B2B] dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)] dark:text-[#FAFAF8]">{item.cta}</a>
                  </article>
                ))}
              </div>
            </section>

            <section id="access" class="space-y-4">
              <div class="space-y-2">
                <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#D42B2B] dark:text-[#ff8a8a]">גישה וחברים</p>
                <h2 class="text-2xl font-semibold text-[#1A1A1A] dark:text-[#FAFAF8]">מי מחובר, מי נראה לאחרונה, ואיפה צריך להתערב</h2>
                <p class="text-sm leading-7 text-[#1A1A1A]/64 dark:text-[#FAFAF8]/64">
                  זה אזור הניהול הראשי. מכאן מחפשים חבר, רואים סטטוס גישה, ובודקים את הציר האחרון בלי להיכנס למסכי עזר מיותרים.
                </p>
              </div>
              <ClubAdminPanel />
            </section>

            <section id="content-health" class="space-y-4">
              <div class="flex flex-wrap items-end justify-between gap-4">
                <div class="space-y-2">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#D42B2B] dark:text-[#ff8a8a]">תוכן</p>
                  <h2 class="text-2xl font-semibold text-[#1A1A1A] dark:text-[#FAFAF8]">מה דורש עדכון, רענון או פתיחה</h2>
                  <p class="text-sm leading-7 text-[#1A1A1A]/64 dark:text-[#FAFAF8]/64">
                    כאן רואים קודם את המאמרים שדורשים החלטה. אם צריך לפתוח מאמר חדש, ממשיכים מכאן ישר למחולל המקוצר.
                  </p>
                </div>
                <a
                  href="/admin/generator/"
                  class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
                >
                  לפתוח מאמר חדש
                </a>
              </div>

              <div class="rounded-[32px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/84 p-5 shadow-[0_24px_70px_rgba(26,26,26,0.05)] dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)]">
                <ContentHealthWidget client:load items={contentHealthItems} />
              </div>
            </section>

            <section id="system-health" class="space-y-4">
              <div class="space-y-2">
                <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#D42B2B] dark:text-[#ff8a8a]">מערכת</p>
                <h2 class="text-2xl font-semibold text-[#1A1A1A] dark:text-[#FAFAF8]">האם הבסיס סגור, ומה עוד פתוח</h2>
                <p class="text-sm leading-7 text-[#1A1A1A]/64 dark:text-[#FAFAF8]/64">
                  בריאות מערכת נשארת כאן כלוח מצב קצר: מה פעיל, מה דורש אימות, ומה אופציונלי בלבד.
                </p>
              </div>

              <div class="rounded-[32px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/84 p-5 shadow-[0_24px_70px_rgba(26,26,26,0.05)] dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)]">
                <SystemHealthWidget
                  client:visible
                  endpoint="/dashboard/api/dashboard/system-health"
                  initialBuildReport={buildReport}
                  pulseEndpoint="/dashboard/api/site/pulse"
                  psiEndpoint="/dashboard/api/admin/psi?strategy=mobile"
                  gapsEndpoint="/dashboard/api/log-search-gap"
                />
              </div>

              <details class="group rounded-[24px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/84 p-5 shadow-[0_18px_50px_rgba(26,26,26,0.05)] dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)]">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-right [&::-webkit-details-marker]:hidden">
                  <div class="space-y-1">
                    <p class="text-sm font-semibold text-[var(--nm-accent)]">בקרה מתקדמת</p>
                    <p class="text-sm leading-7 text-[#1A1A1A]/64 dark:text-[#FAFAF8]/64">
                      חיבורים חיים ופיד חריגות נשארים כאן רק למקרה שבאמת צריך לבדוק אותם.
                    </p>
                  </div>
                  <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-3 py-1 text-xs font-semibold text-[var(--nm-fg)] transition group-open:rotate-45">+</span>
                </summary>

                <div class="mt-5 grid gap-6 xl:grid-cols-2">
                  <div class="rounded-[24px] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[#FAFAF8] p-4">
                    <h3 class="text-lg font-semibold text-[#1A1A1A]">תנועת חברים</h3>
                    <p class="mt-1 text-sm leading-7 text-[#1A1A1A]/58">אם הנתון יציב, רואים מי הופיע עכשיו. אם לא, זה נשאר כאן ולא שובר את הדשבורד הראשי.</p>
                    <div class="mt-4">
                      <LiveConnectionsWidget client:visible endpoint="/dashboard/api/dashboard/live-connections" />
                    </div>
                  </div>

                  <div id="security-feed" class="rounded-[24px] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[#FAFAF8] p-4">
                    <h3 class="text-lg font-semibold text-[#1A1A1A]">פיד חריגות</h3>
                    <p class="mt-1 text-sm leading-7 text-[#1A1A1A]/58">פיד זה נשאר משני. אם אין ערך ניהולי מיידי, לא צריך לראות אותו קודם.</p>
                    <div class="mt-4">
                      <LiveSecurityFeedWidget client:visible endpoint="/dashboard/api/dashboard/security-feed" />
                    </div>
                  </div>
                </div>
              </details>
            </section>
          </div>
        </div>
      </main>
    </div>
  </RoleGate>

  <script>
    import "../../scripts/admin-dashboard.js";
  </script>
</Layout>
