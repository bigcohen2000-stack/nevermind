---
import Layout from "../../../layouts/Layout.astro";
import ServiceRouteGrid from "../../../components/services/ServiceRouteGrid.astro";
import { buildWhatsAppHref, findServiceById, formatMoney } from "../../../lib/services";

const studioService = findServiceById("balcony-experience");
const basePrice = studioService?.price_full ?? 650;
const longSession = studioService?.extensions?.find((item) => item.id === "balcony-90");
const longPrice = longSession?.price ?? 1750;

const faqItems = [
  {
    question: "זה פודקאסט או שירות",
    answer: "לא. זה לא עוד עמוד תוכן. זה שירות חי באולפן, שבו נכנסים לשיחה, חקירה או נוכחות קבוצתית קטנה סביב מנגנון אמיתי.",
  },
  {
    question: "צריך להגיע מוכן לדבר הרבה",
    answer: "לא. זה לא מבחן הופעה. אפשר להגיע כדי להקשיב, לדבר מעט, או לבדוק מה משתקף בך דרך שאלות של אחרים.",
  },
  {
    question: "זה מחליף שיחה אישית",
    answer: "לא. זה מתאים כשהקצב הקבוצתי או מרחב האולפן עצמו משרתים את הבדיקה. אם צריך פירוק פרטי וישיר, שיחה אישית תהיה מדויקת יותר.",
  },
];

const ctaHref = buildWhatsAppHref(
  "היי, הגעתי מעמוד האולפן. רוצה לבדוק אם נכון לי להגיע לנוכחות באולפן ומה ההבדל מול שיחה אישית."
);
---

<Layout
  title="אולפן NeverMind"
  description="אולפן NeverMind הוא מסלול לשיחה חיה, נוכחות קבוצתית קטנה או זמן מורחב באולפן, כשהמנגנון נבדק דרך חוויה ישירה ולא רק דרך עמוד כתוב."
  faqItems={faqItems}
  breadcrumbCurrentLabel="אולפן"
>
  <section class="mx-auto max-w-5xl space-y-12 px-4 pb-24 pt-12 text-right text-[var(--nm-fg)]">
    <header class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 px-6 py-8 shadow-[0_24px_80px_rgba(26,26,26,0.06)]">
      <p class="text-sm font-semibold text-[var(--nm-accent)]">אולפן</p>
      <h1 class="mt-2 text-[clamp(2rem,1.65rem+1.4vw,3.6rem)] font-semibold leading-[1.08]">אולפן NeverMind - נוכחות חיה מול מנגנון חי</h1>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        זה לא עוד דף לקרוא. זה מרחב אולפן לשיחה חיה, קצב קבוצתי קטן, או זמן מורחב, כשצריך לראות איך מנגנון נפתח בזמן אמת ולא רק דרך טקסט.
      </p>
      <div class="mt-6 flex flex-wrap justify-end gap-3">
        <a href={ctaHref} target="_blank" rel="noreferrer" class="inline-flex min-h-[48px] items-center rounded-full bg-[var(--nm-accent)] px-6 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">
          לבדוק התאמה
        </a>
        <a href="/services/" class="inline-flex min-h-[48px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          לכל הייעוצים
        </a>
      </div>
    </header>

    <section class="grid gap-5 md:grid-cols-2">
      <article class="rounded-[1.7rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">מה זה נותן</p>
        <ul class="mt-4 space-y-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          <li class="flex gap-2"><span aria-hidden="true" class="text-[var(--nm-accent)]">•</span><span>כניסה לשיחה חיה שבה מנגנונים נחשפים בזמן אמת.</span></li>
          <li class="flex gap-2"><span aria-hidden="true" class="text-[var(--nm-accent)]">•</span><span>אפשרות לראות את עצמך דרך שאלות של אחרים בלי להישאר לבד מול הסיפור שלך.</span></li>
          <li class="flex gap-2"><span aria-hidden="true" class="text-[var(--nm-accent)]">•</span><span>קצב שונה משיחה פרטית: פחות סגירות, יותר חשיפה ישירה של מה שקורה.</span></li>
        </ul>
      </article>

      <article class="rounded-[1.7rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">מחירים</p>
        <div class="mt-4 space-y-4 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          <div class="rounded-[1.15rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-4">
            <p class="font-semibold text-[var(--nm-fg)]">בסיס</p>
            <p class="mt-1">{formatMoney(basePrice)} לנוכחות באולפן.</p>
          </div>
          <div class="rounded-[1.15rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-4">
            <p class="font-semibold text-[var(--nm-fg)]">90 דקות</p>
            <p class="mt-1">{formatMoney(longPrice)} כשיש כמה שכבות שצריכות יותר זמן ואוויר.</p>
          </div>
        </div>
      </article>
    </section>

    <section class="rounded-[1.7rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
      <p class="text-sm font-semibold text-[var(--nm-accent)]">מתי לבחור בזה</p>
      <p class="mt-3 text-sm leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        אם אתה רוצה קצב חי, השתקפות דרך אנשים נוספים, או מרחב שלא עובד כמו שיחה פרטית, האולפן יכול להיות נכון. אם אתה צריך פירוק ממוקד של מצב אישי, עבור ל<a href="/personal-consultation/" class="font-semibold text-[var(--nm-accent)] underline underline-offset-4">ייעוץ אישי</a>. אם הקונפליקט הוא זוגי, עבור ל<a href="/services/couples/" class="font-semibold text-[var(--nm-accent)] underline underline-offset-4">ייעוץ זוגי</a>.
      </p>
    </section>

    <ServiceRouteGrid
      title="אם אולפן הוא לא המסלול הנכון"
      intro="לא כל בדיקה צריכה קצב חי. לפעמים נכון יותר לפרק אישית, זוגית, מקצועית או לחקור לבד דרך הארכיון."
    />
  </section>
</Layout>
