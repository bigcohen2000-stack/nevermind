---
import Layout from "../layouts/Layout.astro";
import appConfig from "../config/appConfig.json";

const pageTitle = "גישה לתוכן פרימיום";
const pageDescription = "פתיחת גישה זמנית לתוכן פרימיום דרך קוד גישה מתחלף.";
const premiumAccess = appConfig.premiumAccess;
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <section class="mx-auto max-w-2xl space-y-8 px-4 pb-16 text-right text-[#1A1A1A]">
    <header class="space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-[#D42B2B]">Premium Access</p>
      <h1 class="text-[clamp(2.2rem,1.6rem+2vw,3.5rem)] font-semibold leading-[1.05]">פתיחת גישה לתוכן פרימיום</h1>
      <p class="text-[1rem] leading-8 text-[#1A1A1A]/68">{premiumAccess.helperText}</p>
    </header>

    <section class="rounded-[2rem] border border-[#1A1A1A]/10 bg-white/86 p-6 shadow-[0_24px_80px_rgba(26,26,26,0.06)]">
      <div class="space-y-5">
        <label class="block space-y-2">
          <span class="text-sm font-semibold text-[#1A1A1A]">קוד גישה</span>
          <input id="premium-code" type="password" dir="ltr" class="w-full rounded-[1.4rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-left text-base text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15" placeholder="NM-ACCESS-2026" />
        </label>

        <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
          <button id="unlock-premium" type="button" class="inline-flex items-center justify-center rounded-full bg-[#1A1A1A] px-6 py-3 text-sm font-semibold text-[#FAFAF8] transition hover:bg-black">לפתוח גישה</button>
          <a href="/services/" class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-6 py-3 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]">למסלולים ושירותים</a>
        </div>

        <div id="premium-access-status" class="rounded-[1.4rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-3 text-sm leading-7 text-[#1A1A1A]/68">
          הגישה תישמר בדפדפן הזה למשך {premiumAccess.sessionHours} שעות או עד שתפוג תוקף ההרשאה, המוקדם מביניהם.
        </div>
      </div>
    </section>
  </section>

  <script is:inline define:vars={{ premiumAccess }}>
    document.addEventListener("astro:page-load", () => {
      const codeInput = document.getElementById("premium-code");
      const unlockButton = document.getElementById("unlock-premium");
      const status = document.getElementById("premium-access-status");
      if (!(codeInput instanceof HTMLInputElement)) return;
      if (!(unlockButton instanceof HTMLButtonElement)) return;
      if (!(status instanceof HTMLElement)) return;

      const returnTo = new URL(window.location.href).searchParams.get("returnTo") || "/articles/";
      const codes = Array.isArray(premiumAccess?.codes) ? premiumAccess.codes : [];
      const sessionHours = Number(premiumAccess?.sessionHours || 168);

      const writeSession = (matched) => {
        const now = Date.now();
        const sessionExpiry = now + sessionHours * 60 * 60 * 1000;
        const codeExpiry = Date.parse(matched?.expiresAt || "");
        const expiresAt = Number.isFinite(codeExpiry) ? Math.min(sessionExpiry, codeExpiry) : sessionExpiry;
        window.localStorage.setItem(
          "nm-premium-access",
          JSON.stringify({
            codeLabel: matched?.label || "Shared Access",
            unlockedAt: new Date(now).toISOString(),
            expiresAt: new Date(expiresAt).toISOString(),
          })
        );
      };

      unlockButton.addEventListener("click", () => {
        const entered = codeInput.value.trim();
        if (!entered) {
          status.textContent = "הכנס קוד גישה לפני פתיחה.";
          return;
        }

        const matched = codes.find((item) => item.value === entered && (!item.expiresAt || Date.parse(item.expiresAt) > Date.now()));
        if (!matched) {
          status.textContent = "קוד הגישה לא תקין או שכבר פג תוקפו.";
          return;
        }

        writeSession(matched);
        status.textContent = "הגישה נפתחה. מעביר אותך חזרה לתוכן.";
        window.setTimeout(() => {
          window.location.href = returnTo;
        }, 500);
      });
    });
  </script>
</Layout>
