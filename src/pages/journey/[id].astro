---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import clarityPathsFile from "../../config/clarityPaths.json";

type ArticleEntry = CollectionEntry<"articles">;
type JourneyDef = (typeof clarityPathsFile.paths)[number];

export async function getStaticPaths() {
  const entries = await getCollection("articles", ({ data }) => data.draft !== true);
  const slugMap = new Map<string, ArticleEntry>();

  for (const entry of entries) {
    const base = entry.id.replace(/\.mdx$/i, "");
    const tail = base.split("/").pop();
    const keys = [entry.slug, base, tail].filter(Boolean) as string[];

    for (const key of keys) {
      if (!slugMap.has(key)) slugMap.set(key, entry);
    }
  }

  return clarityPathsFile.paths
    .map((journey) => {
      const availableArticles = journey.articleSlugs
        .map((slug) => slugMap.get(slug))
        .filter(Boolean) as ArticleEntry[];

      return {
        params: { id: journey.id },
        props: {
          journey,
          articles: availableArticles,
        },
      };
    })
    .filter(Boolean);
}

const { journey, articles } = Astro.props as { journey: JourneyDef; articles: ArticleEntry[] };

const stepHints = [
  "צעד ראשון: לאסוף את מה שהמחשבה אומרת, בלי למהר להסיק מסקנה.",
  "צעד שני: לבדוק מה כאן עובדה, ומה רק פירוש שהמוח מלביש על המציאות.",
  "צעד שלישי: לבחור פעולה אחת קטנה וברורה שמתאימה למה שרואים עכשיו.",
];

const title = `השם לא משנה | ${journey.title}`;
const description = journey.shortDescription;
---

<Layout {title} {description}>
  <article class="mx-auto max-w-4xl space-y-10 px-5 py-16 text-right sm:px-8 md:py-24" dir="rtl">
    <header class="space-y-4">
      <p class="text-4xl" aria-hidden="true">{journey.emoji}</p>
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">Clarity Path</p>
      <h1 class="text-[clamp(1.85rem,1.4rem+1.6vw,2.75rem)] font-semibold leading-tight text-[var(--nm-fg)]">
        {journey.title}
      </h1>
      <p class="max-w-2xl text-[clamp(1.02rem,0.96rem+0.25vw,1.2rem)] leading-relaxed text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        {journey.shortDescription}
      </p>
      <a
        href="/"
        title="חזרה לדף הבית"
        class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-2 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]"
      >
        חזרה לדף הבית
      </a>
    </header>

    <ol class="space-y-8" role="list">
      {
        articles.map((article, index) => (
          <li class="relative">
            <div class="flex flex-col gap-3 rounded-[1.75rem] border border-[color-mix(in_srgb,var(--nm-fg-secondary)_16%,transparent)] bg-[var(--nm-bg-canvas)]/95 p-6 shadow-[0_20px_60px_color-mix(in_srgb,var(--nm-fg)_6%,transparent)] md:p-8">
              <div class="flex flex-wrap items-baseline justify-between gap-3">
                <span class="inline-flex h-9 min-w-[2.25rem] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-3 text-sm font-bold text-[var(--nm-inverse-fg)]">
                  {index + 1}
                </span>
                <span class="text-xs font-medium text-[var(--nm-fg-secondary)]/55">שלב {index + 1} מתוך 3</span>
              </div>
              <p class="text-sm leading-7 text-[var(--nm-fg-secondary)]/75">{stepHints[index] ?? stepHints[0]}</p>
              <h2 class="text-xl font-semibold text-[var(--nm-fg-secondary)] md:text-2xl">{article.data.title}</h2>
              <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">{article.data.description}</p>
              <a
                href={`/articles/${article.slug}`}
                title={`לקריאת המאמר: ${article.data.title}`}
                class="inline-flex w-fit items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
              >
                לקריאת המאמר
              </a>
            </div>
          </li>
        ))
      }
    </ol>
  </article>
</Layout>