---
import Layout from "../layouts/Layout.astro";

const faqItems = [
  {
    question: "מה ההבדל בין מאמר לשיחה?",
    answer:
      "המאמר מסדר שפה ומפרק מנגנון. השיחה לוקחת את אותו סוג חדות ומיישמת אותו על מצב חי שלך עם משוב בזמן אמת.",
  },
  {
    question: "חייבים לעבור תשלום לפני שמדברים?",
    answer:
      "לא תמיד. יש מסלולים עם בדיקת התאמה קצרה ויש מסלולים עם תשלום מוקדם. העמוד שירותים מפרט מה כולל כל אחד.",
  },
  {
    question: "איך נשמרת פרטיות?",
    answer:
      "טפסים נשלחים דרך ספק חיצוני לפי בחירתך בשליחה. אין שימוש בפרטים לרשימות תדמית. פירוט במדיניות הפרטיות.",
  },
  {
    question: "מה אם אני לא בטוח שזה בשבילי?",
    answer:
      "זו שאלה לגיטימית. מתחילים מארכיון או מטופס התאמה. אם זה לא מתאים, אפשר לצאת בלי דרמה.",
  },
  {
    question: "כמה זמן לוקח לראות שינוי?",
    answer:
      "לפעמים הבנה מגיעה במשפט אחד. לפעמים צריך חזרה על אותו סוג דיוק שבועות. אין הבטחת תוצאה. יש תהליך מדיד.",
  },
];
---

<Layout
  title="שאלות נפוצות"
  description="תשובות קצרות לפני ששואלים אותן בשנית."
  faqItems={faqItems}
>
  <article class="mx-auto max-w-[65ch] space-y-10 px-4 py-14 text-right text-[var(--nm-fg)]">
    <header class="space-y-3">
      <h1 class="text-[clamp(1.75rem,1.4rem+1.2vw,2.5rem)] font-semibold">שאלות נפוצות</h1>
      <p class="text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))] leading-[var(--line-height-ui)]">
        אם משהו לא מכוסה כאן, <a href="/contact/" class="font-semibold text-[var(--nm-accent)] underline-offset-2 hover:underline">יצירת קשר</a>.
      </p>
    </header>

    <div class="space-y-6">
      {
        faqItems.map((item) => (
          <section class="rounded-[1.25rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5">
            <h2 class="text-lg font-semibold text-[var(--nm-fg)]">{item.question}</h2>
            <p class="mt-3 text-sm leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">{item.answer}</p>
          </section>
        ))
      }
    </div>
  </article>
</Layout>
