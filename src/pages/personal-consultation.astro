---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ThoughtShiftProof from "../components/ThoughtShiftProof.astro";
import CostOfNoCalculator from "../components/CostOfNoCalculator.astro";
import DecisionSimulator from "../components/DecisionSimulator.astro";
import WhyThisIsNotForYou from "../components/WhyThisIsNotForYou.astro";
import { findServiceById, servicesThoughtShifts, type FlatService } from "../lib/services";

const consultationService = findServiceById("phone-perspective");
const subscriptionService = findServiceById("retainer-subscription");
const authorityService = findServiceById("podcast-mic");

const fallbackConsultation = ({
  id: "phone-perspective",
  title: "שיחת מיקוד של 20 דקות",
  subtitle: "כדי להפריד בין עובדה לפירוש בזמן אמת",
  description: "שיחה קצרה למצב שבו יש החלטה, קונפליקט, או תקיעות שצריך לפרק עכשיו.",
  price_full: 450,
  action_type: "whatsapp",
  action_text: "אני רוצה להתחיל",
  visible: true,
  badges: [],
  features: ["שיחה קצרה ומדויקת", "פירוק של הנחה אחת מרכזית", "כיוון פעולה אחד ברור"],
  stageName: "בהירות מיידית",
  targetAudience: "למי שצריך תשובה עכשיו",
} as unknown as FlatService);

const fallbackSubscription = ({
  id: "retainer-subscription",
  title: "מסלול המשך חודשי",
  subtitle: "למי שלא מחפש עוד תוכן, אלא רצף עבודה",
  description: "שני מפגשים בחודש וליווי מתמשך למי שרוצה לראות מנגנונים חוזרים ולא רק לפתור רגע אחד.",
  price_full: 1800,
  action_type: "whatsapp",
  action_text: "אני רוצה מסלול המשך",
  visible: true,
  badges: ["מסלול עומק"],
  features: ["שני מפגשים בכל חודש", "מקום לשאלות בין מפגשים", "רצף שמאפשר לראות תבנית"],
  stageName: "ליווי והמשכיות",
  targetAudience: "למי שרוצה גב קבוע",
} as unknown as FlatService);

const fallbackAuthority = ({
  id: "podcast-mic",
  title: "סשן אולפן ותוכן",
  subtitle: "כשהמטרה היא להפוך הבנה למסמך, פרק, או מסר מדויק",
  description: "יום אולפן קצר למי שרוצה לבנות תוכן חד מתוך הבנה ולא מתוך רעש.",
  price_full: 2950,
  action_type: "invoice",
  action_text: "אני רוצה לבדוק התאמה",
  visible: true,
  badges: ["עבודה אסטרטגית"],
  features: ["מיקוד מסר", "צילום או הקלטה", "תרגום של רעיון למבנה"],
  stageName: "השפעה ותוכן",
  targetAudience: "למי שבונה קול ברור החוצה",
} as unknown as FlatService);

const featuredServices: FlatService[] = [
  consultationService ?? fallbackConsultation,
  subscriptionService ?? fallbackSubscription,
  authorityService ?? fallbackAuthority,
];

const mechanismCards = [
  {
    title: "עובדה",
    body: "מה קרה בפועל, בלי שיפוט ובלי סיפור שמתווסף אחר כך.",
  },
  {
    title: "פירוש",
    body: "המשפט שהמוח מוסיף, ואז מתחיל לנהל פחד, תקיעות, או הימנעות.",
  },
  {
    title: "פעולה",
    body: "אחרי שהפירוש נבדק, בוחרים צעד אחד שאפשר באמת לבצע.",
  },
];

const benefits = [
  "בהירות מול החלטה שקפאה יותר מדי זמן.",
  "פירוק של קונפליקט זוגי או אישי בלי להסתבך בעוד שכבות.",
  "הבנה של מה באמת מפעיל אותך לפני שמגיבים שוב מאותו מקום.",
];
---

<Layout title="מיקוד אישי" description="שיחה אישית שמפרקת את המנגנון שמחזיק תקיעות, פחד, או קונפליקט, ובונה צעד פעולה ברור.">
  <section class="mx-auto max-w-6xl space-y-16 px-4 pb-20 text-right text-[var(--nm-fg)]">
    <header class="grid gap-8 rounded-[2.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 px-6 py-10 shadow-[0_24px_80px_rgba(26,26,26,0.06)] lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] lg:px-10">
      <div class="space-y-5">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">מיקוד אישי</p>
        <h1 class="text-[clamp(2.4rem,2rem+1.8vw,4rem)] font-semibold leading-[1.1] text-[var(--nm-fg)]">
          לא עוד עצה. בדיקה של המנגנון שמחזיק את הבעיה.
        </h1>
        <p class="max-w-3xl text-[clamp(1rem,0.96rem+0.25vw,1.15rem)] leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          כשיש רעש, לא חסר מידע. חסרה הבחנה. בשיחה אחת אנחנו מפרידים בין עובדה, פירוש, ופעולה.
        </p>
        <div class="flex flex-wrap justify-end gap-3 pt-2">
          <a href="#pricing" class="inline-flex min-h-[44px] items-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">
            לראות מסלולים
          </a>
          <a href="/intake/" class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
            אני צריך הכוונה
          </a>
        </div>
      </div>

      <aside class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-6">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">איך זה עובד</p>
        <div class="mt-4 grid gap-3">
          {mechanismCards.map((item) => (
            <article class="rounded-[1.3rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-4">
              <h2 class="text-lg font-semibold text-[var(--nm-fg)]">{item.title}</h2>
              <p class="mt-2 text-sm leading-[1.7] text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">{item.body}</p>
            </article>
          ))}
        </div>
      </aside>
    </header>

    <section class="grid gap-5 md:grid-cols-3">
      {benefits.map((item) => (
        <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
          <p class="text-base leading-[1.75] text-[var(--nm-fg)]">{item}</p>
        </article>
      ))}
    </section>

    <ThoughtShiftProof items={servicesThoughtShifts} heading="מה משתנה אחרי שיחה מדויקת" eyebrow="לפני ואחרי" />

    <CostOfNoCalculator />

    <DecisionSimulator />

    <WhyThisIsNotForYou
      title="למי זה לא מתאים כרגע"
      intro="העבודה כאן לא מלטפת את הסיפור. היא בודקת אותו. לכן צריך רצון לראות, לא רק רצון להירגע."
      items={[
        "למי שמחפש אישור שהוא כבר צודק.",
        "למי שרוצה שמישהו אחר יחליט במקומו.",
        "למי שמעדיף להישאר ברמת הסימפטום ולא לגעת בהנחה שמפעילה אותו.",
      ]}
      closing="אם זה לא הזמן שלך להיכנס לשיחה כזאת, זה לגיטימי. עדיף לחכות לרגע שבו יש נכונות אמיתית לראות."
    />

    <section id="pricing" class="space-y-6">
      <div class="space-y-3">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">מסלולי עבודה</p>
        <h2 class="text-[clamp(2rem,1.6rem+1vw,3rem)] font-semibold text-[var(--nm-fg)]">המחירון מסודר לפי עומק, לא לפי רעש.</h2>
        <p class="max-w-3xl text-sm leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
          מתחילים במה שמתאים למצב הנוכחי. אם צריך עומק, ממשיכים. אם צריך בהירות מיידית, לא מעמיסים מסלול ארוך.
        </p>
      </div>

      <div class="grid items-stretch gap-6 lg:grid-cols-2 xl:grid-cols-3">
        {featuredServices.map((featuredService) => (
          <ServiceCard service={featuredService} />
        ))}
      </div>

      <p class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-5 py-4 text-sm leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">
        התשלום מתבצע דרך מערכת Grow. אם צריך לשאול לפני, אפשר לפתוח שאלה קצרה בוואטסאפ מתוך כל כרטיס.
      </p>
    </section>
  </section>
</Layout>
