---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ThoughtShiftProof from "../components/ThoughtShiftProof.astro";
import CostOfNoCalculator from "../components/CostOfNoCalculator.astro";
import DecisionSimulator from "../components/DecisionSimulator.astro";
import WhyThisIsNotForYou from "../components/WhyThisIsNotForYou.astro";
import RelatedTopicVideos from "../components/articles/RelatedTopicVideos.astro";
import {
  assertServicePricingConsistency,
  findServiceById,
  servicesThoughtShifts,
  type FlatService,
} from "../lib/services";

const consultationService = findServiceById("phone-perspective");
const deepService = findServiceById("personal-clinic");
const studioService = findServiceById("podcast-mic");
const archiveService = findServiceById("portal-access");

const fallbackConsultation = ({
  id: "phone-perspective",
  title: "שיחת מיקוד",
  subtitle: "20-60 דקות של בהירות במקום עוד רעש",
  description: "שיחה קצרה ומדויקת למצב שבו יש תקיעות, פחד, החלטה או קונפליקט שצריך לפרק עכשיו.",
  price_full: 450,
  action_type: "whatsapp",
  action_text: "קביעת שיחה",
  visible: true,
  badges: ["בהירות מיידית"],
  features: [
    { text: "טלפון או וידאו", icon: "phone" },
    { text: "20-60 דקות", icon: "time" },
    { text: "כיוון ברור להמשך", icon: "default" },
  ],
  stageName: "מה זה שיחת מיקוד",
  targetAudience: "למי שצריך סדר עכשיו",
} as unknown as FlatService);

const fallbackDeep = ({
  id: "personal-clinic",
  title: "מפגש עומק",
  subtitle: "יותר זמן למי שלא רוצה למהר",
  description: "מפגש פרונטלי או ארוך יותר, כשברור ששיחה קצרה לא תספיק כדי לראות את מה שיושב מתחת.",
  price_full: 900,
  action_type: "whatsapp",
  action_text: "קביעת שיחה",
  visible: true,
  badges: ["עומק ושקט"],
  features: [
    { text: "פרונטלי או ארוך", icon: "location" },
    { text: "תיעוד לפי צורך", icon: "privacy" },
    { text: "פירוק שכבות עמוקות", icon: "default" },
  ],
  stageName: "כשצריך עוד זמן",
  targetAudience: "למי ששיחה קצרה לא מספיקה לו",
} as unknown as FlatService);

const fallbackStudio = ({
  id: "podcast-mic",
  title: "אולפן ותוכן",
  subtitle: "כשצריך מרחב חי או מסר מדויק",
  description: "מסלול למי שרוצה להפוך הבנה לשיחה חיה, צילום או מסר שאפשר להוציא החוצה בלי רעש.",
  price_full: 2950,
  action_type: "invoice",
  action_text: "בדיקת התאמה",
  visible: true,
  badges: ["אולפן ומסר"],
  features: [
    { text: "פודקאסט או צילום", icon: "video" },
    { text: "מיקוד מסר", icon: "default" },
    { text: "תרגום רעיון למבנה ברור", icon: "content" },
  ],
  stageName: "כשיש גם קול החוצה",
  targetAudience: "למי שבונה מסר מדויק",
} as unknown as FlatService);

const fallbackArchive = ({
  id: "portal-access",
  title: "מנוי ארכיון",
  subtitle: "למי שרוצה לחקור לבד, בקצב שלו",
  description: "גישה לתכנים המלאים, לווידאו, ולשכבות שלא מתאימות לעמוד פתוח רגיל.",
  price_full: 175,
  action_type: "link",
  action_href: "/me/unlock/",
  action_text: "בקשה להצטרף",
  visible: true,
  badges: ["מנוי חודשי"],
  features: [
    { text: "וידאו במאמרים", icon: "video" },
    { text: "תכנים שלא מפורסמים בחוץ", icon: "privacy" },
    { text: "גישה לקבוצה השקטה", icon: "group" },
  ],
  stageName: "כשמעדיפים לחקור לבד",
  targetAudience: "למי שרוצה רצף שקט של למידה",
} as unknown as FlatService);

const featuredServices: FlatService[] = [
  consultationService ?? fallbackConsultation,
  deepService ?? fallbackDeep,
  studioService ?? fallbackStudio,
  archiveService ?? fallbackArchive,
];

assertServicePricingConsistency(featuredServices);

const joinClubHref = "/me/unlock/";
const mechanismCards = [
  {
    title: "עובדה",
    body: "מה קרה בפועל, בלי ההסבר שמסביב ובלי הסיפור שנוסף אחרי זה.",
  },
  {
    title: "פירוש",
    body: "מה הראש הוסיף לעובדה, ואיך זה מתחיל לייצר רעש, פחד או תקיעות.",
  },
  {
    title: "תגובה",
    body: "מה אתה עושה בגלל הפירוש, ואיך בוחרים צעד שקט ומדויק יותר.",
  },
];

const benefits = [
  "פירוק של מה שמפעיל אותך עכשיו",
  "הפרדה בין עובדה, פירוש ותגובה",
  "בהירות על החלטה תקועה",
  "שקט לפני פעולה",
  "כיוון ברור להמשך",
];

const fitItems = [
  "למי שתקוע בהחלטה ולא רוצה להסתובב איתה עוד שבועות",
  "למי שמרגיש רעש פנימי ורוצה לראות מה בדיוק מפעיל אותו",
  "למי שרוצה להבין מנגנון, לא רק לפרוק תחושה",
];

const notHereItems = ["לא טיפול", "לא הרגעה", "לא אישור", "לא פתרונות מהירים"];

const faqItems = [
  {
    question: "מה זה שיחת מיקוד",
    answer: "שיחה קצרה שמפרידה בין מה שקרה, מה פירשת, ומה אתה עומד לעשות עכשיו. המטרה היא בהירות, לא עוד עומס.",
  },
  {
    question: "האם זה טיפול",
    answer: "לא. זו בדיקה בהירה של המנגנון שמחזיק את הבעיה, כדי לראות מה נכון לעשות עכשיו.",
  },
  {
    question: "איך בוחרים בין שיחת מיקוד למפגש עומק",
    answer: "אם יש נושא אחד דחוף וברור, לרוב מתחילים בשיחת מיקוד. אם כבר ברור שיש כמה שכבות עמוקות, מפגש עומק יכול להתאים יותר.",
  },
  {
    question: "מה נפתח אחרי ההצטרפות",
    answer: "סרטונים מלאים, תכנים שלא מפורסמים בפומבי, הקבוצה השקטה, ועוד שכבות עומק שלא נכנסות לעמוד פתוח רגיל.",
  },
];
---

<Layout
  title="שיחה אישית | פירוק שקט ומדויק"
  description="שיחה אישית בשיטת NeverMind מפרידה בין עובדה, פירוש ותגובה כדי לראות מה באמת מחזיק את הבעיה ומה נכון לעשות עכשיו."
  faqItems={faqItems}
  breadcrumbCurrentLabel="שיחה אישית"
>
  <section id="main-content" class="mx-auto max-w-5xl space-y-12 px-4 pb-24 pt-12 text-right text-[var(--nm-fg)]">
    <header class="grid gap-6 rounded-[2.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-6 py-8 shadow-[0_24px_80px_rgba(26,26,26,0.06)] xl:grid-cols-[minmax(0,1.2fr)_minmax(20rem,0.8fr)] xl:px-10">
      <div class="space-y-5">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">שיחה אישית</p>
        <h1 class="nm-title-balance text-[clamp(2.2rem,1.8rem+1.8vw,4rem)] font-semibold leading-[1.08] text-[var(--nm-fg)]">
          שיחת מיקוד - פירוק המנגנון שמחזיק את הבעיה
        </h1>
        <p class="nm-copy-balanced max-w-3xl text-[clamp(1rem,0.96rem+0.25vw,1.15rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          20-60 דקות של בהירות במקום עוד סיבוב סביב אותה תחושה. לא עוד עצה, אלא פירוק של מה שקורה בפנים כדי לראות מה נכון
          לעשות עכשיו בלי דרמה ובלי בלבול.
        </p>

        <div class="flex flex-wrap justify-end gap-3 pt-1">
          <a href={joinClubHref} class="inline-flex min-h-[48px] items-center rounded-full bg-[var(--nm-accent)] px-6 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">
            רוצה להצטרף ל-NeverMind
          </a>
          <a href="#pricing" class="inline-flex min-h-[48px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
            מסלולים ומחירים
          </a>
        </div>
      </div>

      <div class="grid gap-4 xl:content-start">
        <article class="rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-5">
          <p class="text-sm font-semibold text-[var(--nm-accent)]">מה מקבלים בשיחה</p>
          <ul class="mt-3 space-y-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
            {benefits.map((item) => (
              <li class="flex gap-2"><span aria-hidden="true" class="text-[var(--nm-accent)]">•</span><span>{item}</span></li>
            ))}
          </ul>
        </article>

        <article class="rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5 shadow-[0_16px_40px_rgba(26,26,26,0.04)]">
          <p class="text-sm font-semibold text-[var(--nm-fg)]">אפשר גם להמשיך לבד</p>
          <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
            אם עוד לא נכון לקבוע שיחה, אפשר לפתוח גישה לארכיון ולהתחיל מתוכן סגור, וידאו ומאמרים עמוקים יותר.
          </p>
          <a href="/services/archive/" class="mt-4 inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
            מעבר למנוי ארכיון
          </a>
        </article>
      </div>
    </header>

    <section class="rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[color-mix(in_srgb,var(--nm-accent)_7%,white)] px-6 py-5 text-right shadow-[0_12px_34px_rgba(26,26,26,0.04)]">
      <p class="text-sm font-semibold text-[var(--nm-fg)]">אם כל הסיפור שאתה מביא הוא זוגי, יש עכשיו עמוד ייעודי</p>
      <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        <a href="/services/couples/" class="font-semibold text-[var(--nm-accent)] underline decoration-[color-mix(in_srgb,var(--nm-accent)_30%,transparent)] underline-offset-4">ייעוץ זוגי בשיטת NeverMind</a> לא מתחיל מ"איך לדבר יפה יותר", אלא מפירוק של המנגנון שמחזיק את המריבה, התלות או הפחד.
      </p>
    </section>

    <RelatedTopicVideos
      topicKey="consultation"
      topicLabel="צפייה וחקירה: שיחה, ייעוץ ופירוק"
      intro="למי שרוצה לראות איך נראית שכבת ההעמקה סביב שיחה אישית, כאן נפתח רצף נוסף לחברי המועדון."
    />

    <section class="space-y-5">
      <div class="space-y-2">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">איך זה עובד</p>
        <h2 class="nm-title-balance text-[clamp(1.8rem,1.5rem+0.9vw,2.7rem)] font-semibold text-[var(--nm-fg)]">שלושה צעדים פשוטים כדי לראות מה קורה בפנים</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {mechanismCards.map((item) => (
          <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
            <h3 class="text-lg font-semibold text-[var(--nm-fg)]">{item.title}</h3>
            <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="grid gap-5 lg:grid-cols-2">
      <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">למי זה מתאים</p>
        <ul class="mt-4 space-y-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          {fitItems.map((item) => (
            <li class="flex gap-2"><span aria-hidden="true" class="text-[var(--nm-accent)]">•</span><span>{item}</span></li>
          ))}
        </ul>
      </article>

      <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">מה לא תמצא כאן</p>
        <ul class="mt-4 space-y-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          {notHereItems.map((item) => (
            <li class="flex gap-2"><span aria-hidden="true" class="text-[var(--nm-accent)]">•</span><span>{item}</span></li>
          ))}
        </ul>
      </article>
    </section>

    <section id="pricing" class="space-y-6 scroll-mt-28">
      <div class="space-y-3">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">מסלולים ומחירים</p>
        <h2 class="nm-title-balance text-[clamp(2rem,1.6rem+1vw,3rem)] font-semibold text-[var(--nm-fg)]">אותו מחירון, מאותו מקור אמת</h2>
        <p class="max-w-3xl text-sm leading-8 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
          המחיר בכרטיס, הכפתור והמשך הזרימה נבנים מאותו מקור נתונים. כך אין פער בין עמוד השירות לבין ההמשך בפועל.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {featuredServices.map((featuredService) => (
          <ServiceCard service={featuredService} />
        ))}
      </div>
    </section>

    <section class="space-y-5 rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
      <ThoughtShiftProof items={servicesThoughtShifts} heading="מה משתנה אחרי שיחה מדויקת" eyebrow="לפני ואחרי" />
    </section>

    <section class="space-y-5 rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
      <div class="space-y-2">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">אם צריך עוד רגע לבדוק</p>
        <h2 class="nm-title-balance text-[clamp(1.7rem,1.45rem+0.8vw,2.4rem)] font-semibold text-[var(--nm-fg)]">אפשר לראות גם את המחיר של לא לזוז</h2>
      </div>
      <div class="grid gap-6 xl:grid-cols-2">
        <CostOfNoCalculator />
        <DecisionSimulator />
      </div>
    </section>

    <WhyThisIsNotForYou
      title="למי זה לא מתאים כרגע"
      intro="העבודה כאן לא מלטפת את הסיפור. היא בודקת אותו. לכן צריך רצון לראות, לא רק רצון להרגיש הקלה רגעית."
      items={[
        "למי שמחפש אישור שהוא כבר צודק.",
        "למי שרוצה שמישהו אחר יחליט במקומו.",
        "למי שמעדיף להישאר רק ברמת הסימפטום ולא לגעת בהנחה שמפעילה אותו.",
      ]}
      closing="אם זה לא הזמן שלך להיכנס לשיחה כזאת, זה לגיטימי. עדיף לחכות לרגע שבו יש נכונות אמיתית לראות."
    />

    <section class="space-y-5 rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
      <div class="space-y-2 text-right">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">אם זה לא רק אישי</p>
        <h2 class="nm-title-balance text-[clamp(1.6rem,1.35rem+0.8vw,2.2rem)] font-semibold text-[var(--nm-fg)]">אפשר לעבור מכאן למסלול המדויק</h2>
        <p class="max-w-3xl text-sm leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          לא כל תקיעות צריכה להישאר בעמוד הזה. אם הסיפור הוא זוגי, או אם נכון יותר לחקור לבד דרך הארכיון, עדיף לעבור ישר למסלול הנכון.
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <a href="/services/couples/" class="rounded-[1.35rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5 text-right transition hover:border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] hover:bg-white">
          <p class="nm-title-balance text-base font-semibold text-[var(--nm-fg)]">ייעוץ זוגי</p>
          <p class="nm-copy-balanced mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">כשהקונפליקט יושב בתוך קשר ולא רק בתוך הראש שלך.</p>
        </a>
        <a href="/services/archive/" class="rounded-[1.35rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5 text-right transition hover:border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] hover:bg-white">
          <p class="nm-title-balance text-base font-semibold text-[var(--nm-fg)]">מנוי ארכיון</p>
          <p class="nm-copy-balanced mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">כשרוצים לחקור לבד, בקצב אישי, בלי לקבוע שיחה.</p>
        </a>
        <a href="/services/" class="rounded-[1.35rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5 text-right transition hover:border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] hover:bg-white">
          <p class="nm-title-balance text-base font-semibold text-[var(--nm-fg)]">כל הייעוצים</p>
          <p class="nm-copy-balanced mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">עמוד השער לכל המסלולים, המחירים וההבדלים ביניהם.</p>
        </a>
      </div>
    </section>

    <section class="space-y-5 rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-[0_18px_50px_rgba(26,26,26,0.04)]">
      <div class="text-right">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">שאלות נפוצות</p>
        <h2 class="mt-2 text-[clamp(1.7rem,1.45rem+0.8vw,2.4rem)] font-semibold text-[var(--nm-fg)]">לפני שקובעים או מצטרפים</h2>
      </div>
      <div class="grid gap-3">
        {faqItems.map((item) => (
          <details class="rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4 text-right">
            <summary class="cursor-pointer list-none text-sm font-semibold text-[var(--nm-fg)] marker:hidden">{item.question}</summary>
            <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </section>
</Layout>
