---
import { getCollection, type CollectionEntry } from "astro:content";
import ClarityAnalogy from "../../components/ClarityAnalogy.astro";
import ConceptCallout from "../../components/ConceptCallout.astro";
import DeepDiveInquiry from "../../components/DeepDiveInquiry.astro";
import InlineGlossaryTerm from "../../components/InlineGlossaryTerm.astro";
import InquirySection from "../../components/InquirySection.astro";
import MechanismCard from "../../components/MechanismCard.astro";
import PremiumBreak from "../../components/PremiumBreak.astro";
import PremiumClubGate from "../../components/PremiumClubGate.astro";
import ClubKeywordWall from "../../components/ClubKeywordWall.astro";
import SocialParadoxes from "../../components/SocialParadoxes.astro";
import SubscribeBanner from "../../components/SubscribeBanner.astro";
import TruthBlock from "../../components/TruthBlock.astro";
import ArticleYoutubeGate from "../../components/ArticleYoutubeGate.astro";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);

  return articles.map((entry) => ({
    params: {
      slug: entry.data.slug ?? entry.slug,
    },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<"articles">;
};

const { entry } = Astro.props as Props;
const frontmatter = entry.data;
const { Content } = await entry.render();
const faqItems = Array.isArray(frontmatter.faq) ? frontmatter.faq : [];
const seoArticleBody = entry.body.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();
const wordCountArticle = seoArticleBody.split(/\s+/).filter(Boolean).length;
const readingMinutesArticle = Math.max(1, Math.ceil(wordCountArticle / 200));
const publishedLabel = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("he-IL", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : "";
const mdxComponents = {
  ClarityAnalogy,
  ConceptCallout,
  DeepDiveInquiry,
  InlineGlossaryTerm,
  InquirySection,
  MechanismCard,
  PremiumBreak,
  SocialParadoxes,
  SubscribeBanner,
  TruthBlock,
};
const youtubeIdArticle =
  typeof frontmatter.youtubeId === "string" && frontmatter.youtubeId.trim()
    ? frontmatter.youtubeId.trim()
    : undefined;
const videoSummaryPointsArticle = Array.isArray(frontmatter.videoSummaryPoints)
  ? frontmatter.videoSummaryPoints
  : [];
const hasQuestionForSchema = Boolean(String(frontmatter.questionForSchema ?? "").trim());
---

<Layout
  title={frontmatter.title}
  description={frontmatter.description}
  frontmatter={frontmatter}
  faqItems={faqItems}
  hasInquirySection={faqItems.length > 0 || hasQuestionForSchema}
  seoArticleBody={seoArticleBody}
  articlePaywalled={frontmatter.isPremium}
>
  <section class="mx-auto max-w-4xl px-4 pb-20 text-right text-[var(--nm-fg)]">
    <header class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 px-6 py-8 shadow-[0_18px_42px_rgba(26,26,26,0.04)]">
      <p class="text-sm font-semibold text-[var(--nm-accent)]">מאמר</p>
      <h1 class="mt-3 text-[clamp(2rem,1.6rem+1.4vw,3.1rem)] font-semibold leading-tight">{frontmatter.title}</h1>
      <p class="mt-4 max-w-3xl text-[clamp(1rem,0.96rem+0.22vw,1.08rem)] leading-[1.8] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
        {frontmatter.description}
      </p>
      <p class="mt-3 text-sm font-medium text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">
        בערך {readingMinutesArticle} דקות קריאה (משוער לפי אורך הטקסט)
      </p>
      {
        publishedLabel ? (
          <p class="mt-4 text-sm text-[color-mix(in_srgb,var(--nm-fg)_50%,var(--nm-bg))]">
            עודכן במערכת ב-{publishedLabel}
          </p>
        ) : null
      }
    </header>

    {
      youtubeIdArticle ? (
        <ArticleYoutubeGate
          youtubeId={youtubeIdArticle}
          title={frontmatter.title}
          isPremium={Boolean(frontmatter.isPremium)}
          videoSummaryPoints={videoSummaryPointsArticle}
        />
      ) : null
    }

    <div class="nm-article-shell mt-8 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_9%,transparent)] bg-[var(--nm-bg-canvas)] px-5 py-8 shadow-[0_18px_42px_rgba(26,26,26,0.03)] md:px-8">
      <ArticleLayout frontmatter={frontmatter}>
        <Content components={mdxComponents} />
      </ArticleLayout>
    </div>

    {
      frontmatter.isPremium ? (
        <section class="mt-8">
          <PremiumClubGate />
        </section>
      ) : null
    }

    {frontmatter.isPremium ? null : <ClubKeywordWall />}
  </section>

  <script is:inline define:vars={{ slug: entry.slug, title: frontmatter.title }}>
    (() => {
      try {
        const row = { slug, title, at: Date.now() };
        localStorage.setItem("nm_last_article_open", JSON.stringify(row));
        const key = "nm_article_open_log";
        const prev = JSON.parse(localStorage.getItem(key) || "[]");
        const arr = Array.isArray(prev) ? prev : [];
        const next = [row, ...arr.filter((x) => x && x.slug !== row.slug)].slice(0, 40);
        localStorage.setItem(key, JSON.stringify(next));
        const onceKey = `nm_sec_once_${slug}`;
        if (!sessionStorage.getItem(onceKey)) {
          sessionStorage.setItem(onceKey, "1");
          const sec = Math.floor(Number.parseInt(localStorage.getItem("nm_reading_seconds_local") || "0", 10) || 0);
          localStorage.setItem("nm_reading_seconds_local", String(sec + 180));
        }
      } catch {
        /* ignore */
      }
    })();
  </script>
</Layout>

<style>
  .nm-article-shell :global(.nm-article .content) {
    display: grid;
    gap: 1.25rem;
  }

  .nm-article-shell :global(.nm-article h2),
  .nm-article-shell :global(.nm-article h3) {
    color: var(--nm-fg);
    line-height: 1.4;
  }

  .nm-article-shell :global(.nm-article p),
  .nm-article-shell :global(.nm-article li) {
    line-height: 1.8;
    color: color-mix(in srgb, var(--nm-fg) 80%, var(--nm-bg));
  }

  .nm-article-shell :global(.nm-article ul),
  .nm-article-shell :global(.nm-article ol) {
    padding-inline: 1.2rem;
  }

  .nm-article-shell :global(.nm-article img) {
    inline-size: 100%;
    block-size: auto;
    border-radius: 1.25rem;
  }
</style>


