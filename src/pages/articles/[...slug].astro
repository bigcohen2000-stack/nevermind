      width: 90%;
    }
    .nm-premium-skeleton-line--w88 {
      width: 88%;
    }
    .nm-premium-skeleton-line--w72 {
      width: 72%;
    }
    .nm-premium-skeleton-line--w56 {
      width: 56%;
    }

    @media (prefers-reduced-motion: reduce) {
      .nm-premium-skeleton-line {
        animation: none;
        opacity: 0.35;
      }
    }

    .nm-locked-content-wrapper {
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 0.5s ease,
        transform 0.5s ease;
    }

    .nm-locked-content-wrapper.nm-locked-content--visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      .nm-locked-content-wrapper {
        transition: none;
        transform: none;
      }
    }

    .nm-premium-skeleton.is-premium-skeleton--done {
      display: none !important;
    }

    [data-truth-block].nm-truth-collapsed {
      visibility: hidden;
      height: 0 !important;
      min-height: 0 !important;
      margin-top: 0 !important;
      margin-bottom: 0 !important;
      padding: 0 !important;
      overflow: hidden !important;
      opacity: 0 !important;
      pointer-events: none !important;
      border: none !important;
      transition:
        opacity 0.35s ease,
        height 0.4s ease;
    }

    .nm-insight-sticky {
      border-bottom: 1px solid color-mix(in srgb, var(--nm-fg) 6%, transparent);
      background: color-mix(in srgb, var(--nm-bg-canvas) 88%, transparent);
      box-shadow: none;
      opacity: 0;
      transform: translate3d(0, calc(-100% - 0.5rem), 0);
      transition:
        transform 0.42s cubic-bezier(0.32, 0.72, 0, 1),
        opacity 0.36s ease,
        background 0.35s ease,
        backdrop-filter 0.35s ease,
        box-shadow 0.35s ease,
        border-color 0.35s ease;
      will-change: transform, opacity;
    }

    .nm-insight-sticky.nm-insight-sticky--visible {
      opacity: 1 !important;
      transform: translate3d(0, 0, 0) !important;
      pointer-events: auto !important;
      background: color-mix(in srgb, var(--nm-bg-canvas) 58%, rgba(255, 255, 255, 0.06));
      -webkit-backdrop-filter: blur(22px) saturate(1.65);
      backdrop-filter: blur(22px) saturate(1.65);
      border-bottom-color: color-mix(in srgb, var(--nm-fg) 5%, transparent);
      box-shadow:
        0 1px 0 color-mix(in srgb, var(--nm-fg) 4%, transparent),
        0 12px 40px color-mix(in srgb, var(--nm-fg) 5%, transparent);
    }

    @media (prefers-reduced-motion: reduce) {
      .nm-insight-sticky {
        transition-duration: 0.05s;
      }
    }
  </style>

  <script lang="ts">
    import { actions } from "astro:actions";

    document.addEventListener("astro:page-load", () => {
      if (window.__nmArticleCleanup) {
        window.__nmArticleCleanup();
      }

      const progressBar = document.getElementById("reading-progress");
      const focusToggle = document.querySelector("[data-focus-toggle]");
      const copyButton = document.querySelector("[data-copy-link]");
      const toast = document.querySelector("[data-copy-toast]");
      const premiumBody = document.querySelector("[data-premium-body]");
      const cleanups: Array<() => void> = [];
      let ticking = false;
      let toastTimeout: ReturnType<typeof window.setTimeout> | undefined;

      const updateProgress = () => {
        const doc = document.documentElement;
        const scrollTop = doc.scrollTop || document.body.scrollTop;
        const scrollHeight = doc.scrollHeight - doc.clientHeight;
        const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
        if (progressBar instanceof HTMLElement) {
          progressBar.style.width = `${progress}%`;
        }
        ticking = false;
      };

      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          window.requestAnimationFrame(updateProgress);
        }
      };

      const setFocusMode = (enabled: boolean) => {
        document.body.classList.toggle("is-focus-mode", enabled);
        if (focusToggle instanceof HTMLButtonElement) {
          focusToggle.setAttribute("aria-pressed", String(enabled));
          focusToggle.textContent = enabled ? "יציאה ממצב פוקוס" : "מצב פוקוס";
        }
      };

      const showToast = (message = "הועתק") => {
        if (!(toast instanceof HTMLElement)) return;
        const previous = toast.textContent || "הועתק";
        toast.textContent = message;
        toast.classList.add("opacity-100");
        window.clearTimeout(toastTimeout);
        toastTimeout = window.setTimeout(() => {
          toast.classList.remove("opacity-100");
          toast.textContent = previous;
        }, 1400);
      };

      const applyPremiumVault = async () => {
        if (!(premiumBody instanceof HTMLElement)) return;
        if (premiumBody.dataset.premiumInitialized === "true") return;

        const SETTINGS_STORAGE_KEY = "nm-site-settings-overrides";

        const readOverrides = () => {
          try {
            return JSON.parse(window.localStorage.getItem(SETTINGS_STORAGE_KEY) || "null");
          } catch {
            return null;
          }
        };

        const overrides = readOverrides()?.premiumVault || {};
        const premiumEnabled = overrides.enabled ?? (premiumBody.dataset.premiumActive === "true");

        if (!premiumEnabled) {
          premiumBody.dataset.premiumInitialized = "true";
          return;
        }

        const articleSlug = (premiumBody.dataset.premiumArticleSlug || "").trim();
        const fragmentSig = (premiumBody.dataset.premiumFragmentSig || "").trim();
        const skeleton = document.getElementById("nm-premium-skeleton");
        const lockedWrap = document.getElementById("locked-content-wrapper");
        const paywallRoot = document.getElementById("nm-premium-paywall-root");

        const finishSkeleton = () => {
          if (skeleton instanceof HTMLElement) {
            skeleton.classList.add("is-premium-skeleton--done");
            skeleton.setAttribute("aria-busy", "false");
          }
        };

        const revealLockedHtml = (html: string) => {
          if (!(lockedWrap instanceof HTMLElement)) return;
          lockedWrap.innerHTML = html;
          lockedWrap.removeAttribute("hidden");
          lockedWrap.classList.remove("nm-locked-content--visible");
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              lockedWrap.classList.add("nm-locked-content--visible");
            });
          });
        };

        const buildPremiumVaultShell = () => {
          if (!(paywallRoot instanceof HTMLElement)) return;
          paywallRoot.innerHTML = "";

          const accessEnabled = premiumBody.dataset.premiumAccessEnabled === "true";
          const vaultTitle = overrides.title || premiumBody.dataset.premiumTitle || "מכאן הלאה - נכנסים לפרטים";
          const description =
            overrides.description ||
            premiumBody.dataset.premiumDescription ||
            "הבסיס תמיד יהיה פתוח לכולם. ההמשך של המאמר הזה מיועד למי שרוצה לקחת את ההבנה צעד אחד קדימה ולהשקיע בתהליך. הגישה פתוחה לחברי המסלול המלא.";
          const fallbackCtaLabel = overrides.ctaLabel || premiumBody.dataset.premiumCtaLabel || "איך מצטרפים?";
          const fallbackCtaHref = overrides.ctaHref || premiumBody.dataset.premiumCtaHref || "/services/";
          const accessRoute = premiumBody.dataset.premiumAccessRoute || "/dashboard/";
          const helperText =
            premiumBody.dataset.premiumAccessHelper || "גישה לתוכן פרימיום נפתחת כרגע דרך קוד גישה מתחלף.";
          const returnTo = encodeURIComponent(window.location.pathname);
          const primaryHref = accessEnabled ? `${accessRoute}?returnTo=${returnTo}` : fallbackCtaHref;
          const primaryLabel = accessEnabled ? "להזין קוד גישה" : fallbackCtaLabel;

          const vaultPaywallCtasHtml = accessEnabled
            ? `<div class="nm-premium-vault-cta-row"><a href="${primaryHref}" class="nm-premium-vault-cta nm-premium-vault-cta--primary">${primaryLabel}</a><a href="${fallbackCtaHref}" class="nm-premium-vault-cta nm-premium-vault-cta--secondary">${fallbackCtaLabel}</a></div>`
            : `<div class="nm-premium-vault-cta-row"><a href="${primaryHref}" class="nm-premium-vault-cta nm-premium-vault-cta--primary">${primaryLabel}</a></div>`;

          const shell = document.createElement("div");
          shell.className = "nm-premium-shell";

          const calloutSrc = premiumBody.querySelector("[data-premium-callout-anchor]");
          if (calloutSrc) {
            const co = calloutSrc.querySelector(".nm-subscription-callout");
            if (co) shell.appendChild(co.cloneNode(true));
          }

          const fogWrap = document.createElement("div");
          fogWrap.className = "nm-premium-fog-wrap";
          fogWrap.setAttribute("aria-hidden", "true");
          const fog = document.createElement("div");
          fog.className = "nm-premium-fog";
          fogWrap.appendChild(fog);
          shell.appendChild(fogWrap);

          const card = document.createElement("section");
          card.className = "nm-premium-card";
          card.innerHTML = `
          <p class="nm-premium-vault-kicker">Premium Vault</p>
          <h2 class="nm-premium-vault-title">${vaultTitle}</h2>
          <p class="nm-premium-vault-body">${description}</p>
          <p class="nm-premium-vault-helper">${helperText}</p>
          ${vaultPaywallCtasHtml}
        `;

          shell.appendChild(card);
          paywallRoot.appendChild(shell);
          paywallRoot.removeAttribute("hidden");
        };

        if (
          !articleSlug ||
          !fragmentSig ||
          !(skeleton instanceof HTMLElement) ||
          !(lockedWrap instanceof HTMLElement) ||
          !(paywallRoot instanceof HTMLElement)
        ) {
          premiumBody.dataset.premiumInitialized = "true";
          return;
        }

        try {
          const gaCid = (() => {
            try {
              const m = document.cookie.match(/(?:^|;\s*)_ga=([^;]+)/);
              if (!m) return "";
              const v = decodeURIComponent(m[1].trim());
              const parts = v.split(".");
              if (parts.length >= 4) {
                return `${parts[parts.length - 2]}.${parts[parts.length - 1]}`.slice(0, 120);
              }
              return v.slice(0, 120);
            } catch {
              return "";
            }
          })();
          const docEl = document.documentElement;
          const scrollRange = docEl.scrollHeight - docEl.clientHeight;
          const scrollRatio =
            scrollRange > 0
              ? Math.min(1, Math.max(0, (docEl.scrollTop || 0) / scrollRange))
              : 0;
          const { data, error } = await actions.premium.getFragment({
            slug: articleSlug,
            signature: fragmentSig,
            gaClientId: gaCid || undefined,
            scrollRatio: Math.round(scrollRatio * 1000) / 1000,
          });

          finishSkeleton();

          if (!error && data?.html && data.html.trim().length > 0) {
            revealLockedHtml(data.html);
            premiumBody.querySelector(".nm-premium-teaser-fade")?.classList.add("nm-premium-teaser-fade--off");
            paywallRoot.setAttribute("hidden", "");
            paywallRoot.innerHTML = "";
          } else {
            buildPremiumVaultShell();
          }
        } catch {
          finishSkeleton();
          buildPremiumVaultShell();
        }

        premiumBody.dataset.premiumInitialized = "true";
      };

      if (copyButton instanceof HTMLElement) {
        const onCopyClick = async () => {
          const value = copyButton.getAttribute("data-copy-value") ?? "";
          try {
            await navigator.clipboard.writeText(value);
            showToast();
          } catch {
            window.prompt("העתק קישור", value);
          }
        };

        copyButton.addEventListener("click", onCopyClick);
        cleanups.push(() => copyButton.removeEventListener("click", onCopyClick));
      }

      const stripInsightPlain = (raw: unknown) => {
        const s = String(raw || "").trim();
        if (!s) return "";
        const div = document.createElement("div");
        div.innerHTML = s;
        const fromDom = div.textContent?.replace(/\s+/g, " ").trim();
        if (fromDom) return fromDom;
        return s.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();
      };

      document.querySelectorAll("[data-copy-insight]").forEach((node) => {
        const onInsightCopy = async () => {
          if (!(node instanceof HTMLElement)) return;
          const insightRaw = (node.getAttribute("data-insight") || "").trim();
          if (!insightRaw) return;
          const usePlain = node.getAttribute("data-copy-plain") === "true";
          const articleTitle = (node.getAttribute("data-article-title") || "").trim();
          const insight = usePlain ? stripInsightPlain(insightRaw) : insightRaw;
          if (!insight) return;
          const payload = usePlain
            ? insight
            : `"${insight}" - מתוך המאמר: ${articleTitle}. לקריאה המלאה ב-NeverMind: https://milog.co.il/%D7%9E%D7%90%D7%9E%D7%A8`;
          try {
            await navigator.clipboard.writeText(payload);
            showToast(usePlain ? "הועתק" : "התובנה הועתקה, אפשר להדביק בוואטסאפ!");
          } catch {
            window.prompt("העתק תובנה", payload);
          }
        };

        node.addEventListener("click", onInsightCopy);
        cleanups.push(() => node.removeEventListener("click", onInsightCopy));
      });

      const truthBlock = document.querySelector("[data-truth-block]");
      const insightSticky = document.querySelector("[data-insight-sticky]");
      if (truthBlock instanceof HTMLElement && insightSticky instanceof HTMLElement) {
        type TruthStickyEntry = Pick<IntersectionObserverEntry, "isIntersecting" | "boundingClientRect">;
        const syncTruthSticky = (entry: TruthStickyEntry) => {
          const rect = entry.boundingClientRect;
          const fullyAboveViewport = !entry.isIntersecting && rect.bottom <= 0;
          truthBlock.classList.toggle("nm-truth-collapsed", fullyAboveViewport);
          insightSticky.classList.toggle("nm-insight-sticky--visible", fullyAboveViewport);
        };
        const io = new IntersectionObserver(
          (entries) => {
            const entry = entries[0];
            if (entry) syncTruthSticky(entry);
          },
          { threshold: 0, root: null, rootMargin: "0px" }
        );
        io.observe(truthBlock);
        cleanups.push(() => io.disconnect());
        const vh = window.innerHeight || document.documentElement.clientHeight;
        const r0 = truthBlock.getBoundingClientRect();
        const initiallyIntersecting = r0.bottom > 0 && r0.top < vh;
        syncTruthSticky({ isIntersecting: initiallyIntersecting, boundingClientRect: r0 });
      }

      if (focusToggle instanceof HTMLButtonElement) {
        const onFocusClick = () => {
          const isPressed = focusToggle.getAttribute("aria-pressed") === "true";
          setFocusMode(!isPressed);
        };

        focusToggle.addEventListener("click", onFocusClick);
        cleanups.push(() => focusToggle.removeEventListener("click", onFocusClick));
      }

      document.addEventListener("scroll", onScroll, { passive: true });
      cleanups.push(() => document.removeEventListener("scroll", onScroll));
      updateProgress();
      setFocusMode(false);
      void applyPremiumVault().catch(() => {
        if (premiumBody instanceof HTMLElement) {
          premiumBody.dataset.premiumInitialized = "true";
        }
      });

      const initPremiumBonus = async () => {
        const root = document.querySelector("[data-premium-bonus-root]");
        if (!(root instanceof HTMLElement)) return;
        const locked = root.querySelector("[data-premium-bonus-locked]");
        const unlocked = root.querySelector("[data-premium-bonus-unlocked]");
        if (!(locked instanceof HTMLElement) || !(unlocked instanceof HTMLElement)) return;
        try {
          const { data, error } = await actions.premium.sessionStatus({});
          if (error || !data?.active) return;
          locked.hidden = true;
          unlocked.hidden = false;
        } catch {
          /* נשאר נעול */
        }
      };
      void initPremiumBonus();

      window.__nmArticleCleanup = () => {
        cleanups.forEach((cleanup) => cleanup());
        window.clearTimeout(toastTimeout);
      };
    });
  </script>
</Layout>
