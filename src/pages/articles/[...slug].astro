---
import { getCollection, type CollectionEntry } from "astro:content";
import ArticlePage from "../../components/articles/ArticlePage.astro";
import StaticRedirectPage from "../../components/StaticRedirectPage.astro";
import { getCanonicalArticleSlug } from "../../lib/articles";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.flatMap((entry) => {
    const sourceSlug = entry.slug.trim();
    const canonicalSlug = getCanonicalArticleSlug(entry);
    const multiPartSource = sourceSlug.includes("/");
    const multiPartCanonical = canonicalSlug.includes("/");
    const rows: Array<{
      params: { slug: string[] };
      props: { entry?: CollectionEntry<"articles">; destination?: string };
    }> = [];

    if (multiPartCanonical) {
      rows.push({
        params: { slug: canonicalSlug.split("/") },
        props: { entry },
      });
    }

    if (multiPartSource && sourceSlug !== canonicalSlug) {
      rows.push({
        params: { slug: sourceSlug.split("/") },
        props: {
          destination: `/articles/${encodeURIComponent(canonicalSlug)}/`,
        },
      });
    }

    return rows;
  });
}

const { destination, entry } = Astro.props as {
  destination?: string;
  entry?: CollectionEntry<"articles">;
};
---

{
  destination ? (
    <StaticRedirectPage
      to={destination}
      title="מעביר למאמר"
      message="המאמר עבר לכתובת חדשה"
      ctaLabel="למאמר"
    />
  ) : entry ? (
    <ArticlePage entry={entry} />
  ) : null
}
