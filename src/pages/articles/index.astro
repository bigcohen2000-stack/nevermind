---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

type DifficultyKey = "beginner" | "advanced" | "deep";

const difficultyConfig: Record<DifficultyKey, { label: string; tone: string }> = {
  beginner: {
    label: "מתחילים",
    tone: "bg-[#F4FAF4] text-[#166534] border-[#BBF7D0]/70",
  },
  advanced: {
    label: "מתקדמים",
    tone: "bg-[#FFF7ED] text-[#9A3412] border-[#FDBA74]/60",
  },
  deep: {
    label: "חקירה עמוקה",
    tone: "bg-[var(--nm-inverse)] text-[var(--nm-inverse-fg)] border-[color-mix(in_srgb,var(--nm-fg)_22%,transparent)]",
  },
};

const resolveDifficulty = (level: DifficultyKey | undefined, body: string): DifficultyKey => {
  if (level && level in difficultyConfig) return level;

  const wordCount = body.replace(/<[^>]*>/g, " ").split(/\s+/).filter(Boolean).length;
  if (wordCount > 1400) return "deep";
  if (wordCount > 900) return "advanced";
  return "beginner";
};

const articles = (await getCollection("articles", ({ data }) => data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((article) => {
    const difficultyKey = resolveDifficulty(article.data.difficultyLevel as DifficultyKey | undefined, article.body ?? "");
    const difficultyMeta = difficultyConfig[difficultyKey];

    return {
      slug: article.slug,
      title: article.data.title,
      description: article.data.description,
      tags: Array.isArray(article.data.tags) ? article.data.tags : [],
      date: article.data.pubDate,
      transitionId: article.slug.replace(/[^\w-]+/g, "-"),
      difficultyLabel: difficultyMeta.label,
      difficultyTone: difficultyMeta.tone,
    };
  });

const tagSet = new Set<string>();
articles.forEach((article) => article.tags.forEach((tag) => tagSet.add(tag)));
const tags = Array.from(tagSet);
---
<Layout title="מאמרים">
  <section class="space-y-10">
    <header class="space-y-4">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div class="space-y-4 text-right">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">מרכז החקירה</p>
          <h1 class="text-[clamp(2.2rem,1.7rem+2vw,3.2rem)] font-semibold text-[var(--nm-fg)]">
            מאמרים
          </h1>
          <p class="text-[clamp(1.05rem,1rem+0.35vw,1.4rem)] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
            ספריית עומק חיה למי שרוצה פחות רעש, יותר דיוק, וכניסה מסודרת לרעיונות שלא נשארים על פני השטח.
          </p>
        </div>
        <button type="button" data-random-article-trigger class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[var(--nm-tint)] px-5 py-3 text-sm font-semibold text-[var(--nm-accent)] transition hover:bg-[var(--nm-tint-strong)]">
          הפתע אותי עם כיוון אקראי
        </button>
      </div>
    </header>

    <div class="space-y-3">
      <p class="text-right text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">
        אפשר להתחיל מהכול, או להיכנס דרך נושא אחד ברור ולהעמיק ממנו.
      </p>
      <div class="flex flex-wrap gap-3">
      <button type="button" data-filter="all" aria-pressed="true" class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/70 px-4 py-2 text-[clamp(0.85rem,0.82rem+0.2vw,1rem)] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))] transition-colors duration-300 hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color-mix(in_srgb,var(--nm-fg)_22%,transparent)]">הכל</button>
      {tags.map((tag) => (
        <button type="button" data-filter={tag} aria-pressed="false" class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/70 px-4 py-2 text-[clamp(0.85rem,0.82rem+0.2vw,1rem)] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))] transition-colors duration-300 hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color-mix(in_srgb,var(--nm-fg)_22%,transparent)]">{tag}</button>
      ))}
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {articles.map((article) => (
        <a href={`/articles/${article.slug}`} data-article-card data-tags={article.tags.join(",")} class="group flex h-full flex-col justify-between gap-6 rounded-3xl border border-white/70 bg-white/70 p-6 shadow-sm backdrop-blur-md transition-all duration-500 ease-out hover:scale-[1.01] focus-visible:scale-[1.01] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color-mix(in_srgb,var(--nm-fg)_22%,transparent)]">
          <div class="space-y-4">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${article.difficultyTone}`}>{article.difficultyLabel}</span>
              <span class="text-[clamp(0.8rem,0.78rem+0.2vw,0.95rem)] text-[color-mix(in_srgb,var(--nm-fg)_50%,var(--nm-bg))]">{article.date.toLocaleDateString("he-IL")}</span>
            </div>
            <div class="space-y-3">
              <h2 transition:name={`article-${article.transitionId}`} class="text-[clamp(1.3rem,1.1rem+0.6vw,1.7rem)] font-semibold text-[var(--nm-fg)]">{article.title}</h2>
              {article.description && <p class="text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] text-[var(--nm-fg)]/65">{article.description}</p>}
            </div>
          </div>
          {article.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 text-[clamp(0.8rem,0.78rem+0.2vw,0.95rem)] text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">
              {article.tags.map((tag) => (
                <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/70 px-3 py-1">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      const buttons = Array.from(document.querySelectorAll("[data-filter]"));
      const cards = Array.from(document.querySelectorAll("[data-article-card]"));

      const setActive = (active) => {
        buttons.forEach((button) => {
          const isActive = button.dataset.filter === active;
          button.setAttribute("aria-pressed", String(isActive));
          button.classList.toggle("bg-white", isActive);
        });
      };

      const filterCards = (active) => {
        cards.forEach((card) => {
          const cardTags = card.dataset.tags ? card.dataset.tags.split(",") : [];
          const shouldShow = active === "all" || cardTags.includes(active);
          card.classList.toggle("hidden", !shouldShow);
        });
      };

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const active = button.dataset.filter || "all";
          setActive(active);
          filterCards(active);
        });
      });
    });
  </script>
</Layout>



