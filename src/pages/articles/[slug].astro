---
import { getCollection, type CollectionEntry } from "astro:content";
import ArticlePage from "../../components/articles/ArticlePage.astro";
import StaticRedirectPage from "../../components/StaticRedirectPage.astro";
import { getCanonicalArticleSlug } from "../../lib/articles";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  const seen = new Set<string>();

  return articles.flatMap((entry) => {
    const sourceSlug = entry.slug.trim();
    const canonicalSlug = getCanonicalArticleSlug(entry);
    const rows: Array<{
      params: { slug: string };
      props: { entry?: CollectionEntry<"articles">; destination?: string };
    }> = [];

    if (canonicalSlug && seen.has(canonicalSlug) === false) {
      seen.add(canonicalSlug);
      rows.push({
        params: { slug: canonicalSlug },
        props: { entry },
      });
    }

    const sourceIsDifferent = sourceSlug === canonicalSlug ? false : true;
    if (sourceSlug && sourceIsDifferent && seen.has(sourceSlug) === false) {
      seen.add(sourceSlug);
      rows.push({
        params: { slug: sourceSlug },
        props: {
          destination: `/articles/${encodeURIComponent(canonicalSlug)}/`,
        },
      });
    }

    return rows;
  });
}

const { destination, entry } = Astro.props as {
  destination?: string;
  entry?: CollectionEntry<"articles">;
};

const hasDestination = typeof destination === "string" && destination.length > 0;
const hasEntry = entry == null ? false : true;

if (hasDestination === false && hasEntry === false) {
  Astro.response.status = 404;
}
---

{
  hasDestination ? (
    <StaticRedirectPage
      to={String(destination)}
      title="מעביר למאמר"
      message="המאמר עבר לכתובת חדשה"
      ctaLabel="למאמר"
    />
  ) : hasEntry ? (
    <ArticlePage entry={entry as CollectionEntry<"articles">} />
  ) : (
    <StaticRedirectPage
      to="/articles/"
      title="המאמר לא נמצא"
      message="יכול להיות שהכתובת השתנתה. אפשר להמשיך לרשימת המאמרים."
      ctaLabel="למאמרים"
    />
  )
}
