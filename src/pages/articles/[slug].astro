---
import { getCollection } from "astro:content";
import StaticRedirectPage from "../../components/StaticRedirectPage.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.flatMap((entry) => {
    const sourceSlug = entry.slug.trim();
    const canonicalSlug =
      typeof entry.data.slug === "string" && entry.data.slug.trim().length > 0
        ? entry.data.slug.trim()
        : sourceSlug;

    if (!sourceSlug || sourceSlug === canonicalSlug) return [];

    return [
      {
        params: { slug: sourceSlug },
        props: {
          destination: `/articles/${encodeURIComponent(canonicalSlug)}/`,
        },
      },
    ];
  });
}

const { destination } = Astro.props;
---

<StaticRedirectPage
  to={destination}
  title="מעביר למאמר"
  message="המאמר עבר לכתובת חדשה"
  ctaLabel="למאמר"
/>
