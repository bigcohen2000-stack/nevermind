---
import Layout from "../layouts/Layout.astro";
---

<Layout title="האזור האישי" description="כאן אפשר לראות גישה פעילה, מועדפים, הערות אישיות, והיסטוריית קריאה.">
  <section class="mx-auto max-w-5xl space-y-8 px-4 pb-20 text-right text-[var(--nm-fg)]">
    <header class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 px-6 py-8 shadow-[0_20px_60px_rgba(26,26,26,0.05)]">
      <p class="text-sm font-semibold text-[var(--nm-accent)]">האזור האישי</p>
      <h1 class="mt-3 text-[clamp(2rem,1.6rem+1.4vw,3rem)] font-semibold">מקום אחד לרצף אישי.</h1>
      <p class="mt-3 max-w-3xl text-[clamp(1rem,0.96rem+0.2vw,1.1rem)] leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        אם יש גישה פעילה, כל מה ששמרת נשאר כאן. אם עדיין אין, אפשר להצטרף בלי להסתבך.
      </p>
    </header>

    <section data-member-preview-root class="hidden rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[var(--nm-tint)] px-5 py-4 shadow-[0_16px_36px_rgba(212,43,43,0.08)]">
      <div class="flex flex-wrap items-start justify-between gap-4 text-right">
        <div class="space-y-3">
          <div class="space-y-1">
            <p class="text-xs font-semibold tracking-[0.18em] text-[var(--nm-accent)]">תצוגת בדיקה</p>
            <h2 data-member-preview-title class="text-lg font-semibold text-[var(--nm-fg)]">תצוגת חבר מתוך הניהול</h2>
            <p data-member-preview-copy class="max-w-3xl text-sm leading-[1.8] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">המסך הזה מציג בדיקה שקטה של חוויית החבר, בלי לשנות את ההתחברות על המכשיר שלך.</p>
          </div>
          <div class="flex flex-wrap justify-end gap-2 text-xs">
            <span data-member-preview-status class="rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_20%,transparent)] bg-white/80 px-3 py-1.5 font-semibold text-[var(--nm-fg)]">טוען מצב</span>
            <span data-member-preview-meta class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/72 px-3 py-1.5 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">הטלפון יופיע כאן</span>
          </div>
        </div>
        <a href="/me/" class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">לצאת מתצוגה</a>
      </div>
    </section>

    <section data-me-guest class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-8 shadow-[0_18px_42px_rgba(26,26,26,0.04)]">
      <p class="text-sm font-semibold text-[var(--nm-accent)]">הצטרפות לחברים</p>
      <h2 class="mt-3 text-[clamp(1.5rem,1.3rem+0.8vw,2rem)] font-semibold">כאן שומרים רצף, לא רק כניסה חד פעמית.</h2>
      <p class="mt-3 max-w-3xl text-sm leading-[1.8] text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        אם מה שקראת כאן כבר נוגע במשהו אמיתי, אפשר להמשיך עם קוד קיים או לפתוח חודש ראשון במחיר השקה רגוע של 175 ש"ח.
      </p>
      <div class="mt-5 flex flex-wrap justify-end gap-3">
        <a href="/me/unlock/" class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">יש לך קוד אישי</a>
        <a href="/me/unlock/" class="inline-flex min-h-[44px] items-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">בקשה להצטרף לחודש ראשון</a>
        <a href="/services/" class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">לבדוק מסלולים</a>
      </div>
    </section>

    <section data-me-member class="hidden space-y-6">
      <div class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[var(--nm-tint)] p-8 shadow-[0_18px_42px_rgba(212,43,43,0.08)]">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">ברוך הבא</p>
        <h2 class="mt-3 text-[clamp(1.6rem,1.35rem+1vw,2.3rem)] font-semibold" data-me-greeting>ברוך הבא</h2>
        <nav class="mt-4 flex flex-wrap justify-end gap-3 text-sm font-semibold" aria-label="קיצורי אזור אישי">
          <a href="/me/learning/" class="underline underline-offset-4">לוח הלמידה</a>
          <a href="/library/" class="underline underline-offset-4">ספריית תכנים</a>
          <a href="/me/settings/" class="underline underline-offset-4">הגדרות</a>
        </nav>

        <div class="mt-4 grid gap-3 md:grid-cols-3">
          <article class="rounded-[1.3rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-4 py-4">
            <p class="text-xs font-semibold text-[var(--nm-accent)]">טלפון</p>
            <p class="mt-2 text-sm leading-[1.7] text-[var(--nm-fg)]" data-me-phone>לא זמין</p>
          </article>
          <article class="rounded-[1.3rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-4 py-4">
            <p class="text-xs font-semibold text-[var(--nm-accent)]">חברות פעילה עד</p>
            <p class="mt-2 text-sm leading-[1.7] text-[var(--nm-fg)]" data-me-expiry>לא ידוע</p>
          </article>
          <article class="rounded-[1.3rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-4 py-4">
            <p class="text-xs font-semibold text-[var(--nm-accent)]">התחברות אחרונה</p>
            <p class="mt-2 text-sm leading-[1.7] text-[var(--nm-fg)]" data-me-last-login>לא ידוע</p>
          </article>
        </div>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-6 shadow-[0_18px_42px_rgba(26,26,26,0.04)] lg:col-span-1">
          <div class="flex items-center justify-between gap-3">
            <h3 class="text-xl font-semibold">מועדפים</h3>
            <span class="text-xs font-semibold text-[var(--nm-accent)]" data-me-favorites-count>0</span>
          </div>
          <div class="mt-4 space-y-3" data-me-favorites-list></div>
          <p class="mt-3 text-sm leading-[1.7] text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]" data-me-favorites-empty>
            עדיין לא שמרת מאמרים. אפשר להתחיל מהספרייה.
          </p>
        </section>

        <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-6 shadow-[0_18px_42px_rgba(26,26,26,0.04)] lg:col-span-1">
          <div class="flex items-center justify-between gap-3">
            <h3 class="text-xl font-semibold">היסטוריית קריאה</h3>
            <span class="text-xs font-semibold text-[var(--nm-accent)]" data-me-history-count>0</span>
          </div>
          <div class="mt-4 space-y-3" data-me-history-list></div>
          <p class="mt-3 text-sm leading-[1.7] text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]" data-me-history-empty>
            ברגע שתעבור בין עמודים, הרצף יופיע כאן.
          </p>
        </section>

        <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-6 shadow-[0_18px_42px_rgba(26,26,26,0.04)] lg:col-span-1">
          <h3 class="text-xl font-semibold">הערות אישיות</h3>
          <p class="mt-2 text-sm leading-[1.7] text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">
            ההערות נשמרות על המכשיר הזה. הן לא נשלחות לשרת.
          </p>
          <textarea data-me-notes rows="10" class="mt-4 w-full rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-3 text-sm leading-[1.7] text-[var(--nm-fg)]" placeholder="למשל: איפה בדיוק אני מערבב עובדה ופירוש"></textarea>
          <p class="mt-3 text-xs text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]" data-me-notes-status aria-live="polite">עדיין לא נכתבה הערה.</p>
        </section>
      </div>
    </section>
  </section>

  <script is:inline>
    (() => {
      const sessionKey = "nm_club_session";
      const favoritesKey = "nm_favorites";
      const historyKey = "nm_watch_history";
      const notesKey = "nm_personal_notes";

      const readJson = (key) => {
        try {
          const raw = window.localStorage.getItem(key);
          return raw ? JSON.parse(raw) : null;
        } catch {
          return null;
        }
      };

      const formatDate = (value) => {
        const date = new Date(value || "");
        if (Number.isNaN(date.getTime())) return "לא ידוע";
        return date.toLocaleDateString("he-IL", { day: "numeric", month: "long", year: "numeric" });
      };

      const formatDateTime = (value) => {
        const date = new Date(value || "");
        if (Number.isNaN(date.getTime())) return "לא ידוע";
        return date.toLocaleString("he-IL", {
          day: "numeric",
          month: "short",
          year: "numeric",
          hour: "2-digit",
          minute: "2-digit",
        });
      };

      const renderList = (root, items, emptyEl) => {
        if (!(root instanceof HTMLElement) || !(emptyEl instanceof HTMLElement)) return;
        root.innerHTML = "";
        emptyEl.classList.toggle("hidden", items.length > 0);
        items.forEach((item) => {
          const link = document.createElement("a");
          link.href = item.href || "/articles/";
          link.className = "block rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3 transition hover:bg-[var(--nm-tint)]";
          link.innerHTML = `<p class=\"font-semibold text-[var(--nm-fg)]\">${item.title || "ללא כותרת"}</p><p class=\"mt-1 text-sm leading-[1.6] text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]\">${item.meta || ""}</p>`;
          root.appendChild(link);
        });
      };

      const init = () => {
        const guest = document.querySelector("[data-me-guest]");
        const member = document.querySelector("[data-me-member]");
        const session = typeof window.__nmReadClubSession === "function" ? window.__nmReadClubSession() : readJson(sessionKey);

        if (!guest || !member) return;

        if (!session || !session.memberName) {
          guest.classList.remove("hidden");
          member.classList.add("hidden");
          return;
        }

        guest.classList.add("hidden");
        member.classList.remove("hidden");

        const greeting = document.querySelector("[data-me-greeting]");
        const phone = document.querySelector("[data-me-phone]");
        const expiry = document.querySelector("[data-me-expiry]");
        const lastLogin = document.querySelector("[data-me-last-login]");
        if (greeting instanceof HTMLElement) greeting.textContent = `${session.memberName} ברוך הבא`;
        if (phone instanceof HTMLElement) phone.textContent = session.phone || "לא זמין";
        if (expiry instanceof HTMLElement) expiry.textContent = formatDate(session.expiresAt);
        if (lastLogin instanceof HTMLElement) lastLogin.textContent = formatDateTime(session.lastLoginAt);

        const favorites = Array.isArray(readJson(favoritesKey)) ? readJson(favoritesKey) : [];
        const history = Array.isArray(readJson(historyKey)) ? readJson(historyKey) : [];
        const notes = String(window.localStorage.getItem(notesKey) || "");

        const favoritesList = document.querySelector("[data-me-favorites-list]");
        const favoritesEmpty = document.querySelector("[data-me-favorites-empty]");
        const historyList = document.querySelector("[data-me-history-list]");
        const historyEmpty = document.querySelector("[data-me-history-empty]");
        const favoritesCount = document.querySelector("[data-me-favorites-count]");
        const historyCount = document.querySelector("[data-me-history-count]");
        const notesField = document.querySelector("[data-me-notes]");
        const notesStatus = document.querySelector("[data-me-notes-status]");

        renderList(
          favoritesList,
          favorites.map((item) => ({ href: item.href, title: item.title, meta: item.description || "נשמר מתוך הספרייה" })),
          favoritesEmpty
        );
        renderList(
          historyList,
          history.map((item) => ({ href: item.href, title: item.title, meta: item.visitedAt ? formatDateTime(item.visitedAt) : "" })),
          historyEmpty
        );

        if (favoritesCount instanceof HTMLElement) favoritesCount.textContent = String(favorites.length);
        if (historyCount instanceof HTMLElement) historyCount.textContent = String(history.length);

        if (notesField instanceof HTMLTextAreaElement) {
          notesField.value = notes;
          const updateStatus = (value) => {
            if (!(notesStatus instanceof HTMLElement)) return;
            notesStatus.textContent = value.trim() ? "ההערה נשמרה על המכשיר הזה." : "עדיין לא נכתבה הערה.";
          };
          updateStatus(notes);
          notesField.addEventListener("input", () => {
            window.localStorage.setItem(notesKey, notesField.value);
            updateStatus(notesField.value);
          });
        }
      };

      init();
      document.addEventListener("astro:page-load", init);
      window.addEventListener("nm-club-session-changed", init);
      window.addEventListener("nm-favorites-changed", init);
      window.addEventListener("nm-watch-history-changed", init);
      window.addEventListener("storage", init);
    })();
  </script>

  <script>
    import "../scripts/me-preview.js";
  </script>
</Layout>
