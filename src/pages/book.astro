---
import Layout from "../layouts/Layout.astro";
import Schema from "../components/Schema.astro";
import appConfig from "../config/appConfig.json";
import { buildServiceReservationWhatsAppHref, buildWhatsAppHref, findServiceById } from "../lib/services";

const siteUrlSlash = appConfig.site.url.endsWith("/") ? appConfig.site.url : `${appConfig.site.url}/`;
const bookProductSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "NeverMind — קביעת שיחה",
    description: "שלושה צעדים: התאמה קצרה, בחירת מסלול, תיאום בפועל.",
    url: new URL("book/", siteUrlSlash).toString(),
    brand: { "@type": "Brand", name: appConfig.site.name },
    offers: {
      "@type": "Offer",
      priceCurrency: "ILS",
      availability: "https://schema.org/InStock",
      url: new URL("services/", siteUrlSlash).toString(),
    },
  },
];

const phonePerspective = findServiceById("phone-perspective");
const waBook = phonePerspective
  ? buildServiceReservationWhatsAppHref(phonePerspective)
  : buildWhatsAppHref(
      "היי, אני רוצה לקבוע שיחה דרך עמוד הקביעה באתר. מה השלב הבא?"
    );
---

<Layout
  title="קביעת שיחה"
  description="שלושה צעדים ברורים: התאמה קצרה, בחירת מסלול, תיאום בפועל."
>
  <Schema graphs={bookProductSchema} />
  <section class="mx-auto max-w-3xl space-y-10 px-4 py-14 text-right text-[var(--nm-fg)]">
    <header class="space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--nm-accent)]">המרה ישירה</p>
      <h1 class="text-[clamp(2rem,1.5rem+2vw,3rem)] font-semibold leading-tight">קביעת שיחה</h1>
      <p class="text-[clamp(1rem,0.95rem+0.25vw,1.15rem)] leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        כאן אין סיבוב. אתה בוחר איך להמשיך. המחירים והמסלולים מופיעים בעמוד השירותים.
      </p>
    </header>

    <ol class="space-y-6 rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6">
      <li class="flex flex-col gap-2">
        <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--nm-accent)]">שלב 1</span>
        <p class="font-semibold">בדיקת התאמה קצרה</p>
        <p class="text-sm leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
          טופס קצר שמסנן רעש. אם זה לא הזמן הנכון, תקבל כיוון ברור לארכיון.
        </p>
        <a
          href="/intake/"
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center self-start rounded-full bg-[var(--nm-inverse)] px-6 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]"
        >
          לטופס ההתאמה
        </a>
      </li>
      <li class="flex flex-col gap-2 border-t border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pt-6">
        <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--nm-accent)]">שלב 2</span>
        <p class="font-semibold">בחירת מסלול ומחירון</p>
        <p class="text-sm leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
          רואים מה כלול, מה המחיר, ומה קורה אחרי התשלום.
        </p>
        <a
          href="/services/#pricing"
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center self-start rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
        >
          לשירותים ולמחירון
        </a>
      </li>
      <li class="flex flex-col gap-2 border-t border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pt-6">
        <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--nm-accent)]">שלב 3</span>
        <p class="font-semibold">תיאום בוואטסאפ</p>
        <p class="text-sm leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
          אם אתה מעדיף לדבר לפני תשלום, פותחים שיחה כאן.
        </p>
        <a
          href={waBook}
          target="_blank"
          rel="noreferrer"
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center self-start rounded-full bg-[var(--nm-accent)] px-6 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
        >
          פתיחת וואטסאפ
        </a>
      </li>
    </ol>

    <p class="text-xs leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">
      פרטי קשר מהאתר: {appConfig.contact.email} · {appConfig.contact.phoneDisplay}
    </p>
  </section>
</Layout>
