---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import appConfig from "../config/appConfig.json";
import { findServiceById, type FlatService } from "../lib/services";

const archiveSubscription = findServiceById("archive-subscription");
const phonePerspective = findServiceById("phone-perspective");

const fallbackArchiveSubscription = ({
  id: "archive-subscription",
  title: "למידה עצמאית",
  subtitle: "המקום שלך לראות ולהבין",
  description:
    "גישה לכל המאמרים והסרטונים - כולל הפודקאסט המלא. יותר מ-12,000 שעות שפותחות הכל: יחסים, אהבה, פחדים ומה שקורה באמת.",
  price_full: 390,
  action_type: "whatsapp",
  action_text: "אני רוצה להצטרף",
  visible: true,
  badges: ["מנוי הארכיון"],
  features: [],
  stageName: "אזור אישי",
  targetAudience: "מי שרוצה ללמוד בקצב שלו",
} satisfies Partial<FlatService>) as FlatService;

const fallbackPhonePerspective = ({
  id: "phone-perspective",
  title: "שיחת מיקוד 20 דקות",
  subtitle: "שיחה קצרה כדי לראות מה נכון עכשיו",
  description: "מדברים קצר. מבינים מה באמת קורה. נכנסים לצעד הבא בלי בלבול.",
  price_full: 450,
  action_type: "whatsapp",
  action_text: "אני רוצה להתחיל",
  visible: true,
  badges: [],
  features: [],
  stageName: "אזור אישי",
  targetAudience: "מי שצריך בהירות מהירה",
} satisfies Partial<FlatService>) as FlatService;

const archiveCard = archiveSubscription
  ? { ...archiveSubscription, title: "למידה עצמאית", badges: ["מנוי הארכיון"], action_text: "אני רוצה להצטרף" }
  : fallbackArchiveSubscription;
const consultationCard = phonePerspective ?? fallbackPhonePerspective;

const whatsAppNumber =
  import.meta.env.PUBLIC_WHATSAPP_NUMBER ||
  import.meta.env.NEXT_PUBLIC_WHATSAPP_NUMBER ||
  appConfig.contact.whatsAppNumber;
const validCodesRaw =
  import.meta.env.PUBLIC_DASHBOARD_CODES ||
  import.meta.env.NEXT_PUBLIC_DASHBOARD_CODES ||
  "";
---

<Layout title="אזור אישי | NeverMind" description="המקום שלך להיכנס עם קוד אישי ולראות את מה שחשוב לך עכשיו.">
  <section class="mx-auto max-w-6xl space-y-16 px-4 py-14 text-[var(--nm-fg)]">
    <div
      id="unauthorized"
      class="space-y-10 rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-6 py-10 text-right md:px-10"
    >
      <header class="space-y-4">
        <p class="text-sm font-light text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">אזור אישי</p>
        <h1 class="text-[clamp(2.1rem,1.6rem+2.2vw,3.6rem)] font-light leading-tight">המפתח שלך.</h1>
        <p class="text-[clamp(1.05rem,1rem+0.2vw,1.2rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          כאן הכל נהיה פשוט.
        </p>
      </header>

      <ol class="space-y-2 text-[1.03rem] leading-8">
        <li>1. מדברים.</li>
        <li>2. משלמים.</li>
        <li>3. נכנסים.</li>
      </ol>

      <div class="space-y-4">
        <label for="dashboard-code" class="block text-sm font-light text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">
          הקוד האישי שלך
        </label>
        <input
          id="dashboard-code"
          type="password"
          autocomplete="off"
          placeholder="הכנס את הקוד שקיבלת"
          class="w-full rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_16%,transparent)] bg-white px-5 py-3 text-right text-[1rem] outline-none transition focus:border-[var(--nm-accent)]"
        />
        <button
          id="dashboard-enter"
          type="button"
          class="inline-flex min-h-[46px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-8 py-2.5 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
        >
          כניסה
        </button>
        <p id="dashboard-error" class="hidden text-sm text-[var(--nm-accent)]">
          <a
            id="dashboard-wa-link"
            href={`https://wa.me/${String(whatsAppNumber || "").replace(/\D/g, "")}`}
            class="underline underline-offset-4"
          >
            הקוד לא נכון. בוא נדבר בוואטסאפ.
          </a>
        </p>
      </div>

      <div class="space-y-2 border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pt-6 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">
        <p>אתה מתחבר מ-IP: <span id="viewer-ip">בודק...</span></p>
        <p>הקוד אישי. אסור להעביר אותו לאחרים.</p>
      </div>
    </div>

    <div
      id="authorized"
      class="hidden space-y-12 rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-6 py-10 text-right md:px-10"
    >
      <header class="space-y-4">
        <p class="text-sm font-light text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">אזור אישי</p>
        <h2 class="text-[clamp(1.9rem,1.4rem+2vw,3.1rem)] font-light leading-tight">מה יש לך פה.</h2>
      </header>

      <nav aria-label="ניווט אזור אישי">
        <ul class="space-y-3 text-[1.03rem] leading-8">
          <li><a href="/articles/" class="underline underline-offset-4">כל המאמרים -></a></li>
          <li><a href="/simulators/" class="underline underline-offset-4">הסימולטורים -></a></li>
          <li><a href="/dashboard/learning/" class="underline underline-offset-4">לוח הלמידה -></a></li>
          <li><a href="/dashboard/settings/" class="underline underline-offset-4">הגדרות -></a></li>
        </ul>
      </nav>

      <section class="grid gap-6 lg:grid-cols-2">
        <ServiceCard service={archiveCard} />
        <ServiceCard service={consultationCard} />
      </section>

      <button id="dashboard-logout" type="button" class="text-sm underline underline-offset-4">
        יציאה
      </button>
    </div>
  </section>

  <script is:inline define:vars={{ whatsAppNumber, validCodesRaw }}>
    (() => {
      const storageKey = "nm_access_code";
      const unauthorized = document.getElementById("unauthorized");
      const authorized = document.getElementById("authorized");
      const input = document.getElementById("dashboard-code");
      const enterButton = document.getElementById("dashboard-enter");
      const errorLine = document.getElementById("dashboard-error");
      const waLink = document.getElementById("dashboard-wa-link");
      const logout = document.getElementById("dashboard-logout");
      const viewerIp = document.getElementById("viewer-ip");

      const number = String(whatsAppNumber || "").trim();
      const validCodes = String(validCodesRaw || "")
        .split(",")
        .map((c) => c.trim())
        .filter(Boolean);

      const params = new URLSearchParams(window.location.search);
      const returnTo = params.get("returnTo");

      const showAuthorized = (on) => {
        if (!unauthorized || !authorized) return;
        unauthorized.classList.toggle("hidden", on);
        authorized.classList.toggle("hidden", !on);
      };

      const isCodeValid = (value) => {
        const clean = String(value || "").trim();
        if (!clean) return false;
        if (!validCodes.length) return true;
        return validCodes.includes(clean);
      };

      const fetchIp = async () => {
        if (!viewerIp) return;
        try {
          const res = await fetch("https://api.ipify.org?format=json");
          const data = await res.json();
          viewerIp.textContent = data?.ip ? String(data.ip) : "לא זוהה";
        } catch {
          viewerIp.textContent = "לא זוהה";
        }
      };

      const updateWhatsAppLink = () => {
        if (!waLink || !number) return;
        const message = "היי, הקוד לא עובד לי. אפשר לבדוק את זה יחד?";
        waLink.setAttribute("href", `https://wa.me/${number}?text=${encodeURIComponent(message)}`);
      };

      const hasPremiumSession = () => {
        try {
          const raw = localStorage.getItem("nm-premium-access");
          if (!raw) return false;
          const parsed = JSON.parse(raw);
          const expiresAt = Date.parse(String(parsed?.expiresAt || ""));
          return Number.isFinite(expiresAt) && expiresAt > Date.now();
        } catch {
          return false;
        }
      };

      const goReturnPath = () => {
        if (!returnTo) return;
        if (!returnTo.startsWith("/")) return;
        window.location.href = returnTo;
      };

      const existing = localStorage.getItem(storageKey) || "";
      const alreadyAuthorized = isCodeValid(existing) || hasPremiumSession();
      showAuthorized(alreadyAuthorized);
      if (alreadyAuthorized) {
        goReturnPath();
      }

      fetchIp();
      updateWhatsAppLink();

      if (enterButton && input) {
        enterButton.addEventListener("click", () => {
          const code = String(input.value || "").trim();
          if (isCodeValid(code)) {
            localStorage.setItem(storageKey, code);
            if (errorLine) errorLine.classList.add("hidden");
            showAuthorized(true);
            goReturnPath();
            return;
          }
          if (errorLine) errorLine.classList.remove("hidden");
          showAuthorized(false);
        });
      }

      if (logout) {
        logout.addEventListener("click", () => {
          localStorage.removeItem(storageKey);
          localStorage.removeItem("nm-premium-access");
          window.location.reload();
        });
      }
    })();
  </script>
</Layout>
