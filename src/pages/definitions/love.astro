---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="מה זו אהבה באמת? | NeverMind" description="הגדרה קצרה לאהבה.">
  <section class="mx-auto max-w-3xl space-y-4 px-4 py-16 text-right text-[var(--nm-fg)]">
    <h1 class="text-[clamp(1.7rem,1.4rem+1.2vw,2.5rem)] font-light">מה זו אהבה באמת?</h1>
    <p class="leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
      אהבה מתחילה כשרואים את מי שמולך כמו שהוא. בלי לנהל אותו. בלי לפחד לאבד שליטה.
    </p>
  </section>
</Layout>
