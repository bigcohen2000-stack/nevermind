---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="למה אנחנו מפחדים? | NeverMind"
  description="הגדרה קצרה לפחד."
  breadcrumbCurrentLabel="למה אנחנו מפחדים?"
>
  <section class="mx-auto max-w-3xl space-y-4 px-4 py-16 text-right text-[var(--nm-fg)]">
    <h1 class="text-[clamp(1.7rem,1.4rem+1.2vw,2.5rem)] font-light">למה אנחנו מפחדים?</h1>
    <p class="leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
      פחד מופיע כשאנחנו מאמינים לסיפור בלי לבדוק עובדות. ברגע שרואים מה אמיתי ומה פירוש, הפחד נחלש.
    </p>
  </section>
</Layout>
