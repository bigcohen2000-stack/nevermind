---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

type DifficultyKey = "beginner" | "advanced" | "deep";

const difficultyConfig: Record<DifficultyKey, { label: string; tone: string }> = {
  beginner: {
    label: "מתחילים",
    tone: "bg-[#F4FAF4] text-[#166534] border-[#BBF7D0]/70",
  },
  advanced: {
    label: "מתקדמים",
    tone: "bg-[#FFF7ED] text-[#9A3412] border-[#FDBA74]/60",
  },
  deep: {
    label: "חקירה עמוקה",
    tone: "bg-[#1A1A1A] text-[#FAFAF8] border-[#1A1A1A]",
  },
};

const pageTitle = "הספרייה האסורה";
const pageDescription = "אוסף המאמרים של NeverMind שנוגעים בנקודות שמעדיפים לא לגעת בהן: פרות קדושות, רעיונות מקובלים, והנחות שמרגישות בטוחות מדי.";

const resolveDifficulty = (level: DifficultyKey | undefined, body: string): DifficultyKey => {
  if (level && level in difficultyConfig) return level;
  const wordCount = body.replace(/<[^>]*>/g, " ").split(/\s+/).filter(Boolean).length;
  if (wordCount > 1400) return "deep";
  if (wordCount > 900) return "advanced";
  return "beginner";
};

const controversyNeedles = ["אגו", "בחירה", "חופש", "אמונה", "שליטה", "פחד", "זוגיות", "דת", "ביקורת", "פרימיום"];

const allArticles = await getCollection("articles", ({ data }) => data.draft !== true);
const forbiddenArticles = allArticles
  .filter((article) => {
    if (article.data.forbiddenLibrary === true) return true;
    const signal = `${article.data.title} ${article.data.description} ${(article.body ?? "").slice(0, 600)}`;
    return controversyNeedles.some((needle) => signal.includes(needle));
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((article) => {
    const difficultyKey = resolveDifficulty(article.data.difficultyLevel as DifficultyKey | undefined, article.body ?? "");
    const difficultyMeta = difficultyConfig[difficultyKey];

    return {
      slug: article.slug,
      title: article.data.title,
      description: article.data.description,
      tags: Array.isArray(article.data.tags) ? article.data.tags : [],
      difficultyLabel: difficultyMeta.label,
      difficultyTone: difficultyMeta.tone,
      dateLabel: article.data.pubDate.toLocaleDateString("he-IL"),
    };
  })
  .slice(0, 12);
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-6xl space-y-10 px-4 pb-20 text-right text-[#1A1A1A]">
    <header class="max-w-4xl space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-[#D42B2B]">פרות קדושות</p>
      <h1 class="text-[clamp(2.2rem,1.7rem+2vw,3.4rem)] font-semibold">הספרייה האסורה</h1>
      <p class="text-[clamp(1rem,0.95rem+0.35vw,1.15rem)] leading-8 text-[#1A1A1A]/68">
        כאן מרוכזים המאמרים שהולכים נגד הכיוון המוכר. לא כדי להיות פרובוקטיבי, אלא כדי לפרק רעיון מקובל בדיוק במקום שבו הוא מרגיש הכי בטוח.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
      {forbiddenArticles.map((article) => (
        <a
          href={`/articles/${article.slug}/`}
          class="group flex h-full flex-col justify-between gap-5 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/84 p-6 shadow-[0_18px_55px_rgba(26,26,26,0.05)] transition hover:translate-y-[-2px] hover:bg-white"
        >
          <div class="space-y-3">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${article.difficultyTone}`}>{article.difficultyLabel}</span>
              <span class="text-xs text-[#1A1A1A]/52">{article.dateLabel}</span>
            </div>
            <h2 class="text-2xl font-semibold text-[#1A1A1A]">{article.title}</h2>
            <p class="text-sm leading-7 text-[#1A1A1A]/68">{article.description}</p>
          </div>
          <div class="space-y-3">
            <div class="flex flex-wrap justify-end gap-2 text-xs text-[#1A1A1A]/55">
              {article.tags.map((tag) => (
                <span class="rounded-full border border-[#1A1A1A]/10 bg-[#FAFAF8] px-3 py-1">{tag}</span>
              ))}
            </div>
            <span class="inline-flex items-center justify-end gap-2 text-sm font-semibold text-[#D42B2B]">
              לקריאה ששוברת מוסכמה
              <span aria-hidden="true">←</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

