---
import Layout from "../../layouts/Layout.astro";
import { microPosts } from "../../data/microPosts";
---

<Layout
  title="שאלות לוגיות קצרות"
  description="מיקרו-פוסטים של NeverMind: שאלות קצרות, תשובות חדות, וקישורים להעמקה כשצריך יותר ממשפט אחד."
>
  <section class="mx-auto max-w-5xl space-y-10 px-4 pb-20 text-right text-[var(--nm-fg)]">
    <header class="space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-[var(--nm-accent)]">מיקרו־פוסטים</p>
      <h1 class="text-[clamp(2.2rem,1.8rem+1.6vw,3.4rem)] font-semibold">שאלות לוגיות קצרות</h1>
      <p class="max-w-3xl text-[clamp(1rem,0.96rem+0.3vw,1.15rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
        לא כל שאלה צריכה מאמר שלם. לפעמים מספיק פירוק אחד מדויק כדי לשנות כיוון, לנקות רעש, או להבין איפה בדיוק התחלת לבלבל בין עובדה לפירוש.
      </p>
    </header>

    <div class="grid gap-5">
      {microPosts.map((post) => (
        <article id={post.slug} class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/84 p-6 shadow-[0_18px_55px_rgba(26,26,26,0.05)]">
          <div class="space-y-3">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h2 class="text-[1.35rem] font-semibold text-[var(--nm-fg)]">{post.question}</h2>
              {post.tag && <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-3 py-1 text-xs font-semibold text-[var(--nm-fg)]/62">{post.tag}</span>}
            </div>
            <p class="text-[1rem] leading-8 text-[var(--nm-fg)]/74">{post.answer}</p>
            {post.relatedHref && post.relatedLabel && (
              <a href={post.relatedHref} class="inline-flex text-sm font-semibold text-[var(--nm-accent)] transition hover:opacity-75">
                {post.relatedLabel}
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

