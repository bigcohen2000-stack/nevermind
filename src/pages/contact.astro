---
import Layout from "../layouts/Layout.astro";
import FormAntispamFields from "../components/FormAntispamFields.astro";
import FormHcaptcha from "../components/FormHcaptcha.astro";
import { FloatingInput } from "../components/ui/FloatingInput";
import appConfig from "../config/appConfig.json";
import { buildWhatsAppHref } from "../lib/services";
import { MAIL_DELIVERY_ENABLED } from "../lib/mail-delivery";

const waGeneral = buildWhatsAppHref("שלום, יש לי שאלה דרך עמוד יצירת הקשר של NeverMind.");
const tel = appConfig.contact.phoneTel?.trim() || "";
const formsEnabled = MAIL_DELIVERY_ENABLED;
---

<Layout title="יצירת קשר" description="אם משהו באתר פתח שאלה, אפשר לכתוב כאן. אפשר גם לעבור ישר לוואטסאפ או למייל.">
  <section class="mx-auto max-w-3xl space-y-12 px-4 py-14 text-right text-[var(--nm-fg)]">
    <header class="space-y-4">
      <p class="text-sm font-semibold text-[var(--nm-accent)]">יצירת קשר</p>
      <h1 class="text-[clamp(2rem,1.5rem+2vw,3rem)] font-semibold leading-[1.15]">אם יש שאלה, אפשר לכתוב אותה פשוט.</h1>
      <p class="text-[clamp(1rem,0.95rem+0.25vw,1.15rem)] leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        לא צריך ניסוח מושלם. מספיק לתאר מה קורה, מה לא ברור, או מה אתה מנסה לבדוק.
      </p>
    </header>

    <aside class="rounded-2xl border border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] bg-[var(--nm-tint)] p-5 text-right">
      <p class="text-sm font-semibold text-[var(--nm-fg)]">רוצה ערוץ מהיר יותר?</p>
      <p class="mt-2 text-sm leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
        אפשר לעבור ישר לוואטסאפ, לטלפון, או למייל. הטופס כאן מתאים למי שרוצה לנסח רגע בשקט.
      </p>
      <a href="/intake/" class="mt-4 inline-flex min-h-[48px] items-center rounded-full bg-[var(--nm-inverse)] px-6 py-3 text-xl font-bold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">
        בואו נבדוק יחד
      </a>
    </aside>

    <nav aria-label="ערוצי קשר מהירים" class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end">
      <a href={waGeneral} target="_blank" rel="noreferrer" class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">
        וואטסאפ
      </a>
      {tel ? (
        <a href={`tel:${tel.replace(/\s/g, "")}`} class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          טלפון: {appConfig.contact.phoneDisplay}
        </a>
      ) : null}
      <a href={`mailto:${appConfig.contact.email}`} class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
        מייל
      </a>
    </nav>

    <section aria-labelledby="contact-form-heading" class="space-y-4">
      <h2 id="contact-form-heading" class="text-xl font-semibold">לשלוח שאלה קצרה</h2>
      <p class="text-sm leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">
        השמירה המקומית פועלת אוטומטית. גם אם תצא מהעמוד, מה שכתבת נשאר על המכשיר שלך.
      </p>

      <form id="contact-form" data-nm-antispam class="space-y-4 rounded-3xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/85 p-6" action="/api/forms/submit" method="POST">
        <input type="hidden" name="subject" value="פנייה מעמוד יצירת קשר | NeverMind" />
        <input type="hidden" name="page" value="contact" />
        <input type="text" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <FormAntispamFields />

        <FloatingInput client:load id="contact-name" name="name" label="שם" required dir="rtl" autoComplete="name" />
        <FloatingInput client:load id="contact-email" name="email" label="אימייל" type="email" required dir="rtl" autoComplete="email" />
        <FloatingInput client:load id="contact-message" name="message" label="מה אתה רוצה לבדוק" multiline rows={5} required dir="rtl" autoComplete="off" />

        <FormHcaptcha idSuffix="contact" />

        <button type="submit" disabled={!formsEnabled} aria-disabled={!formsEnabled} class="w-full rounded-full bg-[var(--nm-inverse)] px-6 py-4 text-xl font-bold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-accent)] disabled:cursor-not-allowed disabled:opacity-55">
          יש לי שאלה
        </button>
        <p data-contact-status aria-live="polite" class="text-center text-sm text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))] opacity-0 transition-opacity"></p>
        {!formsEnabled ? <p class="text-center text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">שליחה במייל ממתינה לחיבור שרת המייל. אפשר לעבור לוואטסאפ או למייל הישיר.</p> : null}
      </form>
    </section>
  </section>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      if (window.__nmContactCleanup) window.__nmContactCleanup();

      const contactForm = document.querySelector("#contact-form");
      const status = document.querySelector("[data-contact-status]");
      const submitButton = contactForm?.querySelector('[type="submit"]');
      if (!(contactForm instanceof HTMLFormElement)) return;

      if (typeof window.__nmStampFormAntispam === "function") {
        window.__nmStampFormAntispam(contactForm);
      }

      let unmountHcaptcha = () => {};
      if (typeof window.__nmMountHcaptcha === "function") {
        unmountHcaptcha = window.__nmMountHcaptcha(contactForm);
      }

      const showStatus = (message) => {
        if (!(status instanceof HTMLElement)) return;
        status.textContent = message;
        status.classList.add("opacity-100");
      };

      const clearLoading = () => {
        if (submitButton instanceof HTMLElement) {
          window.__nmClearButtonLoading?.(submitButton);
        }
      };

      const getHcaptchaToken = () => {
        const tokenInput = contactForm.querySelector('input[name="h-captcha-response"]');
        return tokenInput instanceof HTMLInputElement ? tokenInput.value.trim() : "";
      };

      const hasHcaptcha = () => Boolean(contactForm.querySelector("[data-nm-hcaptcha-wrap]"));
      const onSubmit = async (event) => {
        event.preventDefault();
        if (submitButton instanceof HTMLElement) {
          window.__nmSetButtonLoading?.(submitButton, "מזקק את המנגנון...");
        }

        const fd = new FormData(contactForm);
        const msg = String(fd.get("message") || "").trim();
        const read = window.__nmReadAntispamFromForm;
        const validate = window.__nmValidateAntispamFields;
        if (typeof read === "function" && typeof validate === "function") {
          const as = read(contactForm);
          const check = validate({ ...as, messageTexts: [msg] });
          if (!check.ok) {
            showStatus(check.userMessage);
            clearLoading();
            return;
          }
        }

        const token = getHcaptchaToken();
        if (hasHcaptcha() && !token) {
          showStatus("נא להשלים את האימות לפני השליחה.");
          clearLoading();
          return;
        }
        if (token) {
          fd.set("h-captcha-response", token);
        } else {
          fd.delete("h-captcha-response");
        }

        try {
          const res = await fetch(contactForm.action, { method: "POST", body: fd });
          const payload = await res.json().catch(() => null);
          if (res.ok && payload?.success === true) {
            contactForm.reset();
            showStatus("השאלה נקלטה.");
            window.__nmClearConnectivityIssue?.();
            window.__nmHapticSuccess?.();
            window.__nmAnnounce?.("השאלה נקלטה");
          } else {
            const errorCode = String(payload?.error || "").toLowerCase();
            const message = typeof payload?.message === "string" && payload.message.trim()
              ? payload.message.trim()
              : errorCode.includes("hcaptcha") || errorCode.includes("mandatory")
                ? "צריך להשלים את האימות לפני השליחה."
                : errorCode.includes("missing_mail_delivery_config")
                  ? "שרת המייל עדיין לא הוגדר בפריסה."
                  : "השרת לא אישר קבלה. אפשר לנסות שוב או פשוט לשלוח לנו הודעה בוואטסאפ.";
            showStatus(message);
            window.__nmReportConnectivityIssue?.(message);
          }
        } catch {
          const message = "השרת לא אישר קבלה. אפשר לנסות שוב או פשוט לשלוח לנו הודעה בוואטסאפ.";
          showStatus(message);
          window.__nmReportConnectivityIssue?.(message);
        } finally {
          clearLoading();
        }
      };

      contactForm.addEventListener("submit", onSubmit);

      window.__nmContactCleanup = () => {
        unmountHcaptcha();
        clearLoading();
        contactForm.removeEventListener("submit", onSubmit);
      };
    });
  </script>
</Layout>
