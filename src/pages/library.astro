---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import type { DifficultyKey } from "../components/ArticleCard.astro";

const resolveDifficulty = (level: DifficultyKey | undefined, body: string): DifficultyKey => {
  if (level && (level === "beginner" || level === "advanced" || level === "deep")) return level;
  const wordCount = body.replace(/<[^>]*>/g, " ").split(/\s+/).filter(Boolean).length;
  if (wordCount > 1400) return "deep";
  if (wordCount > 900) return "advanced";
  return "beginner";
};

const articles = (await getCollection("articles", ({ data }) => data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((article) => {
    const body = article.body ?? "";
    const difficultyKey = resolveDifficulty(article.data.difficultyLevel as DifficultyKey | undefined, body);
    const plain = body.replace(/<[^>]*>/g, " ");
    const wordCount = plain.split(/\s+/).filter(Boolean).length;
    const readingMinutes = Math.max(1, Math.ceil(wordCount / 200));
    const freshnessSource = article.data.updatedDate ?? article.data.pubDate;
    const freshnessIso = freshnessSource.toISOString().slice(0, 10);

    return {
      slug: article.slug,
      title: article.data.title,
      description: article.data.description,
      tags: Array.isArray(article.data.tags) ? article.data.tags : [],
      transitionId: article.slug.replace(/[^\w-]+/g, "-"),
      difficultyKey,
      readingMinutes,
      isPremium: Boolean(article.data.isPremium),
      contentFreshnessIso: freshnessIso,
      contentFreshnessIsUpdate: Boolean(article.data.updatedDate),
    };
  });

const tagSet = new Set<string>();
articles.forEach((article) => article.tags.forEach((tag) => tagSet.add(tag)));
const tags = Array.from(tagSet).sort((left, right) => left.localeCompare(right, "he"));
---

<Layout title="ספרייה מובנית" description="מאמרים מסודרים לפי נושא, עומק, וסוג גישה. בוחרים מסנן אחד, ורואים מה באמת מתאים עכשיו.">
  <section id="library-filter-root" class="mx-auto max-w-6xl space-y-8 px-4 pb-20 text-right" data-library-root>
    <header class="space-y-4">
      <p class="text-sm font-semibold text-[var(--nm-accent)]">ספרייה</p>
      <h1 class="text-[clamp(2.2rem,1.8rem+1.8vw,3.4rem)] font-semibold text-[var(--nm-fg)]">ספרייה מובנית</h1>
      <p class="max-w-3xl text-[clamp(1rem,0.96rem+0.25vw,1.15rem)] leading-[1.7] text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        כאן לא צריך לנחש מאיפה להתחיל. בוחרים תגית, עומק, או סוג גישה. המערכת מסננת מיד.
      </p>
      <a
        href="/articles/"
        class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white/90 px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] hover:bg-white"
      >
        לעמוד המאמרים המלא
      </a>
    </header>

    <section class="space-y-5 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 p-5 shadow-[0_20px_60px_rgba(26,26,26,0.05)] md:p-6">
      <div class="space-y-3">
        <p class="text-sm font-semibold text-[var(--nm-fg)]">סינון לפי תגית</p>
        <div class="flex flex-wrap justify-end gap-2" role="group" aria-label="סינון לפי תגית">
          <button type="button" data-lib-tag="all" aria-pressed="true" class="nm-filter-chip is-active">הכל</button>
          {tags.map((tag) => (
            <button type="button" data-lib-tag={tag} aria-pressed="false" class="nm-filter-chip">{tag}</button>
          ))}
        </div>
      </div>

      <div class="space-y-3">
        <p class="text-sm font-semibold text-[var(--nm-fg)]">סינון לפי עומק</p>
        <div class="flex flex-wrap justify-end gap-2" role="group" aria-label="סינון לפי עומק">
          <button type="button" data-lib-diff="all" aria-pressed="true" class="nm-filter-chip is-active">הכל</button>
          <button type="button" data-lib-diff="beginner" aria-pressed="false" class="nm-filter-chip">מתחילים</button>
          <button type="button" data-lib-diff="advanced" aria-pressed="false" class="nm-filter-chip">מתקדמים</button>
          <button type="button" data-lib-diff="deep" aria-pressed="false" class="nm-filter-chip">עמוק</button>
        </div>
      </div>

      <div class="space-y-3">
        <p class="text-sm font-semibold text-[var(--nm-fg)]">סינון לפי גישה</p>
        <div class="flex flex-wrap justify-end gap-2" role="group" aria-label="סינון לפי גישה">
          <button type="button" data-lib-prem="all" aria-pressed="true" class="nm-filter-chip is-active">הכל</button>
          <button type="button" data-lib-prem="free" aria-pressed="false" class="nm-filter-chip">פתוח</button>
          <button type="button" data-lib-prem="premium" aria-pressed="false" class="nm-filter-chip">מועדון</button>
        </div>
      </div>

      <p data-library-feedback class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]" aria-live="polite">
        מוצגים כל המאמרים. אפשר לצמצם לפי מה שמעסיק אותך עכשיו.
      </p>
    </section>

    <p
      id="library-empty"
      class="hidden rounded-[1.6rem] border border-dashed border-[color-mix(in_srgb,var(--nm-fg)_14%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_96%,transparent)] px-5 py-8 text-center text-sm leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]"
      role="status"
    >
      לא מצאנו מאמרים לשילוב הזה. אולי ננסה לשאול את ההפך, או נרחיב מסנן אחד.
    </p>

    <div id="library-grid" data-library-grid class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
      {articles.map((article) => (
        <ArticleCard
          slug={article.slug}
          title={article.title}
          description={article.description}
          tagsCsv={article.tags.join(",")}
          transitionId={article.transitionId}
          difficultyKey={article.difficultyKey}
          readingMinutes={article.readingMinutes}
          isPremium={article.isPremium}
          contentFreshnessIso={article.contentFreshnessIso}
          contentFreshnessIsUpdate={article.contentFreshnessIsUpdate}
        />
      ))}
    </div>
  </section>

  <style>
    .nm-filter-chip {
      min-height: 44px;
      border-radius: 999px;
      border: 1px solid color-mix(in srgb, var(--nm-fg) 12%, transparent);
      background: color-mix(in srgb, white 88%, var(--nm-bg-canvas));
      padding-inline: 1rem;
      padding-block: 0.55rem;
      font-size: 0.95rem;
      font-weight: 600;
      line-height: 1.6;
      color: color-mix(in srgb, var(--nm-fg) 72%, var(--nm-bg));
      transition:
        transform 180ms ease,
        background-color 180ms ease,
        border-color 180ms ease,
        color 180ms ease,
        box-shadow 180ms ease;
    }

    .nm-filter-chip:hover,
    .nm-filter-chip:focus-visible {
      border-color: color-mix(in srgb, var(--nm-accent) 28%, transparent);
      background: white;
      color: var(--nm-fg);
    }

    .nm-filter-chip:active {
      transform: scale(0.98);
    }

    .nm-filter-chip.is-active {
      border-color: color-mix(in srgb, var(--nm-accent) 34%, transparent);
      background: color-mix(in srgb, var(--nm-accent) 9%, white);
      color: var(--nm-accent);
      box-shadow: 0 12px 24px color-mix(in srgb, var(--nm-accent) 10%, transparent);
    }

    [data-library-grid].is-filtering > * {
      transition: opacity 180ms ease, transform 180ms ease;
    }

    [data-library-grid].is-filtering [data-article-card] {
      opacity: 0.42;
      transform: translateY(3px);
    }

    [data-library-grid] [data-article-card].is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script is:inline>
    (function () {
      const state = { tag: "all", diff: "all", prem: "all" };

      const setActive = (root, group, activeVal) => {
        root.querySelectorAll(`[data-lib-${group}]`).forEach((node) => {
          if (!(node instanceof HTMLButtonElement)) return;
          const current = node.getAttribute(`data-lib-${group}`) || "";
          const isActive = current === activeVal;
          node.setAttribute("aria-pressed", String(isActive));
          node.classList.toggle("is-active", isActive);
        });
      };

      const buildFeedback = (visible) => {
        const parts = [];
        parts.push(state.tag === "all" ? "כל התגיות" : `תגית: ${state.tag}`);
        parts.push(state.diff === "all" ? "כל רמות העומק" : `עומק: ${state.diff}`);
        parts.push(
          state.prem === "all" ? "כל סוגי הגישה" : state.prem === "free" ? "גישה פתוחה" : "גישה למועדון"
        );
        return visible > 0 ? `נמצאו ${visible} תוצאות. ${parts.join(" · ")}.` : "לא מצאנו את מה שחיפשת. אולי ננסה לשאול את ההפך?";
      };

      const apply = (root) => {
        const grid = root.querySelector("[data-library-grid]");
        const cards = Array.from(root.querySelectorAll("[data-article-card]"));
        const emptyEl = root.querySelector("#library-empty");
        const feedbackEl = root.querySelector("[data-library-feedback]");
        if (!(grid instanceof HTMLElement)) return;

        grid.classList.add("is-filtering");
        let visible = 0;

        window.setTimeout(() => {
          cards.forEach((card) => {
            if (!(card instanceof HTMLElement)) return;
            const cardTags = (card.dataset.tags || "")
              .split(",")
              .map((tag) => tag.trim())
              .filter(Boolean);
            const matchesTag = state.tag === "all" || cardTags.includes(state.tag);
            const matchesDiff = state.diff === "all" || card.dataset.difficulty === state.diff;
            const isPremium = card.dataset.premium === "true";
            const matchesPrem =
              state.prem === "all" ||
              (state.prem === "free" && !isPremium) ||
              (state.prem === "premium" && isPremium);
            const show = matchesTag && matchesDiff && matchesPrem;
            card.classList.toggle("hidden", !show);
            card.classList.toggle("is-visible", show);
            if (show) visible += 1;
          });

          grid.classList.remove("is-filtering");
          if (emptyEl instanceof HTMLElement) {
            emptyEl.classList.toggle("hidden", visible > 0);
          }
          if (feedbackEl instanceof HTMLElement) {
            feedbackEl.textContent = buildFeedback(visible);
          }
        }, 90);
      };

      const init = () => {
        const root = document.getElementById("library-filter-root");
        if (!(root instanceof HTMLElement)) return;

        const onClick = (event) => {
          const target = event.target instanceof Element ? event.target : null;
          if (!target) return;

          const tagBtn = target.closest("[data-lib-tag]");
          if (tagBtn instanceof HTMLButtonElement) {
            state.tag = tagBtn.getAttribute("data-lib-tag") || "all";
            setActive(root, "tag", state.tag);
            window.__nmHapticLight?.();
            apply(root);
            return;
          }

          const diffBtn = target.closest("[data-lib-diff]");
          if (diffBtn instanceof HTMLButtonElement) {
            state.diff = diffBtn.getAttribute("data-lib-diff") || "all";
            setActive(root, "diff", state.diff);
            window.__nmHapticLight?.();
            apply(root);
            return;
          }

          const premBtn = target.closest("[data-lib-prem]");
          if (premBtn instanceof HTMLButtonElement) {
            state.prem = premBtn.getAttribute("data-lib-prem") || "all";
            setActive(root, "prem", state.prem);
            window.__nmHapticLight?.();
            apply(root);
          }
        };

        if (root.dataset.libraryBound === "true") {
          apply(root);
          return;
        }

        root.dataset.libraryBound = "true";
        root.addEventListener("click", onClick);
        apply(root);
      };

      init();
      document.addEventListener("astro:page-load", init);
    })();
  </script>
</Layout>
