---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import FormAntispamFields from "../components/FormAntispamFields.astro";
import FormHcaptcha from "../components/FormHcaptcha.astro";
import SubscribeBanner from "../components/SubscribeBanner.astro";
import { FloatingInput } from "../components/ui/FloatingInput";
import { MAIL_DELIVERY_ENABLED } from "../lib/mail-delivery";

const whatsappGroupUrl = "https://chat.whatsapp.com/C5M4j0ZCUPa3D3A4zCrCrL";
const allArticles = await getCollection("articles", ({ data }) => data.draft !== true);
const sortedArticles = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const carouselPool = [...sortedArticles].sort(() => Math.random() - 0.5).slice(0, 12);

const formsEnabled = MAIL_DELIVERY_ENABLED;

const siteUpdates = [
  { label: "קביעת שיחה", href: "/book/" },
  { label: "יצירת קשר", href: "/contact/" },
  { label: "שאלות ותשובות", href: "/about/#nm-about-faq" },
  { label: "ספרייה מובנית", href: "/library/" },
  { label: "הגדרות מחדש", href: "/glossary/" },
];
---

<Layout title="מה קורה כאן עכשיו" description="עדכון שקט על מה פתוח עכשיו באתר, ומה אפשר לעשות אם יש שאלה שלא נסגרה.">
  <section class="mx-auto flex min-h-[42vh] max-w-3xl flex-col items-center justify-center gap-6 px-4 text-center">
    <div class="flex items-center justify-center gap-3">
      <h1 class="nm-breathe text-[clamp(2.2rem,1.7rem+2.2vw,3.4rem)] font-semibold text-[var(--nm-fg)]">
        מה קורה כאן עכשיו
      </h1>
      <span aria-hidden="true" class="nm-status-dot"></span>
    </div>
    <p class="text-[clamp(1rem,0.95rem+0.35vw,1.25rem)] leading-[1.75] text-[var(--nm-fg)]/68">
      בלי רעש מיותר. רק לבדוק מה פתוח, מה זמין, ולאן כדאי להמשיך מכאן.
    </p>
    <a href={whatsappGroupUrl} target="_blank" rel="noreferrer" class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/80 px-6 py-3 text-[clamp(0.95rem,0.9rem+0.3vw,1.1rem)] text-[var(--nm-fg)] transition hover:bg-white">
      לעדכונים שקטים בוואטסאפ
    </a>
  </section>

  <section class="mx-auto mt-[clamp(2.5rem,5vw,4rem)] max-w-6xl px-4" aria-labelledby="now-updates">
    <h2 id="now-updates" class="mb-4 text-right text-[clamp(1.05rem,0.98rem+0.5vw,1.25rem)] font-semibold text-[var(--nm-fg)]">
      מה פתוח עכשיו באתר
    </h2>
    <ul class="flex flex-wrap justify-end gap-2" role="list">
      {siteUpdates.map((item) => (
        <li>
          <a href={item.href} class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] hover:bg-[var(--nm-tint)]">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="mx-auto mt-[clamp(2rem,4vw,3rem)] max-w-6xl px-4 pb-4" aria-labelledby="now-carousel">
    <div class="mb-3 flex items-end justify-between gap-4">
      <h2 id="now-carousel" class="text-right text-[clamp(1.15rem,1rem+0.5vw,1.35rem)] font-semibold text-[var(--nm-fg)]">
        מהארכיון עכשיו
      </h2>
      <a href="/articles/" class="text-sm font-semibold text-[var(--nm-accent)]">לכל המאמרים</a>
    </div>
    <p class="mb-4 text-right text-sm leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]">
      גלילה קצרה, כניסה מהירה, ובחירה לפי מה שבאמת מושך אותך עכשיו.
    </p>
    <div class="nm-now-carousel flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" tabindex="0" aria-roledescription="carousel">
      {carouselPool.map((article) => (
        <a href={`/articles/${article.slug}/`} class="w-[min(100%,18rem)] shrink-0 snap-start rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)]/95 p-4 text-right shadow-sm transition hover:border-[color-mix(in_srgb,var(--nm-accent)_30%,transparent)]">
          <p class="text-xs font-semibold text-[var(--nm-accent)]">מאמר</p>
          <h3 class="mt-2 line-clamp-2 text-base font-semibold text-[var(--nm-fg)]">{article.data.title}</h3>
          <p class="mt-2 line-clamp-2 text-sm leading-[1.7] text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">{article.data.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto mt-[clamp(2rem,4vw,3rem)] max-w-2xl space-y-6 px-4">
    <h2 class="text-center text-[clamp(1.4rem,1.15rem+1vw,2rem)] font-semibold text-[var(--nm-fg)]">
      אפשר גם להשאיר הודעה
    </h2>
    <form id="contact-form" data-contact-form data-nm-antispam class="space-y-4 rounded-3xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/80 p-6" action="/api/forms/submit" method="POST">
      <input type="hidden" name="subject" value="פנייה מעמוד מה קורה כאן עכשיו" />
      <input type="text" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <FormAntispamFields />
      <FloatingInput client:load id="name" name="name" label="שם" required dir="rtl" />
      <FloatingInput client:load id="email" name="email" label="אימייל" type="email" required dir="rtl" />
      <FloatingInput client:load id="message" name="message" label="מה אתה רוצה לבדוק" multiline rows={4} required dir="rtl" />
      <FormHcaptcha idSuffix="now" />
      <button type="submit" disabled={!formsEnabled} aria-disabled={!formsEnabled} class="w-full rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-6 py-4 text-xl font-bold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)] disabled:cursor-not-allowed disabled:opacity-55">
        לשלוח
      </button>
      <p data-form-status aria-live="polite" class="text-center text-[clamp(0.85rem,0.8rem+0.2vw,1rem)] text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))] opacity-0 transition-opacity duration-300"></p>
      {!formsEnabled ? <p class="text-center text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">שליחה במייל ממתינה לחיבור שרת המייל. אפשר להמשיך לוואטסאפ או ליצירת קשר.</p> : null}
    </form>
  </section>

  <div class="mt-[clamp(3rem,6vw,5rem)]">
    <SubscribeBanner />
  </div>

  <style>
    @keyframes nmBreathe {
      0%,
      100% { transform: scale(1); opacity: 0.75; }
      50% { transform: scale(1.03); opacity: 1; }
    }

    @keyframes nmPulseDot {
      0%,
      100% { transform: scale(1); opacity: 0.4; }
      50% { transform: scale(1.4); opacity: 0.9; }
    }

    .nm-breathe { animation: nmBreathe 6s ease-in-out infinite; }
    .nm-status-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--nm-fg);
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--nm-fg) 12%, transparent);
      animation: nmPulseDot 2.8s ease-in-out infinite;
    }
  </style>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      if (window.__nmNowFormCleanup) window.__nmNowFormCleanup();

      const form = document.querySelector("[data-contact-form]");
      const contactForm = document.querySelector("#contact-form");
      const status = document.querySelector("[data-form-status]");
      const submitButton = form?.querySelector('[type="submit"]');
      if (!form || !(contactForm instanceof HTMLFormElement)) return;

      if (typeof window.__nmStampFormAntispam === "function") {
        window.__nmStampFormAntispam(contactForm);
      }

      let unmountHcaptcha = () => {};
      if (typeof window.__nmMountHcaptcha === "function") {
        unmountHcaptcha = window.__nmMountHcaptcha(contactForm);
      }

      const showStatus = (message) => {
        if (!(status instanceof HTMLElement)) return;
        status.textContent = message;
        status.classList.add("opacity-100");
      };

      const clearLoading = () => {
        if (submitButton instanceof HTMLElement) {
          window.__nmClearButtonLoading?.(submitButton);
        }
      };

      const getHcaptchaToken = () => {
        const tokenInput = contactForm.querySelector('input[name="h-captcha-response"]');
        return tokenInput instanceof HTMLInputElement ? tokenInput.value.trim() : "";
      };

      const hasHcaptcha = () => Boolean(contactForm.querySelector("[data-nm-hcaptcha-wrap]"));
      const onSubmit = async (event) => {
        event.preventDefault();
        if (submitButton instanceof HTMLElement) {
          window.__nmSetButtonLoading?.(submitButton, "מזקק את המנגנון...");
        }

        const formData = new FormData(form);
        const msg = String(formData.get("message") || "").trim();
        const read = window.__nmReadAntispamFromForm;
        const validate = window.__nmValidateAntispamFields;
        if (typeof read === "function" && typeof validate === "function") {
          const as = read(contactForm);
          const check = validate({ ...as, messageTexts: [msg] });
          if (!check.ok) {
            showStatus(check.userMessage);
            clearLoading();
            return;
          }
        }

        const token = getHcaptchaToken();
        if (hasHcaptcha() && !token) {
          showStatus("נא להשלים את האימות לפני השליחה.");
          clearLoading();
          return;
        }
        if (token) {
          formData.set("h-captcha-response", token);
        } else {
          formData.delete("h-captcha-response");
        }

        try {
          const response = await fetch(contactForm.action, { method: "POST", body: formData });
          const payload = await response.json().catch(() => null);
          if (response.ok && payload?.success === true) {
            form.reset();
            showStatus("השאלה נקלטה. נחזור אליך בהקדם.");
            window.__nmClearConnectivityIssue?.();
            window.__nmHapticSuccess?.();
            window.__nmAnnounce?.("השאלה נקלטה");
          } else {
            const errorCode = String(payload?.error || "").toLowerCase();
            const message = typeof payload?.message === "string" && payload.message.trim()
              ? payload.message.trim()
              : errorCode.includes("hcaptcha") || errorCode.includes("mandatory")
                ? "צריך להשלים את האימות לפני השליחה."
                : errorCode.includes("missing_mail_delivery_config")
                  ? "שרת המייל עדיין לא הוגדר בפריסה."
                  : "השרת לא אישר קבלה. אפשר לנסות שוב או פשוט לשלוח לנו הודעה בוואטסאפ.";
            showStatus(message);
            window.__nmReportConnectivityIssue?.(message);
          }
        } catch {
          const message = "השרת לא אישר קבלה. אפשר לנסות שוב או פשוט לשלוח לנו הודעה בוואטסאפ.";
          showStatus(message);
          window.__nmReportConnectivityIssue?.(message);
        } finally {
          clearLoading();
        }
      };

      form.addEventListener("submit", onSubmit);

      window.__nmNowFormCleanup = () => {
        unmountHcaptcha();
        clearLoading();
        form.removeEventListener("submit", onSubmit);
      };
    });
  </script>
</Layout>
