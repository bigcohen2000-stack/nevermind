---
import Layout from "../layouts/Layout.astro";
import SubscribeBanner from "../components/SubscribeBanner.astro";

const whatsappGroupUrl = "https://chat.whatsapp.com/C5M4j0ZCUPa3D3A4zCrCrL";
const web3formsKey = "94b32b6c-7590-4ac6-b8b4-1bc73dd2e5c8";
---
<Layout title="юф фюІс ыЇтҐ?" description="ЇтҐ їіш їь чщсхЇ ючуї">
  <section class="mx-auto flex min-h-[70vh] max-w-3xl flex-col items-center justify-center gap-6 text-center">
    <div class="flex items-center justify-center gap-3">
      <h1 class="nm-breathe text-[clamp(2.2rem,1.7rem+2.2vw,3.4rem)] font-semibold text-[#1A1A1A]">
        юф фюІс ыЇтҐ?
      </h1>
      <span aria-hidden="true" class="nm-status-dot"></span>
    </div>
    <p class="text-[clamp(1rem,0.95rem+0.35vw,1.3rem)] text-[#1A1A1A]/65">
      ыюф Ёїщюх·, сьщ ЇҐї, сьщ юрює. рЄїЇ Єїхш ьфщх· ыря ЇтҐ.
    </p>
    <a
      href={whatsappGroupUrl}
      target="_blank"
      rel="noreferrer"
      class="rounded-full border border-[#1A1A1A]/10 bg-white/70 px-6 py-3 text-[clamp(0.95rem,0.9rem+0.3vw,1.1rem)] text-[#1A1A1A]/80 transition-colors duration-300 hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#1A1A1A]/20"
    >
      ьфІшЇЄх· ьҐуыхЁщ NeverMind
    </a>
  </section>

  <section class="mx-auto mt-[clamp(3rem,6vw,5rem)] max-w-2xl space-y-6">
    <h2 class="text-center text-[clamp(1.4rem,1.15rem+1vw,2rem)] font-semibold text-[#1A1A1A]">
      рЄїЇ тэ ьфїрщЇ фхуҐф
    </h2>
    <form
      data-contact-form
      class="space-y-4 rounded-3xl border border-[#1A1A1A]/10 bg-white/70 p-6"
      action="https://api.web3forms.com/submit"
      method="POST"
    >
      <input type="hidden" name="access_key" value={web3formsKey} />
      <input type="hidden" name="subject" value="ЄЁщщф ю-NeverMind" />
      <input
        type="text"
        name="botcheck"
        class="hidden"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />
      <div class="space-y-2 text-right">
        <label class="text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] text-[#1A1A1A]/70" for="name">
          їэ юьр
        </label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="w-full rounded-2xl border border-[#1A1A1A]/20 bg-white/80 px-4 py-3 text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] text-[#1A1A1A] outline-none focus-visible:ring-2 focus-visible:ring-[#1A1A1A]/20"
        />
      </div>
      <div class="space-y-2 text-right">
        <label class="text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] text-[#1A1A1A]/70" for="email">
          рщющщь
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full rounded-2xl border border-[#1A1A1A]/20 bg-white/80 px-4 py-3 text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] text-[#1A1A1A] outline-none focus-visible:ring-2 focus-visible:ring-[#1A1A1A]/20"
        />
      </div>
      <div class="space-y-2 text-right">
        <label class="text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] text-[#1A1A1A]/70" for="message">
          фхуҐф
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="w-full rounded-2xl border border-[#1A1A1A]/20 bg-white/80 px-4 py-3 text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] text-[#1A1A1A] outline-none focus-visible:ring-2 focus-visible:ring-[#1A1A1A]/20"
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-[clamp(0.95rem,0.9rem+0.3vw,1.1rem)] text-[#1A1A1A]/80 transition-colors duration-300 hover:bg-white/90"
      >
        їьщчф
      </button>
      <p
        data-form-status
        aria-live="polite"
        class="text-center text-[clamp(0.85rem,0.8rem+0.2vw,1rem)] text-[#1A1A1A]/60 opacity-0 transition-opacity duration-300"
      >
        ·хуф, ффхуҐф ҐсЇф.
      </p>
    </form>
  </section>

  <div class="mt-[clamp(3rem,6vw,5rem)]">
    <SubscribeBanner />
  </div>

  <style>
    @keyframes nmBreathe {
      0%,
      100% {
        transform: scale(1);
        opacity: 0.75;
      }
      50% {
        transform: scale(1.03);
        opacity: 1;
      }
    }

    @keyframes nmPulseDot {
      0%,
      100% {
        transform: scale(1);
        opacity: 0.4;
      }
      50% {
        transform: scale(1.4);
        opacity: 0.9;
      }
    }

    .nm-breathe {
      animation: nmBreathe 6s ease-in-out infinite;
    }

    .nm-status-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: #1a1a1a;
      box-shadow: 0 0 0 6px rgba(26, 26, 26, 0.12);
      animation: nmPulseDot 2.8s ease-in-out infinite;
    }
  </style>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      if (window.__nmNowFormCleanup) {
        window.__nmNowFormCleanup();
      }

      const form = document.querySelector("[data-contact-form]");
      const status = document.querySelector("[data-form-status]");

      if (!form) return;

      const onSubmit = async (event) => {
        event.preventDefault();
        const formData = new FormData(form);

        try {
          const response = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            body: formData,
          });

          if (response.ok) {
            form.reset();
            if (status) {
              status.textContent = "·хуф, ффхуҐф ҐсЇф.";
              status.classList.add("opacity-100");
            }
          } else if (status) {
            status.textContent = "юїфх фї·сї, Ёёф їхс.";
            status.classList.add("opacity-100");
          }
        } catch {
          if (status) {
            status.textContent = "юїфх фї·сї, Ёёф їхс.";
            status.classList.add("opacity-100");
          }
        }
      };

      form.addEventListener("submit", onSubmit);

      window.__nmNowFormCleanup = () => {
        form.removeEventListener("submit", onSubmit);
      };
    });
  </script>
</Layout>
