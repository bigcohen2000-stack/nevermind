---
import Layout from "../../layouts/Layout.astro";

const pageTitle = "כניסה לניהול";
const pageDescription = "הכניסה הישנה בוטלה. הניהול נפתח דרך Cloudflare Access וממשיך אל /dashboard/.";
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <section class="mx-auto max-w-2xl space-y-4 px-4 py-16 text-right text-[var(--nm-fg)]">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">גישה לניהול</p>
    <h1 class="text-[clamp(2rem,1.6rem+1vw,2.7rem)] font-semibold">הכניסה הישנה בוטלה</h1>
    <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
      אזור הניהול כבר לא עובד עם קוד מקומי בדפדפן. הכניסה עוברת דרך Cloudflare Access וממשיכה אל הדשבורד התפעולי.
    </p>
    <div class="flex flex-wrap justify-end gap-3">
      <a
        href="/dashboard/"
        class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]"
      >
        להמשך אל הדשבורד
      </a>
      <a
        href="/dashboard/#access"
        class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
      >
        בדיקת גישה והרשאות
      </a>
    </div>
  </section>
  <script is:inline>
    location.replace("/dashboard/");
  </script>
</Layout>
