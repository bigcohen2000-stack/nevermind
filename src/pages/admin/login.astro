---
import Layout from "../../layouts/Layout.astro";

const pageTitle = "גישת ניהול";
const pageDescription = "הגישה לניהול מתבצעת דרך Cloudflare Access.";
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <section class="mx-auto flex min-h-[70vh] max-w-2xl items-center px-4 py-16 text-right text-[var(--nm-fg)]">
    <div class="w-full rounded-[28px] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-[0_24px_70px_rgba(26,26,26,0.05)]">
      <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">מנהל בלבד</p>
      <h1 class="mt-3 text-[clamp(2rem,1.6rem+1vw,2.8rem)] font-semibold">הגישה לניהול מתבצעת דרך Cloudflare Access</h1>
      <p class="mt-4 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
        אין כאן מסך כניסה רגיל. אם המייל שלך מורשה ב־Access, רענון או מעבר לניהול יחזירו אותך ישר למסכים הפנימיים.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/admin/"
          class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]"
        >
          לעבור לניהול
        </a>
        <a
          href="/cdn-cgi/access/logout"
          class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
        >
          להתנתק מ־Access
        </a>
      </div>
    </div>
  </section>
</Layout>
