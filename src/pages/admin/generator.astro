        if (copyAiPackBtn instanceof HTMLButtonElement) copyAiPackBtn.disabled = false;
        if (copyAiShortBtn instanceof HTMLButtonElement) copyAiShortBtn.disabled = false;
      }

      if (runQaBtn instanceof HTMLButtonElement) {
        runQaBtn.addEventListener("click", () => renderSrtQa(out instanceof HTMLTextAreaElement ? out.value : ""));
      }

      function readImagePackOpts() {
        const imageTopic =
          imgPromptTopicEl instanceof HTMLTextAreaElement ? imgPromptTopicEl.value.trim() : "";
        const imageType =
          imgPromptTypeEl instanceof HTMLSelectElement ? imgPromptTypeEl.value || "minimal" : "minimal";
        return { imageTopic, imageType };
      }

      if (copyAiPackBtn instanceof HTMLButtonElement) {
        copyAiPackBtn.addEventListener("click", async () => {
          const v = out instanceof HTMLTextAreaElement ? out.value.trim() : "";
          if (!v || !window.__nmBuildNeverMindMegaPrompt || !window.__nmCopyLargeText) return;
          const { imageTopic, imageType } = readImagePackOpts();
          const promptText = window.__nmBuildNeverMindMegaPrompt(v, {
            source: "srt",
            imageTopic,
            imageType,
          });
          const ok = await window.__nmCopyLargeText(promptText);
          if (statusEl) {
            statusEl.textContent = ok
              ? "חבילת AI הועתקה (מאמר + תמונה + פרסום)."
              : "ההעתקה נכשלה — נסה לייצא MDX לקובץ ולהדביק ל-AI מהקובץ.";
          }
        });
      }

      if (copyAiShortBtn instanceof HTMLButtonElement) {
        copyAiShortBtn.addEventListener("click", async () => {
          const v = out instanceof HTMLTextAreaElement ? out.value.trim() : "";
          if (!v || !window.__nmBuildNeverMindShortPrompt || !window.__nmCopyLargeText) return;
          const promptText = window.__nmBuildNeverMindShortPrompt(v, { source: "srt" });
          const ok = await window.__nmCopyLargeText(promptText);
          if (statusEl) {
            statusEl.textContent = ok
              ? "פרומפט קצר הועתק ללוח."
              : "ההעתקה נכשלה — נסה לייצא MDX לקובץ ולהדביק ל-AI מהקובץ.";
          }
        });
      }

      fileInput.addEventListener("change", () => {
        const f = fileInput.files && fileInput.files[0];
        if (!f) {
          srtTextCache = "";
          if (fileLabel) fileLabel.textContent = "לא נבחר קובץ";
          if (handoffBtn instanceof HTMLButtonElement) handoffBtn.disabled = true;
          return;
        }
        if (handoffBtn instanceof HTMLButtonElement) handoffBtn.disabled = true;
        if (fileLabel) fileLabel.textContent = f.name;
        const reader = new FileReader();
        reader.onload = () => {
          srtTextCache = String(reader.result || "");
        };
        reader.readAsText(f, "UTF-8");
      });

      function parseSRT(srtText) {
        const blocks = srtText.trim().replace(/\r\n/g, "\n").split(/\n\n+/);
        return blocks
          .map((block) => {
            const lines = block
              .trim()
              .split("\n")
              .map((l) => l.trim())
              .filter(Boolean);
            if (lines.length < 2) return null;
            let i = 0;
            if (/^\d+$/.test(lines[0])) i = 1;
            const timeLine = lines[i];
            if (!timeLine || !timeLine.includes("-->")) return null;
            const parts = timeLine.split("-->").map((s) => s.trim());
            const start = parts[0] || "";
            const endPart = parts[1] || "";
            const end = endPart.split(/\s+/)[0] || endPart;
            const text = lines
              .slice(i + 1)
              .join(" ")
              .replace(/<[^>]+>/g, "")
              .trim();
            const index = i > 0 ? parseInt(lines[0], 10) : 0;
            return { index, start, end, text };
          })
          .filter((b) => b && b.text);
      }

      function srtTimeToSeconds(t) {
        const s = String(t).replace(",", ".").trim();
        const m = s.match(/^(\d+):(\d+):(\d+)(?:\.(\d+))?$/);
        if (!m) return 0;
        const h = +m[1];
        const mn = +m[2];
        const sec = +m[3];
        const frac = m[4] ? Number(`0.${m[4]}`) : 0;
        return h * 3600 + mn * 60 + sec + frac;
      }

      function extractChapters(entries) {
        if (!entries.length) return [];
        const chapters = [];
        const interval = 300;
        let nextMark = 0;
        for (const e of entries) {
          const t = srtTimeToSeconds(e.start);
          if (t >= nextMark) {
            const sum = e.text.slice(0, 80) + (e.text.length > 80 ? "…" : "");
            chapters.push({ timestamp: e.start, summary: sum });
            nextMark += interval;
          }
        }
        if (chapters.length === 0 && entries[0]) {
          chapters.push({
            timestamp: entries[0].start,
            summary: entries[0].text.slice(0, 80) + (entries[0].text.length > 80 ? "…" : ""),
          });
        }
        return chapters;
      }

      function extractVideoSummaryPoints(entries) {
        const substantial = entries.filter((e) => e.text.length >= 25);
        const pool = substantial.length ? substantial : entries;
        if (!pool.length) {
          return [
            "נקודה ראשונה מהתמלול — להשלים לפי AI",
            "נקודה שנייה — להשלים",
            "נקודה שלישית — להשלים",
          ];
        }
        const n = Math.min(5, Math.max(3, pool.length >= 3 ? 4 : pool.length));
        const acc = [];
        const step = Math.max(1, Math.floor(pool.length / n));
        for (let i = 0; i < n && acc.length < 5; i += 1) {
          const idx = Math.min(pool.length - 1, i * step);
          const raw = pool[idx].text.replace(/\s+/g, " ").trim();
          acc.push(raw.length > 220 ? `${raw.slice(0, 217)}…` : raw);
        }
        return [...new Set(acc)].slice(0, 5);
      }

      function transcriptParagraphs(entries) {
        const paras = [];
        let buf = [];
        let prevEnd = -999;
        for (const e of entries) {
          const startSec = srtTimeToSeconds(e.start);
          if (buf.length && startSec - prevEnd > 3) {
            paras.push(buf.join(" "));
            buf = [];
          }
          buf.push(e.text);
          prevEnd = srtTimeToSeconds(e.end);
        }
        if (buf.length) paras.push(buf.join(" "));
        return paras.filter(Boolean);
      }

      function escapeYamlScalar(s) {
        const t = String(s ?? "").trim();
        if (!t) return '""';
        return `"${t.replace(/\\/g, "\\\\").replace(/"/g, '\\"')}"`;
      }

      function oneLineHeading(s) {
        return String(s || "")
          .replace(/\s+/g, " ")
          .replace(/^#+\s*/, "")
          .trim()
          .slice(0, 90) || "כותרת ביניים מהתמלול";
      }

      function buildMDXFromTranscript(params) {
        const {
          youtubeId,
          title,
          description,
          isPremium,
          difficultyLevel,
          workflowStatus,
          points,
          paras,
          chapters,
          entries,
          revealMode = "full",
        } = params;
        const today = new Date().toISOString().slice(0, 10);
        const vidPointsJsx = `[${points.map((p) => JSON.stringify(p)).join(", ")}]`;
        const openPara = paras[0] || entries[0]?.text || "פסקת פתיחה — להשלים מהתמלול.";
        const midStart = Math.floor(paras.length * 0.35);
        const mid2 = Math.floor(paras.length * 0.65);
        const body1 = paras[midStart] || openPara;
        const body2 = paras[mid2] || body1;
        const fullReveal = paras.join("\n\n");
        const revealNote =
          "\n\n---\n\n*[שאר התמלול המלא: בקובץ ה-SRT המקורי או דרך «העתק פרומפט ל-AI» — לא חובה לפרסם את כל הטקסט כאן.]*";
        let revealBody = fullReveal;
        let revealTitle = "תמלול מלא";
        if (revealMode === "compact") {
          const maxChars = 4000;
          if (fullReveal.length > maxChars) {
            const cut = fullReveal.slice(0, maxChars);
            const lastSpace = cut.lastIndexOf(" ");
            revealBody =
              (lastSpace > maxChars * 0.85 ? cut.slice(0, lastSpace) : cut) +
              "\n\n…" +
              revealNote;
            revealTitle = "תמלול (מקוצר)";
          }
        } else if (revealMode === "minimal") {
          const few = paras.slice(0, 3).filter(Boolean).join("\n\n");
          revealBody = (few || fullReveal.slice(0, 800)) + revealNote;
          revealTitle = "תמלול — תצוגה מקדימה";
        }
        const h2a = oneLineHeading(chapters[1]?.summary ? `המשך: ${chapters[1].summary}` : "כותרת ביניים ראשונה — נגזר מהתמלול");
        const h2b = oneLineHeading(chapters[2]?.summary ? `המשך: ${chapters[2].summary}` : "כותרת ביניים שנייה — נגזר מהתמלול");

        const reflectYaml = `reflectionQuestions:
  - ${escapeYamlScalar(`מה מתוך "${title}" נוגע בך הכי ישירות עכשיו?`)}
  - ${escapeYamlScalar("איזו התנגדות עולה בך כשאתה קורא את זה?")}
  - ${escapeYamlScalar("מה צעד קטן אחד אפשרי היום — בלי הבטחות מיותרות?")}`;

        const faqYaml = `faq:
  - question: ${escapeYamlScalar("שאלה נפוצה ראשונה — להתאים לתוכן")}
    answer: ${escapeYamlScalar("תשובה קצרה — להשלים לפי המאמר.")}
  - question: ${escapeYamlScalar("שאלה נפוצה שנייה — להתאים לתוכן")}
    answer: ${escapeYamlScalar("תשובה קצרה — להשלים.")}
  - question: ${escapeYamlScalar("שאלה נפוצה שלישית — להתאים לתוכן")}
    answer: ${escapeYamlScalar("תשובה קצרה — להשלים.")}`;

        return `---
title: ${escapeYamlScalar(title)}
description: ${escapeYamlScalar(description)}
bottomLine: ""
pubDate: ${today}
author: ${escapeYamlScalar("השם לא משנה")}
tags: []
image: "/og.jpg"
youtubeId: ${escapeYamlScalar(youtubeId)}
videoSummaryPoints:
${points.map((p) => `  - ${escapeYamlScalar(p)}`).join("\n")}
isPremium: ${isPremium ? "true" : "false"}
draft: true
workflowStatus: ${workflowStatus}
difficultyLevel: ${difficultyLevel}
${reflectYaml}
${faqYaml}
forbiddenLibrary: false
relatedConcepts: []
---

${openPara}

<VideoPlayer youtubeId={${JSON.stringify(youtubeId)}} title={${JSON.stringify(title)}} videoSummaryPoints={${vidPointsJsx}} />

<RevealInsight title={${JSON.stringify(revealTitle)}}>
${revealBody}
</RevealInsight>

## ${h2a}

${body1}

<SkepticBox title="ההתנגדות המרכזית — להשלים לפי AI">
כאן תשובה ישירה להתנגדות — טיוטה להרחבה ב־Claude/ChatGPT.
</SkepticBox>

## ${h2b}

${body2}

<ConceptCallout term="המושג הכי קשה — להשלים">
הסבר פשוט — טיוטה להרחבה ב־AI.
</ConceptCallout>

<InquiryBox title="שאלה שמכריחה לעצור — להתאים לתוכן ולתמלול" />

<WhatsAppButton />
`;
      }

      buildBtn.addEventListener("click", async () => {
        if (handoffBtn instanceof HTMLButtonElement) handoffBtn.disabled = true;
        const yt = (ytInput && ytInput.value ? ytInput.value : "").trim();
        if (!/^[a-zA-Z0-9_-]{11}$/.test(yt)) {
          if (statusEl) statusEl.textContent = "youtubeId חייב להיות בדיוק 11 תווים (אותיות באנגלית, מספרים, _ או -).";
          return;
        }
        let text = srtTextCache;
        const f = fileInput.files && fileInput.files[0];
        if (!text.trim() && f) {
          try {
            text = await f.text();
            srtTextCache = text;
          } catch {
            if (statusEl) statusEl.textContent = "לא ניתן לקרוא את הקובץ.";
            return;
          }
        }
        if (!text.trim()) {
          if (statusEl) statusEl.textContent = "בחר קובץ .srt תקין.";
          return;
        }
        const entries = parseSRT(text);
        if (!entries.length) {
          if (statusEl) statusEl.textContent = "לא נמצאו כתוביות בקובץ. ודא פורמט SRT.";
          return;
        }
        const topic = (topicInput && topicInput.value ? topicInput.value : "").trim();
        const merged = entries
          .map((e) => e.text)
          .join(" ")
          .replace(/\s+/g, " ")
          .trim();
        const title =
          topic ||
          (merged.slice(0, 72) + (merged.length > 72 ? "…" : "")) ||
          `מאמר וידאו ${yt}`;
        const description =
          (merged.slice(0, 155) + (merged.length > 155 ? "…" : "")) || "תיאור קצר מהתמלול — להשלים לפי AI.";
        const points = extractVideoSummaryPoints(entries);
        const chapters = extractChapters(entries);
        const paras = transcriptParagraphs(entries);
        const revealMode =
          revealModeEl && revealModeEl.value && ["full", "compact", "minimal"].includes(revealModeEl.value)
            ? revealModeEl.value
            : "full";
        const mdx = buildMDXFromTranscript({
          entries,
          youtubeId: yt,
          title,
          description,
          isPremium: !!(prem && prem.checked),
          difficultyLevel: (diff && diff.value) || "advanced",
          workflowStatus: (wf && wf.value) || "writing",
          points,
          paras,
          chapters,
          revealMode,
        });
        out.value = mdx;
        copyBtn.disabled = false;
        exportBtn.disabled = false;
        if (handoffBtn instanceof HTMLButtonElement) handoffBtn.disabled = false;
        const splitMdx = mdx.match(/^---\r?\n[\s\S]*?\r?\n---\r?\n([\s\S]*)$/);
        const bodyOnly = splitMdx ? String(splitMdx[1] || "").replace(/^\r?\n/, "") : "";
        window.__nmSrtHandoff = {
          title,
          description,
          youtubeId: yt,
          body: bodyOnly,
          fullMdx: mdx,
        };
        let statusMsg = `נוצר MDX מתוך ${entries.length} כתוביות.`;
        if (description.length < 80) {
          statusMsg += " שקול להאריך את התיאור ל־80+ תווים לפני פרסום (לפי QA).";
        }
        if (title.length < 20) {
          statusMsg += " הכותרת קצרה — מומלץ לחדד ל־20+ תווים.";
        }
        if (statusEl) statusEl.textContent = statusMsg;
        renderSrtQa(mdx);
      });

      copyBtn.addEventListener("click", async () => {
        const v = out instanceof HTMLTextAreaElement ? out.value.trim() : "";
        if (!v) return;
        const ok = window.__nmCopyLargeText ? await window.__nmCopyLargeText(v) : false;
        if (statusEl) {
          statusEl.textContent = ok
            ? "MDX הועתק ללוח."
            : "ההעתקה נכשלה — לחץ «ייצא קובץ» או Ctrl+A בתיבת הפלט והעתק ידנית.";
        }
      });

      exportBtn.addEventListener("click", () => {
        const v = out instanceof HTMLTextAreaElement ? out.value.trim() : "";
        if (!v) return;
        const yt = (ytInput && ytInput.value ? ytInput.value : "article").trim() || "article";
        try {
          const blob = new Blob([`${v}\n`], { type: "text/markdown;charset=utf-8" });
          const href = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = href;
          a.download = `transcript-${yt}.mdx`;
          a.rel = "noopener";
          document.body.appendChild(a);
          a.click();
          a.remove();
          URL.revokeObjectURL(href);
          if (statusEl) statusEl.textContent = "הקובץ ירד. אם לא נפתח חלון — בדוק חסימת הורדות בדפדפן.";
        } catch {
          if (statusEl) statusEl.textContent = "ייצוא נכשל — נסה דפדפן אחר או העתקה ידנית מהתיבה.";
        }
      });
    });
  </script>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      function buildImagePrompt(opts) {
        const topic = opts.topic || "the article theme";
        const type = opts.type || "minimal";
        const base = [
          "Minimalist 3D render, pure white background #f8fafc,",
          "studio lighting, sharp shadows.",
          "Brand colors: deep red #D42B2B as accent,",
          "near-black #000000 for shadows, off-white #f8fafc background.",
          "No text. No humans. No logos. No clutter.",
          "Aspect ratio 16:9. Ultra clean, architectural.",
        ].join("\n");
        const typeMap = {
          object: `Single object that metaphorically represents: ${topic}`,
          abstract: `Abstract geometric form suggesting: ${topic}`,
          landscape: `Minimal landscape metaphor for: ${topic}`,
          minimal: `Single pure shape representing: ${topic}`,
        };
        const head = typeMap[type] || typeMap.minimal;
        return `${head}\n${base}`;
      }

      const topicEl = document.getElementById("img-prompt-topic");
      const typeEl = document.getElementById("img-prompt-type");
      const buildBtn = document.getElementById("img-prompt-build");
      const outEl = document.getElementById("img-prompt-output");
      const copyBtn = document.getElementById("img-prompt-copy");
      if (!topicEl || !typeEl || !buildBtn || !outEl || !copyBtn) return;

      buildBtn.addEventListener("click", () => {
        const topic = topicEl.value.trim() || "the article theme";
        const type = typeEl.value || "minimal";
        outEl.value = buildImagePrompt({ topic, type });
        copyBtn.disabled = false;
      });

      copyBtn.addEventListener("click", async () => {
        const v = outEl.value.trim();
        if (!v) return;
        const ok = window.__nmCopyLargeText ? await window.__nmCopyLargeText(v) : false;
        copyBtn.textContent = ok ? "הועתק" : "ההעתקה נכשלה";
        window.setTimeout(() => {
          copyBtn.textContent = "העתק פרומפט";
        }, 1200);
      });
    });
  </script>
</Layout>







































































