  <script is:inline define:vars={{ githubFolderBase, githubRepoLabel }}>
    document.addEventListener("astro:page-load", () => {
      const postTitle = document.getElementById("postTitle");
      const postSlug = document.getElementById("postSlug");
      const postDescription = document.getElementById("postDescription");
      const postTags = document.getElementById("postTags");
      const postWorkflowStatus = document.getElementById("postWorkflowStatus");
      const postContent = document.getElementById("postContent");
      const generatorPremium = document.getElementById("is-premium");
      const videoUrlInput = document.getElementById("video-url");
      const validationBox = document.getElementById("validationBox");
      const errorList = document.getElementById("errorList");
      const publishStatusText = document.getElementById("publishStatusText");
      const copyMdxButton = document.getElementById("copyMdx");
      const injectIntoSandboxButton = document.getElementById("injectIntoSandbox");
      const exportMdxFileButton = document.getElementById("export-mdx-file");
      const openGithubButton = document.getElementById("open-github");
      const previewInput = document.getElementById("preview-mdx");
      const renderPreviewButton = document.getElementById("render-preview");
      const helperButtons = Array.from(document.querySelectorAll("[data-helper-insert]"));

      if (!(postTitle instanceof HTMLInputElement)) return;
      if (!(postSlug instanceof HTMLInputElement)) return;
      if (!(postDescription instanceof HTMLInputElement)) return;
      if (!(postTags instanceof HTMLInputElement)) return;
      if (!(postWorkflowStatus instanceof HTMLSelectElement)) return;
      if (!(postContent instanceof HTMLTextAreaElement)) return;
      if (!(generatorPremium instanceof HTMLInputElement)) return;
      if (!(videoUrlInput instanceof HTMLInputElement)) return;
      if (!(validationBox instanceof HTMLElement)) return;
      if (!(errorList instanceof HTMLElement)) return;
      if (!(publishStatusText instanceof HTMLElement)) return;
      if (!(copyMdxButton instanceof HTMLButtonElement)) return;
      if (!(injectIntoSandboxButton instanceof HTMLButtonElement)) return;
      if (!(exportMdxFileButton instanceof HTMLButtonElement)) return;
      if (!(openGithubButton instanceof HTMLButtonElement)) return;
      if (!(previewInput instanceof HTMLTextAreaElement)) return;
      if (!(renderPreviewButton instanceof HTMLButtonElement)) return;

      /** Keep in sync with `src/utils/textCleaner.ts` */
      function cleanHumanTouch(text) {
        if (!text) return text;
        return text
          .replace(/\u2014/g, "-")
          .replace(/\u2013/g, "-")
          .replace(/\u201c/g, '"')
          .replace(/\u201d/g, '"')
          .replace(/\u2018/g, "'")
          .replace(/\u2019/g, "'")
          .replace(/\u2026/g, "...");
      }

      const repoFolderBase = githubFolderBase;
      const MAX_SAFE_BYTES = 800_000;
      const today = new Date().toISOString().slice(0, 10);

      const extractYoutubeId = (value) => {
        const source = String(value || "").trim();
        if (!source) return "";
        if (/^[a-zA-Z0-9_-]{11}$/.test(source)) return source;
        try {
          const url = new URL(source);
          const host = url.hostname.replace(/^www\./, "");
          if (host === "youtu.be") {
            return url.pathname.split("/").filter(Boolean)[0] || "";
          }
          if (host.endsWith("youtube.com")) {
            if (url.searchParams.get("v")) return url.searchParams.get("v") || "";
            const parts = url.pathname.split("/").filter(Boolean);
            if (parts[0] === "embed" || parts[0] === "shorts") {
              return parts[1] || "";
            }
          }
        } catch {
          return "";
        }
        return "";
      };

      const generateSlug = (value) => {
        const ascii = String(value || "")
          .toLowerCase()
          .normalize("NFKD")
          .replace(/[^\x00-\x7F]/g, "")
          .replace(/['"`]/g, "")
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "");
        return ascii || "new-article";
      };

      // Keep the same behavior as src/lib/services.ts:validateSlug for client-side guard.
      const validateSlugInput = (slug, title) => {
        const trimmedSlug = String(slug || "").trim();
        const trimmedTitle = String(title || "").trim();
        const hebrewOnlyTitle = Boolean(trimmedTitle) && /^[\u0590-\u05FF\s\-.,'"!?()]+$/.test(trimmedTitle);
        const hasHebrew = /[\u0590-\u05FF]/.test(trimmedTitle);
        const hasLatin = /[A-Za-z]/.test(trimmedTitle);

        if (!trimmedSlug) {
          if (hebrewOnlyTitle) {
            return {
              valid: false,
              error: "כותרת בעברית מחייבת slug באנגלית לפני ייצוא",
            };
          }
          const suggested = generateSlug(trimmedTitle);
          if (hasHebrew && hasLatin && suggested && suggested !== "new-article") {
            return {
              valid: false,
              error:
                "הכותרת כוללת עברית - ה-Slug האוטומטי חלקי. נא להזין Slug ידני באנגלית שמתאר את נושא המאמר",
            };
          }
          if (suggested && suggested !== "new-article") {
            return { valid: true, suggested };
          }
          return { valid: true };
        }

        if (!/^[a-z0-9-]+$/.test(trimmedSlug)) {
          return {
            valid: false,
            error: "Slug חייב להיות באנגלית קטנה, מספרים ומקפים בלבד",
          };
        }

        return { valid: true };
      };

      const buildDescription = () => {
        const existing = postDescription.value.trim();
        if (existing) return existing;
        const title = postTitle.value.trim();
        if (!title) return "";
        return `${title} בלי ערפל, עם מבנה חד, ברור ומוכן לפרסום.`.slice(0, 160);
      };

      const parseTags = () => {
        const source = postTags.value.trim();
        if (!source) return ["בהירות"];
        return source
          .split(/[\n,]/)
          .map((tag) => tag.trim())
          .filter(Boolean);
      };

      const getWorkflowMeta = () => {
        const workflowStatus = postWorkflowStatus.value || "writing";
        return {
          workflowStatus,
          draft: workflowStatus === "published" ? "false" : "true",
          label:
            workflowStatus === "review"
              ? "מוכן לבדיקה"
              : workflowStatus === "ready"
                ? "מוכן לפרסום"
                : workflowStatus === "published"
                  ? "פורסם"
                  : "בכתיבה",
        };
      };

      const cleanFrontmatterObject = (obj) =>
        Object.fromEntries(
          Object.entries(obj).filter(([, value]) => {
            if (value == null) return false;
            if (typeof value === "string" && value.trim() === "") return false;
            return true;
          })
        );

      const serializeFrontmatterValue = (value) => {
        if (Array.isArray(value)) {
          if (value.length === 0) return "[]";
          if (value.every((item) => typeof item === "string")) {
            return `[${value.map((item) => `"${String(item).replace(/"/g, '\\"')}"`).join(", ")}]`;
          }
          return "[]";
        }
        if (typeof value === "boolean") return value ? "true" : "false";
        if (typeof value === "number") return String(value);
        return `"${String(value ?? "").replace(/"/g, '\\"')}"`;
      };

      const buildFrontmatterYaml = (meta) =>
        [
          "---",
          ...Object.entries(meta).map(([key, value]) => `${key}: ${serializeFrontmatterValue(value)}`),
          "---",
          "",
        ].join("\n");

      const generateFullMdx = () => {
        const title = postTitle.value.trim();
        const slug = postSlug.value.trim() || generateSlug(title);
        const description = buildDescription();
        const tags = parseTags();
        const content = postContent.value.trim();
        const youtubeId = extractYoutubeId(videoUrlInput.value);
        const isPremium = generatorPremium.checked;
        const workflow = getWorkflowMeta();

        const srtBundle = window.__nmSrtComposerBundle;
        if (srtBundle && typeof srtBundle.fullMdx === "string") {
          const descField = postDescription.value.trim();
          if (
            content === srtBundle.bodySnapshot &&
            title === srtBundle.titleSnapshot &&
            descField === srtBundle.descriptionSnapshot &&
            youtubeId === srtBundle.youtubeSnapshot
          ) {
            return cleanHumanTouch(String(srtBundle.fullMdx).trim() + "\n");
          }
        }

        const frontmatterMeta = cleanFrontmatterObject({
          title,
          description,
          pubDate: today,
          updatedDate: "",
          author: "השם לא משנה",
          tags,
          image: "/og.jpg",
          canonicalUrl: "",
          keywords: "",
          audioUrl: "",
          youtubeId,
          videoSummaryPoints: [],
          tallyUrl: "",
          isPremium,
          draft: workflow.draft === "true",
          workflowStatus: workflow.workflowStatus,
          faq: [],
        });

        const frontmatter = buildFrontmatterYaml(frontmatterMeta);

        return cleanHumanTouch(`${frontmatter}${content}\n`);
      };

      const guardExport = (content) => {
        const bytes = new TextEncoder().encode(content).length;
        if (bytes > MAX_SAFE_BYTES) {
          return {
            safe: false,
            message: `הקובץ גדול מדי (${Math.round(bytes / 1024)}KB). פצל לפני ייצוא.`,
          };
        }
        return { safe: true };
      };

      const exportMdxFile = (content, filename) => {
        const guard = guardExport(content);
        if (!guard.safe) {
          publishStatusText.textContent = guard.message;
          return false;
        }

        const blob = new Blob([`${content}\n`], { type: "text/markdown;charset=utf-8" });
        const href = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = href;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(href);
