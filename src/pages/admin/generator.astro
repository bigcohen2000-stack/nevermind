          const el = document.querySelector(sel);
          el?.classList.remove("nm-qa-field-error");
        });
      };

      const applyQaFieldHighlights = (issues) => {
        const seen = new Set();
        issues.forEach((issue) => {
          const sel = issue.target;
          if (!sel || seen.has(sel)) return;
          seen.add(sel);
          const el = document.querySelector(sel);
          if (el instanceof HTMLElement) el.classList.add("nm-qa-field-error");
