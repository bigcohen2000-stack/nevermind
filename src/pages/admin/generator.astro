      const renderValidation = () => {
        lastValidationIssues = validateContent();
        const title = postTitle.value.trim();
        const slugRaw = postSlug.value.trim();
        const slugCheck = validateSlugInput(slugRaw, title);
        const slug = slugCheck.valid
          ? slugCheck.suggested || slugRaw || generateSlug(title)
          : slugRaw || generateSlug(title);
        const workflow = getWorkflowMeta();
        if (!slugRaw && title && slugCheck.valid && slugCheck.suggested) {
          postSlug.value = slugCheck.suggested;
        }

        clearQaFieldHighlights();

        if (lastValidationIssues.length > 0) {
          applyQaFieldHighlights(lastValidationIssues);
          validationBox.classList.remove("hidden");
          errorList.innerHTML = lastValidationIssues
            .map(
              (issue, index) =>
                `<li class="flex flex-wrap items-center justify-between gap-2 rounded-2xl border border-[color-mix(in_srgb,var(--nm-accent)_12%,transparent)] bg-white/80 px-4 py-3"><span class="min-w-0 flex-1">${escapeHtml(issue.message)}</span><button type="button" class="js-ai-fix shrink-0 rounded-lg border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-surface-muted)] px-2 py-1 text-base leading-none transition-colors hover:bg-white" data-ai-fix-index="${index}" title="העתק פרומפט ממוקד לתיקון השדה" aria-label="תיקון עם AI">🪄</button></li>`,
            )
            .join("");
          publishStatusText.textContent = `המאמר עדיין לא נקי. תקן את החסמים לפני העתקה או פתיחה ב-GitHub. שלב העבודה הנוכחי: ${workflow.label}.`;
