      };

      const openGitHubFolder = () => {
        window.open(repoFolderBase, "_blank", "noopener,noreferrer");
      };

      const escapeHtml = (value) =>
        String(value ?? "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
