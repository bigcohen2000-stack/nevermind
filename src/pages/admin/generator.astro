      /** @type {{ message: string; target: string; prompt: string }[]} */
      let lastValidationIssues = [];

      const validateContent = () => {
        /** @type {{ message: string; target: string; prompt: string }[]} */
        const issues = [];
        const title = postTitle.value.trim();
        const slugRaw = postSlug.value.trim();
        const slugCheck = validateSlugInput(slugRaw, title);
        const slug = slugCheck.valid
          ? slugCheck.suggested || slugRaw || generateSlug(title)
          : slugRaw || generateSlug(title);
        const description = buildDescription();
        const content = postContent.value.trim();
        const youtubeId = extractYoutubeId(videoUrlInput.value);
        const workflow = getWorkflowMeta();

        if (title.length < 10) {
          issues.push({
            message: "כותרת קצרה מדי (מינימום 10 תווים)",
            target: "#postTitle",
            prompt: `You fix MDX article metadata for a Hebrew site. The TITLE is too short (minimum 10 characters; current length ${title.length}).\nCurrent title:\n${title}\nReturn ONLY the improved Hebrew title, one line, SEO-friendly, same intent. No quotes or explanation.`,
