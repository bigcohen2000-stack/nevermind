---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { FloatingInput } from "../../components/ui/FloatingInput";
import appConfig from "../../config/appConfig.json";
import { ARTICLE_TAG_WHITELIST } from "../../data/article-tags";

const pageTitle = "אשף מאמרים";
const pageDescription = "אשף שלושה שלבים ליצירת פרומפט מדויק לכתיבת מאמר.";
const githubNewArticleBase = `https://github.com/${appConfig.github.owner}/${appConfig.github.repo}/new/${appConfig.github.branch}/${appConfig.github.articlesPath}`;

const publishedArticles = await getCollection("articles", ({ data }) => !data.draft);
const existingSlugs = publishedArticles.map((e) => e.slug);
const latestArticlesForWizard = [...publishedArticles]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5)
  .map((e) => ({
    title: e.data.title,
    href: `/articles/${e.slug}/`,
  }));
const tagWhitelist = [...ARTICLE_TAG_WHITELIST];
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <style is:global>
    #nm-article-wizard.nm-wizard--focus #wiz-chrome {
      display: none;
    }
    [data-wiz-tab].nm-wizard-tab-active {
      border-color: var(--nm-accent);
      background: var(--nm-tint);
    }
    #wiz-tag-chips .nm-wiz-chip {
      display: inline-flex;
      min-height: 44px;
      align-items: center;
      border-radius: 9999px;
      border: 1px solid color-mix(in srgb, var(--nm-fg) 12%, transparent);
      background: #fff;
      padding: 0.375rem 0.75rem;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--nm-fg);
      transition: border-color 0.15s ease, background 0.15s ease;
    }
    #wiz-tag-chips .nm-wiz-chip.nm-wiz-chip--on {
      border-color: #0f172a;
      background: var(--nm-tint);
    }
  </style>
  <script is:inline define:vars={{ existingSlugs, latestArticlesForWizard, tagWhitelist }}>
    window.__NM_WIZARD_BOOT = { existingSlugs, latestArticlesForWizard, tagWhitelist };
  </script>
  <section class="mx-auto max-w-4xl space-y-8 px-4 pb-16 text-right text-[var(--nm-fg)]">
    <header class="space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">יצירת תוכן</p>
      <h1 class="text-[clamp(2rem,1.5rem+1.8vw,3.2rem)] font-semibold leading-[1.05]">אשף מאמרים</h1>
      <p class="text-[clamp(1rem,0.95rem+0.25vw,1.15rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
        שלושה שלבים קצרים. בסוף מתקבל פרומפט מוכן להעתקה.
      </p>
    </header>

    <article id="nm-article-wizard" class="space-y-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 shadow-[0_22px_60px_color-mix(in_srgb,var(--nm-fg)_5%,transparent)] md:p-8">
      <div id="wiz-chrome" class="space-y-2">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <nav class="flex flex-wrap gap-2" aria-label="שלבי האשף">
          <button
            type="button"
            data-wiz-tab="1"
            class="inline-flex min-h-[44px] items-center gap-1.5 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white/90 px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-tint)]"
          >
            שלב 1
            <span data-wiz-tab-dot="1" class="hidden text-[#0F172A]" aria-hidden="true" title="חסרים שדות">●</span>
          </button>
          <button
            type="button"
            data-wiz-tab="2"
            class="inline-flex min-h-[44px] items-center gap-1.5 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white/90 px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-tint)]"
          >
            שלב 2
          </button>
          <button
            type="button"
            data-wiz-tab="3"
            class="inline-flex min-h-[44px] items-center gap-1.5 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white/90 px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-tint)]"
          >
            שלב 3
          </button>
        </nav>
        <button
          type="button"
          id="wiz-focus-toggle"
          class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-4 py-2 text-xs font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
        >
          מצב מיקוד
        </button>
      </div>
      <div class="space-y-2">
        <div class="h-1.5 w-full overflow-hidden rounded-full bg-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)]">
          <div id="wizard-progress" class="h-full rounded-full bg-[var(--nm-accent)] transition-all duration-300" style="width: 33%;"></div>
        </div>
        <p id="wizard-step-label" class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">שלב 1 מתוך 3</p>
      </div>
      </div>

      <section data-step="1" class="wizard-step space-y-4">
        <h2 class="text-2xl font-semibold">שלב 1: הליבה</h2>
        <FloatingInput
          client:load
          id="wiz-topic"
          label="נושא או כותרת"
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <label class="block space-y-2">
          <span class="text-sm font-semibold">למי מיועד המאמר?</span>
          <select id="wiz-audience" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option value="Beginners">מתחילים</option>
            <option value="Advanced">קוראים מנוסים</option>
            <option value="Internal Community">קהילה פנימית</option>
          </select>
        </label>
        <FloatingInput
          client:load
          id="wiz-aha"
          label="תובנת ליבה (משפט אחד עד שלושה)"
          multiline
          rows={3}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <FloatingInput
          client:load
          id="wiz-question-schema"
          label="שאלה מזוקקת למנועי חיפוש (עברית)"
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <FloatingInput
          client:load
          id="wiz-image-alt"
          label="מה התמונה מייצגת (רעיון ונגישות, לא רק תיאור פיקסלים)"
          multiline
          rows={2}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <label class="block space-y-2">
          <span class="text-sm font-semibold">עוצמת שינוי תפיסתי (1-5)</span>
          <select id="wiz-mind-shift" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option value="1">1 - עדין</option>
            <option value="2">2</option>
            <option value="3" selected>3 - איזון</option>
            <option value="4">4</option>
            <option value="5">5 - חד</option>
          </select>
        </label>
        <FloatingInput
          client:load
          id="wiz-bottom-line"
          label="שורת תחתית לקורא (bottomLine)"
          multiline
          rows={2}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <FloatingInput
          client:load
          id="wiz-inversion"
          label="עומק / היפוך (אופציונלי)"
          multiline
          rows={2}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <label class="flex cursor-pointer items-center gap-3 rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-4 py-3">
          <input id="wiz-is-premium" type="checkbox" class="size-4 accent-[var(--nm-accent)]" />
          <span class="text-sm font-semibold">תוכן למנויים בלבד</span>
        </label>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">רמת עומק במאמר</span>
          <select id="wiz-difficulty" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option value="beginner">מתחילים</option>
            <option value="advanced">מתקדמים</option>
            <option value="deep">עומק / מועדון</option>
          </select>
        </label>
        <div class="grid gap-4 md:grid-cols-2">
          <FloatingInput
            client:load
            id="wiz-slug"
            label="כתובת נקייה באנגלית (slug)"
            dir="ltr"
            hideValidation={true}
            className="[&_.nm-floating-control]:bg-transparent [&_.nm-floating-control]:text-left"
          />
          <div class="space-y-1">
            <p class="text-xs text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">ממופה לתיאור בקובץ המאמר</p>
            <FloatingInput
              client:load
              id="wiz-summary"
              label="תקציר קצר ומדויק (למנועי חיפוש)"
              hideValidation={true}
              className="[&_.nm-floating-control]:bg-transparent"
            />
          </div>
        </div>
      </section>

      <section data-step="2" class="wizard-step hidden space-y-4">
        <h2 class="text-2xl font-semibold">שלב 2: מבנה ותדר</h2>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">תדר השיחה</span>
          <select id="wiz-tone" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option value="Provocative">חד</option>
            <option value="Analytical">אנליטי</option>
            <option value="Grounded">מחובר לקרקע</option>
          </select>
        </label>
        <FloatingInput
          client:load
          id="wiz-points"
          label="נקודות מפתח (כל שורה נקודה אחת)"
          multiline
          rows={5}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <label class="block space-y-2">
          <span class="text-sm font-semibold">אורך משוער</span>
          <select id="wiz-length" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option value="Short Post">פוסט קצר</option>
            <option value="Deep Dive">צלילה עמוקה</option>
            <option value="Full Research">מחקר מלא</option>
          </select>
        </label>
        <div class="space-y-2">
          <span class="text-sm font-semibold text-[var(--nm-fg)]">תגיות (מהרשימה המאושרת)</span>
          <p class="text-xs text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">לחיצה מוסיפה או מסירה. תגיות לא מהרשימה מוסרות אוטומטית לפני בדיקה.</p>
          <div id="wiz-tag-chips" class="flex flex-wrap justify-end gap-2" role="group" aria-label="תגיות מאושרות"></div>
          <input type="hidden" id="wiz-tags" value="" />
        </div>
        <FloatingInput
          client:load
          id="wiz-youtube"
          label="קישור YouTube או מזהה (11 תווים)"
          dir="ltr"
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent [&_.nm-floating-control]:text-left"
        />
        <FloatingInput
          client:load
          id="wiz-body"
          label="טיוטת גוף (Markdown, אופציונלי)"
          multiline
          rows={6}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <p id="wiz-word-count" class="text-xs font-semibold text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">מילים בטיוטה: 0</p>
        <p id="wiz-sentence-warn" class="hidden text-xs font-semibold text-amber-800" aria-live="polite"></p>
        <div
          id="wiz-blockers"
          class="hidden rounded-[1rem] border border-red-600/35 bg-red-50 px-4 py-3 text-xs font-semibold leading-6 text-red-900"
          aria-live="assertive"
        />
        <div
          id="wiz-preflight"
          class="rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3 text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]"
          aria-live="polite"
        >
          בדיקות לפני שלב 3: חסימות באדום למעלה. כאן אזהרות בלבד.
        </div>
      </section>

      <section data-step="3" class="wizard-step hidden space-y-4">
        <h2 class="text-2xl font-semibold">שלב 3: סיכום ולזיקה</h2>
        <div id="wiz-latest-internal" class="rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3 text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
          <p class="font-semibold text-[var(--nm-fg)]">קישורים פנימיים אחרונים (לשילוב בגוף)</p>
          <ul class="mt-2 list-inside list-disc space-y-1" id="wiz-latest-internal-list"></ul>
        </div>
        <button id="wiz-generate" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-6 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">
          לזקק למאמר
        </button>
        <button id="wiz-copy-package" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          יצירה מהירה
        </button>
        <button
          id="wiz-mobile-preview"
          type="button"
          class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
        >
          תצוגה צרה (נייד)
        </button>
        <FloatingInput
          client:load
          id="wiz-output"
          label="פרומפט מלא"
          multiline
          rows={12}
          readOnly={true}
          hideValidation={true}
          dir="ltr"
          defaultValue=""
          className="[&_.nm-floating-control]:bg-[var(--nm-surface-muted)] [&_.nm-floating-control]:text-left [&_.nm-floating-control]:leading-7"
        />
        <button
          id="wiz-copy-all-mdx"
          type="button"
          class="inline-flex min-h-[44px] items-center justify-center rounded-full px-6 py-3 text-sm font-semibold text-white transition hover:opacity-95"
          style="background-color: #0F172A;"
        >
          העתק את כל קוד ה-MDX
        </button>
        <button id="wiz-save" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          שמור טיוטה
        </button>
        <button id="wiz-download-mdx" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          הורד טיוטת MDX
        </button>
        <a id="wiz-open-github" href={githubNewArticleBase} target="_blank" rel="noreferrer" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] no-underline transition hover:bg-[var(--nm-surface-muted)]">
          פתח יצירה ב-GitHub
        </a>
        <FloatingInput
          client:load
          id="wiz-external-mdx"
          label="הדבק כאן פלט MDX ממודל חיצוני"
          multiline
          rows={10}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-[var(--nm-surface-muted)] [&_.nm-floating-control]:leading-7"
        />
        <div class="flex flex-wrap gap-3">
          <button id="wiz-validate-external" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-6 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">
            בדוק ונקה
          </button>
          <button id="wiz-invert-claim" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
            הפוך טענה
          </button>
        </div>
        <div
          id="wiz-external-result"
          class="hidden rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3 text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]"
        />
        <div id="wiz-inversion-wrap" class="hidden space-y-2 rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3">
          <p class="text-xs font-semibold text-[var(--nm-accent)]">בדיקת היפוך לפני הורדה</p>
          <p id="wiz-claim-source" class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_74%,var(--nm-bg))]"></p>
          <FloatingInput
            client:load
            id="wiz-claim-inversion"
            label="כתוב את ההיפוך של המשפט הזה"
            multiline
            rows={3}
            hideValidation={true}
            className="[&_.nm-floating-control]:bg-transparent"
          />
        </div>
        <p id="wiz-save-status" class="text-xs font-semibold text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]"></p>
      </section>

      <div class="flex items-center justify-between gap-3">
        <button id="wiz-back" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-5 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          חזור
        </button>
        <button id="wiz-next" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-2 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">
          המשך
        </button>
      </div>
    </article>

    <dialog id="wiz-mobile-dialog" class="max-h-[90vh] w-[min(100%,420px)] max-w-[calc(100%-2rem)] rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-bg-canvas)] p-4 text-right text-[var(--nm-fg)] shadow-[0_22px_60px_color-mix(in_srgb,var(--nm-fg)_12%,transparent)] backdrop:bg-black/40">
      <div class="mb-3 flex items-center justify-between gap-2">
        <p class="text-sm font-semibold">תצוגה צרה</p>
        <button type="button" data-wiz-close-mobile class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-3 text-sm font-semibold text-[var(--nm-fg)]">סגור</button>
      </div>
      <div id="wiz-mobile-preview-body" class="mx-auto max-h-[70vh] w-[min(100%,360px)] overflow-y-auto rounded-xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white p-3 text-sm leading-relaxed text-[var(--nm-fg)] [overflow-wrap:anywhere]"></div>
    </dialog>
  </section>

  <script>
    import "../../scripts/admin-generator.js";
  </script>
</Layout>


