      const handleClearPreview = () => {
        previewInput.value = "";
        articlePreview.innerHTML = "הדבק MDX ולחץ על Render Preview כדי לראות את המאמר לפני commit.";
        articlePreviewFrame.srcdoc = buildPreviewDocument("Preview", `<article class="mx-auto max-w-3xl rounded-[1.75rem] bg-white p-7"><p style="font-size:1rem;line-height:1.8;color:rgba(26,26,26,.68);text-align:right">הדבק MDX ולחץ על Render Preview כדי לראות את המאמר לפני commit.</p></article>`);
        validatorOutput.innerHTML = '<div class="rounded-2xl border border-dashed border-[#1A1A1A]/12 bg-white/70 px-4 py-3">אין עדיין בדיקות. הרץ Preview כדי לקבל סטטוס.</div>';
        autofixOutput.innerHTML = 'אין עדיין הצעות תיקון.';
        githubReadyOutput.innerHTML = 'סטטוס GitHub-ready יופיע אחרי Preview.';
        suggestedFilename.textContent = 'Filename: -';
