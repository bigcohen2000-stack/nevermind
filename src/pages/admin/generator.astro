  <script is:inline define:vars={{ githubDraftBase, githubRepoLabel }}>
    document.addEventListener("astro:page-load", () => {
      const postTitle = document.getElementById("postTitle");
      const postSlug = document.getElementById("postSlug");
      const postDescription = document.getElementById("postDescription");
      const postTags = document.getElementById("postTags");
      const postWorkflowStatus = document.getElementById("postWorkflowStatus");
      const postContent = document.getElementById("postContent");
      const generatorPremium = document.getElementById("is-premium");
      const videoUrlInput = document.getElementById("video-url");
      const validationBox = document.getElementById("validationBox");
      const errorList = document.getElementById("errorList");
      const publishStatusText = document.getElementById("publishStatusText");
      const copyMdxButton = document.getElementById("copyMdx");
      const injectIntoSandboxButton = document.getElementById("injectIntoSandbox");
      const publishToGithubButton = document.getElementById("publishToGithub");
      const previewInput = document.getElementById("preview-mdx");
      const renderPreviewButton = document.getElementById("render-preview");
      const helperButtons = Array.from(document.querySelectorAll("[data-helper-insert]"));

      if (!(postTitle instanceof HTMLInputElement)) return;
      if (!(postSlug instanceof HTMLInputElement)) return;
      if (!(postDescription instanceof HTMLInputElement)) return;
      if (!(postTags instanceof HTMLInputElement)) return;
      if (!(postWorkflowStatus instanceof HTMLSelectElement)) return;
      if (!(postContent instanceof HTMLTextAreaElement)) return;
      if (!(generatorPremium instanceof HTMLInputElement)) return;
      if (!(videoUrlInput instanceof HTMLInputElement)) return;
      if (!(validationBox instanceof HTMLElement)) return;
      if (!(errorList instanceof HTMLElement)) return;
      if (!(publishStatusText instanceof HTMLElement)) return;
      if (!(copyMdxButton instanceof HTMLButtonElement)) return;
      if (!(injectIntoSandboxButton instanceof HTMLButtonElement)) return;
      if (!(publishToGithubButton instanceof HTMLButtonElement)) return;
      if (!(previewInput instanceof HTMLTextAreaElement)) return;
      if (!(renderPreviewButton instanceof HTMLButtonElement)) return;

      const repoNewFileBase = githubDraftBase;
      const today = new Date().toISOString().slice(0, 10);

      const extractYoutubeId = (value) => {
        const source = String(value || "").trim();
        if (!source) return "";
        if (/^[a-zA-Z0-9_-]{11}$/.test(source)) return source;
        try {
          const url = new URL(source);
          const host = url.hostname.replace(/^www\./, "");
          if (host === "youtu.be") {
            return url.pathname.split("/").filter(Boolean)[0] || "";
          }
          if (host.endsWith("youtube.com")) {
            if (url.searchParams.get("v")) return url.searchParams.get("v") || "";
            const parts = url.pathname.split("/").filter(Boolean);
            if (parts[0] === "embed" || parts[0] === "shorts") {
              return parts[1] || "";
            }
          }
        } catch {
          return "";
        }
        return "";
      };

      const generateSlug = (value) => {
        const ascii = String(value || "")
          .toLowerCase()
          .normalize("NFKD")
          .replace(/[^\x00-\x7F]/g, "")
          .replace(/['"`]/g, "")
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "");
        return ascii || "new-article";
      };

      const buildDescription = () => {
        const existing = postDescription.value.trim();
        if (existing) return existing;
        const title = postTitle.value.trim();
        if (!title) return "";
        return `${title} בלי ערפל, עם מבנה חד, ברור ומוכן לפרסום.`.slice(0, 160);
      };

      const parseTags = () => {
        const source = postTags.value.trim();
        if (!source) return ["בהירות"];
        return source
          .split(/[\n,]/)
          .map((tag) => tag.trim())
          .filter(Boolean);
      };

      const getWorkflowMeta = () => {
        const workflowStatus = postWorkflowStatus.value || "writing";
        return {
          workflowStatus,
          draft: workflowStatus === "published" ? "false" : "true",
          label:
            workflowStatus === "review"
              ? "מוכן לבדיקה"
              : workflowStatus === "ready"
                ? "מוכן לפרסום"
                : workflowStatus === "published"
                  ? "פורסם"
                  : "בכתיבה",
        };
      };

      const generateFullMdx = () => {
        const title = postTitle.value.trim();
        const slug = postSlug.value.trim() || generateSlug(title);
        const description = buildDescription();
        const tags = parseTags();
        const content = postContent.value.trim();
        const youtubeId = extractYoutubeId(videoUrlInput.value);
        const isPremium = generatorPremium.checked;
        const workflow = getWorkflowMeta();
        const frontmatter = [
          "---",
          `title: \"${title.replace(/\"/g, '\\\"')}\"`,
          `description: \"${description.replace(/\"/g, '\\\"')}\"`,
          `pubDate: ${today}`,
          'updatedDate: ""',
          'author: "השם לא משנה"',
          `tags: [${tags.map((tag) => `\"${tag.replace(/\"/g, '\\\"')}\"`).join(", ")}]`,
          'image: "/og.jpg"',
          'canonicalUrl: ""',
          'keywords: ""',
          'audioUrl: ""',
          `youtubeId: "${youtubeId}"`,
          'tallyUrl: ""',
          `isPremium: ${isPremium ? "true" : "false"}`,
          `draft: ${workflow.draft}`,
          `workflowStatus: "${workflow.workflowStatus}"`,
          'faq: []',
          "---",
          "",
        ].join("\n");

        return `${frontmatter}${content}\n`;
      };

      const validateContent = () => {
        const errors = [];
        const title = postTitle.value.trim();
        const slug = postSlug.value.trim() || generateSlug(title);
        const description = buildDescription();
        const content = postContent.value.trim();
        const youtubeId = extractYoutubeId(videoUrlInput.value);
        const workflow = getWorkflowMeta();

        if (title.length < 10) errors.push("כותרת קצרה מדי (מינימום 10 תווים)");
        if (!slug.match(/^[a-z0-9-]+$/)) errors.push("Slug חייב להיות באנגלית ומקפים בלבד");
        if (description.length < 30) errors.push("התיאור קצר מדי. צריך שורת SEO אמיתית ולא placeholder");
        if (content.length < 120) errors.push("התוכן עדיין קצר מדי כדי להיחשב כטיוטת מאמר רצינית");
        if (generatorPremium.checked && !content.includes("<!--premium-break-->")) {
          errors.push("סימנת Premium אבל חסר התג <!--premium-break--> בתוך התוכן");
        }
        if (youtubeId && youtubeId.length !== 11) {
          errors.push("ID של יוטיוב לא תקין (חייב להיות 11 תווים)");
        }
        if (!["writing", "review", "ready", "published"].includes(workflow.workflowStatus)) {
          errors.push("בחר שלב עבודה תקין מתוך הרשימה");
        }

        return errors;
      };

      const renderValidation = () => {
        const errors = validateContent();
        const title = postTitle.value.trim();
        const slug = postSlug.value.trim() || generateSlug(title);
        const workflow = getWorkflowMeta();
        if (!postSlug.value.trim() && title) {
          postSlug.value = slug;
        }

        if (errors.length > 0) {
          validationBox.classList.remove("hidden");
          errorList.innerHTML = errors
            .map((error) => `<li class="rounded-2xl border border-[#D42B2B]/10 bg-white/80 px-4 py-3">${error}</li>`)
            .join("");
          publishStatusText.textContent = `המאמר עדיין לא נקי. תקן את החסמים לפני העתקה או פתיחה ב-GitHub. שלב העבודה הנוכחי: ${workflow.label}.`;
          publishToGithubButton.disabled = true;
          publishToGithubButton.classList.add("opacity-50", "cursor-not-allowed");
        } else {
          validationBox.classList.add("hidden");
          errorList.innerHTML = "";
          publishStatusText.textContent = `מוכן לייצוא. ${githubRepoLabel}/${slug}.mdx | שלב עבודה: ${workflow.label} | publish state: ${workflow.draft === "false" ? "באוויר" : "טיוטה"}`;
          publishToGithubButton.disabled = false;
          publishToGithubButton.classList.remove("opacity-50", "cursor-not-allowed");
        }
      };

      const insertTag = (tag) => {
        const start = postContent.selectionStart || 0;
        const end = postContent.selectionEnd || 0;
        const before = postContent.value.slice(0, start);
        const after = postContent.value.slice(end);
        const needsPadding = before && !before.endsWith("\n") ? "\n" : "";
        const suffixPadding = after && !after.startsWith("\n") ? "\n" : "";
        postContent.value = `${before}${needsPadding}${tag}${suffixPadding}${after}`;
        postContent.focus();
        postContent.selectionStart = postContent.selectionEnd = before.length + needsPadding.length + tag.length;
        renderValidation();
      };

      const copyMdx = async () => {
        renderValidation();
        const errors = validateContent();
        if (errors.length > 0) {
          copyMdxButton.textContent = "תקן קודם את החסמים";
          window.setTimeout(() => {
            copyMdxButton.textContent = "העתק MDX מוכן";
          }, 1500);
          return;
        }

        try {
          await navigator.clipboard.writeText(generateFullMdx());
          copyMdxButton.textContent = "MDX הועתק";
        } catch {
          copyMdxButton.textContent = "ההעתקה נכשלה";
        }
        window.setTimeout(() => {
          copyMdxButton.textContent = "העתק MDX מוכן";
        }, 1500);
      };

      const injectIntoSandbox = () => {
        renderValidation();
        previewInput.value = generateFullMdx();
        renderPreviewButton.click();
      };

      const publishToGithub = () => {
        renderValidation();
        const errors = validateContent();
        if (errors.length > 0) {
          publishToGithubButton.textContent = "תקן קודם את החסמים";
          window.setTimeout(() => {
            publishToGithubButton.textContent = "?? פרסם ישירות ל-GitHub";
          }, 1500);
          return;
        }

        const slug = postSlug.value.trim() || generateSlug(postTitle.value.trim());
        const content = generateFullMdx();
        const githubUrl = `${repoNewFileBase}?filename=${encodeURIComponent(`${slug}.mdx`)}&value=${encodeURIComponent(content)}`;
        window.open(githubUrl, "_blank", "noopener,noreferrer");
      };

      [postTitle, postSlug, postDescription, postTags, postWorkflowStatus, postContent, generatorPremium, videoUrlInput].forEach((element) => {
        element.addEventListener("input", renderValidation);
        element.addEventListener("change", renderValidation);
      });

      helperButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener("click", () => insertTag(button.dataset.helperInsert || ""));
      });

      copyMdxButton.addEventListener("click", copyMdx);
      injectIntoSandboxButton.addEventListener("click", injectIntoSandbox);
      publishToGithubButton.addEventListener("click", publishToGithub);
      renderValidation();
    });
  </script>
</Layout>





























































