---
import Layout from "../../layouts/Layout.astro";
import servicesConfig from "../../config/services.json";
import appConfig from "../../config/appConfig.json";

const pageTitle = "מחולל Mega-Prompt";
const pageDescription = "כלי פנימי ליצירת פרומפטים, preview, validation וזרימת publish למאמרי MDX.";
const githubDraftBase = `https://github.com/${appConfig.github.owner}/${appConfig.github.repo}/new/${appConfig.github.branch}/${appConfig.github.articlesPath}/`;
const githubRepoLabel = `${appConfig.github.owner}/${appConfig.github.repo}`;
const documentationService = servicesConfig.services.find((service) => service.id === "memory-documentation");
const grossPrice = (basePrice: number, taxPercent: number) => Math.round(basePrice * (1 + taxPercent / 100));
const upsellPreviewText = documentationService
  ? `${grossPrice(documentationService.basePrice, documentationService.taxPercent).toLocaleString("he-IL")} ${servicesConfig.currency} כולל מע״מ (${documentationService.title})`
  : `לא הוגדר שירות תיעוד ב-services.json`;
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-7xl space-y-10 px-4 pb-12 text-[#1A1A1A]">
    <header class="max-w-4xl space-y-5 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.26em] text-[#D42B2B]">
        Internal Generator
      </p>
      <h1 class="text-[clamp(2.4rem,1.8rem+2vw,4.1rem)] font-semibold leading-[1.04]">
        מחולל Mega-Prompt למאמרי MDX
      </h1>
      <p class="max-w-3xl text-[clamp(1rem,0.94rem+0.3vw,1.18rem)] leading-8 text-[#1A1A1A]/72">
        מזינים טקסט גולמי, הקשר של קישורים פנימיים, והעדפות תוכן. הכלי מחזיר פרומפט אחד כבד ומדויק,
        ואז מאפשר להדביק את ה־MDX שחזר מהמודל ולבדוק תצוגה לפני commit ל־GitHub.
      </p>
    </header>

    <div class="grid gap-8 xl:grid-cols-[minmax(0,34rem)_minmax(0,1fr)]">
      <form
        id="prompt-generator-form"
        class="space-y-6 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md"
      >
        <div class="space-y-2 text-right">
          <label for="raw-text" class="block text-sm font-semibold text-[#1A1A1A]">
            Topic / Raw Text
          </label>
          <p class="text-sm leading-6 text-[#1A1A1A]/60">
            רעיון, תמלול, נקודות, כאב, זווית כתיבה או כל חומר גולמי שממנו נרצה לבנות את המאמר.
          </p>
          <textarea
            id="raw-text"
            rows="14"
            class="w-full rounded-[1.6rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-right text-base leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15"
            dir="rtl"
            placeholder="הדבק כאן טקסט גולמי, כיוון למאמר או נושא מרכזי"
          ></textarea>
        </div>

        <div class="space-y-2 text-right">
          <label for="sitemap" class="block text-sm font-semibold text-[#1A1A1A]">
            Sitemap / Existing URLs
          </label>
          <p class="text-sm leading-6 text-[#1A1A1A]/60">
            הדבק רשימת כתובות קיימות, סלאגים או מפת אתר כדי שהמודל ישלב 2–3 קישורים פנימיים באופן טבעי.
          </p>
          <textarea
            id="sitemap"
            rows="10"
            class="w-full rounded-[1.6rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-right text-base leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15"
            dir="rtl"
            placeholder="/articles/freedom-example&#10;/topics/clarity&#10;https://www.nevermind.co.il/articles/..."
          ></textarea>
        </div>

        <div class="space-y-2 text-right">
          <label for="video-url" class="block text-sm font-semibold text-[#1A1A1A]">
            Video URL
          </label>
          <p class="text-sm leading-6 text-[#1A1A1A]/60">
            הדבק לינק ליוטיוב אם המאמר אמור להתבסס על סרטון. הכלי יחלץ את ה־<code>youtubeId</code> ויזריק אותו
            ל־prompt ול־autofix.
          </p>
          <input
            id="video-url"
            type="url"
            dir="ltr"
            class="w-full rounded-[1.6rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-left text-base leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15"
            placeholder="https://www.youtube.com/watch?v=..."
          />
          <div id="video-helper" class="rounded-[1.2rem] border border-[#1A1A1A]/10 bg-white/80 px-4 py-3 text-sm leading-6 text-[#1A1A1A]/68">
            עדיין לא הוזן לינק וידאו.
          </div>
        </div>

        <div class="space-y-2 text-right">
          <label for="video-transcript-notes" class="block text-sm font-semibold text-[#1A1A1A]">
            Video Transcript Notes
          </label>
          <p class="text-sm leading-6 text-[#1A1A1A]/60">
            אופציונלי. הדבק תמלול חלקי, נקודות מהסרטון או סיכום ידני כדי לדייק את המאמר סביב הווידאו.
          </p>
          <textarea
            id="video-transcript-notes"
            rows="6"
            class="w-full rounded-[1.6rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-right text-base leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15"
            dir="rtl"
            placeholder="הדבק כאן תמלול, ציטוטים או נקודות מפתח מהווידאו"
          ></textarea>
        </div>

        <section class="space-y-3 rounded-[1.5rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-4 text-right">
          <div>
            <p class="text-sm font-semibold text-[#1A1A1A]">Template Presets</p>
            <p class="mt-1 text-sm leading-6 text-[#1A1A1A]/60">בחר תבנית עבודה אחת. ה־preset יכוון את ה־prompt וגם יעדכן את אפשרויות ה־Premium וה־TruthSlider אוטומטית כשצריך.</p>
          </div>
          <input id="selected-preset" type="hidden" value="regular" />
          <div class="grid gap-3 sm:grid-cols-2">
            <button type="button" data-preset="regular" class="preset-button rounded-[1.2rem] border border-[#1A1A1A]/10 bg-white px-4 py-4 text-right transition hover:border-[#D42B2B]/25">
              <span class="block text-sm font-semibold text-[#1A1A1A]">מאמר רגיל</span>
              <span class="mt-1 block text-sm leading-6 text-[#1A1A1A]/60">מבנה מאוזן של מאמר תוכן רגיל, בלי נעילה ובלי רכיבים נוספים.</span>
            </button>
            <button type="button" data-preset="premium" class="preset-button rounded-[1.2rem] border border-[#1A1A1A]/10 bg-white px-4 py-4 text-right transition hover:border-[#D42B2B]/25">
              <span class="block text-sm font-semibold text-[#1A1A1A]">מאמר פרימיום</span>
              <span class="mt-1 block text-sm leading-6 text-[#1A1A1A]/60">מפעיל Premium ומחייב נקודת חסימה חכמה עם ערך גבוה אחרי ה־hook.</span>
            </button>
            <button type="button" data-preset="video" class="preset-button rounded-[1.2rem] border border-[#1A1A1A]/10 bg-white px-4 py-4 text-right transition hover:border-[#D42B2B]/25">
              <span class="block text-sm font-semibold text-[#1A1A1A]">מאמר עם וידאו</span>
              <span class="mt-1 block text-sm leading-6 text-[#1A1A1A]/60">מכריח שילוב YouTube ID, הקשר וידאו והטמעה דרך LiteYouTubeEmbed.</span>
            </button>
            <button type="button" data-preset="truthslider" class="preset-button rounded-[1.2rem] border border-[#1A1A1A]/10 bg-white px-4 py-4 text-right transition hover:border-[#D42B2B]/25">
              <span class="block text-sm font-semibold text-[#1A1A1A]">מאמר עם TruthSlider</span>
              <span class="mt-1 block text-sm leading-6 text-[#1A1A1A]/60">מפעיל TruthSlider JSON ודוחף לסיום אינטראקטיבי עם dataset מסודר.</span>
            </button>
          </div>
          <div id="preset-description" class="rounded-[1.2rem] border border-[#1A1A1A]/10 bg-white/80 px-4 py-3 text-sm leading-6 text-[#1A1A1A]/68">
            מצב ברירת מחדל: מאמר רגיל.
          </div>
        </section>

        <div class="grid gap-3 sm:grid-cols-2">
          <label class="flex items-start gap-3 rounded-[1.35rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-4 text-right">
            <input id="is-premium" type="checkbox" class="mt-1 h-4 w-4 accent-[#D42B2B]" />
            <span>
              <span class="block text-sm font-semibold text-[#1A1A1A]">Is Premium?</span>
              <span class="mt-1 block text-sm leading-6 text-[#1A1A1A]/60">
                יכריח את הפרומפט להגדיר <code>isPremium: true</code> ולבנות גם היגיון חסימה עתידי.
              </span>
            </span>
          </label>

          <label class="flex items-start gap-3 rounded-[1.35rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-4 text-right">
            <input id="include-truth-slider" type="checkbox" class="mt-1 h-4 w-4 accent-[#D42B2B]" />
            <span>
              <span class="block text-sm font-semibold text-[#1A1A1A]">Include Interactive JSON for TruthSlider?</span>
              <span class="mt-1 block text-sm leading-6 text-[#1A1A1A]/60">
                יוסיף הוראה קשיחה לפלט JSON קטן בסוף הקובץ עבור <code>&lt;TruthSlider /&gt;</code>.
              </span>
            </span>
          </label>
        </div>

        <button
          id="generate-prompt"
          type="submit"
          class="inline-flex w-full items-center justify-center rounded-full bg-[#D42B2B] px-6 py-4 text-base font-semibold text-white transition hover:bg-[#ba2424] focus:outline-none focus:ring-2 focus:ring-[#D42B2B]/30"
        >
          Generate Prompt
        </button>
      </form>

      <section class="space-y-4 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md">
        <div class="flex flex-col gap-4 border-b border-[#1A1A1A]/10 pb-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="space-y-1 text-right">
            <h2 class="text-2xl font-semibold text-[#1A1A1A]">Prompt Output</h2>
            <p class="text-sm leading-6 text-[#1A1A1A]/60">
              פלט אחד מוכן להדבקה ל־Claude, ChatGPT או כל LLM אחר, כולל שלד MDX והרחבות עבודה.
            </p>
          </div>
          <button
            id="copy-prompt"
            type="button"
            disabled
            class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-2 text-sm font-semibold text-[#1A1A1A]/72 transition hover:bg-white disabled:cursor-not-allowed disabled:opacity-50"
          >
            העתק ללוח
          </button>
        </div>

        <div class="grid gap-3 rounded-[1.5rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-4 text-right sm:grid-cols-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#D42B2B]">Perspective</p>
            <p class="mt-2 text-sm leading-6 text-[#1A1A1A]/72">גוף ראשון בלבד, ללא ז'רגון, למתחילים חכמים.</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#D42B2B]">Output</p>
            <p class="mt-2 text-sm leading-6 text-[#1A1A1A]/72">MDX מלא + FAQ + אודיו + סניפטים + GitHub meta.</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#D42B2B]">Workflow</p>
            <p class="mt-2 text-sm leading-6 text-[#1A1A1A]/72">העתקה, הדבקה, בדיקה ויזואלית, ואז פרסום ידני ומבוקר.</p>
          </div>
        </div>

        <pre class="min-h-[42rem] overflow-auto rounded-[1.6rem] bg-[#111111] p-5 text-sm leading-7 text-[#F4F4EF] shadow-inner"><code id="generated-prompt">הפרומפט יופיע כאן אחרי הלחיצה על Generate Prompt.</code></pre>
      </section>
    </div>

    <section class="grid gap-8 xl:grid-cols-[minmax(0,32rem)_minmax(0,1fr)]">
      <section class="space-y-5 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md">
        <div class="space-y-2 text-right">
          <p class="text-sm font-semibold uppercase tracking-[0.26em] text-[#D42B2B]">Sandbox</p>
          <h2 class="text-2xl font-semibold text-[#1A1A1A]">מצב תצוגה מקדימה</h2>
          <p class="text-sm leading-6 text-[#1A1A1A]/60">
            הדבק כאן את ה־MDX שחזר מהמודל. הכלי יפרק frontmatter, יזהה רכיבים מוכרים, ויציג preview נאמן מספיק
            כדי לבדוק מבנה, היררכיה, CTAים, בלוקים ורצף תוכני לפני commit.
          </p>
        </div>

        <textarea
          id="preview-mdx"
          rows="22"
          class="w-full rounded-[1.6rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-left text-sm leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15"
          dir="ltr"
          placeholder="הדבק כאן את כל ה־MDX שקיבלת, כולל frontmatter"
        ></textarea>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end">
          <button
            id="render-preview"
            type="button"
            class="inline-flex items-center justify-center rounded-full bg-[#1A1A1A] px-5 py-3 text-sm font-semibold text-white transition hover:bg-black"
          >
            Render Preview
          </button>
          <button
            id="copy-clean-mdx"
            type="button"
            class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]"
          >
            Copy clean MDX
          </button>
          <button
            id="export-mdx"
            type="button"
            class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]"
          >
            Export .mdx
          </button>
          <button
            id="clear-preview"
            type="button"
            class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-[#FAFAF8] px-5 py-3 text-sm font-semibold text-[#1A1A1A]/72 transition hover:bg-white"
          >
            נקה תצוגה
          </button>
        </div>
      </section>

      <section class="space-y-5 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md">
        <div class="flex flex-col gap-3 border-b border-[#1A1A1A]/10 pb-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="space-y-1 text-right">
            <h2 class="text-2xl font-semibold text-[#1A1A1A]">Article Preview</h2>
            <p class="text-sm leading-6 text-[#1A1A1A]/60">
              תצוגת sandbox חזותית. היא לא מריצה MDX אמיתי, אבל כן משחזרת את מבנה הקריאה באתר.
            </p>
          </div>
          <span id="preview-status" class="text-sm font-medium text-[#1A1A1A]/55">ממתין ל־MDX</span>
        </div>

        <div id="preview-shell" class="space-y-4 rounded-[1.75rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5">
          <div
            id="article-preview"
            class="min-h-[28rem] rounded-[1.5rem] border border-dashed border-[#1A1A1A]/12 bg-white/70 p-6 text-right text-[#1A1A1A]/72"
          >
            הדבק MDX ולחץ על Render Preview כדי לראות את המאמר לפני commit.
          </div>
          <div class="space-y-2 text-right">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">Live Shell Preview</p>
            <iframe id="article-preview-frame" title="תצוגה חיה של המאמר" class="min-h-[36rem] w-full rounded-[1.5rem] border border-[#1A1A1A]/10 bg-white" loading="lazy"></iframe>
          </div>
        </div>

        <section class="grid gap-4 rounded-[1.5rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-start">
          <div class="space-y-3 text-right">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">Publish Helpers</p>
              <p class="mt-2 text-sm leading-6 text-[#1A1A1A]/60">בדיקות קצרות לפני העלאה, יחד עם שם קובץ והודעת commit מוכנים להעתקה.</p>
            </div>
            <div id="validator-output" class="grid gap-2 text-sm text-[#1A1A1A]/72">
              <div class="rounded-2xl border border-dashed border-[#1A1A1A]/12 bg-white/70 px-4 py-3">אין עדיין בדיקות. הרץ Preview כדי לקבל סטטוס.</div>
            </div>
            <div id="autofix-output" class="rounded-2xl border border-[#1A1A1A]/10 bg-white/80 px-4 py-3 text-sm text-[#1A1A1A]/68">
              אין עדיין הצעות תיקון.
            </div>
            <div id="github-ready-output" class="rounded-2xl border border-[#1A1A1A]/10 bg-white/80 px-4 py-3 text-sm text-[#1A1A1A]/68">
              סטטוס GitHub-ready יופיע אחרי Preview.
            </div>
          </div>
          <div class="flex flex-col gap-3 lg:min-w-[15rem]">
            <button
              id="copy-filename"
              type="button"
              class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]"
            >
              Copy suggested filename
            </button>
            <button
              id="copy-commit-message"
              type="button"
              class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]"
            >
              Copy commit message
            </button>
            <button
              id="copy-description-seed"
              type="button"
              class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]"
            >
              Copy description seed
            </button>
            <button
              id="apply-autofix"
              type="button"
              class="inline-flex items-center justify-center rounded-full border border-[#D42B2B]/16 bg-[#FFF4F3] px-5 py-3 text-sm font-semibold text-[#D42B2B] transition hover:bg-[#ffe7e5]"
            >
              Apply frontmatter autofix
            </button>
            <button
              id="export-package"
              type="button"
              class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]"
            >
              Export article package
            </button>
            <div class="rounded-2xl border border-[#1A1A1A]/10 bg-white/80 px-4 py-3 text-right text-sm text-[#1A1A1A]/62">
              <p id="suggested-filename">Filename: -</p>
              <p id="suggested-commit" class="mt-2">Commit: -</p>
              <p id="suggested-description" class="mt-2">Description seed: -</p>
            </div>
          </div>
        </section>
      </section>
    </section>
  </section>


    <section class="grid gap-8 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md xl:grid-cols-[minmax(0,1.2fr)_22rem]">
      <section class="space-y-5 text-right">
        <div class="space-y-2">
          <p class="text-sm font-semibold uppercase tracking-[0.26em] text-[#D42B2B]">Quick Composer</p>
          <h2 class="text-2xl font-semibold text-[#1A1A1A]">מנוע תיקוף וטיוטה מהירה</h2>
          <p class="text-sm leading-6 text-[#1A1A1A]/60">
            כאן לא בונים prompt אלא קובץ MDX ישיר. אתה מזין כותרת, slug ותוכן, רואה שגיאות בזמן אמת,
            ומייצר Draft מוכן להעתקה או לפתיחה ישירה ב־GitHub.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <label class="space-y-2">
            <span class="block text-sm font-semibold text-[#1A1A1A]">כותרת המאמר (SEO Friendly)</span>
            <input id="postTitle" type="text" dir="rtl" placeholder="איך להקליט פודקאסט ב-2026 בלי להישמע מאולץ" class="w-full rounded-[1.4rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-right text-base leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15" />
          </label>
          <label class="space-y-2">
            <span class="block text-sm font-semibold text-[#1A1A1A]">Slug</span>
            <input id="postSlug" type="text" dir="ltr" placeholder="ego-is-a-defense-not-an-identity" class="w-full rounded-[1.4rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-left text-base leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15" />
          </label>
        </div>

        <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_12rem] xl:grid-cols-[minmax(0,1fr)_12rem_14rem]">
          <label class="space-y-2">
            <span class="block text-sm font-semibold text-[#1A1A1A]">תיאור קצר</span>
            <input id="postDescription" type="text" dir="rtl" placeholder="תיאור קצר, חד ומובן ל-SEO ולוואטסאפ" class="w-full rounded-[1.4rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-right text-base leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15" />
          </label>
          <label class="space-y-2">
            <span class="block text-sm font-semibold text-[#1A1A1A]">תגיות</span>
            <input id="postTags" type="text" dir="rtl" placeholder="בהירות, מכניקת מחשבה" class="w-full rounded-[1.4rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-right text-base leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15" />
          </label>
          <label class="space-y-2">
            <span class="block text-sm font-semibold text-[#1A1A1A]">תור עבודה</span>
            <select id="postWorkflowStatus" class="w-full rounded-[1.4rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-[1.1rem] text-right text-base leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15">
              <option value="writing">בכתיבה</option>
              <option value="review">מוכן לבדיקה</option>
              <option value="ready">מוכן לפרסום</option>
              <option value="published">פורסם</option>
            </select>
          </label>
        </div>

        <div class="space-y-2">
          <span class="block text-sm font-semibold text-[#1A1A1A]">תוכן (Markdown / MDX)</span>
          <textarea id="postContent" rows="15" dir="rtl" class="w-full rounded-[1.6rem] border border-[#1A1A1A]/12 bg-[#FAFAF8] px-5 py-4 text-right text-base leading-7 text-[#1A1A1A] outline-none transition focus:border-[#D42B2B]/40 focus:ring-2 focus:ring-[#D42B2B]/15" placeholder="הדבק כאן את גוף המאמר. אם זה מאמר פרימיום, הוסף את תג החסימה במקום הנכון."></textarea>
          <div class="flex flex-wrap justify-end gap-3">
            <button type="button" data-helper-insert="<!--premium-break-->" class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-4 py-2 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]">+ הוסף חסימת פרימיום</button>
            <button type="button" data-helper-insert={"<InquiryBox title=\"כאן מתחילה החקירה\" />"} class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-4 py-2 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]">+ הוסף InquiryBox</button>
            <button type="button" data-helper-insert="<WhatsAppButton />" class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-4 py-2 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]">+ הוסף WhatsAppButton</button>
          </div>
        </div>
      </section>

      <aside class="space-y-4">
        <div id="validationBox" class="hidden rounded-[1.6rem] border border-[#D42B2B]/14 bg-[#FFF4F3] p-5 text-right">
          <h3 class="text-lg font-semibold text-[#1A1A1A]">בדיקת איכות (QA)</h3>
          <ul id="errorList" class="mt-3 space-y-2 text-sm leading-7 text-[#1A1A1A]/78"></ul>
        </div>

        <div class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right">
          <h3 class="text-lg font-semibold text-[#1A1A1A]">סטטוס פרסום</h3>
          <p id="publishStatusText" class="mt-3 text-sm leading-7 text-[#1A1A1A]/68">ממתין לתוכן. ברגע שיהיה שלד תקין ותבחר שלב עבודה, תוכל להעתיק MDX או לפתוח קובץ חדש ב-GitHub.</p>
        </div>

        <div class="space-y-3">
          <button id="copyMdx" type="button" class="inline-flex w-full items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]">העתק MDX מוכן</button>
          <button id="injectIntoSandbox" type="button" class="inline-flex w-full items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white px-5 py-3 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-[#FAFAF8]">העבר לתצוגה מקדימה</button>
          <button id="publishToGithub" type="button" class="inline-flex w-full items-center justify-center rounded-full bg-[#D42B2B] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#ba2424]">?? פרסם ישירות ל-GitHub</button>
        </div>

        <div class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right">
          <h4 class="text-base font-semibold text-[#1A1A1A]">תצוגה מקדימה לחבילה מוצעת</h4>
          <p id="upsellText" class="mt-3 text-sm leading-7 text-[#1A1A1A]/68">${upsellPreviewText} (סנכרון אוטומטי מ־services.json)</p>
        </div>
      </aside>
    </section>
  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      const form = document.getElementById("prompt-generator-form");
      const rawText = document.getElementById("raw-text");
      const sitemap = document.getElementById("sitemap");
      const videoUrl = document.getElementById("video-url");
      const videoHelper = document.getElementById("video-helper");
      const videoTranscriptNotes = document.getElementById("video-transcript-notes");
      const isPremium = document.getElementById("is-premium");
      const includeTruthSlider = document.getElementById("include-truth-slider");
      const selectedPreset = document.getElementById("selected-preset");
      const presetDescription = document.getElementById("preset-description");
      const presetButtons = Array.from(document.querySelectorAll(".preset-button"));
      const output = document.getElementById("generated-prompt");
      const copyButton = document.getElementById("copy-prompt");
      const previewInput = document.getElementById("preview-mdx");
      const renderPreviewButton = document.getElementById("render-preview");
      const copyCleanMdxButton = document.getElementById("copy-clean-mdx");
      const exportMdxButton = document.getElementById("export-mdx");
      const clearPreviewButton = document.getElementById("clear-preview");
      const copyFilenameButton = document.getElementById("copy-filename");
      const copyCommitMessageButton = document.getElementById("copy-commit-message");
      const copyDescriptionSeedButton = document.getElementById("copy-description-seed");
      const applyAutofixButton = document.getElementById("apply-autofix");
      const exportPackageButton = document.getElementById("export-package");
      const suggestedFilename = document.getElementById("suggested-filename");
      const suggestedCommit = document.getElementById("suggested-commit");
      const suggestedDescription = document.getElementById("suggested-description");
      const validatorOutput = document.getElementById("validator-output");
      const autofixOutput = document.getElementById("autofix-output");
      const githubReadyOutput = document.getElementById("github-ready-output");
      const articlePreview = document.getElementById("article-preview");
      const previewStatus = document.getElementById("preview-status");

      if (!(form instanceof HTMLFormElement)) return;
      if (!(rawText instanceof HTMLTextAreaElement)) return;
      if (!(sitemap instanceof HTMLTextAreaElement)) return;
      if (!(videoUrl instanceof HTMLInputElement)) return;
      if (!(videoHelper instanceof HTMLElement)) return;
      if (!(videoTranscriptNotes instanceof HTMLTextAreaElement)) return;
      if (!(isPremium instanceof HTMLInputElement)) return;
      if (!(includeTruthSlider instanceof HTMLInputElement)) return;
      if (!(selectedPreset instanceof HTMLInputElement)) return;
      if (!(presetDescription instanceof HTMLElement)) return;
      if (!(output instanceof HTMLElement)) return;
      if (!(copyButton instanceof HTMLButtonElement)) return;
      if (!(previewInput instanceof HTMLTextAreaElement)) return;
      if (!(renderPreviewButton instanceof HTMLButtonElement)) return;
      if (!(copyCleanMdxButton instanceof HTMLButtonElement)) return;
      if (!(exportMdxButton instanceof HTMLButtonElement)) return;
      if (!(clearPreviewButton instanceof HTMLButtonElement)) return;
      if (!(copyFilenameButton instanceof HTMLButtonElement)) return;
      if (!(copyCommitMessageButton instanceof HTMLButtonElement)) return;
      if (!(copyDescriptionSeedButton instanceof HTMLButtonElement)) return;
      if (!(applyAutofixButton instanceof HTMLButtonElement)) return;
      if (!(exportPackageButton instanceof HTMLButtonElement)) return;
      if (!(suggestedFilename instanceof HTMLElement)) return;
      if (!(suggestedCommit instanceof HTMLElement)) return;
      if (!(suggestedDescription instanceof HTMLElement)) return;
      if (!(validatorOutput instanceof HTMLElement)) return;
      if (!(autofixOutput instanceof HTMLElement)) return;
      if (!(githubReadyOutput instanceof HTMLElement)) return;
      if (!(articlePreview instanceof HTMLElement)) return;
      if (!(previewStatus instanceof HTMLElement)) return;

      const normalizeBlock = (value) =>
        value
          .split(/\r?\n/)
          .map((line) => line.trim())
          .filter(Boolean)
          .join("\n");

      const getCleanMdx = () => previewInput.value.replace(/\r\n/g, "\n").trim();

      const slugify = (value) =>
        String(value ?? "")
          .toLowerCase()
          .replace(/['"`]/g, "")
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "") || "new-article";

      const extractYouTubeId = (value) => {
        const source = String(value ?? "").trim();
        if (!source) return "";
        if (/^[a-zA-Z0-9_-]{11}$/.test(source)) return source;

        try {
          const url = new URL(source);
          const host = url.hostname.replace(/^www\./, "");
          if (host === "youtu.be") {
            return url.pathname.split("/").filter(Boolean)[0] || "";
          }
          if (host.endsWith("youtube.com")) {
            if (url.searchParams.get("v")) return url.searchParams.get("v") || "";
            const parts = url.pathname.split("/").filter(Boolean);
            const markerIndex = parts.findIndex((part) => ["embed", "shorts", "live"].includes(part));
            if (markerIndex !== -1 && parts[markerIndex + 1]) return parts[markerIndex + 1];
          }
        } catch {
          return "";
        }

        return "";
      };

      const createVideoSeed = (url, youtubeId) => {
        if (!url && !youtubeId) {
          return {
            descriptionSeed: "",
            promptSeed: "",
            helperText: "עדיין לא הוזן לינק וידאו.",
          };
        }

        if (youtubeId) {
          return {
            descriptionSeed: "מאמר מבוסס וידאו שמזקק את הרעיון המרכזי לשפה פשוטה וברורה.",
            promptSeed: `Use the provided video source as a structural anchor. Extract the core promise of the video, summarize the practical insight in plain language, and make the article useful even for readers who will never press play. The extracted youtubeId is: ${youtubeId}.`,
            helperText: `זוהה youtubeId: ${youtubeId}`,
          };
        }

        return {
          descriptionSeed: "מאמר מבוסס וידאו שדורש בדיקה ידנית של הקישור לפני פרסום.",
          promptSeed: "A video URL was provided but no valid youtubeId could be extracted. Tell the model to avoid inventing an ID and to leave youtubeId empty if extraction is impossible.",
          helperText: "הלינק הוזן, אבל לא הצלחתי לחלץ ממנו youtubeId תקין.",
        };
      };

      const createMetaHelpers = (meta) => {
        const extractedVideoId = extractYouTubeId(videoUrl.value);
        const videoSeed = createVideoSeed(videoUrl.value.trim(), extractedVideoId);
        const baseTitle = String(meta.title || "").replace(/^"|"$/g, "").trim();
        const fallbackTitle = selectedPreset.value === "video" && extractedVideoId ? `video-${extractedVideoId}` : "new article";
        const filename = `${slugify(baseTitle || fallbackTitle)}.mdx`;
        const commitTopic = baseTitle || fallbackTitle;
        const commitMessage = `feat: added guide on ${commitTopic}`;
        const descriptionSeed = String(meta.description || "").trim() || videoSeed.descriptionSeed || "תיאור קצר, מדויק, וסקרן ל-SEO.";
        return { filename, commitMessage, descriptionSeed };
      };

      const updateVideoHelper = () => {
        const source = videoUrl.value.trim();
        const youtubeId = extractYouTubeId(source);
        const videoSeed = createVideoSeed(source, youtubeId);
        const transcriptSummary = videoTranscriptNotes.value.trim()
          ? `תמלול/הערות: ${videoTranscriptNotes.value.trim().split(/\s+/).length} מילים בקירוב.`
          : "אין עדיין הערות וידאו.";
        videoHelper.innerHTML = `<p>${escapeHtml(videoSeed.helperText)}</p><p class="mt-1">${escapeHtml(transcriptSummary)}</p>`;
      };

      const formatScalar = (value) => `"${String(value ?? "").replace(/"/g, '\\"')}"`;

      const formatBoolean = (value, fallback = false) => {
        if (typeof value === "boolean") return value ? "true" : "false";
        const normalized = String(value ?? "").toLowerCase();
        if (normalized === "true" || normalized === "false") return normalized;
        return fallback ? "true" : "false";
      };

      const formatWorkflowStatus = (value, draftValue) => {
        const normalized = String(value ?? "").trim().toLowerCase();
        const allowed = ["writing", "review", "ready", "published"];
        if (allowed.includes(normalized)) return formatScalar(normalized);
        const inferred = String(draftValue ?? "true").toLowerCase() === "false" ? "published" : "writing";
        return formatScalar(inferred);
      };

      const formatTags = (value) => {
        const source = Array.isArray(value)
          ? value
          : String(value ?? "")
              .split(",")
              .map((item) => item.trim())
              .filter(Boolean);
        const tags = source.length > 0 ? source : ["בהירות"];
        return `[${tags.map((tag) => `"${String(tag).replace(/"/g, '\\"')}"`).join(", ")}]`;
      };

      const buildCanonicalFrontmatter = (meta, existingFaqBlock = "faq: []") => {
        const lines = [
          "---",
          `title: ${formatScalar(meta.title || "")}`,
          `description: ${formatScalar(meta.description || "")}`,
          `pubDate: ${meta.pubDate || new Date().toISOString().slice(0, 10)}`,
          `updatedDate: ${formatScalar(meta.updatedDate || "")}`,
          `author: ${formatScalar(meta.author || "השם לא משנה")}`,
          `tags: ${formatTags(meta.tags)}`,
          `image: ${formatScalar(meta.image || "/og.jpg")}`,
          `canonicalUrl: ${formatScalar(meta.canonicalUrl || "")}`,
          `keywords: ${formatScalar(meta.keywords || "")}`,
          `audioUrl: ${formatScalar(meta.audioUrl || "")}`,
          `youtubeId: ${formatScalar(meta.youtubeId || extractYouTubeId(videoUrl.value) || "")}`,
          `tallyUrl: ${formatScalar(meta.tallyUrl || "")}`,
          `isPremium: ${formatBoolean(meta.isPremium, false)}`,
          `draft: ${formatBoolean(meta.draft, true)}`,
          `workflowStatus: ${formatWorkflowStatus(meta.workflowStatus, meta.draft)}`,
          existingFaqBlock.trim() || "faq: []",
          "---",
        ];
        return lines.join("\n");
      };

      const applyFrontmatterAutofix = (raw) => {
        const normalized = raw.replace(/\r\n/g, "\n").trim();
        if (!normalized) return "";

        const frontmatterMatch = normalized.match(/^---\s*\n([\s\S]*?)\n---\s*\n?/);
        const parsed = parseFrontmatter(normalized);
        const body = parsed.body.trim();
        const meta = parsed.meta;
        let faqBlock = "faq: []";

        if (frontmatterMatch) {
          const faqMatch = frontmatterMatch[1].match(/(^faq:\s*[\s\S]*$)/m);
          if (faqMatch) faqBlock = faqMatch[1].trim();
        }

        const frontmatter = buildCanonicalFrontmatter(meta, faqBlock);
        return `${frontmatter}\n\n${body}`.trim() + "\n";
      };

      const escapeHtml = (value) =>
        value
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/\"/g, "&quot;")
          .replace(/'/g, "&#39;");

      const renderInline = (value) => {
        let result = escapeHtml(value);
        result = result.replace(/`([^`]+)`/g, "<code class=\"rounded bg-[#1A1A1A]/6 px-1.5 py-0.5 text-[0.92em]\">$1</code>");
        result = result.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
        result = result.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-[#D42B2B] underline decoration-[#D42B2B]/30 underline-offset-4">$1</a>');
        return result;
      };

      const parseAttributes = (value) => {
        const attrs = {};
        const attrRegex = /(\w+)="([^"]*)"/g;
        let match;
        while ((match = attrRegex.exec(value)) !== null) {
          attrs[match[1]] = match[2];
        }
        return attrs;
      };

      const parseFrontmatter = (raw) => {
        const frontmatterMatch = raw.match(/^---\s*\n([\s\S]*?)\n---\s*\n?/);
        if (!frontmatterMatch) {
          return { meta: {}, body: raw.trim() };
        }

        const meta = {};
        const lines = frontmatterMatch[1].split(/\r?\n/);

        for (const line of lines) {
          const trimmed = line.trim();
          if (!trimmed || trimmed.startsWith("faq:")) continue;
          const index = trimmed.indexOf(":");
          if (index === -1) continue;

          const key = trimmed.slice(0, index).trim();
          const rawValue = trimmed.slice(index + 1).trim();

          if (rawValue.startsWith("[") && rawValue.endsWith("]")) {
            meta[key] = rawValue
              .slice(1, -1)
              .split(",")
              .map((item) => item.trim().replace(/^"|"$/g, ""))
              .filter(Boolean);
          } else {
            meta[key] = rawValue.replace(/^"|"$/g, "");
          }
        }

        const body = raw.slice(frontmatterMatch[0].length).trim();
        return { meta, body };
      };

      const validateMdx = (meta, body) => {
        const extractedVideoId = extractYouTubeId(videoUrl.value);
        const videoPresetActive = selectedPreset.value === "video";
        const checks = [
          {
            label: "כותרת",
            ok: Boolean(meta.title),
            detail: meta.title ? `נמצאה כותרת (${String(meta.title).length} תווים)` : "חסר title",
          },
          {
            label: "תיאור",
            ok: Boolean(meta.description),
            detail: meta.description ? `נמצא description (${String(meta.description).length} תווים)` : "חסר description",
          },
          {
            label: "תאריך פרסום",
            ok: Boolean(meta.pubDate),
            detail: meta.pubDate ? `pubDate = ${meta.pubDate}` : "חסר pubDate",
          },
          {
            label: "טיוטה",
            ok: Object.prototype.hasOwnProperty.call(meta, "draft"),
            detail: Object.prototype.hasOwnProperty.call(meta, "draft") ? `draft = ${meta.draft}` : "חסר draft",
          },
          {
            label: "תור עבודה",
            ok: ["writing", "review", "ready", "published"].includes(String(meta.workflowStatus || "")),
            detail: ["writing", "review", "ready", "published"].includes(String(meta.workflowStatus || ""))
              ? `workflowStatus = ${meta.workflowStatus}`
              : "חסר workflowStatus או שהערך לא תקין",
          },
          {
            label: "שאלות FAQ",
            ok: /faq\s*:/m.test(previewInput.value),
            detail: /faq\s*:/m.test(previewInput.value) ? "נמצא מקטע FAQ" : "לא זוהה FAQ",
          },
          {
            label: "גוף המאמר",
            ok: Boolean(body.trim()),
            detail: body.trim() ? `זוהה גוף מאמר (${body.trim().split(/\s+/).length} מילים בקירוב)` : "גוף המאמר ריק",
          },
          {
            label: "youtubeId",
            ok: !videoPresetActive || Boolean(meta.youtubeId || extractedVideoId),
            detail: !videoPresetActive
              ? "לא חובה בפריסט הנוכחי"
              : meta.youtubeId || extractedVideoId
                ? `youtubeId = ${meta.youtubeId || extractedVideoId}`
                : "נבחר preset של וידאו אבל לא זוהה youtubeId",
          },
        ];

        return checks;
      };

      const renderValidator = (checks) => {
        validatorOutput.innerHTML = checks
          .map((check) => {
            const tone = check.ok
              ? "border-[#1A1A1A]/10 bg-white/80 text-[#1A1A1A]/72"
              : "border-[#D42B2B]/18 bg-[#FFF4F3] text-[#1A1A1A]/78";
            const badge = check.ok ? "תקין" : "חסר";
            return `<div class="rounded-2xl border px-4 py-3 ${tone}">
              <div class="flex items-center justify-between gap-3">
                <span class="text-sm font-semibold">${check.label}</span>
                <span class="text-xs font-semibold uppercase tracking-[0.18em] ${check.ok ? "text-[#1A1A1A]/48" : "text-[#D42B2B]"}">${badge}</span>
              </div>
              <p class="mt-2 text-sm leading-6">${escapeHtml(check.detail)}</p>
            </div>`;
          })
          .join("");
      };

      const renderAutofixSuggestions = (meta, body, checks) => {
        const suggestions = [];
        const extractedVideoId = extractYouTubeId(videoUrl.value);
        if (!meta.title) suggestions.push('הוסף title חד וקצר ב-frontmatter.');
        if (!meta.description) suggestions.push('הוסף description עד 160 תווים.');
        if (!meta.pubDate) suggestions.push('הוסף pubDate בפורמט YYYY-MM-DD.');
        if (!Object.prototype.hasOwnProperty.call(meta, "draft")) suggestions.push('הוסף draft: true או draft: false במפורש.');
