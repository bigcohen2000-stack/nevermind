  <script is:inline>
    (function () {
      function splitFmBody(raw) {
        const m = String(raw || "").match(/^---\r?\n([\s\S]*?)\r?\n---\s*\r?\n([\s\S]*)$/);
        if (!m) return { fm: "", body: String(raw || "") };
        return { fm: m[1], body: m[2] };
      }
      function unescapeYamlString(s) {
        return String(s || "")
          .replace(/\\"/g, '"')
          .replace(/\\\\/g, "\\");
      }
      function extractYamlQuoted(fm, key) {
        const re = new RegExp(`^${key}:\\s*"((?:\\\\.|[^"\\\\])*)"`, "m");
        const x = fm.match(re);
        return x ? unescapeYamlString(x[1]) : "";
      }
      function extractYoutubeFromFm(fm) {
        const q = extractYamlQuoted(fm, "youtubeId");
        if (q) return q;
        const m = fm.match(/^youtubeId:\s*([a-zA-Z0-9_-]{11})\s*$/m);
        return m ? m[1] : "";
      }

      window.__nmBuildMdxQaRows = function (mdxText, opts) {
        const profile = (opts && opts.profile) || "srt";
        const raw = String(mdxText || "").trim();
        if (!raw) return [];
        const { fm, body } = splitFmBody(raw);
        const title = extractYamlQuoted(fm, "title");
        const description = extractYamlQuoted(fm, "description");
        const yt = extractYoutubeFromFm(fm);
        const bottomLine = extractYamlQuoted(fm, "bottomLine");
        const refMatch = fm.match(/reflectionQuestions:\s*\n((?:\s+-\s[^\n]*\n)+)/);
        const refCount = refMatch ? (refMatch[1].match(/^\s+-\s/gm) || []).length : 0;
        const faqCount = (fm.match(/^\s+-\s+question:/gm) || []).length;
        const h2Count = (body.match(/^##\s+/gm) || []).length;
        const bodyForWordCount = body.replace(/<RevealInsight\b[^>]*>[\s\S]*?<\/RevealInsight>/gi, " ");
        const plain = bodyForWordCount.replace(/<[^>]+>/g, " ");
        const wordish = plain.split(/\s+/).filter(Boolean).length;
        const clicheHits = ["תהליך רוחני", "מסע של", "צמיחה רוחנית"].filter((c) => body.includes(c));

        /** @type {{ ok: boolean; label: string }[]} */
        const rows = [];
        const row = (ok, label) => rows.push({ ok, label });

        row(title.length >= 20, `כותרת: מינימום 20 תווים (עכשיו ${title.length})`);
        row(description.length >= 80 && description.length <= 170, `תיאור: בערך 80–160 תווים (עכשיו ${description.length})`);

        if (profile === "composer") {
          row(!yt || /^[a-zA-Z0-9_-]{11}$/.test(yt), yt ? "youtubeId: 11 תווים תקינים" : "youtubeId: ריק (מאמר ללא וידאו)");
          row(refCount === 0 || refCount === 3, `reflectionQuestions: 0 או 3 (עכשיו ${refCount})`);
          row(faqCount === 0 || faqCount === 3, `faq: ריק או 3 שאלות (עכשיו ${faqCount})`);
        } else {
          row(/^[a-zA-Z0-9_-]{11}$/.test(yt), "youtubeId: 11 תווים תקינים");
          row(refCount === 3, `reflectionQuestions: בדיוק 3 (עכשיו ${refCount})`);
          row(faqCount === 3, `faq: בדיוק 3 שאלות (עכשיו ${faqCount})`);
        }

        row(h2Count >= 2, `לפחות 2 כותרות ## (עכשיו ${h2Count})`);
        row(/<SkepticBox\b/i.test(body), "גוף: SkepticBox");
        row(/<ConceptCallout\b/i.test(body), "גוף: ConceptCallout");
        row(/<WhatsAppButton\b/i.test(body) || /<InquiryBox\b/i.test(body), "גוף: WhatsAppButton או InquiryBox");

        if (profile === "srt") {
          row(/<RevealInsight\b/i.test(body), "גוף: RevealInsight (תמלול)");
          row(/<VideoPlayer\b/i.test(body), "גוף: VideoPlayer");
        } else if (yt) {
          row(/<VideoPlayer\b/i.test(body), "גוף: VideoPlayer (נדרש כשיש youtubeId)");
        }

        row(clicheHits.length === 0, clicheHits.length ? `שפה: ערוך קלישאות — ${clicheHits.join(", ")}` : "שפה: ללא קלישאות נבדקות");
        row(
          wordish < 900 || bottomLine.trim().length >= 20,
          `bottomLine: ${wordish >= 900 ? `מומלץ למאמר ארוך (~${wordish} מילים בגוף, בלי תמלול ב-RevealInsight)` : "לא חובה בטיוטה קצרה"}`,
        );

        return rows;
      };

      window.__nmRenderMdxQaToDom = function (mdxText, listEl, panelEl, opts) {
        const raw = String(mdxText || "").trim();
        if (!listEl || !panelEl) return { allOk: true, total: 0, passed: 0 };
        if (!raw) {
          panelEl.classList.add("hidden");
          listEl.innerHTML = "";
          return { allOk: true, total: 0, passed: 0 };
        }
        const rows = window.__nmBuildMdxQaRows(raw, opts || { profile: "srt" });
        listEl.innerHTML = "";
        let passed = 0;
        for (const { ok, label } of rows) {
          if (ok) passed += 1;
          const li = document.createElement("li");
          li.textContent = `${ok ? "✓" : "✗"} ${label}`;
          li.className = ok ? "text-[#166534]" : "text-[#b91c1c]";
          listEl.appendChild(li);
        }
        panelEl.classList.remove("hidden");
        const allOk = passed === rows.length && rows.length > 0;
        return { allOk, total: rows.length, passed };
      };

      window.__nmCopyLargeText = function (text) {
        return new Promise((resolve) => {
          function fallbackExec() {
            const t = String(text ?? "");
            const ta = document.createElement("textarea");
            ta.value = t;
            ta.setAttribute("readonly", "");
            ta.style.position = "fixed";
            ta.style.opacity = "0";
            ta.style.left = "-9999px";
            ta.style.top = "0";
            document.body.appendChild(ta);
            ta.focus();
            ta.select();
            ta.setSelectionRange(0, t.length);
            let ok = false;
            try {
              ok = document.execCommand("copy");
            } catch {
              ok = false;
            }
            ta.remove();
            return ok;
          }
          const s = String(text ?? "");
          if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard
              .writeText(s)
              .then(() => resolve(true))
              .catch(() => resolve(fallbackExec()));
          } else {
            resolve(fallbackExec());
          }
        });
      };

      function nmBuildImagePromptForPack(opts) {
        const topic = opts.topic || "the article theme";
        const type = opts.type || "minimal";
        const base = [
          "Minimalist 3D render, pure white background #f8fafc,",
          "studio lighting, sharp shadows.",
          "Brand colors: deep red #D42B2B as accent,",
          "near-black #000000 for shadows, off-white #f8fafc background.",
          "No text. No humans. No logos. No clutter.",
          "Aspect ratio 16:9. Ultra clean, architectural.",
        ].join("\n");
        const typeMap = {
          object: `Single object that metaphorically represents: ${topic}`,
          abstract: `Abstract geometric form suggesting: ${topic}`,
          landscape: `Minimal landscape metaphor for: ${topic}`,
          minimal: `Single pure shape representing: ${topic}`,
        };
        const head = typeMap[type] || typeMap.minimal;
        return `${head}\n${base}`;
      }

      window.__nmBuildNeverMindShortPrompt = function (mdxFull, opts) {
        const source = (opts && opts.source) || "srt";
        const lines =
          source === "composer"
            ? [
                "אתה עורך תוכן לאתר NeverMind (עברית). להלן MDX של מאמר מהעורך הפנימי.",
                "משימה: שפר ניסוח, חדד היררכיית H2, חיזוק SkepticBox ו-ConceptCallout, description בערך 80–160 תווים וכותרת 20+ תווים.",
                "אל תמחק שדות frontmatter קיימים. אם reflectionQuestions או faq ריקים — אפשר להשלים אחרי חידוד הגוף.",
                "שמור רכיבי MDX. הוסף דוגמה ישראלית יומיומית אחת לפחות אם חסרה.",
                "החזר את קובץ ה-MDX המלא בלבד, בלי טקסט נלווה.",
              ]
            : [
                "אתה עורך תוכן לאתר NeverMind (עברית). להלן קובץ MDX שלד שנבנה מתמלול וידאו.",
                "משימה: שפר ניסוח, חדד כותרות H2, מלא SkepticBox ו-ConceptCallout בתוכן אמיתי (לא placeholder), ודא description בין 80 ל-160 תווים וכותרת 20+ תווים.",
                "שמור: מבנה frontmatter, שמות שדות, youtubeId, רשימות reflectionQuestions (3) ו-faq (3) — אפשר לנסח מחדש רק את הטקסטים בתוך המרכאות.",
                "שמור את כל רכיבי ה-MDX הקיימים (VideoPlayer, RevealInsight, וכו'). הוסף דוגמה ישראלית יומיומית אחת לפחות בגוף.",
                "החזר את קובץ ה-MDX המלא בלבד, בלי הסבר לפני או אחרי.",
              ];
        return [...lines, "", "---", String(mdxFull || "").trim()].join("\n");
      };

      window.__nmBuildNeverMindMegaPrompt = function (mdxFull, opts) {
        const source = (opts && opts.source) || "srt";
        const raw = String(mdxFull || "").trim();
        const { fm } = splitFmBody(raw);
        const extractedTitle = extractYamlQuoted(fm, "title");
        const imgTopic =
          (opts && opts.imageTopic && String(opts.imageTopic).trim()) || extractedTitle || "נושא המאמר";
        const imgType = (opts && opts.imageType) || "minimal";
        const imagePromptEn = nmBuildImagePromptForPack({ topic: imgTopic, type: imgType });
        const srcLabel = source === "composer" ? "העורך הפנימי" : "ממיר תמלול SRT";

        const partA = `=== חלק א' — MDX סופי לפרסום (NeverMind) ===

אתה עורך בכיר לתוכן עברי בערוץ NeverMind («השם לא משנה»). מקור הקלט: ${srcLabel}.

משימתך בחלק זה: לקבל שלד MDX ולהחזיר קובץ MDX אחד, תקין תחבירית, מוכן לשמירה כ־.mdx ב־Astro Content Collections.

## שדות frontmatter (מבנה)
- title, description (חובה)
- bottomLine — מומלץ במיוחד אם גוף המאמר מעל ~900 מילים **ללא** הטקסט שבתוך RevealInsight (רק טקסט מאמר רגיל)
- pubDate, author, tags (מערך)
- image (ברירת מחדל "/og.jpg" אלא אם יש סיבה)
- youtubeId אופציונלי — אם קיים: בדיוק 11 תווים [a-zA-Z0-9_-]
- videoSummaryPoints — מערך נקודות לווידאו/SEO
- isPremium, draft, workflowStatus ∈ writing | review | ready | published
- difficultyLevel ∈ beginner | advanced | deep
- reflectionQuestions — בדיוק 3 מחרוזות
- faq — בדיוק 3 פריטים (question + answer)
- relatedConcepts, forbiddenLibrary — אל תמחק מפתחות קיימים
- אופציונלי: updatedDate, canonicalUrl, keywords, audioUrl, audioFile, tallyUrl
- אופציונלי (אחרי חלק ג' בחבילת AI): **slug** — מילה אחת או שתיים באנגלית lowercase (קונספט, לא תיאור ליטרלי)
- אופציונלי: **videoContent** — אובייקט עם hook, questions (מערך), visualDirection, reelScript, bridgeLogic (תסריט/לוגיקה להמשך צפייה)

## רכיבי MDX
אל תמחק ואל תשנה **שמות** רכיבים: VideoPlayer, RevealInsight, SkepticBox, ConceptCallout, InquiryBox, WhatsAppButton וכו'. מותר למלא תוכן במקום placeholders ולשפר ניסוח.
שמור על props תקינים (למשל youtubeId={...}, videoSummaryPoints={...}).

## מבנה גוף מומלץ
1. פתיחה קצרה — מה כואב לקורא (לא קלישאת «מסע»).
2. ## H2 ראשון — הכאב / הבעיה
3. ## H2 שני — פירוק הרעיון
4. ## H2 שלישי — אם חסר, הוסף — סגירה בהירה
