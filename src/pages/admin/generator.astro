      const tokenizeBody = (body) => {
        const lines = body.split(/\r?\n/);
        const tokens = [];
        let index = 0;

        while (index < lines.length) {
          const current = lines[index].trim();

          if (!current || current.startsWith("import ") || current.startsWith("export ")) {
            index += 1;
            continue;
          }

          if (current === "<!--premium-break-->") {
            tokens.push({ type: "premium-break" });
            index += 1;
            continue;
          }

          const selfClosingComponent = current.match(/^<(InquiryBox|SkepticBox|ConceptCallout|WhatsAppButton|LiteYouTubeEmbed|TruthSlider|פרספקטיבהToggle)([^>]*)\/>$/);
          if (selfClosingComponent) {
            tokens.push({
              type: "component",
              name: selfClosingComponent[1],
              attrs: parseAttributes(selfClosingComponent[2] || ""),
              content: "",
            });
            index += 1;
            continue;
          }

          const openingComponent = current.match(/^<(InquiryBox|SkepticBox|ConceptCallout)([^>]*)>$/);
          if (openingComponent) {
            const name = openingComponent[1];
            const attrs = parseAttributes(openingComponent[2] || "");
            const closingTag = `</${name}>`;
            const contentLines = [];
            index += 1;

            while (index < lines.length && lines[index].trim() !== closingTag) {
              contentLines.push(lines[index]);
              index += 1;
            }

            if (index < lines.length && lines[index].trim() === closingTag) {
              index += 1;
            }

            tokens.push({ type: "component", name, attrs, content: contentLines.join("\n").trim() });
            continue;
          }

          if (current.startsWith("## ")) {
            tokens.push({ type: "h2", content: current.slice(3).trim() });
            index += 1;
            continue;
          }

          if (current.startsWith("### ")) {
            tokens.push({ type: "h3", content: current.slice(4).trim() });
            index += 1;
            continue;
          }

          if (current.startsWith("- ")) {
            const items = [];
            while (index < lines.length && lines[index].trim().startsWith("- ")) {
              items.push(lines[index].trim().slice(2).trim());
              index += 1;
            }
            tokens.push({ type: "ul", items });
            continue;
          }

          const paragraph = [];
          while (index < lines.length) {
            const candidate = lines[index].trim();
            if (
              !candidate ||
              candidate.startsWith("## ") ||
              candidate.startsWith("### ") ||
              candidate.startsWith("- ") ||
              candidate === "<!--premium-break-->" ||
              candidate.startsWith("<InquiryBox") ||
              candidate.startsWith("<SkepticBox") ||
              candidate.startsWith("<ConceptCallout") ||
              candidate.startsWith("<WhatsAppButton") ||
              candidate.startsWith("<LiteYouTubeEmbed") ||
              candidate.startsWith("<TruthSlider") ||
              candidate.startsWith("<פרספקטיבהToggle") ||
              candidate.startsWith("import ") ||
              candidate.startsWith("export ")
            ) {
              break;
            }
            paragraph.push(lines[index].trim());
            index += 1;
          }

          if (paragraph.length > 0) {
            tokens.push({ type: "p", content: paragraph.join(" ") });
            continue;
          }

          index += 1;
        }

        return tokens;
      };

