          publishStatusText.textContent =
            "הפרומפט לתיקון השדה הועתק ללוח — הדבק ב-LLM, החזר את הטקסט המתוקן לשדה.";
        });
      });

      const insertTag = (tag) => {
        const start = postContent.selectionStart || 0;
        const end = postContent.selectionEnd || 0;
        const before = postContent.value.slice(0, start);
        const after = postContent.value.slice(end);
        const needsPadding = before && !before.endsWith("\n") ? "\n" : "";
        const suffixPadding = after && !after.startsWith("\n") ? "\n" : "";
        postContent.value = `${before}${needsPadding}${tag}${suffixPadding}${after}`;
        postContent.focus();
        postContent.selectionStart = postContent.selectionEnd = before.length + needsPadding.length + tag.length;
        renderValidation();
