---
import Layout from "../../layouts/Layout.astro";
import { FloatingInput } from "../../components/ui/FloatingInput";

const pageTitle = "Strategic Article Wizard";
const pageDescription = "אשף 3 שלבים ליצירת Master Prompt מדויק לכתיבת מאמר.";
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <section class="mx-auto max-w-4xl space-y-8 px-4 pb-16 text-right text-[var(--nm-fg)]">
    <header class="space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">Article Creator</p>
      <h1 class="text-[clamp(2rem,1.5rem+1.8vw,3.2rem)] font-semibold leading-[1.05]">Strategic Wizard</h1>
      <p class="text-[clamp(1rem,0.95rem+0.25vw,1.15rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
        שלושה שלבים קצרים. בסוף מתקבל Master Prompt מוכן להעתקה.
      </p>
    </header>

    <article id="nm-article-wizard" class="space-y-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 shadow-[0_22px_60px_color-mix(in_srgb,var(--nm-fg)_5%,transparent)] md:p-8">
      <div class="space-y-2">
        <div class="h-1.5 w-full overflow-hidden rounded-full bg-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)]">
          <div id="wizard-progress" class="h-full rounded-full bg-[var(--nm-accent)] transition-all duration-300" style="width: 33%;"></div>
        </div>
        <p id="wizard-step-label" class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">שלב 1 מתוך 3</p>
        </div>

      <section data-step="1" class="wizard-step space-y-4">
        <h2 class="text-2xl font-semibold">Step 1: The Core</h2>
        <FloatingInput
          client:load
          id="wiz-topic"
          label="Topic / Title - הנושא המרכזי"
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Target Audience</span>
          <select id="wiz-audience" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option>Beginners</option>
            <option>Advanced</option>
            <option>Internal Community</option>
          </select>
          </label>
        <FloatingInput
          client:load
          id="wiz-aha"
          label="originalInsight (תובנת ליבה — משפט אחד עד שלושה)"
          multiline
          rows={3}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <FloatingInput
          client:load
          id="wiz-question-schema"
          label="questionForSchema — שאלה מזוקקת למנועי חיפוש (עברית)"
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <FloatingInput
          client:load
          id="wiz-image-alt"
          label="imageAlt — מה התמונה מייצגת (קונספט + נגישות), לא רק 'מה רואים'"
          multiline
          rows={2}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <label class="block space-y-2">
          <span class="text-sm font-semibold">mindShiftIntensity (1–5)</span>
          <select id="wiz-mind-shift" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option value="1">1 — עדין</option>
            <option value="2">2</option>
            <option value="3" selected>3 — איזון</option>
            <option value="4">4</option>
            <option value="5">5 — חד</option>
          </select>
        </label>
        <FloatingInput
          client:load
          id="wiz-bottom-line"
          label="Bottom line (frontmatter bottomLine)"
          multiline
          rows={2}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <FloatingInput
          client:load
          id="wiz-inversion"
          label="Inversion / עומק (אופציונלי, inversionNote)"
          multiline
          rows={2}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <label class="flex cursor-pointer items-center gap-3 rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-4 py-3">
          <input id="wiz-is-premium" type="checkbox" class="size-4 accent-[var(--nm-accent)]" />
          <span class="text-sm font-semibold">תוכן פרימיום (isPremium)</span>
        </label>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">רמת עומק ב-MDX (difficultyLevel)</span>
          <select id="wiz-difficulty" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option value="beginner">מתחילים (beginner)</option>
            <option value="advanced">מתקדמים (advanced)</option>
            <option value="deep">עומק / קהילה (deep)</option>
          </select>
        </label>
        <div class="grid gap-4 md:grid-cols-2">
          <FloatingInput
            client:load
            id="wiz-slug"
            label="Clean Link (Slug)"
            dir="ltr"
            hideValidation={true}
            className="[&_.nm-floating-control]:bg-transparent [&_.nm-floating-control]:text-left"
          />
          <div class="space-y-1">
            <p class="text-xs text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">ממופה ל-description ב-frontmatter</p>
            <FloatingInput
              client:load
              id="wiz-summary"
              label="Marketing Summary - תקציר קצר ומדויק"
              hideValidation={true}
              className="[&_.nm-floating-control]:bg-transparent"
            />
          </div>
        </div>
        </section>

      <section data-step="2" class="wizard-step hidden space-y-4">
        <h2 class="text-2xl font-semibold">Step 2: Structure & Tone</h2>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Tone</span>
          <select id="wiz-tone" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option>Provocative</option>
            <option>Analytical</option>
            <option>Grounded</option>
          </select>
          </label>
        <FloatingInput
          client:load
          id="wiz-points"
          label="Key Bullet Points - כל נקודה בשורה חדשה"
          multiline
          rows={5}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Length</span>
          <select id="wiz-length" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option>Short Post</option>
            <option>Deep Dive</option>
            <option>Full Research</option>
          </select>
        </label>
        <FloatingInput
          client:load
          id="wiz-tags"
          label="Tags - בהירות, בחירה, פירוק"
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <FloatingInput
          client:load
          id="wiz-youtube"
          label="YouTube ID (אופציונלי, 11 תווים)"
          dir="ltr"
          maxLength={11}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent [&_.nm-floating-control]:text-left"
        />
        <FloatingInput
          client:load
          id="wiz-body"
          label="Draft Body (Markdown, אופציונלי)"
          multiline
          rows={6}
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-transparent"
        />
        <p id="wiz-word-count" class="text-xs font-semibold text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">מילים בטיוטה: 0</p>
        <div
          id="wiz-blockers"
          class="hidden rounded-[1rem] border border-red-600/35 bg-red-50 px-4 py-3 text-xs font-semibold leading-6 text-red-900"
          aria-live="assertive"
        />
        <div
          id="wiz-preflight"
          class="rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3 text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]"
          aria-live="polite"
        >
          בדיקות לפני שלב 3: חסימות באדום למעלה. כאן אזהרות בלבד.
          </div>
      </section>

      <section data-step="3" class="wizard-step hidden space-y-4">
        <h2 class="text-2xl font-semibold">Step 3: Final Review & Generator</h2>
        <button id="wiz-generate" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-6 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">
          Generate Master Prompt
          </button>
        <FloatingInput
          client:load
          id="wiz-output"
          label="Master Prompt"
          multiline
          rows={12}
          readOnly={true}
          hideValidation={true}
          dir="ltr"
          defaultValue=""
          className="[&_.nm-floating-control]:bg-[var(--nm-surface-muted)] [&_.nm-floating-control]:text-left [&_.nm-floating-control]:leading-7"
        />
        <button id="wiz-copy" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          Copy to Clipboard
          </button>
        <button id="wiz-save" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          Save Draft Data
          </button>
        <p id="wiz-save-status" class="text-xs font-semibold text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]"></p>
      </section>

      <div class="flex items-center justify-between gap-3">
        <button id="wiz-back" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-5 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          חזור
            </button>
        <button id="wiz-next" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-2 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">
          המשך
            </button>
            </div>
    </article>
  </section>

  <script lang="ts">
    import { ARTICLE_TAG_WHITELIST, ARTICLE_TAG_WHITELIST_SET } from "../../data/article-tags";
    import { ROBOTIC_BLOCKLIST, SENSITIVE_TOPIC_WARNING, validateAndClassify } from "../../utils/contentValidator";
    import { validateContent } from "../../utils/validateContent";

    const SLUG_EN_RE = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
    const YOUTUBE_ID_RE = /^[a-zA-Z0-9_-]{11}$/;
    const WORD_WARN = 900;
    const WORD_DEEP = 1400;

    function countWords(raw: string): number {
      return raw
        .trim()
        .split(/\s+/)
        .filter((w) => w.length > 0).length;
    }

    function runBlockingChecks(data: {
      tags: string;
      body: string;
      summary: string;
      bottomLine: string;
      topic: string;
      aha: string;
      questionForSchema: string;
      imageAlt: string;
      slug: string;
    }): string[] {
      const errors: string[] = [];
      const slug = data.slug.trim();
      if (!slug) errors.push("חסר slug באנגלית.");
      else if (!SLUG_EN_RE.test(slug)) errors.push("slug חייב באנגלית קטנה, מקפים בלבד, בלי רווחים.");

      const tagParts = data.tags
        .split(/[,،]/)
        .map((t) => t.trim())
        .filter(Boolean);
      if (tagParts.length === 0) errors.push("חסרות תגיות. רק מהרשימה הקנונית ב-src/data/article-tags.ts.");
      for (const t of tagParts) {
        if (!ARTICLE_TAG_WHITELIST_SET.has(t)) {
          errors.push(`תגית לא ברשימה המאושרת: "${t}".`);
        }
      }

      const scanBlob = [
        data.body,
        data.summary,
        data.bottomLine,
        data.topic,
        data.aha,
        data.questionForSchema,
        data.imageAlt,
      ].join("\n");
      const { hits } = validateContent(scanBlob);
      if (hits.length > 0) {
        errors.push(`מילים/ביטויים חסומים ב-Content Score: ${hits.join(", ")}.`);
      }

      if (!data.questionForSchema.trim()) errors.push("חסר questionForSchema.");
      if (!data.aha.trim()) errors.push("חסר originalInsight (שדה תובנת ליבה).");
      if (!data.imageAlt.trim()) errors.push("חסר imageAlt.");

      return errors;
    }

    function runPreflight(data: {
      tags: string;
      youtubeId: string;
      body: string;
      summary: string;
    }): string[] {
      const warnings: string[] = [];
      const yt = data.youtubeId.trim();
      if (yt && !YOUTUBE_ID_RE.test(yt)) {
        warnings.push("מזהה YouTube לא תקין (צפוי בדיוק 11 תווים, אותיות מספרים מקף תחתון).");
      }
      const desc = data.summary.trim();
      if (desc.length > 0 && (desc.length < 150 || desc.length > 160)) {
        warnings.push(`Meta description צריך להיות בין 150 ל-160 תווים. כעת: ${desc.length}.`);
      }
      const wc = countWords(data.body);
      if (wc > 0 && wc < 120) {
        warnings.push(`מעט מילים בטיוטה (${wc}). אם זה מכוון, בסדר.`);
      }
      if (wc >= WORD_DEEP) {
        warnings.push(`הטיוטה ארוכה (${wc} מילים). זה מתאים בדרך כלל ל-deep / מחקר מלא.`);
      } else if (wc >= WORD_WARN) {
        warnings.push(`הטיוטה מעל ${WORD_WARN} מילים. שקול difficultyLevel: advanced או deep.`);
      }
      return warnings;
    }

    document.addEventListener("astro:page-load", () => {
      const root = document.getElementById("nm-article-wizard");
      if (!(root instanceof HTMLElement)) return;

      const steps = Array.from(root.querySelectorAll(".wizard-step"));
      const progress = document.getElementById("wizard-progress");
      const stepLabel = document.getElementById("wizard-step-label");
      const backBtn = document.getElementById("wiz-back");
      const nextBtn = document.getElementById("wiz-next");
      const genBtn = document.getElementById("wiz-generate");
      const copyBtn = document.getElementById("wiz-copy");
      const output = document.getElementById("wiz-output");
      const saveBtn = document.getElementById("wiz-save");
      const saveStatus = document.getElementById("wiz-save-status");
      const topic = document.getElementById("wiz-topic");
      const audience = document.getElementById("wiz-audience");
      const aha = document.getElementById("wiz-aha");
      const bottomLine = document.getElementById("wiz-bottom-line");
      const inversion = document.getElementById("wiz-inversion");
      const isPremium = document.getElementById("wiz-is-premium");
      const difficulty = document.getElementById("wiz-difficulty");
      const slug = document.getElementById("wiz-slug");
      const questionSchema = document.getElementById("wiz-question-schema");
      const imageAlt = document.getElementById("wiz-image-alt");
      const mindShift = document.getElementById("wiz-mind-shift");
      const summary = document.getElementById("wiz-summary");
      const tone = document.getElementById("wiz-tone");
      const points = document.getElementById("wiz-points");
      const length = document.getElementById("wiz-length");
      const tags = document.getElementById("wiz-tags");
      const youtube = document.getElementById("wiz-youtube");
      const body = document.getElementById("wiz-body");
      const wordCountEl = document.getElementById("wiz-word-count");
      const preflightEl = document.getElementById("wiz-preflight");
      const blockersEl = document.getElementById("wiz-blockers");

      let current = 1;

      const collectData = () => ({
        topic: topic instanceof HTMLInputElement ? topic.value.trim() : "",
        audience: audience instanceof HTMLSelectElement ? audience.value : "",
        aha: aha instanceof HTMLTextAreaElement ? aha.value.trim() : "",
        bottomLine: bottomLine instanceof HTMLTextAreaElement ? bottomLine.value.trim() : "",
        inversionNote: inversion instanceof HTMLTextAreaElement ? inversion.value.trim() : "",
        isPremium: isPremium instanceof HTMLInputElement ? isPremium.checked : false,
        difficultyLevel: difficulty instanceof HTMLSelectElement ? difficulty.value : "beginner",
        slug: slug instanceof HTMLInputElement ? slug.value.trim() : "",
        questionForSchema:
          questionSchema instanceof HTMLInputElement || questionSchema instanceof HTMLTextAreaElement
            ? questionSchema.value.trim()
            : "",
        imageAlt:
          imageAlt instanceof HTMLInputElement || imageAlt instanceof HTMLTextAreaElement
            ? imageAlt.value.trim()
            : "",
        mindShiftIntensity: mindShift instanceof HTMLSelectElement ? mindShift.value : "3",
        summary: summary instanceof HTMLInputElement ? summary.value.trim() : "",
        tone: tone instanceof HTMLSelectElement ? tone.value : "",
        points: points instanceof HTMLTextAreaElement ? points.value : "",
        length: length instanceof HTMLSelectElement ? length.value : "",
        tags: tags instanceof HTMLInputElement ? tags.value.trim() : "",
        youtubeId: youtube instanceof HTMLInputElement ? youtube.value.trim() : "",
        body: body instanceof HTMLTextAreaElement ? body.value : "",
      });

      function updateWordCountAndPreflight() {
        const data = collectData();
        const wc = countWords(data.body);
        if (wordCountEl) wordCountEl.textContent = `מילים בטיוטה: ${wc}`;
        if (current === 2) {
          const blockers = runBlockingChecks(data);
          if (blockersEl) {
            if (blockers.length > 0) {
              blockersEl.classList.remove("hidden");
              blockersEl.textContent = ["חסימות (לא עוברים לשלב 3):", ...blockers.map((x) => `• ${x}`)].join("\n");
            } else {
              blockersEl.classList.add("hidden");
              blockersEl.textContent = "";
            }
          }
        if (preflightEl) {
          const w = runPreflight(data);
          const scanBlob = [
            data.body,
            data.summary,
            data.bottomLine,
            data.topic,
            data.aha,
            data.questionForSchema,
            data.imageAlt,
          ].join("\n");
          const c = validateAndClassify(scanBlob);
          if (c.recommendPremium) {
            w.push(`${SENSITIVE_TOPIC_WARNING} — זוהו: ${c.matchedSensitive.join(", ")}`);
          }
          preflightEl.textContent =
            w.length > 0 ? ["אזהרות:", ...w.map((x) => `• ${x}`)].join("\n") : "אין אזהרות. אם אין חסימות באדום, אפשר לשלב 3.";
        }
        }
      }

      const render = () => {
        steps.forEach((step, idx) => step.classList.toggle("hidden", idx + 1 !== current));
        if (progress instanceof HTMLElement) progress.style.width = `${(current / 3) * 100}%`;
        if (stepLabel instanceof HTMLElement) stepLabel.textContent = `שלב ${current} מתוך 3`;
        if (backBtn instanceof HTMLButtonElement) backBtn.disabled = current === 1;
        if (nextBtn instanceof HTMLButtonElement) nextBtn.classList.toggle("hidden", current === 3);
        if (current === 2) updateWordCountAndPreflight();
      };

      const canonicalTagsCsv = ARTICLE_TAG_WHITELIST.join(", ");

      const depthBlock = `[Depth layers for NeverMind]
- Level 1 (beginner): plain language, clarity at a level a smart reader can follow without jargon.
- Level 2 (advanced): eye-level, precise, professional but still clean.
- Level 3 (deep / club): radical doubt, ontological inquiry, and the Inversion Method (flip default assumptions).`;

      const buildPrompt = () => {
        const data = collectData();
        const rawPoints = points instanceof HTMLTextAreaElement ? points.value : "";
        const normalizedPoints = rawPoints
          .split("\n")
          .map((line) => line.trim())
          .filter(Boolean)
          .join(", ");
        const inv = data.inversionNote ? ` Inversion / depth notes: ${data.inversionNote}.` : "";
        const bl = data.bottomLine ? ` Bottom line for the reader: ${data.bottomLine}.` : "";
        const defaultImagePath = data.slug ? `/uploads/${data.slug}.jpg` : "/uploads/[slug].jpg";
        const roboticBannedList = ROBOTIC_BLOCKLIST.join(", ");
        return `[Role: Strategic Content Expert]
[Context: NeverMind Project]
Act as a high-end content strategist for NeverMind. Write an article about ${data.topic || "[Topic]"} for ${data.audience || "[Audience]"}. The core insight is ${data.aha || "[originalInsight]"}.${bl}${inv}

[Content policy — Hebrew instruction for the model]
חוקי תוכן: היה מודע לכך שנושאים כמו סמים, מין, פורנו, הימורים והתמכרויות (וביטויים קרובים באנגלית כגון drugs, porn, gambling, addiction) גורמים לזיהוי פרימיום בזרימת האתר. אם הנושא נוגע לכך, הגדר isPremium: true. השתמש בשפה ישירה אך אחראית. בלי סנסציה. בלי הנחיות מפרות חוק.

You MUST output a single MDX file with YAML frontmatter.

Mandatory frontmatter — always generate these keys with real, non-empty values (never placeholder text, never skip):
- questionForSchema
- originalInsight
- difficultyLevel (beginner | advanced | deep)
- mindShiftIntensity (integer 1–5)
- imageAlt

Forbidden robotic / corporate cliché vocabulary — do NOT use these strings anywhere in the entire output (including YAML values, title, description, and body). Case-insensitive; includes multi-word phrases:
${roboticBannedList}

Required frontmatter keys (all must be present with non-empty values where noted):
- title: Hebrew title
- description: meta description ~150-160 chars
- pubDate: YYYY-MM-DD
- author: default "השם לא משנה"
- questionForSchema: distilled search-facing question (Hebrew) — ${data.questionForSchema || "[fill]"}
- originalInsight: same core as the article spine — ${data.aha || "[fill]"}
- difficultyLevel: one of beginner | advanced | deep — use ${data.difficultyLevel}
- mindShiftIntensity: integer 1-5 — use ${data.mindShiftIntensity}
- imageAlt: Hebrew. Describe the CONCEPT the hero image stands for, not only pixels. Pattern: [brief visible scene] — [semantic role for the article]. Example shape: "אדם עומד מול מראה שבורה — ייצוג ויזואלי לפירוק האגו". Search engines use this for topical/philosophical context; keep concrete + interpretive in one line. Wizard draft: ${data.imageAlt || "[fill]"}
- slug: REQUIRED, English only, kebab-case, aligned with title — ${data.slug || "[Slug]"}
- tags: array; ONLY these exact Hebrew strings (comma-separated canonical list): ${canonicalTagsCsv}
- image: default hero path ${defaultImagePath} unless a different asset is explicitly intended
- isPremium: ${data.isPremium}
- youtubeId, bottomLine, inversionNote, reflectionQuestions, faq: as in project conventions

Tags rule: never invent a tag outside the canonical list. Slug rule: [a-z0-9-] only.
imageAlt rule: must fuse literal scene with symbolic meaning tied to the article thesis; avoid generic stock phrases ("תמונה של אדם").

Style: ${data.tone || "[Tone]"}. Ensure the piece includes: ${normalizedPoints || "[Key Points]"}. Length intent: ${data.length || "[Length]"}. Draft body (if any) should be refined, not duplicated blindly:
[DRAFT_BODY_START]
${data.body.trim() || "[no draft yet]"}
[DRAFT_BODY_END]
${depthBlock}
Follow the brand identity: zero fluff, focus on thought-shifts, NeverMind voice (direct, analytical, no filler).
[Output Instructions: Markdown; no fluff; focus on Thought-Shifts; structure for web reading.
- Use the following heading order and exact labels (must match exactly):
  1) ## מה המנגנון כאן
  2) ## שאלת היפוך
  3) ### ניסוי קצר
  4) ## סיכום פרקטי
- Inside at least 2 headings above, weave 2-3 natural SEO phrases derived from the topic (use Hebrew patterns like: איך {topic}, איך להפסיק {topic}, פתרון ... בזוגיות when relevant).
- Two-layer writing: each paragraph has two sentences. First sentence simple and concrete. Second sentence deeper and more precise.
- Keep paragraphs short. No generic filler.
]`;
      };

      backBtn?.addEventListener("click", () => {
        current = Math.max(1, current - 1);
        render();
      });

      nextBtn?.addEventListener("click", () => {
        if (current === 2) {
          updateWordCountAndPreflight();
          const blockers = runBlockingChecks(collectData());
          if (blockers.length > 0) return;
        }
        current = Math.min(3, current + 1);
        render();
      });

      genBtn?.addEventListener("click", () => {
        if (!(output instanceof HTMLTextAreaElement)) return;
        output.value = buildPrompt();
      });

      copyBtn?.addEventListener("click", async () => {
        if (!(output instanceof HTMLTextAreaElement) || !output.value.trim()) return;
        try {
          await navigator.clipboard.writeText(output.value);
          const original = copyBtn.textContent || "Copy to Clipboard";
          copyBtn.textContent = "הועתק";
          window.setTimeout(() => {
            copyBtn.textContent = original;
          }, 2000);
        } catch {
          // no-op
        }
      });

      const storageKey = "nm-article-wizard-draft";
      const restoreDraft = () => {
        try {
          const raw = localStorage.getItem(storageKey);
          if (!raw) return;
          const data = JSON.parse(raw) as Record<string, unknown>;
          if (topic instanceof HTMLInputElement) topic.value = String(data.topic ?? "");
          if (audience instanceof HTMLSelectElement) audience.value = String(data.audience ?? "Beginners");
          if (aha instanceof HTMLTextAreaElement) aha.value = String(data.aha ?? "");
          if (bottomLine instanceof HTMLTextAreaElement) bottomLine.value = String(data.bottomLine ?? "");
          if (inversion instanceof HTMLTextAreaElement) inversion.value = String(data.inversionNote ?? "");
          if (isPremium instanceof HTMLInputElement) isPremium.checked = Boolean(data.isPremium);
          if (difficulty instanceof HTMLSelectElement) {
            const d = String(data.difficultyLevel ?? "beginner");
            difficulty.value = ["beginner", "advanced", "deep"].includes(d) ? d : "beginner";
          }
          if (slug instanceof HTMLInputElement) slug.value = String(data.slug ?? "");
          if (questionSchema instanceof HTMLInputElement || questionSchema instanceof HTMLTextAreaElement) {
            questionSchema.value = String(data.questionForSchema ?? "");
          }
          if (imageAlt instanceof HTMLInputElement || imageAlt instanceof HTMLTextAreaElement) {
            imageAlt.value = String(data.imageAlt ?? "");
          }
          if (mindShift instanceof HTMLSelectElement) {
            const m = String(data.mindShiftIntensity ?? "3");
            mindShift.value = ["1", "2", "3", "4", "5"].includes(m) ? m : "3";
          }
          if (summary instanceof HTMLInputElement) summary.value = String(data.summary ?? "");
          if (tone instanceof HTMLSelectElement) tone.value = String(data.tone ?? "Provocative");
          if (points instanceof HTMLTextAreaElement) points.value = String(data.points ?? "");
          if (length instanceof HTMLSelectElement) length.value = String(data.length ?? "Short Post");
          if (tags instanceof HTMLInputElement) tags.value = String(data.tags ?? "");
          if (youtube instanceof HTMLInputElement) youtube.value = String(data.youtubeId ?? "");
          if (body instanceof HTMLTextAreaElement) body.value = String(data.body ?? "");
        } catch {
          // no-op
        }
      };

      const persistDraft = () => {
        localStorage.setItem(storageKey, JSON.stringify(collectData()));
      };

      const fields: (Element | null)[] = [
        topic,
        audience,
        aha,
        bottomLine,
        inversion,
        isPremium,
        difficulty,
        slug,
        questionSchema,
        imageAlt,
        mindShift,
        summary,
        tone,
        points,
        length,
        tags,
        youtube,
        body,
      ];
      fields.forEach((field) => {
        field?.addEventListener("input", () => {
          persistDraft();
          updateWordCountAndPreflight();
        });
        field?.addEventListener("change", () => {
          persistDraft();
          updateWordCountAndPreflight();
        });
      });

      saveBtn?.addEventListener("click", async () => {
        const payload = collectData();
        persistDraft();
        let savedViaHook = false;
        if (typeof (window as unknown as { __nmGeneratorSave?: (p: unknown) => Promise<void> }).__nmGeneratorSave === "function") {
          try {
            await (window as unknown as { __nmGeneratorSave: (p: unknown) => Promise<void> }).__nmGeneratorSave(payload);
            savedViaHook = true;
        } catch {
            savedViaHook = false;
          }
        }
        if (saveStatus instanceof HTMLElement) {
          saveStatus.textContent = savedViaHook ? "נשמר דרך save hook פעיל." : "נשמר מקומית בדפדפן (localStorage).";
        }
      });

      restoreDraft();
      render();
    });
  </script>
</Layout>
