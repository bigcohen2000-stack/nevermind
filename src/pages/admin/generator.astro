          });
        }
        if (description.length < 30) {
          issues.push({
            message: "התיאור קצר מדי. צריך שורת SEO אמיתית ולא placeholder",
            target: "#postDescription",
            prompt: `Write a Hebrew meta description for an MDX article (minimum 30 characters, max ~160).\nTitle: ${title}\nCurrent description (${description.length} chars): ${description}\nReturn ONLY the description text, one paragraph.`,
          });
        }
        if (content.length < 120) {
