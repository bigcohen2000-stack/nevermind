            }

            if (token.type === "h3") {
              return `<h3 class="mt-8 text-[clamp(1.2rem,1.05rem+0.45vw,1.5rem)] font-semibold leading-tight text-[#1A1A1A]">${renderInline(token.content)}</h3>`;
            }

            if (token.type === "p") {
              return `<p class="mt-5 text-[1.06rem] leading-8 text-[#1A1A1A]/78">${renderInline(token.content)}</p>`;
            }

            if (token.type === "ul") {
