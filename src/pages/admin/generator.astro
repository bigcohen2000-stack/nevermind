      }

      if (composerRunQa instanceof HTMLButtonElement) {
        composerRunQa.addEventListener("click", () => runComposerArticleQa());
      }
      if (composerCopyAiPack instanceof HTMLButtonElement) {
        composerCopyAiPack.addEventListener("click", async () => {
          const mdx = generateFullMdx().trim();
          if (!mdx || !window.__nmBuildNeverMindMegaPrompt || !window.__nmCopyLargeText) return;
          const { imageTopic, imageType } = readImageOptsForComposerPack();
          const text = window.__nmBuildNeverMindMegaPrompt(mdx, {
            source: "composer",
            imageTopic,
            imageType,
          });
          const ok = await window.__nmCopyLargeText(text);
          if (publishStatusText instanceof HTMLElement) {
            publishStatusText.textContent = ok
              ? "חבילת AI מהעורך הועתקה ללוח."
              : "העתקה נכשלה — בדוק HTTPS או העתק ידנית.";
          }
        });
      }
      if (composerCopyAiShort instanceof HTMLButtonElement) {
        composerCopyAiShort.addEventListener("click", async () => {
          const mdx = generateFullMdx().trim();
          if (!mdx || !window.__nmBuildNeverMindShortPrompt || !window.__nmCopyLargeText) return;
          const text = window.__nmBuildNeverMindShortPrompt(mdx, { source: "composer" });
          const ok = await window.__nmCopyLargeText(text);
          if (publishStatusText instanceof HTMLElement) {
            publishStatusText.textContent = ok
              ? "פרומפט קצר הועתק ללוח."
              : "העתקה נכשלה.";
          }
        });
      }

      renderValidation();
    });
  </script>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
