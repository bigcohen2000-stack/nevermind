          validatorOutput.innerHTML = '<div class="rounded-2xl border border-[#D42B2B]/18 bg-[#FFF4F3] px-4 py-3 text-[#1A1A1A]/78">לא ניתן היה להריץ בדיקות בגלל שגיאת parsing.</div>';
