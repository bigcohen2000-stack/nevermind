              <div class="flex flex-wrap justify-end gap-2">${tags
                .map((tag) => `<span class="rounded-full border border-[#1A1A1A]/10 bg-[#FAFAF8] px-3 py-1 text-xs font-semibold text-[#1A1A1A]/62">${escapeHtml(tag)}</span>`)
                .join("")}</div>
              <h1 class="mt-5 text-[clamp(2rem,1.55rem+1.6vw,3.1rem)] font-semibold leading-[1.08] text-[#1A1A1A]">${escapeHtml(title)}</h1>
              <p class="mt-4 text-[1.05rem] leading-8 text-[#1A1A1A]/68">${escapeHtml(description)}</p>
