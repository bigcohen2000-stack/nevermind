        if (!/faq\s*:/m.test(previewInput.value)) suggestions.push('הוסף faq עם לפחות 3 שאלות קצרות ל-SEO.');
        if (!body.trim()) suggestions.push('גוף המאמר ריק. הוסף תוכן לפני export.');
        if (selectedPreset.value === "video" && !(meta.youtubeId || extractedVideoId)) {
