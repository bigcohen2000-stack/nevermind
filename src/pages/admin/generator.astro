        <div class="mx-auto flex max-w-7xl flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end">
          <button
            id="copyMdx"
            type="button"
            class="inline-flex w-full items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition-colors hover:bg-[var(--nm-surface-muted)] sm:w-auto sm:min-w-[11rem]"
          >
            העתק MDX מוכן
          </button>
          <button
            id="injectIntoSandbox"
            type="button"
            class="inline-flex w-full items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition-colors hover:bg-[var(--nm-surface-muted)] sm:w-auto sm:min-w-[11rem]"
          >
            העבר לתצוגה מקדימה
          </button>
          <button
            id="export-mdx-file"
            type="button"
            class="inline-flex w-full items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition-colors hover:bg-[var(--nm-accent-hover)] sm:w-auto sm:min-w-[11rem]"
          >
            הורד קובץ MDX
          </button>
          <button
            id="open-github"
            type="button"
            class="inline-flex w-full items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition-colors hover:bg-[var(--nm-surface-muted)] sm:w-auto sm:min-w-[11rem]"
          >
            פתח GitHub ←
          </button>
        </div>
        <p class="text-right text-xs text-[color-mix(in_srgb,var(--nm-fg)_50%,var(--nm-bg))]">
          הורד את הקובץ ← גרור לתיקייה articles ב-GitHub
        </p>
      </div>
    </section>
  <script>
    // @ts-nocheck — סקריפט ארוך לכלי פנימי; לא לחייב strict על כל הפונקציות
    import yaml from "js-yaml";

    document.addEventListener("astro:page-load", () => {
      const form = document.getElementById("prompt-generator-form");
      const rawText = document.getElementById("raw-text");
      const sitemap = document.getElementById("sitemap");
      const videoUrl = document.getElementById("video-url");
      const videoHelper = document.getElementById("video-helper");
      const videoTranscriptNotes = document.getElementById("video-transcript-notes");
      const isPremium = document.getElementById("is-premium");
      const includeTruthSlider = document.getElementById("include-truth-slider");
      const selectedPreset = document.getElementById("selected-preset");
      const presetDescription = document.getElementById("preset-description");
      const presetButtons = Array.from(document.querySelectorAll(".preset-button"));
      const output = document.getElementById("generated-prompt");
      const copyButton = document.getElementById("copy-prompt");
      const previewInput = document.getElementById("preview-mdx");
      const renderPreviewButton = document.getElementById("render-preview");
      const copyCleanMdxButton = document.getElementById("copy-clean-mdx");
      const exportMdxButton = document.getElementById("export-mdx");
      const clearPreviewButton = document.getElementById("clear-preview");
      const copyFilenameButton = document.getElementById("copy-filename");
      const copyCommitMessageButton = document.getElementById("copy-commit-message");
      const copyDescriptionSeedButton = document.getElementById("copy-description-seed");
      const applyAutofixButton = document.getElementById("apply-autofix");
      const exportPackageButton = document.getElementById("export-package");
      const suggestedFilename = document.getElementById("suggested-filename");
      const suggestedCommit = document.getElementById("suggested-commit");
      const suggestedDescription = document.getElementById("suggested-description");
      const validatorפלט = document.getElementById("validator-output");
      const autofixפלט = document.getElementById("autofix-output");
      const githubReadyOutput = document.getElementById("github-ready-output");
      const articlePreview = document.getElementById("article-preview");
      const previewStatus = document.getElementById("preview-status");
      const articlePreviewFrame = document.getElementById("article-preview-frame");

      if (!(form instanceof HTMLFormElement)) return;
      if (!(rawText instanceof HTMLTextAreaElement)) return;
      if (!(sitemap instanceof HTMLTextAreaElement)) return;
      if (!(videoUrl instanceof HTMLInputElement)) return;
      if (!(videoHelper instanceof HTMLElement)) return;
      if (!(videoTranscriptNotes instanceof HTMLTextAreaElement)) return;
      if (!(isPremium instanceof HTMLInputElement)) return;
      if (!(includeTruthSlider instanceof HTMLInputElement)) return;
      if (!(selectedPreset instanceof HTMLInputElement)) return;
      if (!(presetDescription instanceof HTMLElement)) return;
      if (!(output instanceof HTMLElement)) return;
      if (!(copyButton instanceof HTMLButtonElement)) return;
      if (!(previewInput instanceof HTMLTextAreaElement)) return;
      if (!(renderPreviewButton instanceof HTMLButtonElement)) return;
      if (!(copyCleanMdxButton instanceof HTMLButtonElement)) return;
      if (!(exportMdxButton instanceof HTMLButtonElement)) return;
      if (!(clearPreviewButton instanceof HTMLButtonElement)) return;
      if (!(copyFilenameButton instanceof HTMLButtonElement)) return;
      if (!(copyCommitMessageButton instanceof HTMLButtonElement)) return;
      if (!(copyDescriptionSeedButton instanceof HTMLButtonElement)) return;
      if (!(applyAutofixButton instanceof HTMLButtonElement)) return;
      if (!(exportPackageButton instanceof HTMLButtonElement)) return;
      if (!(suggestedFilename instanceof HTMLElement)) return;
      if (!(suggestedCommit instanceof HTMLElement)) return;
      if (!(suggestedDescription instanceof HTMLElement)) return;
      if (!(validatorפלט instanceof HTMLElement)) return;
      if (!(autofixפלט instanceof HTMLElement)) return;
      if (!(githubReadyOutput instanceof HTMLElement)) return;
      if (!(articlePreview instanceof HTMLElement)) return;
      if (!(articlePreviewFrame instanceof HTMLIFrameElement)) return;
      if (!(previewStatus instanceof HTMLElement)) return;

      /** Keep in sync with `src/utils/textCleaner.ts` */
      function cleanHumanTouch(text) {
        if (!text) return text;
        return text
          .replace(/\u2014/g, "-")
          .replace(/\u2013/g, "-")
          .replace(/\u201c/g, '"')
          .replace(/\u201d/g, '"')
          .replace(/\u2018/g, "'")
          .replace(/\u2019/g, "'")
          .replace(/\u2026/g, "...");
      }

      const normalizeBlock = (value) =>
        value
          .split(/\r?\n/)
          .map((line) => line.trim())
          .filter(Boolean)
          .join("\n");

      const getCleanMdx = () =>
        cleanHumanTouch(previewInput.value.replace(/\r\n/g, "\n").trim());

      const slugify = (value) =>
        String(value ?? "")
          .toLowerCase()
          .replace(/['"`]/g, "")
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "") || "new-article";

      const extractYouTubeId = (value) => {
        const source = String(value ?? "").trim();
        if (!source) return "";
        if (/^[a-zA-Z0-9_-]{11}$/.test(source)) return source;

        try {
          const url = new URL(source);
          const host = url.hostname.replace(/^www\./, "");
          if (host === "youtu.be") {
            return url.pathname.split("/").filter(Boolean)[0] || "";
          }
          if (host.endsWith("youtube.com")) {
            if (url.searchParams.get("v")) return url.searchParams.get("v") || "";
            const parts = url.pathname.split("/").filter(Boolean);
            const markerIndex = parts.findIndex((part) => ["embed", "shorts", "live"].includes(part));
            if (markerIndex !== -1 && parts[markerIndex + 1]) return parts[markerIndex + 1];
          }
        } catch {
          return "";
        }

        return "";
      };

      const createVideoSeed = (url, youtubeId) => {
        if (!url && !youtubeId) {
          return {
            descriptionSeed: "",
            promptSeed: "",
            helperText: "עדיין לא הוזן לינק וידאו.",
          };
        }

        if (youtubeId) {
          return {
            descriptionSeed: "מאמר מבוסס וידאו שמזקק את הרעיון המרכזי לשפה פשוטה וברורה.",
            promptSeed: `Use the provided video source as a structural anchor. Extract the core promise of the video, summarize the practical insight in plain language, and make the article useful even for readers who will never press play. The extracted youtubeId is: ${youtubeId}.`,
            helperText: `זוהה youtubeId: ${youtubeId}`,
          };
        }

        return {
          descriptionSeed: "מאמר מבוסס וידאו שדורש בדיקה ידנית של הקישור לפני פרסום.",
          promptSeed: "A video URL was provided but no valid youtubeId could be extracted. Tell the model to avoid inventing an ID and to leave youtubeId empty if extraction is impossible.",
          helperText: "הלינק הוזן, אבל לא הצלחתי לחלץ ממנו youtubeId תקין.",
        };
      };

      const createMetaHelpers = (meta) => {
        const extractedVideoId = extractYouTubeId(videoUrl.value);
        const videoSeed = createVideoSeed(videoUrl.value.trim(), extractedVideoId);
        const baseTitle = String(meta.title || "").replace(/^"|"$/g, "").trim();
        const fallbackTitle = selectedPreset.value === "video" && extractedVideoId ? `video-${extractedVideoId}` : "new article";
        const filename = `${slugify(baseTitle || fallbackTitle)}.mdx`;
        const commitTopic = baseTitle || fallbackTitle;
        const commitMessage = `feat: added guide on ${commitTopic}`;
        const descriptionSeed = String(meta.description || "").trim() || videoSeed.descriptionSeed || "תיאור קצר, מדויק, וסקרן ל-SEO.";
        return { filename, commitMessage, descriptionSeed };
      };

      const updateVideoHelper = () => {
        const source = videoUrl.value.trim();
        const youtubeId = extractYouTubeId(source);
        const videoSeed = createVideoSeed(source, youtubeId);
        const transcriptSummary = videoTranscriptNotes.value.trim()
          ? `תמלול/הערות: ${videoTranscriptNotes.value.trim().split(/\s+/).length} מילים בקירוב.`
          : "אין עדיין הערות וידאו.";
        videoHelper.innerHTML = `<p>${escapeHtml(videoSeed.helperText)}</p><p class="mt-1">${escapeHtml(transcriptSummary)}</p>`;
      };

      const formatScalar = (value) => `"${String(value ?? "").replace(/"/g, '\\"')}"`;

      const formatBoolean = (value, fallback = false) => {
        if (typeof value === "boolean") return value ? "true" : "false";
        const normalized = String(value ?? "").toLowerCase();
        if (normalized === "true" || normalized === "false") return normalized;
        return fallback ? "true" : "false";
      };

      const formatWorkflowStatus = (value, draftValue) => {
        const normalized = String(value ?? "").trim().toLowerCase();
        const allowed = ["writing", "review", "ready", "published"];
        if (allowed.includes(normalized)) return formatScalar(normalized);
        const inferred = String(draftValue ?? "true").toLowerCase() === "false" ? "published" : "writing";
        return formatScalar(inferred);
      };

      const formatTags = (value) => {
        const source = Array.isArray(value)
          ? value
          : String(value ?? "")
              .split(",")
              .map((item) => item.trim())
              .filter(Boolean);
        const tags = source.length > 0 ? source : ["בהירות"];
        return `[${tags.map((tag) => `"${String(tag).replace(/"/g, '\\"')}"`).join(", ")}]`;
      };

      const buildCanonicalFrontmatter = (meta) => {
        const finalMeta = {
          ...meta,
        };

        // Non-destructive defaults: fill only when missing.
        if (!Object.prototype.hasOwnProperty.call(finalMeta, "author")) {
          finalMeta.author = "השם לא משנה";
        }
        if (!Object.prototype.hasOwnProperty.call(finalMeta, "layout")) {
          finalMeta.layout = "../../layouts/Layout.astro";
        }

        // Preserve rich/structured fields exactly as provided.
        if (Object.prototype.hasOwnProperty.call(meta, "reflectionQuestions")) {
          finalMeta.reflectionQuestions = meta.reflectionQuestions;
        }
        if (Object.prototype.hasOwnProperty.call(meta, "videoSummaryPoints")) {
          finalMeta.videoSummaryPoints = meta.videoSummaryPoints;
        }
        if (Object.prototype.hasOwnProperty.call(meta, "relatedConcepts")) {
          finalMeta.relatedConcepts = meta.relatedConcepts;
        }
        if (Object.prototype.hasOwnProperty.call(meta, "faq")) {
          finalMeta.faq = meta.faq;
        }

        const yamlBody = yaml
          .dump(finalMeta, {
            lineWidth: -1,
            noRefs: true,
            sortKeys: false,
            noCompatMode: true,
          })
          .trimEnd();

        return `---\n${yamlBody}\n---`;
      };

      const applyFrontmatterAutofix = (raw) => {
        const normalized = raw.replace(/\r\n/g, "\n").trim();
        if (!normalized) return "";

        const parsed = parseFrontmatter(normalized);
        if (!parsed.hasFrontmatter || parsed.parseError) {
          // Fail safe: never rewrite MDX when frontmatter parsing fails.
          return `${normalized}\n`;
        }
        const body = parsed.body.trim();
        const meta = parsed.meta;
        const frontmatter = buildCanonicalFrontmatter(meta);
        return `${frontmatter}\n\n${body}`.trim() + "\n";
      };

      const escapeHtml = (value) =>
        value
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/\"/g, "&quot;")
          .replace(/'/g, "&#39;");

      const renderInline = (value) => {
        let result = escapeHtml(value);
        result = result.replace(/`([^`]+)`/g, "<code class=\"rounded bg-[var(--nm-inverse)]/6 px-1.5 py-0.5 text-[0.92em]\">$1</code>");
        result = result.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
        result = result.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-[var(--nm-accent)] underline decoration-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)] underline-offset-4">$1</a>');
        return result;
      };

      const parseAttributes = (value) => {
        const attrs = {};
        const attrRegex = /(\w+)="([^"]*)"/g;
        let match;
        while ((match = attrRegex.exec(value)) !== null) {
          attrs[match[1]] = match[2];
        }
        return attrs;
      };

      const parseFrontmatter = (raw) => {
        const frontmatterMatch = raw.match(/^---\s*\n([\s\S]*?)\n---\s*\n?/);
        if (!frontmatterMatch) {
          return { meta: {}, body: raw.trim(), hasFrontmatter: false, parseError: null };
        }

        let meta = {};
        let parseError = null;
        try {
          const loaded = yaml.load(frontmatterMatch[1]);
          if (loaded && typeof loaded === "object" && !Array.isArray(loaded)) {
            meta = loaded;
          }
        } catch (error) {
          meta = {};
          parseError = error instanceof Error ? error.message : "YAML parse error";
        }

        const body = raw.slice(frontmatterMatch[0].length).trim();
        return { meta, body, hasFrontmatter: true, parseError };
      };

      const validateMdx = (meta, body) => {
        const extractedVideoId = extractYouTubeId(videoUrl.value);
        const videoPresetActive = selectedPreset.value === "video";
        const checks = [
          {
            label: "כותרת",
            ok: Boolean(meta.title),
            detail: meta.title ? `נמצאה כותרת (${String(meta.title).length} תווים)` : "חסר title",
          },
          {
            label: "תיאור",
            ok: Boolean(meta.description),
            detail: meta.description ? `נמצא description (${String(meta.description).length} תווים)` : "חסר description",
          },
          {
            label: "תאריך פרסום",
            ok: Boolean(meta.pubDate),
            detail: meta.pubDate ? `pubDate = ${meta.pubDate}` : "חסר pubDate",
          },
          {
            label: "טיוטה",
            ok: Object.prototype.hasOwnProperty.call(meta, "draft"),
            detail: Object.prototype.hasOwnProperty.call(meta, "draft") ? `draft = ${meta.draft}` : "חסר draft",
          },
          {
            label: "תור עבודה",
            ok: ["writing", "review", "ready", "published"].includes(String(meta.workflowStatus || "")),
            detail: ["writing", "review", "ready", "published"].includes(String(meta.workflowStatus || ""))
              ? `workflowStatus = ${meta.workflowStatus}`
              : "חסר workflowStatus או שהערך לא תקין",
          },
          {
            label: "שאלות FAQ",
            ok: /faq\s*:/m.test(previewInput.value),
            detail: /faq\s*:/m.test(previewInput.value) ? "נמצא מקטע FAQ" : "לא זוהה FAQ",
          },
          {
            label: "גוף המאמר",
            ok: Boolean(body.trim()),
            detail: body.trim() ? `זוהה גוף מאמר (${body.trim().split(/\s+/).length} מילים בקירוב)` : "גוף המאמר ריק",
          },
          {
            label: "youtubeId",
            ok: !videoPresetActive || Boolean(meta.youtubeId || extractedVideoId),
            detail: !videoPresetActive
              ? "לא חובה בפריסט הנוכחי"
              : meta.youtubeId || extractedVideoId
                ? `youtubeId = ${meta.youtubeId || extractedVideoId}`
                : "נבחר preset של וידאו אבל לא זוהה youtubeId",
          },
        ];

        return checks;
      };

      const renderValidator = (checks) => {
        validatorפלט.innerHTML = checks
          .map((check) => {
            const tone = check.ok
              ? "border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/80 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]"
              : "border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] bg-[var(--nm-tint)] text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]";
            const badge = check.ok ? "תקין" : "חסר";
            return `<div class="rounded-2xl border px-4 py-3 ${tone}">
              <div class="flex items-center justify-between gap-3">
                <span class="text-sm font-semibold">${check.label}</span>
                <span class="text-xs font-semibold uppercase tracking-[0.18em] ${check.ok ? "text-[var(--nm-fg)]/48" : "text-[var(--nm-accent)]"}">${badge}</span>
              </div>
              <p class="mt-2 text-sm leading-6">${escapeHtml(check.detail)}</p>
            </div>`;
          })
          .join("");
      };

      const renderAutofixSuggestions = (meta, body, checks) => {
        const suggestions = [];
        const extractedVideoId = extractYouTubeId(videoUrl.value);
        if (!meta.title) suggestions.push('הוסף title חד וקצר ב-frontmatter.');
        if (!meta.description) suggestions.push('הוסף description עד 160 תווים.');
        if (!meta.pubDate) suggestions.push('הוסף pubDate בפורמט YYYY-MM-DD.');
        if (!Object.prototype.hasOwnProperty.call(meta, "draft")) suggestions.push('הוסף draft: true או draft: false במפורש.');
        if (!["writing", "review", "ready", "published"].includes(String(meta.workflowStatus || ""))) suggestions.push('הוסף workflowStatus עם אחד הערכים: writing, review, ready, published.');
        if (!/faq\s*:/m.test(previewInput.value)) suggestions.push('הוסף faq עם לפחות 3 שאלות קצרות ל-SEO.');
        if (!body.trim()) suggestions.push('גוף המאמר ריק. הוסף תוכן לפני export.');
        if (selectedPreset.value === "video" && !(meta.youtubeId || extractedVideoId)) {
          suggestions.push('נבחר preset של וידאו אבל לא זוהה youtubeId. הדבק לינק YouTube תקין או מלא את youtubeId ידנית.');
        }

        autofixפלט.innerHTML = suggestions.length > 0
          ? `<div><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">Auto-fix Suggestions</p><ul class="mt-3 space-y-2 pr-5 list-disc">${suggestions.map((item) => `<li>${escapeHtml(item)}</li>`).join("")}</ul></div>`
          : '<div><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-fg)]/48">Auto-fix Suggestions</p><p class="mt-3">לא נמצאו חוסרים בסיסיים. אפשר לעבור ל־commit אם התוכן עצמו תקין.</p></div>';

        const blockingChecks = checks.filter((check) => !check.ok);
        githubReadyOutput.innerHTML = blockingChecks.length === 0
          ? '<div><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-fg)]/48">מוכן ל־GitHub</p><p class="mt-3">מבחינת frontmatter ומבנה בסיסי, הקובץ מוכן להעתקה או לייצוא.</p></div>'
          : `<div><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">מוכן ל־GitHub</p><p class="mt-3">עדיין לא מוכן. חסרים כרגע: ${escapeHtml(blockingChecks.map((check) => check.label).join(', '))}.</p></div>`;
      };

      const setMetaHelpers = (meta) => {
        const { filename, commitMessage, descriptionSeed } = createMetaHelpers(meta);
        suggestedFilename.textContent = `שם קובץ: ${filename}`;
        suggestedCommit.textContent = `הודעת commit: ${commitMessage}`;
        suggestedDescription.textContent = `Description מוצע: ${descriptionSeed}`;
      };

      const buildPreviewDocument = (title, articleHtml) => `<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>${escapeHtml(title || "Preview")}</title>
    <style>
      body { margin: 0; background: #f8fafc; color: #000000; font-family: "Assistant Variable", system-ui, sans-serif; }
      .shell { max-width: 980px; margin: 0 auto; padding: 32px 20px 56px; }
      .label { font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #D42B2B; margin-bottom: 16px; }
      article { max-width: 72ch; margin: 0 auto; }
      a { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="shell">
      <div class="label">מעטפת תצוגה חיה</div>
      ${articleHtml}
    </div>
  </body>
</html>`;

      const renderParagraphs = (content) => {
        return content
          .split(/\n{2,}/)
          .map((chunk) => chunk.trim())
          .filter(Boolean)
          .map((chunk) => `<p class="mt-3 leading-8">${renderInline(chunk.replace(/\n/g, " "))}</p>`)
          .join("");
      };

      const renderComponentBlock = (name, attrs = {}, content = "") => {
        if (name === "InquiryBox") {
          return `<aside class="my-8 rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/85 p-6 shadow-sm">
            <p class="text-sm text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">${renderInline(attrs.title || "שאלת חקירה")}</p>
            <div class="mt-3 text-lg leading-8 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">${content ? renderParagraphs(content) : "בלוק חקירה יופיע כאן."}</div>
          </aside>`;
        }

        if (name === "SkepticBox") {
          return `<aside class="my-8 rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] bg-[var(--nm-tint)] p-6 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">פינת הספקן</p>
            <h3 class="mt-2 text-xl font-semibold text-[var(--nm-fg)]">${renderInline(attrs.title || "ההתנגדות המרכזית")}</h3>
            <div class="mt-3 text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_76%,var(--nm-bg))]">${content ? renderParagraphs(content) : "כאן תופיע התשובה לספק המרכזי."}</div>
          </aside>`;
        }

        if (name === "ConceptCallout") {
