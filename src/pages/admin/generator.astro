          : '<div><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#1A1A1A]/48">Auto-fix Suggestions</p><p class="mt-3">לא נמצאו חוסרים בסיסיים. אפשר לעבור ל־commit אם התוכן עצמו תקין.</p></div>';

        const blockingChecks = checks.filter((check) => !check.ok);
        githubReadyOutput.innerHTML = blockingChecks.length === 0
          ? '<div><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#1A1A1A]/48">GitHub-ready</p><p class="mt-3">מבחינת frontmatter ומבנה בסיסי, הקובץ מוכן להעתקה או export.</p></div>'
          : `<div><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">GitHub-ready</p><p class="mt-3">עדיין לא מוכן. חסרים כרגע: ${escapeHtml(blockingChecks.map((check) => check.label).join(', '))}.</p></div>`;
      };

