---
import Layout from "../../layouts/Layout.astro";

const pageTitle = "Strategic Article Wizard";
const pageDescription = "אשף 3 שלבים ליצירת Master Prompt מדויק לכתיבת מאמר.";
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <section class="mx-auto max-w-4xl space-y-8 px-4 pb-16 text-right text-[var(--nm-fg)]">
    <header class="space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">Article Creator</p>
      <h1 class="text-[clamp(2rem,1.5rem+1.8vw,3.2rem)] font-semibold leading-[1.05]">Strategic Wizard</h1>
      <p class="text-[clamp(1rem,0.95rem+0.25vw,1.15rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
        שלושה שלבים קצרים. בסוף מתקבל Master Prompt מוכן להעתקה.
      </p>
    </header>

    <article id="nm-article-wizard" class="space-y-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 shadow-[0_22px_60px_color-mix(in_srgb,var(--nm-fg)_5%,transparent)] md:p-8">
      <div class="space-y-2">
        <div class="h-1.5 w-full overflow-hidden rounded-full bg-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)]">
          <div id="wizard-progress" class="h-full rounded-full bg-[var(--nm-accent)] transition-all duration-300" style="width: 33%;"></div>
        </div>
        <p id="wizard-step-label" class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">שלב 1 מתוך 3</p>
      </div>

      <section data-step="1" class="wizard-step space-y-4">
        <h2 class="text-2xl font-semibold">Step 1: The Core</h2>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Topic / Title</span>
          <input id="wiz-topic" type="text" placeholder="מה הנושא המרכזי?" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]" />
        </label>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Target Audience</span>
          <select id="wiz-audience" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option>Beginners</option>
            <option>Advanced</option>
            <option>Internal Community</option>
          </select>
        </label>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Aha! Moment</span>
          <textarea id="wiz-aha" rows="3" placeholder="מה הדבר האחד שהם חייבים להבין?" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]"></textarea>
        </label>
        <div class="grid gap-4 md:grid-cols-2">
          <label class="block space-y-2">
            <span class="text-sm font-semibold">Clean Link (Slug)</span>
            <input id="wiz-slug" type="text" placeholder="nevermind-clean-link" dir="ltr" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 text-left outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]" />
          </label>
          <label class="block space-y-2">
            <span class="text-sm font-semibold">Marketing Summary</span>
            <input id="wiz-summary" type="text" placeholder="תקציר קצר ומדויק" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]" />
          </label>
        </div>
      </section>

      <section data-step="2" class="wizard-step hidden space-y-4">
        <h2 class="text-2xl font-semibold">Step 2: Structure & Tone</h2>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Tone</span>
          <select id="wiz-tone" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option>Provocative</option>
            <option>Analytical</option>
            <option>Grounded</option>
          </select>
        </label>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Key Bullet Points (Must-Haves)</span>
          <textarea id="wiz-points" rows="5" placeholder="כל נקודה בשורה חדשה" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]"></textarea>
        </label>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Length</span>
          <select id="wiz-length" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]">
            <option>Short Post</option>
            <option>Deep Dive</option>
            <option>Full Research</option>
          </select>
        </label>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Tags</span>
          <input id="wiz-tags" type="text" placeholder="בהירות, בחירה, פירוק" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]" />
        </label>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Draft Body (Markdown, optional)</span>
          <textarea id="wiz-body" rows="6" placeholder="טיוטת גוף המאמר (אופציונלי)" class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-4 py-3 outline-none focus:border-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)]"></textarea>
        </label>
      </section>

      <section data-step="3" class="wizard-step hidden space-y-4">
        <h2 class="text-2xl font-semibold">Step 3: Final Review & Generator</h2>
        <button id="wiz-generate" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-6 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">
          Generate Master Prompt
        </button>
        <label class="block space-y-2">
          <span class="text-sm font-semibold">Master Prompt</span>
          <textarea id="wiz-output" rows="8" readonly class="w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3 text-left leading-7 outline-none"></textarea>
        </label>
        <button id="wiz-copy" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          Copy to Clipboard
        </button>
        <button id="wiz-save" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          Save Draft Data
        </button>
        <p id="wiz-save-status" class="text-xs font-semibold text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]"></p>
      </section>

      <div class="flex items-center justify-between gap-3">
        <button id="wiz-back" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-transparent px-5 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          חזור
        </button>
        <button id="wiz-next" type="button" class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-2 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">
          המשך
        </button>
      </div>
    </article>
  </section>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      const root = document.getElementById("nm-article-wizard");
      if (!(root instanceof HTMLElement)) return;

      const steps = Array.from(root.querySelectorAll(".wizard-step"));
      const progress = document.getElementById("wizard-progress");
      const stepLabel = document.getElementById("wizard-step-label");
      const backBtn = document.getElementById("wiz-back");
      const nextBtn = document.getElementById("wiz-next");
      const genBtn = document.getElementById("wiz-generate");
      const copyBtn = document.getElementById("wiz-copy");
      const output = document.getElementById("wiz-output");
      const saveBtn = document.getElementById("wiz-save");
      const saveStatus = document.getElementById("wiz-save-status");
      const topic = document.getElementById("wiz-topic");
      const audience = document.getElementById("wiz-audience");
      const aha = document.getElementById("wiz-aha");
      const slug = document.getElementById("wiz-slug");
      const summary = document.getElementById("wiz-summary");
      const tone = document.getElementById("wiz-tone");
      const points = document.getElementById("wiz-points");
      const length = document.getElementById("wiz-length");
      const tags = document.getElementById("wiz-tags");
      const body = document.getElementById("wiz-body");

      let current = 1;

      const render = () => {
        steps.forEach((step, idx) => step.classList.toggle("hidden", idx + 1 !== current));
        if (progress instanceof HTMLElement) progress.style.width = `${(current / 3) * 100}%`;
        if (stepLabel instanceof HTMLElement) stepLabel.textContent = `שלב ${current} מתוך 3`;
        if (backBtn instanceof HTMLButtonElement) backBtn.disabled = current === 1;
        if (nextBtn instanceof HTMLButtonElement) nextBtn.classList.toggle("hidden", current === 3);
      };

      const collectData = () => ({
        topic: topic instanceof HTMLInputElement ? topic.value.trim() : "",
        audience: audience instanceof HTMLSelectElement ? audience.value : "",
        aha: aha instanceof HTMLTextAreaElement ? aha.value.trim() : "",
        slug: slug instanceof HTMLInputElement ? slug.value.trim() : "",
        summary: summary instanceof HTMLInputElement ? summary.value.trim() : "",
        tone: tone instanceof HTMLSelectElement ? tone.value : "",
        points: points instanceof HTMLTextAreaElement ? points.value : "",
        length: length instanceof HTMLSelectElement ? length.value : "",
        tags: tags instanceof HTMLInputElement ? tags.value.trim() : "",
        body: body instanceof HTMLTextAreaElement ? body.value : "",
      });

      const buildPrompt = () => {
        const data = collectData();
        const rawPoints = points instanceof HTMLTextAreaElement ? points.value : "";
        const normalizedPoints = rawPoints
          .split("\n")
          .map((line) => line.trim())
          .filter(Boolean)
          .join(", ");
        return `[Role: Strategic Content Expert]\n[Context: NeverMind Project]\nAct as a high-end content strategist for NeverMind. Write an article about ${data.topic || "[Topic]"} for ${data.audience || "[Audience]"}. The core insight is ${data.aha || "[Aha Moment]"}. Style: ${data.tone || "[Tone]"}. Ensure it includes ${normalizedPoints || "[Key Points]"}. Optional context: slug=${data.slug || "[Slug]"}, summary=${data.summary || "[Summary]"}, tags=${data.tags || "[Tags]"}. Follow the brand identity: zero fluff, focus on thought-shifts, and use the ${data.length || "[Length]"} format.\n[Output Instructions: Markdown, no fluff, focus on Thought-Shifts]`;
      };

      backBtn?.addEventListener("click", () => {
        current = Math.max(1, current - 1);
        render();
      });

      nextBtn?.addEventListener("click", () => {
        current = Math.min(3, current + 1);
        render();
      });

      genBtn?.addEventListener("click", () => {
        if (!(output instanceof HTMLTextAreaElement)) return;
        output.value = buildPrompt();
      });

      copyBtn?.addEventListener("click", async () => {
        if (!(output instanceof HTMLTextAreaElement) || !output.value.trim()) return;
        try {
          await navigator.clipboard.writeText(output.value);
          const original = copyBtn.textContent || "Copy to Clipboard";
          copyBtn.textContent = "✓ הועתק";
          window.setTimeout(() => {
            copyBtn.textContent = original;
          }, 2000);
        } catch {
          // no-op
        }
      });

      const storageKey = "nm-article-wizard-draft";
      const restoreDraft = () => {
        try {
          const raw = localStorage.getItem(storageKey);
          if (!raw) return;
          const data = JSON.parse(raw);
          if (topic instanceof HTMLInputElement) topic.value = data.topic || "";
          if (audience instanceof HTMLSelectElement) audience.value = data.audience || "Beginners";
          if (aha instanceof HTMLTextAreaElement) aha.value = data.aha || "";
          if (slug instanceof HTMLInputElement) slug.value = data.slug || "";
          if (summary instanceof HTMLInputElement) summary.value = data.summary || "";
          if (tone instanceof HTMLSelectElement) tone.value = data.tone || "Provocative";
          if (points instanceof HTMLTextAreaElement) points.value = data.points || "";
          if (length instanceof HTMLSelectElement) length.value = data.length || "Short Post";
          if (tags instanceof HTMLInputElement) tags.value = data.tags || "";
          if (body instanceof HTMLTextAreaElement) body.value = data.body || "";
        } catch {
          // no-op
        }
      };

      const persistDraft = () => {
        localStorage.setItem(storageKey, JSON.stringify(collectData()));
      };
      [topic, audience, aha, slug, summary, tone, points, length, tags, body].forEach((field) => {
        field?.addEventListener("input", persistDraft);
      });

      saveBtn?.addEventListener("click", async () => {
        const payload = collectData();
        persistDraft();
        let savedViaHook = false;
        if (typeof window.__nmGeneratorSave === "function") {
          try {
            await window.__nmGeneratorSave(payload);
            savedViaHook = true;
          } catch {
            savedViaHook = false;
          }
        }
        if (saveStatus instanceof HTMLElement) {
          saveStatus.textContent = savedViaHook ? "נשמר דרך save hook פעיל." : "נשמר מקומית בדפדפן (localStorage).";
        }
      });

      restoreDraft();
      render();
    });
  </script>
</Layout>
