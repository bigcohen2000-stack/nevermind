---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import siteSettings from "../../config/siteSettings.json";
import ArticlesTable from "../../components/admin/ArticlesTable.astro";
import ServicesControlPanel from "../../components/admin/ServicesControlPanel.astro";
import AppConfigControlPanel from "../../components/admin/AppConfigControlPanel.astro";
import appConfig from "../../config/appConfig.json";
import { flattenVisibleServices } from "../../lib/services";

const pageTitle = "Creator Dashboard";
const pageDescription = "מרכז תפעולי פרטי לניהול מאמרים, שירותים, והרחבות המערכת של NeverMind.";
const githubArticleBase = `https://github.com/${appConfig.github.owner}/${appConfig.github.repo}/blob/${appConfig.github.branch}/${appConfig.github.articlesPath}/`;
const formatDate = new Intl.DateTimeFormat("he-IL", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});

const workflowConfig = {
  writing: {
    label: "בכתיבה",
    tone: "bg-[#FFF7ED] text-[#9A3412] border-[#FDBA74]/60",
  },
  review: {
    label: "מוכן לבדיקה",
    tone: "bg-[#EFF6FF] text-[#1D4ED8] border-[#BFDBFE]/70",
  },
  ready: {
    label: "מוכן לפרסום",
    tone: "bg-[#F4FAF4] text-[#166534] border-[#BBF7D0]/70",
  },
  published: {
    label: "פורסם",
    tone: "bg-[#1A1A1A] text-[#FAFAF8] border-[#1A1A1A]",
  },
} as const;

type WorkflowKey = keyof typeof workflowConfig;

const difficultyConfig = {
  beginner: {
    label: "מתחילים",
    tone: "bg-[#F4FAF4] text-[#166534] border-[#BBF7D0]/70",
  },
  advanced: {
    label: "מתקדמים",
    tone: "bg-[#FFF7ED] text-[#9A3412] border-[#FDBA74]/60",
  },
  deep: {
    label: "חקירה עמוקה",
    tone: "bg-[#1A1A1A] text-[#FAFAF8] border-[#1A1A1A]",
  },
} as const;

type DifficultyKey = keyof typeof difficultyConfig;

const resolveWorkflowStatus = (workflowStatus: WorkflowKey | undefined, draft: boolean): WorkflowKey => {
  if (workflowStatus && workflowStatus in workflowConfig) {
    return workflowStatus;
  }

  return draft ? "writing" : "published";
};

const resolveDifficulty = (difficultyLevel: DifficultyKey | undefined, body: string): DifficultyKey => {
  if (difficultyLevel && difficultyLevel in difficultyConfig) {
    return difficultyLevel;
  }

  const wordCount = body.replace(/<[^>]*>/g, " ").split(/\s+/).filter(Boolean).length;
  if (wordCount > 1400) return "deep";
  if (wordCount > 900) return "advanced";
  return "beginner";
};

const articles = (await getCollection("articles"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((article) => {
    const workflowKey = resolveWorkflowStatus(article.data.workflowStatus as WorkflowKey | undefined, article.data.draft);
    const workflowMeta = workflowConfig[workflowKey];
    const difficultyKey = resolveDifficulty(article.data.difficultyLevel as DifficultyKey | undefined, article.body ?? "");
    const difficultyMeta = difficultyConfig[difficultyKey];

    return {
      title: article.data.title,
      workflowStatus: workflowMeta.label,
      workflowTone: workflowMeta.tone,
      difficulty: difficultyMeta.label,
      difficultyTone: difficultyMeta.tone,
      status: article.data.draft ? "טיוטה" : "באוויר",
      statusTone: article.data.draft ? "bg-[#FFF4F3] text-[#D42B2B] border-[#D42B2B]/12" : "bg-[#F4FAF4] text-[#1A1A1A] border-[#1A1A1A]/10",
      premium: article.data.isPremium ? "כן" : "לא",
      premiumTone: article.data.isPremium ? "bg-[#1A1A1A] text-[#FAFAF8] border-[#1A1A1A]" : "bg-white text-[#1A1A1A]/72 border-[#1A1A1A]/10",
      dateLabel: formatDate.format(article.data.pubDate),
      editHref: `${githubArticleBase}${article.id}`,
      slug: article.slug,
      workflowKey,
    };
  });

const quickActions = [
  {
    title: "מאמר חדש",
    description: "מחולל prompt, sandbox ל-MDX, autofix וייצוא לקובץ לפני commit.",
    href: "/admin/generator/",
    cta: "לפתוח את המחולל",
  },
  {
    title: "עמוד השירותים",
    description: "מסלולים לפי שלבים, כפתורי וואטסאפ/חשבונית ותמחור ברור.",
    href: "/services/",
    cta: "לבדוק את העמוד",
  },
  {
    title: "טופס intake",
    description: "לינק פרטי לשליחה ללידים, עם Gatekeeper ו־WhatsApp handoff.",
    href: "/intake/",
    cta: "לפתוח את הטופס",
  },
  {
    title: "Viral Paradox Generator",
    description: "כלי מהיר ליצירת 20 פרדוקסים חדים לסטוריז, הוקים וכותרות משנה.",
    href: "/admin/paradoxes/",
    cta: "לייצר פרדוקסים",
  },
  {
    title: "עץ שורש הבעיה",
    description: "אינפוגרפיקה אינטראקטיבית שמפרקת בעיה גלויה לשורשים תודעתיים עמוקים יותר.",
    href: "/root-problem-tree/",
    cta: "לפתוח את המפה",
  },
  {
    title: "הספרייה האסורה",
    description: "ריכוז המאמרים ששוברים פרות קדושות ויוצרים curiosity gap חזק יותר.",
    href: "/forbidden-library/",
    cta: "להיכנס לספרייה",
  },
];

const visibleServices = flattenVisibleServices();
const stats = {
  totalArticles: articles.length,
  drafts: articles.filter((article) => article.status === "טיוטה").length,
  live: articles.filter((article) => article.status === "באוויר").length,
  writing: articles.filter((article) => article.workflowKey === "writing").length,
  review: articles.filter((article) => article.workflowKey === "review").length,
  ready: articles.filter((article) => article.workflowKey === "ready").length,
  published: articles.filter((article) => article.workflowKey === "published").length,
  activeServices: visibleServices.length,
  featuredServices: visibleServices.filter((service) => Array.isArray(service.badges) && service.badges.length > 0).length,
};
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <section class="mx-auto max-w-7xl space-y-10 px-4 pb-12 text-[#1A1A1A]">
    <header class="max-w-4xl space-y-5 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.26em] text-[#D42B2B]">Creator Dashboard</p>
      <h1 class="text-[clamp(2.4rem,1.8rem+2vw,4rem)] font-semibold leading-[1.05]">מרכז התפעול של התוכן</h1>
      <p class="max-w-3xl text-[clamp(1rem,0.94rem+0.3vw,1.15rem)] leading-8 text-[#1A1A1A]/70">
        זה המרכז שמרכז את העבודה בפועל: מאמרים, שירותים פעילים, וכלי היצירה של האתר. לא CMS כללי, אלא קוקפיט שמכוון לזרימת העבודה שלך.
      </p>
    </header>

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {quickActions.map((item) => (
        <article class="rounded-[1.8rem] border border-[#1A1A1A]/10 bg-white/82 p-5 shadow-[0_24px_70px_rgba(26,26,26,0.06)]">
          <h2 class="text-xl font-semibold text-[#1A1A1A]">{item.title}</h2>
          <p class="mt-4 text-sm leading-7 text-[#1A1A1A]/68">{item.description}</p>
          <a href={item.href} class="mt-6 inline-flex items-center rounded-full bg-[#1A1A1A] px-4 py-2 text-sm font-semibold text-[#FAFAF8] transition hover:bg-black">{item.cta}</a>
        </article>
      ))}
    </section>

    <section class="grid gap-4 md:grid-cols-4 xl:grid-cols-8">
      <article class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right"><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">Articles</p><p class="mt-3 text-3xl font-semibold text-[#1A1A1A]">{stats.totalArticles}</p></article>
      <article class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right"><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">Drafts</p><p class="mt-3 text-3xl font-semibold text-[#1A1A1A]">{stats.drafts}</p></article>
      <article class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right"><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">Live</p><p class="mt-3 text-3xl font-semibold text-[#1A1A1A]">{stats.live}</p></article>
      <article class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right"><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">בכתיבה</p><p class="mt-3 text-3xl font-semibold text-[#1A1A1A]">{stats.writing}</p></article>
      <article class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right"><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">לבדיקה</p><p class="mt-3 text-3xl font-semibold text-[#1A1A1A]">{stats.review}</p></article>
      <article class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right"><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">מוכן לפרסום</p><p class="mt-3 text-3xl font-semibold text-[#1A1A1A]">{stats.ready}</p></article>
      <article class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right"><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">פורסם</p><p class="mt-3 text-3xl font-semibold text-[#1A1A1A]">{stats.published}</p></article>
      <article class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right"><p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">Active Services</p><p class="mt-3 text-3xl font-semibold text-[#1A1A1A]">{stats.activeServices}</p></article>
    </section>

    <ArticlesTable articles={articles} />

    <div class="grid gap-8 xl:grid-cols-2">
      <ServicesControlPanel />
      <AppConfigControlPanel />
    </div>

    <section class="grid gap-4 md:grid-cols-2">
      <article class="rounded-[1.8rem] border border-[#1A1A1A]/10 bg-white/82 p-5 shadow-[0_24px_70px_rgba(26,26,26,0.06)] text-right">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">System State</p>
        <h2 class="mt-3 text-2xl font-semibold text-[#1A1A1A]">מודולים גלובליים</h2>
        <ul class="mt-5 space-y-3 text-sm leading-7 text-[#1A1A1A]/72">
          <li class="rounded-[1.2rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-3">Whisper Banner: <strong>{siteSettings.whisperBanner.enabled ? "מופעל" : "כבוי"}</strong></li>
          <li class="rounded-[1.2rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-3">Premium Vault: <strong>{siteSettings.premiumVault.enabled ? "מופעל" : "כבוי"}</strong></li>
        </ul>
      </article>

      <article class="rounded-[1.8rem] border border-[#1A1A1A]/10 bg-white/82 p-5 shadow-[0_24px_70px_rgba(26,26,26,0.06)] text-right">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">Next Step</p>
        <h2 class="mt-3 text-2xl font-semibold text-[#1A1A1A]">מה עושים מכאן</h2>
        <ol class="mt-5 space-y-3 text-sm leading-7 text-[#1A1A1A]/72">
          <li class="rounded-[1.2rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-3">יוצרים מאמר חדש דרך המחולל.</li>
          <li class="rounded-[1.2rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-3">מקדמים כל מאמר דרך התור: בכתיבה, לבדיקה, מוכן לפרסום, ואז פורסם.</li>
          <li class="rounded-[1.2rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-3">בודקים את מסלולי השירות לפי השלבים החדשים לפני כל push.</li>
        </ol>
      </article>
    </section>
  </section>
</Layout>


