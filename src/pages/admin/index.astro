---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import RoleGate from "../../components/admin/RoleGate.astro";

const pageTitle = "לוח ניהול NeverMind";
const pageDescription = "מרכז הניהול של NeverMind - מאמרים, שירותים והגדרות";

// קבל כל המאמרים
const allArticles = await getCollection("articles");
const stats = {
  total: allArticles.length,
  published: allArticles.filter((a) => !a.data.draft).length,
  draft: allArticles.filter((a) => a.data.draft).length,
};

const articles = allArticles
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 10);

const formatDate = new Intl.DateTimeFormat("he-IL", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});

const quickStats = [
  { icon: "📝", label: "כל המאמרים", value: stats.total },
  { icon: "✅", label: "פורסמו", value: stats.published },
  { icon: "⏳", label: "טיוטות", value: stats.draft },
];

const recentArticles = articles.map((a) => ({
  title: a.data.title,
  status: a.data.draft ? "טיוטה" : "פורסם",
  date: formatDate.format(a.data.pubDate),
  slug: a.slug,
  href: `/articles/${a.slug}/`,
}));
---

<Layout
  title={pageTitle}
  description={pageDescription}
  noIndex={true}
>
  <RoleGate requiredRole="viewer">
    <div class="mx-auto max-w-6xl space-y-8 px-5 py-8 text-right sm:px-8 lg:px-12">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--nm-accent)]">לוח בקרה</p>
        <h1 class="text-[clamp(2rem,1.6rem+1vw,2.8rem)] font-semibold">ברוכים הבאים לניהול</h1>
        <p class="max-w-2xl text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
          כאן אתה יכול לנהל את כל התכנים, השירותים וההגדרות של NeverMind.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        {quickStats.map((stat) => (
          <div class="rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 p-6 shadow-sm backdrop-blur-md">
            <div class="text-4xl">{stat.icon}</div>
            <p class="mt-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">{stat.label}</p>
            <p class="mt-1 text-2xl font-bold text-[var(--nm-fg)]">{stat.value}</p>
          </div>
        ))}
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <RoleGate requiredRole="editor">
          <a href="/admin/articles/" class="group rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-sm transition hover:border-[var(--nm-accent)] hover:shadow-md">
            <div class="text-3xl">📝</div>
            <h3 class="mt-3 font-semibold text-[var(--nm-fg)]">ניהול מאמרים</h3>
            <p class="mt-2 text-sm text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">
              יצירה, עריכה ופרסום של מאמרים
            </p>
          </a>
        </RoleGate>

        <RoleGate requiredRole="editor">
          <a href="/admin/services/" class="group rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-sm transition hover:border-[var(--nm-accent)] hover:shadow-md">
            <div class="text-3xl">🛠️</div>
            <h3 class="mt-3 font-semibold text-[var(--nm-fg)]">שירותים</h3>
            <p class="mt-2 text-sm text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">
              ניהול שירותים וחבילות
            </p>
          </a>
        </RoleGate>

        <RoleGate requiredRole="admin">
          <a href="/admin/settings/" class="group rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-sm transition hover:border-[var(--nm-accent)] hover:shadow-md">
            <div class="text-3xl">⚙️</div>
            <h3 class="mt-3 font-semibold text-[var(--nm-fg)]">הגדרות</h3>
            <p class="mt-2 text-sm text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">
              הגדרות כלל-אתר והרשאות
            </p>
          </a>
        </RoleGate>

        <RoleGate requiredRole="admin">
          <a href="/admin/users/" class="group rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 shadow-sm transition hover:border-[var(--nm-accent)] hover:shadow-md">
            <div class="text-3xl">👥</div>
            <h3 class="mt-3 font-semibold text-[var(--nm-fg)]">משתמשים</h3>
            <p class="mt-2 text-sm text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">
              ניהול משתמשים והרשאות
            </p>
          </a>
        </RoleGate>
      </div>

      <RoleGate requiredRole="editor">
        <div class="space-y-4">
          <h2 class="font-semibold text-[var(--nm-fg)]">מאמרים אחרונים</h2>
          <div class="overflow-x-auto rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 shadow-sm">
            <table class="w-full text-right text-sm">
              <thead class="border-b border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)]">
                <tr>
                  <th class="px-4 py-3 font-semibold">כותרת</th>
                  <th class="px-4 py-3 font-semibold">סטטוס</th>
                  <th class="px-4 py-3 font-semibold">תאריך</th>
                </tr>
              </thead>
              <tbody>
                {recentArticles.map((article) => (
                  <tr class="border-b border-[color-mix(in_srgb,var(--nm-fg)_6%,transparent)] transition hover:bg-[var(--nm-surface-muted)]">
                    <td class="px-4 py-3">
                      <a href={article.href} class="font-semibold text-[var(--nm-accent)] underline underline-offset-2">
                        {article.title}
                      </a>
                    </td>
                    <td class="px-4 py-3">
                      <span class={`inline-flex rounded-full px-2 py-1 text-xs font-semibold ${article.status === "פורסם" ? "bg-green-100 text-green-800" : "bg-yellow-100 text-yellow-800"}`}>
                        {article.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">{article.date}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </RoleGate>

      <div class="flex justify-end gap-3">
        <button type="button" id="admin-logout-btn" class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-6 py-3 font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          התנתקות
        </button>
      </div>
    </div>

    <script>
      import { AdminAuth } from "../../lib/admin-auth";

      document.addEventListener("astro:page-load", () => {
        const logoutBtn = document.getElementById("admin-logout-btn");
        logoutBtn?.addEventListener("click", () => {
          AdminAuth.logout();
          window.location.href = "/admin/login/";
        });
      });
    </script>
  </RoleGate>
</Layout>
