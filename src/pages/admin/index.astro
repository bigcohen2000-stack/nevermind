const formatDate = new Intl.DateTimeFormat("he-IL", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});

const workflowConfig = {
  writing: {
    label: "׳‘׳›׳×׳™׳‘׳”",
    tone: "bg-[var(--nm-tint)] text-[var(--nm-fg)] border-[color-mix(in_srgb,var(--nm-accent)_20%,transparent)]",
  },
  review: {
    label: "׳׳‘׳“׳™׳§׳”",
    tone: "bg-[var(--nm-surface-muted)] text-[var(--nm-fg)] border-[color-mix(in_srgb,var(--nm-fg)_14%,transparent)]",
  },
  ready: {
