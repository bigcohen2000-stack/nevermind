---
import Layout from "../../layouts/Layout.astro";
import { FloatingInput } from "../../components/ui/FloatingInput";

const pageTitle = "Viral Paradox Generator";
const pageDescription = "כלי פנימי ליצירת 20 פרדוקסים חדים לשיתוף, על בסיס רעיון, כאב או טקסט גולמי.";
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <section class="mx-auto max-w-7xl space-y-10 px-4 pb-12 text-[var(--nm-fg)]">
    <header class="max-w-4xl space-y-5 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.26em] text-[var(--nm-accent)]">Viral Paradoxes</p>
      <h1 class="text-[clamp(2.4rem,1.8rem+2vw,4rem)] font-semibold leading-[1.05]">מחולל 20 פרדוקסים לשיתוף</h1>
      <p class="max-w-3xl text-[clamp(1rem,0.94rem+0.3vw,1.15rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
        מזינים רעיון, כאב או טקסט גולמי. הכלי מפרק את החומר לציר מרכזי ומייצר 20 משפטים קצרים, חדים וניידים לרשתות,
        פתיחים למאמרים, כותרות משנה או סטוריז.
      </p>
    </header>

    <div class="grid gap-8 xl:grid-cols-[minmax(0,30rem)_minmax(0,1fr)]">
      <section class="space-y-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md">
        <div class="space-y-2 text-right">
          <p class="text-sm font-semibold text-[var(--nm-fg)]">רעיון / טקסט גולמי</p>
          <p class="text-sm leading-6 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">תיאור של נושא, מתח פנימי, כאב, טענה או תמלול קצר. לא צריך להיות מסודר.</p>
          <FloatingInput
            client:load
            id="paradox-raw-text"
            label="דוגמה: אנשים מחפשים שליטה, אבל ככל שהם מנסים לשלוט יותר, הם נהיים יותר חרדים"
            multiline
            rows={14}
            dir="rtl"
            hideValidation={true}
            className="[&_.nm-floating-control]:bg-[var(--nm-surface-muted)] [&_.nm-floating-control--textarea]:min-h-[20rem]"
          />
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="space-y-2 text-right">
            <FloatingInput
              client:load
              id="paradox-core-topic"
              label="ציר מרכזי, למשל שליטה"
              dir="rtl"
              hideValidation={true}
              className="[&_.nm-floating-control]:bg-[var(--nm-surface-muted)]"
            />
          </div>
          <div class="space-y-2 text-right">
            <label for="paradox-tone" class="block text-sm font-semibold text-[var(--nm-fg)]">טון</label>
            <select id="paradox-tone" class="w-full rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3 text-right text-base text-[var(--nm-fg)] outline-none transition focus:border-[color-mix(in_srgb,var(--nm-accent)_40%,transparent)] focus:ring-2 focus:ring-[color-mix(in_srgb,var(--nm-accent)_20%,transparent)]">
              <option value="direct">ישיר</option>
              <option value="cold">קר וחותך</option>
              <option value="reflective">מהורהר</option>
              <option value="provocative">פרובוקטיבי</option>
            </select>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <button id="generate-paradoxes" type="button" class="inline-flex items-center justify-center rounded-full bg-[var(--nm-accent)] px-6 py-4 text-base font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)] focus:outline-none focus:ring-2 focus:ring-[color-mix(in_srgb,var(--nm-accent)_32%,transparent)]">Generate 20 Paradoxes</button>
          <button id="copy-all-paradoxes" type="button" disabled class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-6 py-4 text-base font-semibold text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))] transition hover:bg-white disabled:cursor-not-allowed disabled:opacity-50">העתק הכול</button>
        </div>

        <div class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">איך לעבוד עם זה</p>
          <ol class="mt-3 space-y-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
            <li>1. מתחילים ברעיון גולמי ולא מנסים ללטש אותו.</li>
            <li>2. בוחרים טון אחד, כדי שכל ה־20 יצאו בקו עקבי.</li>
            <li>3. מעתיקים את הטובים ביותר לסטוריז, פתיחים, כותרות משנה או hook למאמר.</li>
          </ol>
        </div>
      </section>

      <section class="space-y-5 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md">
        <div class="flex flex-col gap-3 border-b border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pb-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="space-y-1 text-right">
            <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">פלט</h2>
            <p id="paradox-status" class="text-sm leading-6 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">ממתין לחומר גלם.</p>
          </div>
          <button id="copy-social-block" type="button" disabled class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-2 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)] disabled:cursor-not-allowed disabled:opacity-50">העתק בלוק שיתופי</button>
        </div>

        <div id="paradox-meta" class="grid gap-3 rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right sm:grid-cols-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">ציר</p>
            <p id="paradox-topic-label" class="mt-2 text-sm leading-6 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">עדיין לא זוהה ציר.</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">טון</p>
            <p id="paradox-tone-label" class="mt-2 text-sm leading-6 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">לא נבחר עדיין.</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">שימוש מהיר</p>
            <p class="mt-2 text-sm leading-6 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">כותרות, סטוריז, hooks, ציטוטי קרוסלה או פתיח לפוסט.</p>
          </div>
        </div>

        <div id="paradox-list" class="grid gap-3"></div>
      </section>
    </div>
  </section>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      const rawTextInput = document.getElementById("paradox-raw-text");
      const coreTopicInput = document.getElementById("paradox-core-topic");
      const toneSelect = document.getElementById("paradox-tone");
      const generateButton = document.getElementById("generate-paradoxes");
      const copyAllButton = document.getElementById("copy-all-paradoxes");
      const copySocialButton = document.getElementById("copy-social-block");
      const paradoxList = document.getElementById("paradox-list");
      const status = document.getElementById("paradox-status");
      const topicLabel = document.getElementById("paradox-topic-label");
      const toneLabel = document.getElementById("paradox-tone-label");

      if (!(rawTextInput instanceof HTMLTextAreaElement) ||
          !(coreTopicInput instanceof HTMLInputElement) ||
          !(toneSelect instanceof HTMLSelectElement) ||
          !(generateButton instanceof HTMLButtonElement) ||
          !(copyAllButton instanceof HTMLButtonElement) ||
          !(copySocialButton instanceof HTMLButtonElement) ||
          !(paradoxList instanceof HTMLElement) ||
          !(status instanceof HTMLElement) ||
          !(topicLabel instanceof HTMLElement) ||
          !(toneLabel instanceof HTMLElement)) {
        return;
      }

      const STOPWORDS = new Set(["אני","אתה","את","הוא","היא","אנחנו","אתם","אתן","הם","הן","זה","זאת","הזה","הזאת","של","על","עם","בלי","אבל","אם","או","כי","כדי","ככל","יותר","פחות","גם","כבר","עוד","רק","לא","כן","מה","איך","למה","מול","בתוך","אחרי","לפני","דרך","כאילו","פשוט","מאוד","הכי","הכל","כולם","כלום","מישהו","משהו","שם","כאן","עכשיו","אדם","אנשים"]);
      const toneLabels = {
        direct: "ישיר",
        cold: "קר וחותך",
        reflective: "מהורהר",
        provocative: "פרובוקטיבי",
      };
      let latestParadoxes = [];

      const safeCopy = async (value) => {
        try {
          await navigator.clipboard.writeText(value);
        } catch {
          window.prompt("העתק", value);
        }
      };

      const normalizeWord = (value) => value.replace(/[^\p{L}\p{N}\s-]/gu, " ").replace(/\s+/g, " ").trim();

      const extractKeywords = (text) => {
        const normalized = normalizeWord(text);
        return normalized
          .split(" ")
          .map((word) => word.trim())
          .filter((word) => word.length >= 3)
          .filter((word) => !STOPWORDS.has(word))
          .filter((word, index, array) => array.indexOf(word) === index)
          .slice(0, 8);
      };

      const pick = (items, index, fallback) => items[index % items.length] || fallback;

      const buildTemplates = (topic, words, tone) => {
        const w1 = pick(words, 0, topic);
        const w2 = pick(words, 1, "שליטה");
        const w3 = pick(words, 2, "בהירות");
        const w4 = pick(words, 3, "פחד");
        const w5 = pick(words, 4, "חופש");
        const w6 = pick(words, 5, "אמת");
        const w7 = pick(words, 6, "קרבה");
        const w8 = pick(words, 7, "שקט");

        const base = [
          `ככל שאנשים רודפים יותר אחרי ${w1}, כך הם מתרחקים יותר מ-${w3}.`,
          `מה שנראה כמו ${w2}, הוא לפעמים רק פחד עמוק מ-${w6}.`,
          `אנשים לא נשברים מ-${w4}. הם נשברים מהמאמץ להסתיר אותו.`,
          `הבעיה ב-${w1} היא לא המחיר שלו, אלא הסיפור שבונים סביבו.`,
          `ככל שיותר חשוב להיראות ${w3}, כך קשה יותר לפגוש את ${w6}.`,
          `הרצון ב-${w5} הופך מהר מאוד לעוד צורה של ${w2}.`,
          `מה שנחווה כ-${w4}, הוא לפעמים רק התנגדות לראות ${w1} כמו שהוא.`,
          `אנשים מבקשים ${w8}, אבל לא מוכנים לוותר על הרעש שמחזיק להם זהות.`,
          `ככל שמנסים לשלוט יותר ב-${w7}, כך הוא נעשה פחות אמיתי.`,
          `הדרך המהירה ל-${w5} עוברת דווקא דרך ויתור על ${w2}.`,
          `המאבק ב-${w4} מזין אותו יותר מכל דבר אחר.`,
          `מי שמחפש ${w6} רק כשנוח לו, מחפש בעצם אישור ולא אמת.`,
          `הצורך להיות צודק הוא לעיתים רק צורה מנומסת של ${w4}.`,
          `הניסיון לשמור על ${w1} בכל מחיר, הוא מה שמפרק אותו מבפנים.`,
          `הבטחה ל-${w3} נהיית מסוכנת כשהיא לא כוללת מפגש עם ${w4}.`,
          `אנשים לא מחפשים תמיד פתרון. לפעמים הם מחפשים דרך לשמור על ${w2}.`,
          `מה שנראה כמו בחירה חופשית הוא לפעמים רק נאמנות ישנה ל-${w1}.`,
          `ככל שהדימוי של ${w7} חשוב יותר, כך פחות מרגישים את הקרבה עצמה.`,
          `הרבה פעמים ${w8} מפחיד יותר מהרעש, כי בו כבר אין את מי להאשים.`,
          `הפרדוקס ב-${topic}: מה שאמור להציל אותך, הוא בדיוק מה שמחזיק אותך תקוע.`,
        ];

        const toneTweaks = {
          direct: (value) => value,
          cold: (value) => value.replace(/\.$/, " - וזה כל הסיפור."),
          reflective: (value) => value.replace(/\.$/, ", ורק אחר כך מבינים למה."),
          provocative: (value) => value.replace(/\.$/, ". רוב האנשים יעדיפו לא לראות את זה."),
        };

        return base.map((item) => toneTweaks[tone](item));
      };

      const renderParadoxes = (topic, tone, paradoxes) => {
        paradoxList.innerHTML = "";
        const fragment = document.createDocumentFragment();

        paradoxes.forEach((text, index) => {
          const article = document.createElement("article");
          article.className = "rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 shadow-sm";
          article.innerHTML = `
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div class="space-y-2 text-right">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">Paradox ${index + 1}</p>
                <p class="text-[1rem] leading-8 text-[var(--nm-fg)]">${text}</p>
              </div>
              <button type="button" data-copy-item="${index}" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-2 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">העתק</button>
            </div>
          `;
          fragment.appendChild(article);
        });

        paradoxList.appendChild(fragment);
        paradoxList.querySelectorAll("[data-copy-item]").forEach((button) => {
          button.addEventListener("click", () => {
            const index = Number(button.getAttribute("data-copy-item"));
            safeCopy(paradoxes[index] || "");
          });
        });

        status.textContent = `נוצרו ${paradoxes.length} פרדוקסים סביב ${topic}.`;
        topicLabel.textContent = topic;
        toneLabel.textContent = toneLabels[tone] || tone;
        copyAllButton.disabled = paradoxes.length === 0;
        copySocialButton.disabled = paradoxes.length === 0;
      };

      generateButton.addEventListener("click", () => {
        const rawText = rawTextInput.value.trim();
        const manualTopic = coreTopicInput.value.trim();
        const tone = toneSelect.value;
        const words = extractKeywords(`${manualTopic} ${rawText}`);
        const topic = manualTopic || words[0] || "המתח המרכזי";

        if (!rawText && !manualTopic) {
          status.textContent = "צריך להזין לפחות רעיון אחד או ציר מרכזי כדי לייצר פרדוקסים.";
          paradoxList.innerHTML = "";
          copyAllButton.disabled = true;
          copySocialButton.disabled = true;
          return;
        }

        latestParadoxes = buildTemplates(topic, words, tone);
        renderParadoxes(topic, tone, latestParadoxes);
      });

      copyAllButton.addEventListener("click", () => {
        if (!latestParadoxes.length) return;
        safeCopy(latestParadoxes.map((item, index) => `${index + 1}. ${item}`).join("\n"));
      });

      copySocialButton.addEventListener("click", () => {
        if (!latestParadoxes.length) return;
        const socialBlock = latestParadoxes.slice(0, 5).map((item) => `• ${item}`).join("\n");
        safeCopy(socialBlock);
      });
    });
  </script>
</Layout>
