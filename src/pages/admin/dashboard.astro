---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import fs from "node:fs/promises";
import path from "node:path";

const pageTitle = "Content Health Dashboard";
const pageDescription = "ציון בריאות תוכן לכל מאמר לפי Insight, עדכניות ויחס רכיבי QA.";
const nowMs = Date.now();
const dayMs = 24 * 60 * 60 * 1000;
const recencyWindowDays = 90;

const articles = await getCollection("articles");

const countQaComponents = (body: string) => {
  const patterns = [/<SkepticBox\b/g, /<FAQ\b/g, /<Reflection\b/g];
  return patterns.reduce((sum, pattern) => sum + ((body.match(pattern) || []).length || 0), 0);
};

const computeContentQualityScore = (wordCount: number, qaCount: number) => {
  if (qaCount <= 0) return 0;
  const ratio = wordCount / qaCount;
  const delta = Math.abs(ratio - 300);
  const closeness = Math.max(0, 1 - Math.min(delta / 300, 1));
  return Math.round(closeness * 30);
};

const rows = articles
  .map((entry) => {
    const title = entry.data.title || entry.slug || entry.id;
    const originalInsight = String(entry.data.originalInsight || "").trim();
    const hasOriginalInsight = originalInsight.length > 0;
    const insightScore = hasOriginalInsight ? 40 : 0;

    const updatedAt = entry.data.updatedDate ?? entry.data.pubDate;
    const updatedMs = updatedAt instanceof Date ? updatedAt.getTime() : NaN;
    const ageDays = Number.isFinite(updatedMs) ? (nowMs - updatedMs) / dayMs : Number.POSITIVE_INFINITY;
    const recencyScore = ageDays <= recencyWindowDays ? 30 : 0;

    const body = entry.body || "";
    const wordCount = body.replace(/<[^>]*>/g, " ").split(/\s+/).filter(Boolean).length;
    const qaCount = countQaComponents(body);
    const contentQualityScore = computeContentQualityScore(wordCount, qaCount);

    const score = insightScore + recencyScore + contentQualityScore;

    const badge =
      score < 50
        ? {
            label: "Critical",
            tone: "bg-[color-mix(in_srgb,var(--nm-accent)_8%,var(--nm-bg-canvas))] text-[var(--nm-accent)] border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)]",
          }
        : score < 80
          ? {
              label: "Needs Update",
              tone: "bg-[var(--nm-tint-strong)] text-[var(--nm-fg)] border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)]",
            }
          : {
              label: "Premium Health",
              tone: "bg-[var(--nm-inverse)] text-[var(--nm-inverse-fg)] border-[color-mix(in_srgb,var(--nm-fg)_22%,transparent)]",
            };

    const idBase = entry.id.replace(/\.mdx$/i, "");
    const slugTail = idBase.split("/").pop() || entry.slug || "article";
    const generatorHref = `/admin/generator/?slug=${encodeURIComponent(slugTail)}&title=${encodeURIComponent(title)}`;

    return {
      title,
      score,
      badge,
      insightScore,
      recencyScore,
      contentQualityScore,
      wordCount,
      qaCount,
      updatedLabel: Number.isFinite(updatedMs)
        ? new Intl.DateTimeFormat("he-IL", { year: "numeric", month: "2-digit", day: "2-digit" }).format(
            new Date(updatedMs)
          )
        : "לא זמין",
      generatorHref,
    };
  })
  .sort((a, b) => a.score - b.score);

type SearchGapRow = {
  query: string;
  count: number;
  lastSeen: string;
};

const gapFilePath = path.resolve(process.cwd(), "src/pages/admin/search-gaps.json");
let searchGaps: SearchGapRow[] = [];
try {
  const raw = await fs.readFile(gapFilePath, "utf8");
  const parsed = JSON.parse(raw);
  if (Array.isArray(parsed)) {
    searchGaps = parsed
      .filter((item) => item && typeof item.query === "string")
      .map((item) => ({
        query: String(item.query),
        count: Number(item.count) > 0 ? Number(item.count) : 1,
        lastSeen: String(item.lastSeen || ""),
      }))
      .sort((a, b) => b.count - a.count);
  }
} catch {
  searchGaps = [];
}
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <section class="mx-auto max-w-7xl space-y-8 px-4 pb-14 text-right text-[var(--nm-fg)]">
    <header class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/85 p-6 shadow-[0_24px_70px_rgba(26,26,26,0.06)]">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">Admin Dashboard</p>
      <h1 class="mt-3 text-[clamp(2rem,1.6rem+1.4vw,3rem)] font-semibold">Content Health</h1>
      <p class="mt-3 max-w-3xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
        ציון בריאות לכל מאמר (0-100): Original Insight (40), עדכניות SEO ב־90 ימים אחרונים (30), ויחס איכות תוכן לפי רכיבי QA (30).
      </p>
    </header>

    <div class="overflow-x-auto rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 shadow-[0_24px_70px_rgba(26,26,26,0.06)]">
      <table class="min-w-full text-right">
        <thead class="border-b border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)]">
          <tr class="text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_75%,var(--nm-bg))]">
            <th class="px-4 py-3">מאמר</th>
            <th class="px-4 py-3">Health</th>
            <th class="px-4 py-3">פירוק ציון</th>
            <th class="px-4 py-3">עדכון אחרון</th>
            <th class="px-4 py-3">Actions</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class="border-b border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] text-sm align-top">
              <td class="px-4 py-4 font-semibold text-[var(--nm-fg)]">{row.title}</td>
              <td class="px-4 py-4">
                <div class="flex flex-col items-end gap-2">
                  <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${row.badge.tone}`}>{row.badge.label}</span>
                  <span class="text-lg font-semibold text-[var(--nm-fg)]">{row.score}</span>
                </div>
              </td>
              <td class="px-4 py-4 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
                <div>Insight: {row.insightScore}/40</div>
                <div>Recency: {row.recencyScore}/30</div>
                <div>Quality: {row.contentQualityScore}/30</div>
                <div class="text-xs text-[color-mix(in_srgb,var(--nm-fg)_56%,var(--nm-bg))]">
                  {row.wordCount} מילים · {row.qaCount} רכיבי QA
                </div>
              </td>
              <td class="px-4 py-4 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">{row.updatedLabel}</td>
              <td class="px-4 py-4">
                <a
                  href={row.generatorHref}
                  class="inline-flex items-center rounded-full bg-[var(--nm-accent)] px-4 py-2 text-xs font-semibold text-white transition hover:bg-[var(--nm-accent-hover)]"
                >
                  עריכה ב-Generator
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <section class="space-y-4 rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-5 shadow-[0_24px_70px_rgba(26,26,26,0.06)]">
      <header class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">Insight Gaps</p>
        <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">מה הקהל מחפש ולא מוצא</h2>
      </header>

      <p id="insight-gaps-empty" class:list={["text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]", searchGaps.length > 0 && "hidden"]}>
        עדיין אין פערי חיפוש מתועדים. כשמשתמש יחפש בלי תוצאות, המונח יופיע כאן אוטומטית.
      </p>

      <div id="insight-gaps-table-wrap" class:list={["overflow-x-auto", searchGaps.length === 0 && "hidden"]}>
        <table class="min-w-full text-right">
          <thead class="border-b border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)]">
            <tr class="text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_75%,var(--nm-bg))]">
              <th class="px-4 py-3">מילת חיפוש</th>
              <th class="px-4 py-3">כמות פעמים</th>
              <th class="px-4 py-3">תאריך אחרון</th>
              <th class="px-4 py-3">Actions</th>
            </tr>
          </thead>
          <tbody id="insight-gaps-body">
            {searchGaps.map((row) => (
              <tr class="border-b border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] text-sm">
                <td class="px-4 py-3 font-semibold text-[var(--nm-fg)]">{row.query}</td>
                <td class="px-4 py-3 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">{row.count}</td>
                <td class="px-4 py-3 text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">
                  {new Intl.DateTimeFormat("he-IL", { year: "numeric", month: "2-digit", day: "2-digit" }).format(
                    new Date(row.lastSeen || Date.now())
                  )}
                </td>
                <td class="px-4 py-3">
                  <a
                    href={`/admin/generator/?title=${encodeURIComponent(row.query)}`}
                    class="inline-flex items-center rounded-full bg-[var(--nm-accent)] px-4 py-2 text-xs font-semibold text-white transition hover:bg-[var(--nm-accent-hover)]"
                  >
                    צור מאמר בנושא
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </section>

  <script is:inline>
    document.addEventListener("astro:page-load", async () => {
      const tableBody = document.getElementById("insight-gaps-body");
      const emptyState = document.getElementById("insight-gaps-empty");
      const tableWrap = document.getElementById("insight-gaps-table-wrap");

      try {
        const response = await fetch("/api/log-search-gap", { headers: { accept: "application/json" } });
        if (!response.ok) return;
        const payload = await response.json();
        const rows = Array.isArray(payload?.rows) ? payload.rows : [];

        if (!rows.length) {
          if (emptyState) emptyState.classList.remove("hidden");
          if (tableWrap) tableWrap.classList.add("hidden");
          return;
        }

        if (emptyState) emptyState.classList.add("hidden");
        if (tableWrap) tableWrap.classList.remove("hidden");
        if (!(tableBody instanceof HTMLElement)) return;

        const formatDate = (value) => {
          const date = new Date(value);
          if (Number.isNaN(date.getTime())) return "לא זמין";
          return new Intl.DateTimeFormat("he-IL", { year: "numeric", month: "2-digit", day: "2-digit" }).format(date);
        };

        tableBody.innerHTML = rows
          .map((row) => {
            const query = String(row?.query || "").trim();
            const count = Number(row?.count) > 0 ? Number(row.count) : 1;
            const lastSeen = formatDate(row?.lastSeen);
            const href = `/admin/generator/?title=${encodeURIComponent(query)}`;
            return `
              <tr class="border-b border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] text-sm">
                <td class="px-4 py-3 font-semibold text-[var(--nm-fg)]">${query}</td>
                <td class="px-4 py-3 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">${count}</td>
                <td class="px-4 py-3 text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">${lastSeen}</td>
                <td class="px-4 py-3">
                  <a href="${href}" class="inline-flex items-center rounded-full bg-[var(--nm-accent)] px-4 py-2 text-xs font-semibold text-white transition hover:bg-[var(--nm-accent-hover)]">
                    צור מאמר בנושא
                  </a>
                </td>
              </tr>
            `;
          })
          .join("");
      } catch {
        // keep static fallback table/empty state
      }
    });
  </script>
</Layout>
