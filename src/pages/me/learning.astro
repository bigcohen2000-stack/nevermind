---
import { getCollection } from "astro:content";
import MeLearningBoard from "../../components/me/MeLearningBoard";
import Layout from "../../layouts/Layout.astro";
import { getArticleYoutubeId, getCanonicalArticleSlug } from "../../lib/articles";
import { resolveArticleHeroImage } from "../../lib/resolve-article-hero-image";

const articleEntries = await getCollection("articles", ({ data }) => (data.draft === true ? false : true));
const orderedEntries = [...articleEntries].sort((left, right) => {
  const leftTime = Date.parse((left.data.updatedDate ?? left.data.pubDate).toISOString());
  const rightTime = Date.parse((right.data.updatedDate ?? right.data.pubDate).toISOString());
  return rightTime - leftTime;
});
const totalPublished = orderedEntries.length;
const learningRows = orderedEntries.map((entry) => {
  const slug = getCanonicalArticleSlug(entry);
  return {
    slug,
    title: entry.data.title,
    description: entry.data.description,
    pubDate: entry.data.pubDate.toISOString(),
    updatedDate: entry.data.updatedDate?.toISOString(),
    tags: entry.data.tags ?? [],
    difficultyLevel: entry.data.difficultyLevel,
    image: resolveArticleHeroImage(slug, entry.data.image),
    youtubeId: getArticleYoutubeId(entry.data),
  };
});
---

<Layout title="לוח הלמידה | אזור אישי" description="מעקב אחרי מאמרים, רמות ותגיות לפי נתונים מקומיים ושרת.">
  <section id="main-content" class="mx-auto max-w-5xl space-y-10 px-4 py-14 text-right text-[var(--nm-fg)]">
    <header class="space-y-3">
      <p class="text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">אזור אישי</p>
      <h1 class="text-[clamp(1.85rem,1.5rem+1.2vw,2.65rem)] font-semibold leading-tight">לוח הלמידה</h1>
      <p class="max-w-2xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        סינון לפי רמה ותגיות. ההתקדמות וזמן הקריאה מסומנים בשרת כשיש כניסת מועדון פעילה.
      </p>
    </header>

    <nav class="flex flex-wrap justify-end gap-3 text-sm font-semibold text-[var(--nm-accent)]">
      <a href="/articles/" class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-2 transition hover:bg-[var(--nm-surface-muted)]">כל המאמרים</a>
      <a href="/glossary/" class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-2 transition hover:bg-[var(--nm-surface-muted)]">מילון המושגים</a>
      <a href="/me/unlock/" class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-2 transition hover:bg-[var(--nm-surface-muted)]">המשך למועדון</a>
    </nav>

    <MeLearningBoard client:visible articles={learningRows} totalPublished={totalPublished} />
  </section>
</Layout>
