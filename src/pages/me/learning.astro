---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import MeLearningBoard from "../../components/me/MeLearningBoard";

const articleEntries = await getCollection("articles", ({ data }) => !data.draft);
const totalPublished = articleEntries.length;
const learningRows = articleEntries.map((e) => ({
  slug: e.slug,
  title: e.data.title,
  pubDate: e.data.pubDate.toISOString(),
  updatedDate: e.data.updatedDate?.toISOString(),
  tags: e.data.tags ?? [],
  difficultyLevel: e.data.difficultyLevel,
}));
---

<Layout title="לוח הלמידה | אזור אישי" description="מעקב אחר מאמרים, רמות ותגיות לפי נתונים מקומיים ושרת.">
  <section class="mx-auto max-w-5xl space-y-10 px-4 py-14 text-right text-[var(--nm-fg)]">
    <header class="space-y-3">
      <p class="text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">אזור אישי</p>
      <h1 class="text-[clamp(1.85rem,1.5rem+1.2vw,2.65rem)] font-semibold leading-tight">לוח הלמידה</h1>
      <p class="max-w-2xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        סינון לפי רמה ותגיות. התקדמות וזמן מסומנים בשרת כשיש כניסת מועדון פעילה.
      </p>
    </header>

    <MeLearningBoard client:visible articles={learningRows} totalPublished={totalPublished} />
  </section>
</Layout>
