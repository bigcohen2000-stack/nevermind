          <div class="mt-5 space-y-3">
            <label class="sr-only" for="unlock-code-input">הכנס קוד אישי</label>
            <input
              id="unlock-code-input"
              type="password"
              autocomplete="off"
              placeholder="הכנס קוד אישי"
              class="min-h-[54px] w-full rounded-full border border-[rgba(26,26,26,0.12)] bg-[#FAFAF8] px-5 text-right text-base outline-none transition placeholder:text-[rgba(26,26,26,0.32)] focus:border-[rgba(94,116,104,0.34)]"
            />
            <button
              id="unlock-enter"
              type="button"
              class="inline-flex min-h-[54px] w-full items-center justify-center rounded-full border border-[rgba(26,26,26,0.12)] bg-[#1A1A1A] px-6 text-base font-semibold text-[#FAFAF8] transition hover:bg-[#2A2A2A] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#1A1A1A]"
            >
              פתח לי את הדלת
            </button>
            <p id="unlock-error" class="hidden text-sm leading-7 text-[#8E4E4E]">
              הקוד לא זוהה עדיין. אפשר לדבר איתי ישירות ולקבל כיוון קצר.
            </p>
            <p id="unlock-success" class="hidden text-sm leading-7 text-[#4B6055]">
              הקוד זוהה. אתה כבר בפנים.
            </p>
          </div>
        </section>

        <section class="unlock-rise rounded-[1.75rem] border border-[rgba(26,26,26,0.1)] bg-white/90 p-6 shadow-[0_18px_48px_rgba(67,82,72,0.05)]" style="--delay: 280ms;">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-sm font-semibold text-[rgba(26,26,26,0.46)]">הדרך שלך</p>
              <h2 class="mt-2 text-[1.45rem] font-semibold tracking-[-0.03em]">ניווט קצר ונעים</h2>
            </div>
            <button id="unlock-logout" type="button" class="hidden text-sm text-[rgba(26,26,26,0.6)] underline underline-offset-4">יציאה</button>
          </div>
          <div id="unlock-links" class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-2">
            {previewLinks.map((item) => (
              <a
                href={item.href}
                class="unlock-link-card group relative rounded-[1.35rem] border border-[rgba(26,26,26,0.08)] bg-[rgba(250,250,248,0.92)] p-4 transition hover:border-[rgba(94,116,104,0.24)] hover:bg-white"
                data-premium-card={item.premium ? "true" : "false"}
                data-wa-link={item.label === "בוא נדבר" ? "true" : undefined}
                target={item.href.startsWith("https://wa.me/") ? "_blank" : undefined}
                rel={item.href.startsWith("https://wa.me/") ? "noopener noreferrer" : undefined}
              >
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-base font-semibold group-hover:text-[#4B6055]">{item.label}</h3>
                  {item.premium ? <span class="unlock-lock text-sm text-[rgba(26,26,26,0.46)]">סגור</span> : null}
                </div>
                <p class="mt-2 text-sm leading-7 text-[rgba(26,26,26,0.64)]">{item.description}</p>
              </a>
            ))}
          </div>
        </section>
      </aside>
    </section>

    <section class="unlock-rise mt-6 rounded-[1.75rem] border border-[rgba(26,26,26,0.1)] bg-white/88 p-6 shadow-[0_18px_48px_rgba(67,82,72,0.05)]" style="--delay: 320ms;">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:items-start">
        <div class="space-y-3">
          <p class="text-sm font-semibold text-[rgba(26,26,26,0.46)]">שאלות קצרות</p>
          <h2 class="text-[clamp(1.45rem,1.3rem+0.7vw,2rem)] font-semibold tracking-[-0.03em]">לפני שנשארים בחיבור</h2>
          <p class="text-sm leading-7 text-[rgba(26,26,26,0.66)]">
            כאן יש תשובות קצרות. אם משהו עדיין לא יושב טוב, בוא נדבר.
          </p>
        </div>
        <div class="space-y-3">
          {faqItems.map((item) => (
            <details class="group rounded-[1.25rem] border border-[rgba(26,26,26,0.08)] bg-[rgba(250,250,248,0.92)] p-4 open:bg-white">
              <summary class="cursor-pointer list-none text-base font-semibold marker:content-none [&::-webkit-details-marker]:hidden">
                <span class="flex items-start justify-between gap-3">
                  <span>{item.question}</span>
                  <span class="text-[#5E7468] transition group-open:rotate-45" aria-hidden="true">+</span>
                </span>
              </summary>
              <p class="mt-3 border-t border-[rgba(26,26,26,0.08)] pt-3 text-sm leading-7 text-[rgba(26,26,26,0.68)]">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="unlock-rise mt-6 text-center" style="--delay: 360ms;">
      <p class="text-sm font-semibold text-[rgba(26,26,26,0.48)]">אתה כבר בבית</p>
      <p class="mx-auto mt-3 max-w-2xl text-[clamp(1.2rem,1.05rem+0.6vw,1.65rem)] font-semibold leading-8 tracking-[-0.03em]">
        רוצה להישאר בחיבור
      </p>
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-[rgba(26,26,26,0.64)]">
        שיחה אחת קצרה בוואטסאפ מספיקה כדי להבין אם המועדון מתאים לך עכשיו.
      </p>
      <a
        href={whatsAppHref}
        target="_blank"
        rel="noopener noreferrer"
        data-wa-link
        class="mt-5 inline-flex min-h-[62px] items-center justify-center rounded-full bg-[#5E7468] px-8 text-lg font-semibold text-[#FAFAF8] shadow-[0_18px_40px_rgba(94,116,104,0.28)] transition hover:-translate-y-0.5 hover:bg-[#50655A]"
      >
        בוא נדבר בוואטסאפ - זה עדיין חינם בשבילך
      </a>
    </section>
  </section>

  <style>
    .unlock-shell {
      direction: rtl;
    }

    .unlock-rise {
      opacity: 0;
      transform: translateY(18px);
      animation: unlock-rise 760ms cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-delay: var(--delay, 0ms);
    }

    .door-scene {
      position: relative;
      width: min(100%, 14rem);
      aspect-ratio: 1 / 1.15;
      display: grid;
      place-items: end center;
    }

    .door-glow {
      position: absolute;
      inset: 8% 20% 18%;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(255, 243, 214, 0.95), rgba(255, 243, 214, 0.2) 50%, transparent 72%);
      filter: blur(10px);
    }

    .door-frame {
      position: relative;
      width: 68%;
      height: 78%;
      border-radius: 1.2rem 1.2rem 0.9rem 0.9rem;
      border: 1px solid rgba(26, 26, 26, 0.12);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(223, 231, 225, 0.9));
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.36);
      overflow: hidden;
    }

    .door-panel {
      position: absolute;
      inset: 4%;
      border-radius: 1rem 1rem 0.7rem 0.7rem;
      background: linear-gradient(180deg, rgba(94, 116, 104, 0.95), rgba(72, 92, 81, 0.98));
      transform-origin: left center;
      animation: door-open 4.8s ease-in-out infinite alternate;
      box-shadow: 0 16px 32px rgba(67, 82, 72, 0.25);
    }

    .door-handle {
      position: absolute;
      top: 48%;
      right: 17%;
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 999px;
      background: rgba(255, 246, 222, 0.95);
      box-shadow: 0 0 0 4px rgba(255, 246, 222, 0.12);
      z-index: 2;
    }

    .door-floor {
      position: absolute;
      bottom: 7%;
      width: 86%;
      height: 12%;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(94, 116, 104, 0.18), rgba(94, 116, 104, 0.04) 60%, transparent 72%);
      filter: blur(6px);
    }

    .coffee-mark {
      position: absolute;
      bottom: 2%;
      left: 8%;
      font-size: 0.75rem;
      font-weight: 600;
      color: rgba(26, 26, 26, 0.45);
      letter-spacing: 0.04em;
    }

    .unlock-link-card[data-premium-card="true"] {
      filter: grayscale(0.28);
    }

    .unlock-shell[data-authorized="true"] .unlock-link-card[data-premium-card="true"] {
      filter: none;
    }

    .unlock-shell[data-authorized="true"] .unlock-lock {
      display: none;
    }

    @keyframes unlock-rise {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes door-open {
      from {
        transform: perspective(520px) rotateY(0deg);
      }
      to {
        transform: perspective(520px) rotateY(-34deg);
      }
    }

    @media (prefers-color-scheme: dark) {
      .unlock-shell {
        color: #fafaf8;
      }

      .unlock-shell :is(header, section, article, aside) {
        border-color: rgba(250, 250, 248, 0.12);
      }

      .unlock-shell .bg-white\/88,
      .unlock-shell .bg-white\/90,
      .unlock-shell .bg-\[rgba\(250\,250\,248\,0\.92\)\],
      .unlock-shell .bg-\[rgba\(250\,250\,248\,0\.9\)\] {
        background: rgba(255, 255, 255, 0.05);
      }

      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.72\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.68\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.66\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.64\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.62\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.6\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.58\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.56\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.52\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.48\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.46\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.45\)\] {
        color: rgba(250, 250, 248, 0.72);
      }

      .unlock-shell .door-frame {
        border-color: rgba(250, 250, 248, 0.18);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.04));
      }

      .unlock-shell input {
        border-color: rgba(250, 250, 248, 0.16);
        background: rgba(255, 255, 255, 0.04);
        color: #fafaf8;
      }

      .unlock-shell input::placeholder {
        color: rgba(250, 250, 248, 0.34);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .unlock-rise,
      .door-panel {
        animation: none;
        opacity: 1;
        transform: none;
      }
    }
  </style>

  <script is:inline define:vars={{ validCodesRaw, whatsAppHref, whatsAppMessage, joinOfferHref, launchOfferPrice, pulseEndpoint }}>
    (() => {
      const shell = document.querySelector(".unlock-shell");
      const input = document.getElementById("unlock-code-input");
      const enterButton = document.getElementById("unlock-enter");
      const errorLine = document.getElementById("unlock-error");
      const successLine = document.getElementById("unlock-success");
      const logoutButton = document.getElementById("unlock-logout");
      const liveCounterCount = document.querySelector('[data-live-counter-count]');
      const liveCounterCopy = document.querySelector('[data-live-counter-copy]');
      const liveCounterNote = document.querySelector('[data-live-counter-note]');
      const joinDot = document.querySelector('[data-join-dot]');
      const joinLabel = document.querySelector('[data-join-label]');
      const joinTitle = document.querySelector('[data-join-title]');
      const joinCopy = document.querySelector('[data-join-copy]');
      const joinOffer = document.getElementById('unlock-join-offer');
      const statStreak = document.querySelector('[data-stat="streak"]');
      const statSeconds = document.querySelector('[data-stat="seconds"]');
      const statSession = document.querySelector('[data-stat="session"]');
      const streakBar = document.querySelector('[data-progress="streak"]');
      const secondsBar = document.querySelector('[data-progress="seconds"]');
      const sessionBar = document.querySelector('[data-progress="session"]');
      const validCodes = String(validCodesRaw || "")
        .split(",")
        .map((code) => code.trim())
        .filter(Boolean);

      const storageKey = "nm_access_code";
      const LS_LOG = "nm_article_open_log";
      const LS_SECONDS = "nm_reading_seconds_local";
      const LS_STREAK = "nm_dashboard_streak";

      const readJson = (key) => {
        try {
          const raw = localStorage.getItem(key);
          return raw ? JSON.parse(raw) : null;
        } catch {
          return null;
        }
      };

      const hasPremiumSession = () => {
        const premium = readJson("nm-premium-access");
        const club = readJson("nm_club_session");
        const premiumExpiry = Date.parse(String(premium?.expiresAt || ""));
        const clubExpiry = Date.parse(String(club?.expiresAt || ""));
        return (Number.isFinite(premiumExpiry) && premiumExpiry > Date.now()) || (Number.isFinite(clubExpiry) && clubExpiry > Date.now());
      };

      const isCodeValid = (value) => {
        const clean = String(value || "").trim();
        if (!clean) return false;
        if (!validCodes.length) return false;
        return validCodes.includes(clean);
      };

      const formatSeconds = (value) => {
        const total = Number(value) || 0;
        const minutes = Math.floor(total / 60);
        if (minutes <= 0) return "0 דקות";
        if (minutes < 60) return `${minutes} דקות`;
        const hours = Math.floor(minutes / 60);
        const rest = minutes % 60;
        return rest > 0 ? `${hours} שעות ו-${rest} דקות` : `${hours} שעות`;
      };

      const readOpenLogCount = () => {
        try {
          const raw = JSON.parse(localStorage.getItem(LS_LOG) || "[]");
          if (!Array.isArray(raw)) return 0;
          return new Set(raw.map((item) => item?.slug).filter(Boolean)).size;
        } catch {
          return 0;
        }
      };

      const readSeconds = () => {
        try {
          const value = Number.parseInt(localStorage.getItem(LS_SECONDS) || "0", 10);
          return Number.isFinite(value) && value > 0 ? value : 0;
        } catch {
          return 0;
        }
      };

      const readStreak = () => {
        try {
          const raw = JSON.parse(localStorage.getItem(LS_STREAK) || "{}");
          return Number(raw?.count) || 0;
        } catch {
          return 0;
        }
      };

      const trackWaClick = (location) => {
        try {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: "unlock_whatsapp_click", location });
          if (typeof window.gtag === "function") {
            window.gtag("event", "unlock_whatsapp_click", {
              event_category: "engagement",
              event_label: location,
              destination: "whatsapp",
            });
          }
        } catch {
          /* ignore */
        }
      };

      const renderLiveCounter = (activeNow, mood, available = true) => {
        if (!available) {
          if (liveCounterCount instanceof HTMLElement) {
            liveCounterCount.textContent = "--";
          }
          if (liveCounterCopy instanceof HTMLElement) {
            liveCounterCopy.textContent = "הספירה החיה תופעל כשהחיבור לאנליטיקס יושלם.";
          }
          if (liveCounterNote instanceof HTMLElement) {
            liveCounterNote.textContent = "בינתיים אפשר להישאר כאן בשקט בלי מספר מומצא.";
          }
          return;
        }
        const safeCount = Math.max(1, Number(activeNow) || 1);
        if (liveCounterCount instanceof HTMLElement) {
          liveCounterCount.textContent = String(safeCount);
        }
        if (liveCounterCopy instanceof HTMLElement) {
          liveCounterCopy.textContent = safeCount === 1
            ? "כרגע יש כאן אדם אחד עם הטקסט הזה. זה יכול להיות רק אתה, וזה עדיין מספיק."
            : `כרגע יש כאן ${safeCount} אנשים באתר. ${String(mood || "יש כאן תנועה שקטה")}`;
        }
        if (liveCounterNote instanceof HTMLElement) {
          liveCounterNote.textContent = safeCount === 1
            ? "גם אם זה רק אתה, המקום הזה עדיין פתוח בשבילך."
            : "כל אחד מגיע בקצב שלו. אתה יכול להישאר כאן בלי למהר."
        }
      };

      const renderJoinState = (authorized) => {
        if (joinTitle instanceof HTMLElement) {
          joinTitle.textContent = authorized ? "החיבור שלך פעיל" : "החיבור שלך עוד לא פעיל";
        }
        if (joinLabel instanceof HTMLElement) {
          joinLabel.textContent = authorized ? "נורה ירוקה" : "נורה אדומה";
        }
        if (joinCopy instanceof HTMLElement) {
          joinCopy.textContent = authorized
            ? "יש כבר גישה פעילה במכשיר הזה. אפשר להמשיך ישר לאזור האישי או לקרוא בלי להיתקע בדרך."
            : `אפשר לפתוח חודש ראשון במחיר השקה של ${launchOfferPrice} ש"ח, להיכנס בשקט, ולקבל גישה למה שנשמר לחברים.`;
        }
        if (joinDot instanceof HTMLElement) {
          joinDot.style.background = authorized ? "#4B6055" : "#D42B2B";
          joinDot.style.boxShadow = authorized
            ? "0 0 0 6px rgba(75,96,85,0.12)"
            : "0 0 0 6px rgba(212,43,43,0.12)";
        }
        if (joinOffer instanceof HTMLAnchorElement) {
          if (authorized) {
            joinOffer.href = "/me/";
            joinOffer.textContent = "להיכנס לאזור האישי";
            joinOffer.removeAttribute("target");
            joinOffer.removeAttribute("rel");
          } else {
            joinOffer.href = joinOfferHref;
            joinOffer.textContent = `בקשה להצטרף לחודש ראשון ב-${launchOfferPrice} ש"ח`;
            joinOffer.setAttribute("target", "_blank");
            joinOffer.setAttribute("rel", "noopener noreferrer");
          }
        }
      };

      const refreshPulse = async () => {
        try {
          const response = await fetch(pulseEndpoint, {
            headers: { accept: "application/json" },
            cache: "no-store",
          });
          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload?.ok) {
            renderLiveCounter(null, "הספירה החיה ממתינה לחיבור", false);
            return;
          }
          if (payload.available === false) {
            renderLiveCounter(null, payload.mood, false);
            return;
          }
          renderLiveCounter(payload.activeNow, payload.mood, true);
        } catch {
          renderLiveCounter(null, "הספירה החיה ממתינה לחיבור", false);
        }
      };

      const syncAuthorizedState = () => {
        const storedCode = localStorage.getItem(storageKey) || "";
        const authorized = isCodeValid(storedCode) || hasPremiumSession();
        shell?.setAttribute("data-authorized", authorized ? "true" : "false");
        logoutButton?.classList.toggle("hidden", !authorized);
        if (statSession instanceof HTMLElement) {
          statSession.textContent = authorized ? "פעיל" : "ממתין";
        }
        if (sessionBar instanceof HTMLElement) {
          sessionBar.style.width = authorized ? "88%" : "18%";
        }
        if (successLine instanceof HTMLElement) {
          successLine.classList.toggle("hidden", !authorized);
        }
        renderJoinState(authorized);
        return authorized;
      };

      const syncStats = () => {
        const streak = readStreak();
        const seconds = readSeconds();
        const readCount = readOpenLogCount();
        if (statStreak instanceof HTMLElement) {
          statStreak.textContent = String(streak);
        }
        if (streakBar instanceof HTMLElement) {
          streakBar.style.width = `${Math.min(100, 8 + streak * 12)}%`;
        }
        if (statSeconds instanceof HTMLElement) {
          statSeconds.textContent = formatSeconds(seconds);
        }
        if (secondsBar instanceof HTMLElement) {
          secondsBar.style.width = `${Math.min(100, 8 + Math.round(seconds / 90))}%`;
        }
        const articlesCard = document.querySelector('[data-stat="articles"]');
        if (articlesCard instanceof HTMLElement && readCount > 0) {
          articlesCard.textContent = String(readCount);
        }
      };

      document.querySelectorAll("[data-wa-link]").forEach((link, index) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        if (!link.href || link.getAttribute("href") === "#") {
          link.href = whatsAppHref;
        }
        link.addEventListener("click", () => trackWaClick(index === 0 ? "hero" : "page"));
      });

      enterButton?.addEventListener("click", () => {
        const code = String(input instanceof HTMLInputElement ? input.value : "").trim();
        const authorized = isCodeValid(code);
        if (authorized) {
          localStorage.setItem(storageKey, code);
          errorLine?.classList.add("hidden");
          successLine?.classList.remove("hidden");
          syncAuthorizedState();
          return;
        }
        errorLine?.classList.remove("hidden");
        successLine?.classList.add("hidden");
      });

      if (input instanceof HTMLInputElement) {
        input.addEventListener("keydown", (event) => {
          if (event.key === "Enter") {
            event.preventDefault();
            enterButton?.click();
          }
        });
      }

      logoutButton?.addEventListener("click", () => {
        localStorage.removeItem(storageKey);
        localStorage.removeItem("nm-premium-access");
        syncAuthorizedState();
      });

      syncStats();
      syncAuthorizedState();
      void refreshPulse();
      window.setInterval(() => {
        void refreshPulse();
      }, 45000);
      window.addEventListener("storage", () => {
        syncStats();
        syncAuthorizedState();
        void refreshPulse();
      });
      window.addEventListener("nm-club-session-changed", () => {
        syncStats();
        syncAuthorizedState();
        void refreshPulse();
      });
    })();
  </script>

  <script>
    import "../../scripts/unlock-preview.js";
  </script>
</Layout>

