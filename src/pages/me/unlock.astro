---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import appConfig from "../../config/appConfig.json";
import { jsonLdForInlineScript } from "../../lib/json-ld-inline";
import { getArticleYoutubeId, getCanonicalArticleSlug } from "../../lib/articles";
import { resolveArticleHeroImage } from "../../lib/resolve-article-hero-image";

const whatsAppNumber =
  import.meta.env.PUBLIC_WHATSAPP_NUMBER ||
  import.meta.env.NEXT_PUBLIC_WHATSAPP_NUMBER ||
  appConfig.contact.whatsAppNumber;
const validCodesRaw =
  import.meta.env.PUBLIC_DASHBOARD_CODES ||
  import.meta.env.NEXT_PUBLIC_DASHBOARD_CODES ||
  "";
const unlockAccessModeRaw =
  import.meta.env.PUBLIC_UNLOCK_ACCESS_MODE ||
  import.meta.env.NEXT_PUBLIC_UNLOCK_ACCESS_MODE ||
  "";
const verifyCodeEndpoint = "/api/site/verify-unlock-code";
const sharedAccessSessionEndpoint = "/api/site/shared-access-session";
const premiumSessionHours = Number(appConfig.premiumAccess?.sessionHours ?? 168);
const whatsAppDigits = String(whatsAppNumber || "").replace(/\D/g, "");
const whatsAppMessage = "היי, הגעתי מהלוח האישי. רוצה להצטרף למועדון ולהישאר בחיבור פעיל.";
const whatsAppHref = whatsAppDigits
  ? `https://wa.me/${whatsAppDigits}?text=${encodeURIComponent(whatsAppMessage)}`
  : "/contact/";
const launchOfferPrice = 175;
const joinOfferMessage = `היי, הגעתי מהלוח האישי. אני רוצה להצטרף לחודש ראשון במחיר השקה של ${launchOfferPrice} ש"ח.`;
const joinOfferHref = whatsAppDigits
  ? `https://wa.me/${whatsAppDigits}?text=${encodeURIComponent(joinOfferMessage)}`
  : "/contact/?source=unlock-launch";
const pulseEndpoint = "/api/site/pulse";

const entries = await getCollection("articles", ({ data }) => !data.draft);
const latestArticles = [...entries]
  .sort((a, b) => {
    const aTime = Date.parse(a.data.updatedDate?.toISOString() || a.data.pubDate.toISOString());
    const bTime = Date.parse(b.data.updatedDate?.toISOString() || b.data.pubDate.toISOString());
    return bTime - aTime;
  })
  .slice(0, 4)
  .map((entry) => {
    const slug = getCanonicalArticleSlug(entry);
    return {
      slug,
      title: entry.data.title,
      description: String(entry.data.description || "").trim(),
      updatedAt: (entry.data.updatedDate ?? entry.data.pubDate).toISOString(),
      image: resolveArticleHeroImage(slug, entry.data.image),
      youtubeId: getArticleYoutubeId(entry.data),
      tags: Array.isArray(entry.data.tags) ? entry.data.tags.slice(0, 3) : [],
    };
  });

const totalArticles = entries.length;
const latestUpdate = latestArticles[0]?.updatedAt
  ? new Date(latestArticles[0].updatedAt).toLocaleDateString("he-IL", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
    })
  : "אין עדכון עדיין";

const previewLinks = [
  {
    label: "ספרייה",
    href: "/library/",
    description: "אוסף קריאה שקט שמחכה לך בקצב שלך.",
    premium: true,
  },
  {
    label: "מאמרים",
    href: "/articles/",
    description: "כניסה ישר לטקסטים הפתוחים ולמה שחדש עכשיו.",
    premium: false,
  },
  {
    label: "עומק",
    href: "/me/learning/",
    description: "מסלול אישי למי שרוצה להישאר קרוב לחומר.",
    premium: true,
  },
  {
    label: "בוא נדבר",
    href: whatsAppHref,
    description: "שיחה קצרה כשבא לך לבדוק אם זה מתאים לך.",
    premium: false,
  },
];

const clubBenefits = [
  {
    title: "מועדון והטבות",
    body: "כאן אתה מקבל גישה קרובה יותר, קצב אישי, ותחושה שאתה כבר בבית.",
  },
  {
    title: "עד 10,000 שעות מחכות לך",
    body: "כתיבה, קריאה ושיחות שנבנו כדי לעזור לך להישאר צלול גם ביום רגיל.",
  },
  {
    title: "זה עדיין חינם בשבילך",
    body: "אפשר להתחיל משיחה קצרה, בלי טופס ארוך ובלי לחץ מיותר.",
  },
];

const faqItems = [
  {
    question: "מה קורה אם הקוד לא זוהה",
    answer:
      "העמוד נשאר פתוח, אתה עדיין בבית, ואפשר להמשיך למאמרים או לדבר איתי ישירות בוואטסאפ.",
  },
  {
    question: "מה מקבלים במועדון",
    answer:
      "גישה קרובה יותר לתוכן, המשך למידה מסודר, ושיחה ישירה כשצריך כיוון קצר.",
  },
  {
    question: "האם זה עדיין חינם בשבילי",
    answer:
      "כן. כאן מתחילים ברכות, בודקים התאמה, ורק אז מחליטים אם רוצים להישאר בחיבור.",
  },
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "יקיר כהן",
  url: "https://www.nevermind.co.il/about/",
  image: "https://www.nevermind.co.il/uploads/nevermind-yakir.webp",
  description: "פרספקטיבה אישית עם מעל 10,000 שעות תוכן, כתיבה ושיחות סביב חשיבה צלולה ושיטת ההיפוכים.",
  jobTitle: "יוצר NeverMind",
  worksFor: {
    "@type": "Organization",
    name: "NeverMind",
    url: "https://www.nevermind.co.il/",
  },
  sameAs: [
    "https://www.facebook.com/nevermindyakir",
    "https://www.instagram.com/nevermind.co.il/",
    "https://x.com/nevermindyakir",
  ],
};

const offerSchema = {
  "@context": "https://schema.org",
  "@type": "Offer",
  name: "מועדון NeverMind חינם",
  url: "https://www.nevermind.co.il/me/unlock/",
  price: "0",
  priceCurrency: "ILS",
  availability: "https://schema.org/InStock",
  description: "מועדון NeverMind חינם עם חיבור פעיל, גישה פתוחה למאמרים ושיחה ישירה בוואטסאפ.",
  seller: {
    "@type": "Organization",
    name: "NeverMind",
    url: "https://www.nevermind.co.il/",
  },
};
---

<Layout
  title="ברוך הבא ל-NeverMind - גם בלי קוד"
  description="מועדון NeverMind חינם + חיבור פעיל. גם בלי קוד, אתה כבר בבית: מאמרים, חשיבה צלולה, שיטת ההיפוכים ושיחה ישירה בוואטסאפ."
  faqItems={faqItems}
  breadcrumbCurrentLabel="ברוך הבא ל-NeverMind - גם בלי קוד"
>
  <script is:inline type="application/ld+json" set:html={jsonLdForInlineScript(personSchema)} />
  <script is:inline type="application/ld+json" set:html={jsonLdForInlineScript(offerSchema)} />

  <section class="unlock-shell mx-auto max-w-6xl px-4 pb-24 pt-12 text-right text-[#1A1A1A] sm:px-6 lg:px-8">
    <header class="unlock-rise grid gap-6 rounded-[2rem] border border-[rgba(26,26,26,0.08)] bg-[linear-gradient(135deg,rgba(255,255,255,0.94),rgba(242,245,242,0.92),rgba(250,250,248,0.98))] p-6 shadow-[0_24px_80px_rgba(67,82,72,0.06)] md:p-8 lg:grid-cols-[minmax(0,1.2fr)_22rem] lg:items-center" style="--delay: 20ms;">
      <div class="space-y-6">
        <div class="flex flex-wrap justify-end gap-2 text-[0.75rem] font-semibold text-[rgba(26,26,26,0.62)]">
          <span class="rounded-full border border-[rgba(88,108,97,0.16)] bg-[rgba(88,108,97,0.08)] px-3 py-1.5">אתה כבר בבית</span>
          <span class="rounded-full border border-[rgba(88,108,97,0.16)] bg-[rgba(88,108,97,0.08)] px-3 py-1.5">זה עדיין חינם בשבילך</span>
          <span class="rounded-full border border-[rgba(88,108,97,0.16)] bg-[rgba(88,108,97,0.08)] px-3 py-1.5">חיבור פעיל</span>
        </div>

        <div class="space-y-4">
          <p class="text-sm font-semibold tracking-[0.16em] text-[rgba(26,26,26,0.46)]">אזור אישי</p>
          <h1 class="max-w-3xl text-[clamp(2.4rem,1.9rem+2.5vw,4.8rem)] font-semibold leading-[1.02] tracking-[-0.04em]">
            ברוך הבא ל-NeverMind - גם בלי קוד
          </h1>
          <p class="max-w-2xl text-[1.06rem] leading-8 text-[rgba(26,26,26,0.72)]">
            גם אם הקוד לא נפתח, הדלת כאן נשארת פתוחה. אתה כבר בבית, זה עדיין חינם בשבילך, וכאן כבר מרגישים את השקט.
          </p>
          <p class="max-w-2xl text-[1rem] leading-8 text-[rgba(26,26,26,0.66)]">
            יש כאן טעימה מהספרייה, מאמרים פתוחים, והזמנה אחת פשוטה לדבר. רוצה להישאר בחיבור.
          </p>
        </div>

        <div class="space-y-3">
          <a
            href={whatsAppHref}
            target="_blank"
            rel="noopener noreferrer"
            data-wa-link
            class="inline-flex min-h-[64px] w-full items-center justify-center rounded-full bg-[#5E7468] px-8 text-center text-lg font-semibold text-[#FAFAF8] shadow-[0_18px_40px_rgba(94,116,104,0.28)] transition hover:-translate-y-0.5 hover:bg-[#50655A] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#5E7468] sm:w-auto sm:min-w-[24rem] sm:text-xl"
          >
            בוא נדבר בוואטסאפ - זה מרגיש כמו בית
          </a>
          <p class="text-sm text-[rgba(26,26,26,0.58)]">
            זה עדיין חינם בשבילך. אם וואטסאפ לא נפתח, אפשר לעבור גם ל<a href="/contact/" class="font-semibold underline underline-offset-4">דף קשר</a>.
          </p>
        </div>

        <div class="flex flex-wrap justify-end gap-3 text-sm text-[rgba(26,26,26,0.62)]">
          <a href="/me/" class="rounded-full border border-[rgba(26,26,26,0.1)] px-4 py-2 transition hover:border-[rgba(94,116,104,0.28)] hover:bg-white/70">חזרה לאזור האישי</a>
          <a href="/articles/" class="rounded-full border border-[rgba(26,26,26,0.1)] px-4 py-2 transition hover:border-[rgba(94,116,104,0.28)] hover:bg-white/70">מעבר למאמרים</a>
          <a href="/me/learning/" class="rounded-full border border-[rgba(26,26,26,0.1)] px-4 py-2 transition hover:border-[rgba(94,116,104,0.28)] hover:bg-white/70">לוח הלמידה</a>
          <a href="/glossary/" class="rounded-full border border-[rgba(26,26,26,0.1)] px-4 py-2 transition hover:border-[rgba(94,116,104,0.28)] hover:bg-white/70">מילון המושגים</a>
        </div>
      </div>

      <div class="relative overflow-hidden rounded-[1.8rem] border border-[rgba(26,26,26,0.08)] bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.96),rgba(227,234,229,0.88),rgba(243,245,242,0.92))] p-6">
        <div class="door-scene mx-auto">
          <div class="door-glow"></div>
          <div class="door-frame">
            <div class="door-panel"></div>
            <div class="door-handle"></div>
          </div>
          <div class="door-floor"></div>
          <div class="coffee-mark">מרגיש כמו בית</div>
        </div>
        <div class="mt-6 space-y-2 text-center">
          <p class="text-sm font-semibold text-[rgba(26,26,26,0.58)]">יש כאן תנועה אמיתית</p>
          <p class="text-[2rem] font-semibold tracking-[-0.04em] text-[#1A1A1A]" data-live-counter-count>--</p>
          <p class="text-sm leading-7 text-[rgba(26,26,26,0.66)]" data-live-counter-copy>
            כרגע אין כאן מונה חי זמין. כשהחיבור יפעל נחזיר אותו בלי לנחש מספרים.
          </p>
          <p class="text-xs leading-6 text-[rgba(26,26,26,0.5)]" data-live-counter-note>
            בינתיים אפשר להישאר כאן בשקט, לקרוא, ולתת לתוכן לעבוד בלי רעש מסביב.
          </p>
        </div>
      </div>
    </header>

    <section data-unlock-preview-root class="hidden mt-6 rounded-[1.6rem] border border-[rgba(212,43,43,0.18)] bg-[rgba(212,43,43,0.06)] px-5 py-4 shadow-[0_16px_36px_rgba(212,43,43,0.08)]">
      <div class="flex flex-wrap items-start justify-between gap-4 text-right">
        <div class="space-y-3">
          <div class="space-y-1">
            <p class="text-xs font-semibold tracking-[0.18em] text-[#D42B2B]">תצוגת טרום חיבור</p>
            <h2 data-unlock-preview-title class="text-lg font-semibold text-[#1A1A1A]">כך נראה המסך לפני כניסה</h2>
            <p data-unlock-preview-copy class="max-w-3xl text-sm leading-8 text-[rgba(26,26,26,0.72)]">הבדיקה הזאת פתוחה מתוך הניהול בלבד, כדי לראות איך עמוד הטרום־חיבור מרגיש לפני שיש גישה פעילה מהמכשיר.</p>
          </div>
          <div class="flex flex-wrap justify-end gap-2 text-xs">
            <span data-unlock-preview-status class="rounded-full border border-[rgba(212,43,43,0.2)] bg-white/82 px-3 py-1.5 font-semibold text-[#1A1A1A]">טוען מצב</span>
            <span data-unlock-preview-meta class="rounded-full border border-[rgba(26,26,26,0.1)] bg-white/76 px-3 py-1.5 text-[rgba(26,26,26,0.68)]">הטלפון יופיע כאן</span>
          </div>
        </div>
        <a href="/me/unlock/" class="inline-flex min-h-[44px] items-center rounded-full border border-[rgba(26,26,26,0.12)] bg-white px-4 py-2 text-sm font-semibold text-[#1A1A1A] transition hover:bg-[rgba(255,255,255,0.84)]">לצאת מתצוגה</a>
      </div>
    </section>

    <section class="mt-6 grid gap-4 md:grid-cols-4">
      {[
        { label: "מאמרים שקראת", value: "0", tone: "data", key: "articles" },
        { label: "ימים ברצף", value: "0", tone: "progress", key: "streak" },
        { label: "זמן קריאה", value: "0 דקות", tone: "progress", key: "seconds" },
        { label: "חיבור", value: "ממתין", tone: "status", key: "session" },
      ].map((item, index) => (
        <article class="unlock-rise rounded-[1.5rem] border border-[rgba(26,26,26,0.1)] bg-white/88 p-5 shadow-[0_12px_36px_rgba(67,82,72,0.05)]" style={`--delay: ${80 + index * 60}ms;`}>
          <p class="text-sm font-semibold text-[rgba(26,26,26,0.56)]">{item.label}</p>
          <p
            class="mt-3 text-[1.85rem] font-semibold tracking-[-0.03em]"
            data-stat={item.key}
          >
            {item.value}
          </p>
          <div class="mt-4 h-2 overflow-hidden rounded-full bg-[rgba(94,116,104,0.09)]" aria-hidden="true">
            <div
              class="h-full rounded-full bg-[linear-gradient(90deg,rgba(94,116,104,0.9),rgba(148,168,157,0.85))]"
              data-progress={item.key}
              style={item.tone === "data" ? "width: 72%;" : item.tone === "status" ? "width: 18%;" : "width: 6%;"}
            ></div>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)] lg:items-start">
      <div class="space-y-6">
        <section class="unlock-rise rounded-[1.75rem] border border-[rgba(26,26,26,0.1)] bg-white/88 p-6 shadow-[0_18px_48px_rgba(67,82,72,0.05)]" style="--delay: 180ms;">
          <div class="flex items-start justify-between gap-4">
            <div class="space-y-2">
              <p class="text-sm font-semibold text-[rgba(26,26,26,0.46)]">מועדון והטבות</p>
              <h2 class="text-[clamp(1.6rem,1.4rem+0.8vw,2.3rem)] font-semibold tracking-[-0.03em]">החלק שמרגיש כמו בית</h2>
            </div>
            <span class="rounded-full border border-[rgba(94,116,104,0.15)] bg-[rgba(94,116,104,0.08)] px-3 py-1.5 text-xs font-semibold text-[#4B6055]">אתה כבר בבית</span>
          </div>
          <div class="mt-5 grid gap-3 md:grid-cols-3">
            {clubBenefits.map((benefit) => (
              <article class="rounded-[1.4rem] border border-[rgba(26,26,26,0.08)] bg-[rgba(250,250,248,0.9)] p-4">
                <h3 class="text-lg font-semibold">{benefit.title}</h3>
                <p class="mt-2 text-sm leading-7 text-[rgba(26,26,26,0.68)]">{benefit.body}</p>
              </article>
            ))}
          </div>
          <div class="mt-5 rounded-[1.4rem] border border-[rgba(94,116,104,0.12)] bg-[rgba(94,116,104,0.08)] p-4">
            <p class="text-sm font-semibold text-[#4B6055]">כאן כבר מרגישים את השקט</p>
            <p class="mt-2 text-sm leading-7 text-[rgba(26,26,26,0.7)]">
              אין כאן הרשמה ארוכה. יש שיחה אחת קצרה, חיבור פעיל, ודרך פשוטה להישאר קרוב למה שעוזר לך.
            </p>
          </div>
        </section>

        <section class="unlock-rise rounded-[1.75rem] border border-[rgba(26,26,26,0.1)] bg-white/88 p-6 shadow-[0_18px_48px_rgba(67,82,72,0.05)]" style="--delay: 240ms;">
          <div class="space-y-2">
            <p class="text-sm font-semibold text-[rgba(26,26,26,0.46)]">טעימה מהדרך</p>
            <h2 class="text-[clamp(1.45rem,1.3rem+0.7vw,2rem)] font-semibold tracking-[-0.03em]">מאמרים שאפשר לפתוח כבר עכשיו</h2>
            <p class="text-sm leading-7 text-[rgba(26,26,26,0.66)]">
              גם בלי קוד, יש לך על מה להישען. יש כאן {totalArticles} מאמרים פתוחים, וזה עדיין חינם בשבילך. העדכון האחרון היה ב-{latestUpdate}.
            </p>
          </div>
          <div class="mt-5 grid gap-3 sm:grid-cols-2">
            {latestArticles.length > 0 ? (
              latestArticles.map((article) => (
                <a
                  href={`/articles/${article.slug}/`}
                  class="group overflow-hidden rounded-[1.35rem] border border-[rgba(26,26,26,0.08)] bg-[rgba(250,250,248,0.92)] transition hover:border-[rgba(94,116,104,0.24)] hover:bg-white"
                >
                  {article.image && article.image !== "/images/logo.svg" ? (
                    <img
                      src={article.image}
                      alt={article.title}
                      width="1200"
                      height="675"
                      loading="lazy"
                      class="aspect-[16/9] w-full object-cover"
                    />
                  ) : null}
                  <div class="p-4">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                      <p class="text-sm font-semibold text-[rgba(26,26,26,0.52)]">מאמר פתוח</p>
                      {article.youtubeId ? (
                        <span class="rounded-full bg-[rgba(94,116,104,0.1)] px-2.5 py-1 text-[0.72rem] font-semibold text-[#4B6055]">וידאו</span>
                      ) : null}
                    </div>
                    <h3 class="mt-2 text-lg font-semibold leading-7 group-hover:text-[#4B6055]">{article.title}</h3>
                    <p class="mt-2 text-sm leading-7 text-[rgba(26,26,26,0.64)]">
                      {article.description || "קריאה שקטה שמחזירה אותך למה שחשוב עכשיו."}
                    </p>
                    {article.tags.length ? (
                      <div class="mt-3 flex flex-wrap justify-end gap-2 text-[0.72rem] text-[rgba(26,26,26,0.58)]">
                        {article.tags.map((tag) => (
                          <span class="rounded-full border border-[rgba(26,26,26,0.08)] bg-white/70 px-2.5 py-1">{tag}</span>
                        ))}
                      </div>
                    ) : null}
                  </div>
                </a>
              ))
            ) : (
              <article class="rounded-[1.35rem] border border-[rgba(26,26,26,0.08)] bg-[rgba(250,250,248,0.92)] p-4 sm:col-span-2">
                <p class="text-lg font-semibold">המאמרים יופיעו כאן ברגע שיעלו לאתר</p>
                <p class="mt-2 text-sm leading-7 text-[rgba(26,26,26,0.64)]">גם מצב של אפס נשאר מסודר, נקי ומוכן להמשך.</p>
              </article>
            )}
          </div>
        </section>
      </div>

      <aside class="space-y-6 lg:sticky lg:top-28">
        <section class="unlock-rise rounded-[1.75rem] border border-[rgba(26,26,26,0.1)] bg-white/90 p-6 shadow-[0_18px_48px_rgba(67,82,72,0.05)]" style="--delay: 220ms;">
          <div class="flex items-start justify-between gap-4">
            <div class="space-y-2">
              <p class="text-sm font-semibold text-[rgba(26,26,26,0.46)]">מצב החיבור</p>
              <h2 class="text-[1.5rem] font-semibold tracking-[-0.03em]" data-join-title>החיבור שלך עוד לא פעיל</h2>
            </div>
            <span class="inline-flex items-center gap-2 rounded-full border border-[rgba(212,43,43,0.16)] bg-[rgba(212,43,43,0.05)] px-3 py-1.5 text-xs font-semibold text-[#A12B2B]">
              <span data-join-dot class="h-2.5 w-2.5 rounded-full bg-[#D42B2B] shadow-[0_0_0_6px_rgba(212,43,43,0.12)]"></span>
              <span data-join-label>נורה אדומה</span>
            </span>
          </div>
          <p class="mt-4 text-sm leading-7 text-[rgba(26,26,26,0.68)]" data-join-copy>
            אפשר לפתוח חודש ראשון במחיר השקה של 175 ש"ח, להיכנס בשקט, ולקבל גישה למה שנשמר לחברים.
          </p>
          <div class="mt-5 flex flex-wrap justify-end gap-3">
            <a
              id="unlock-join-offer"
              href={joinOfferHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-[52px] items-center justify-center rounded-full bg-[#1A1A1A] px-6 text-sm font-semibold text-[#FAFAF8] transition hover:bg-[#2A2A2A]"
            >
              בקשה להצטרף לחודש ראשון ב-175 ש"ח
            </a>
            <a href="/services/" class="inline-flex min-h-[52px] items-center justify-center rounded-full border border-[rgba(26,26,26,0.12)] px-5 text-sm font-semibold text-[#1A1A1A] transition hover:bg-[rgba(26,26,26,0.04)]">
              לבדוק מה נפתח בפנים
            </a>
          </div>
          <p class="mt-3 text-xs leading-6 text-[rgba(26,26,26,0.5)]">
            הנורה הופכת לירוקה ברגע שיש חיבור פעיל במכשיר הזה.
          </p>
        </section>

        <section class="unlock-rise rounded-[1.75rem] border border-[rgba(26,26,26,0.1)] bg-white/90 p-6 shadow-[0_18px_48px_rgba(67,82,72,0.05)]" style="--delay: 260ms;">
          <div class="space-y-2">
            <p class="text-sm font-semibold text-[rgba(26,26,26,0.46)]">קוד אישי</p>
            <h2 class="text-[1.5rem] font-semibold tracking-[-0.03em]">כניסה שקטה למי שכבר קיבל קוד</h2>
            <p class="text-sm leading-7 text-[rgba(26,26,26,0.68)]">
              אם יש לך קוד, אפשר לפתוח כאן את הדלת. אם לא, אתה עדיין בבית ויכול להמשיך ישר לוואטסאפ.
            </p>
          </div>
          <div class="mt-5 space-y-3">
            <label class="sr-only" for="unlock-code-input">הכנס קוד אישי</label>
            <input
              id="unlock-code-input"
              type="password"
              autocomplete="off"
              placeholder="הכנס קוד אישי"
              class="min-h-[54px] w-full rounded-full border border-[rgba(26,26,26,0.12)] bg-[#FAFAF8] px-5 text-right text-base outline-none transition placeholder:text-[rgba(26,26,26,0.32)] focus:border-[rgba(94,116,104,0.34)]"
            />
            <button
              id="unlock-enter"
              type="button"
              class="inline-flex min-h-[54px] w-full items-center justify-center rounded-full border border-[rgba(26,26,26,0.12)] bg-[#1A1A1A] px-6 text-base font-semibold text-[#FAFAF8] transition hover:bg-[#2A2A2A] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#1A1A1A]"
            >
              פתח לי את הדלת
            </button>
            <p id="unlock-error" class="hidden text-sm leading-7 text-[#8E4E4E]">
              הקוד לא זוהה עדיין. אפשר לדבר איתי ישירות ולקבל כיוון קצר.
            </p>
            <p id="unlock-success" class="hidden text-sm leading-7 text-[#4B6055]">
              הקוד זוהה. אתה כבר בפנים.
            </p>
            <div id="unlock-identity-panel" class="hidden rounded-[1.35rem] border border-[rgba(26,26,26,0.1)] bg-[rgba(250,250,248,0.92)] p-4">
              <div class="space-y-2">
                <p class="text-sm font-semibold text-[rgba(26,26,26,0.56)]">רק כדי לזהות את הכניסה</p>
                <p class="text-sm leading-7 text-[rgba(26,26,26,0.68)]">
                  אחרי שהקוד נפתח, נשמור שם וטלפון כדי שאדע מי נכנס ומתי.
                </p>
              </div>
              <div class="mt-4 grid gap-3">
                <label class="space-y-2">
                  <span class="block text-sm font-semibold text-[rgba(26,26,26,0.72)]">שם</span>
                  <input
                    id="unlock-fullname-input"
                    type="text"
                    autocomplete="name"
                    placeholder="איך לקרוא לך"
                    class="min-h-[52px] w-full rounded-[1.1rem] border border-[rgba(26,26,26,0.12)] bg-white px-4 text-right text-base outline-none transition placeholder:text-[rgba(26,26,26,0.32)] focus:border-[rgba(94,116,104,0.34)]"
                  />
                </label>
                <label class="space-y-2">
                  <span class="block text-sm font-semibold text-[rgba(26,26,26,0.72)]">טלפון</span>
                  <input
                    id="unlock-phone-input"
                    type="tel"
                    inputmode="numeric"
                    autocomplete="tel"
                    placeholder="למשל 0555634035"
                    class="min-h-[52px] w-full rounded-[1.1rem] border border-[rgba(26,26,26,0.12)] bg-white px-4 text-right text-base outline-none transition placeholder:text-[rgba(26,26,26,0.32)] focus:border-[rgba(94,116,104,0.34)]"
                  />
                </label>
                <button
                  id="unlock-identity-submit"
                  type="button"
                  class="inline-flex min-h-[52px] w-full items-center justify-center rounded-full border border-[rgba(26,26,26,0.12)] bg-[#5E7468] px-6 text-base font-semibold text-[#FAFAF8] transition hover:bg-[#50655A] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#5E7468]"
                >
                  להיכנס ולשמור זיהוי
                </button>
                <p id="unlock-identity-status" class="hidden text-sm leading-7 text-[#4B6055]"></p>
              </div>
            </div>
          </div>
        </section>

        <section class="unlock-rise rounded-[1.75rem] border border-[rgba(26,26,26,0.1)] bg-white/90 p-6 shadow-[0_18px_48px_rgba(67,82,72,0.05)]" style="--delay: 280ms;">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-sm font-semibold text-[rgba(26,26,26,0.46)]">הדרך שלך</p>
              <h2 class="mt-2 text-[1.45rem] font-semibold tracking-[-0.03em]">ניווט קצר ונעים</h2>
            </div>
            <button id="unlock-logout" type="button" class="hidden text-sm text-[rgba(26,26,26,0.6)] underline underline-offset-4">יציאה</button>
          </div>
          <div id="unlock-links" class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-2">
            {previewLinks.map((item) => (
              <a
                href={item.href}
                class="unlock-link-card group relative rounded-[1.35rem] border border-[rgba(26,26,26,0.08)] bg-[rgba(250,250,248,0.92)] p-4 transition hover:border-[rgba(94,116,104,0.24)] hover:bg-white"
                data-premium-card={item.premium ? "true" : "false"}
                data-wa-link={item.label === "בוא נדבר" ? "true" : undefined}
                target={item.href.startsWith("https://wa.me/") ? "_blank" : undefined}
                rel={item.href.startsWith("https://wa.me/") ? "noopener noreferrer" : undefined}
              >
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-base font-semibold group-hover:text-[#4B6055]">{item.label}</h3>
                  {item.premium ? <span class="unlock-lock text-sm text-[rgba(26,26,26,0.46)]">סגור</span> : null}
                </div>
                <p class="mt-2 text-sm leading-7 text-[rgba(26,26,26,0.64)]">{item.description}</p>
              </a>
            ))}
          </div>
        </section>
      </aside>
    </section>

    <section class="unlock-rise mt-6 rounded-[1.75rem] border border-[rgba(26,26,26,0.1)] bg-white/88 p-6 shadow-[0_18px_48px_rgba(67,82,72,0.05)]" style="--delay: 320ms;">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:items-start">
        <div class="space-y-3">
          <p class="text-sm font-semibold text-[rgba(26,26,26,0.46)]">שאלות קצרות</p>
          <h2 class="text-[clamp(1.45rem,1.3rem+0.7vw,2rem)] font-semibold tracking-[-0.03em]">לפני שנשארים בחיבור</h2>
          <p class="text-sm leading-7 text-[rgba(26,26,26,0.66)]">
            כאן יש תשובות קצרות. אם משהו עדיין לא יושב טוב, בוא נדבר.
          </p>
        </div>
        <div class="space-y-3">
          {faqItems.map((item) => (
            <details class="group rounded-[1.25rem] border border-[rgba(26,26,26,0.08)] bg-[rgba(250,250,248,0.92)] p-4 open:bg-white">
              <summary class="cursor-pointer list-none text-base font-semibold marker:content-none [&::-webkit-details-marker]:hidden">
                <span class="flex items-start justify-between gap-3">
                  <span>{item.question}</span>
                  <span class="text-[#5E7468] transition group-open:rotate-45" aria-hidden="true">+</span>
                </span>
              </summary>
              <p class="mt-3 border-t border-[rgba(26,26,26,0.08)] pt-3 text-sm leading-7 text-[rgba(26,26,26,0.68)]">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="unlock-rise mt-6 text-center" style="--delay: 360ms;">
      <p class="text-sm font-semibold text-[rgba(26,26,26,0.48)]">אתה כבר בבית</p>
      <p class="mx-auto mt-3 max-w-2xl text-[clamp(1.2rem,1.05rem+0.6vw,1.65rem)] font-semibold leading-8 tracking-[-0.03em]">
        רוצה להישאר בחיבור
      </p>
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-[rgba(26,26,26,0.64)]">
        שיחה אחת קצרה בוואטסאפ מספיקה כדי להבין אם המועדון מתאים לך עכשיו.
      </p>
      <a
        href={whatsAppHref}
        target="_blank"
        rel="noopener noreferrer"
        data-wa-link
        class="mt-5 inline-flex min-h-[62px] items-center justify-center rounded-full bg-[#5E7468] px-8 text-lg font-semibold text-[#FAFAF8] shadow-[0_18px_40px_rgba(94,116,104,0.28)] transition hover:-translate-y-0.5 hover:bg-[#50655A]"
      >
        בוא נדבר בוואטסאפ - זה עדיין חינם בשבילך
      </a>
    </section>
  </section>

  <style>
    .unlock-shell {
      direction: rtl;
    }

    .unlock-rise {
      opacity: 0;
      transform: translateY(18px);
      animation: unlock-rise 760ms cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-delay: var(--delay, 0ms);
    }

    .door-scene {
      position: relative;
      width: min(100%, 14rem);
      aspect-ratio: 1 / 1.15;
      display: grid;
      place-items: end center;
    }

    .door-glow {
      position: absolute;
      inset: 8% 20% 18%;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(255, 243, 214, 0.95), rgba(255, 243, 214, 0.2) 50%, transparent 72%);
      filter: blur(10px);
    }

    .door-frame {
      position: relative;
      width: 68%;
      height: 78%;
      border-radius: 1.2rem 1.2rem 0.9rem 0.9rem;
      border: 1px solid rgba(26, 26, 26, 0.12);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(223, 231, 225, 0.9));
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.36);
      overflow: hidden;
    }

    .door-panel {
      position: absolute;
      inset: 4%;
      border-radius: 1rem 1rem 0.7rem 0.7rem;
      background: linear-gradient(180deg, rgba(94, 116, 104, 0.95), rgba(72, 92, 81, 0.98));
      transform-origin: left center;
      animation: door-open 4.8s ease-in-out infinite alternate;
      box-shadow: 0 16px 32px rgba(67, 82, 72, 0.25);
    }

    .door-handle {
      position: absolute;
      top: 48%;
      right: 17%;
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 999px;
      background: rgba(255, 246, 222, 0.95);
      box-shadow: 0 0 0 4px rgba(255, 246, 222, 0.12);
      z-index: 2;
    }

    .door-floor {
      position: absolute;
      bottom: 7%;
      width: 86%;
      height: 12%;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(94, 116, 104, 0.18), rgba(94, 116, 104, 0.04) 60%, transparent 72%);
      filter: blur(6px);
    }

    .coffee-mark {
      position: absolute;
      bottom: 2%;
      left: 8%;
      font-size: 0.75rem;
      font-weight: 600;
      color: rgba(26, 26, 26, 0.45);
      letter-spacing: 0.04em;
    }

    .unlock-link-card[data-premium-card="true"] {
      filter: grayscale(0.28);
    }

    .unlock-shell[data-authorized="true"] .unlock-link-card[data-premium-card="true"] {
      filter: none;
    }

    .unlock-shell[data-authorized="true"] .unlock-lock {
      display: none;
    }

    @keyframes unlock-rise {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes door-open {
      from {
        transform: perspective(520px) rotateY(0deg);
      }
      to {
        transform: perspective(520px) rotateY(-34deg);
      }
    }

    @media (prefers-color-scheme: dark) {
      .unlock-shell {
        color: #fafaf8;
      }

      .unlock-shell :is(header, section, article, aside) {
        border-color: rgba(250, 250, 248, 0.12);
      }

      .unlock-shell .bg-white\/88,
      .unlock-shell .bg-white\/90,
      .unlock-shell .bg-\[rgba\(250\,250\,248\,0\.92\)\],
      .unlock-shell .bg-\[rgba\(250\,250\,248\,0\.9\)\] {
        background: rgba(255, 255, 255, 0.05);
      }

      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.72\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.68\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.66\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.64\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.62\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.6\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.58\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.56\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.52\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.48\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.46\)\],
      .unlock-shell .text-\[rgba\(26\,26\,26\,0\.45\)\] {
        color: rgba(250, 250, 248, 0.72);
      }

      .unlock-shell .door-frame {
        border-color: rgba(250, 250, 248, 0.18);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.04));
      }

      .unlock-shell input {
        border-color: rgba(250, 250, 248, 0.16);
        background: rgba(255, 255, 255, 0.04);
        color: #fafaf8;
      }

      .unlock-shell input::placeholder {
        color: rgba(250, 250, 248, 0.34);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .unlock-rise,
      .door-panel {
        animation: none;
        opacity: 1;
        transform: none;
      }
    }
  </style>

    <script
    is:inline
    define:vars={{ validCodesRaw, unlockAccessModeRaw, verifyCodeEndpoint, sharedAccessSessionEndpoint, premiumSessionHours, whatsAppHref, joinOfferHref, launchOfferPrice, pulseEndpoint }}
  >
    window.__NM_UNLOCK_CONFIG__ = {
      validCodesRaw,
      unlockAccessModeRaw,
      verifyCodeEndpoint,
      sharedAccessSessionEndpoint,
      premiumSessionHours,
      whatsAppHref,
      joinOfferHref,
      launchOfferPrice,
      pulseEndpoint,
    };
  </script>

  <script>
    import "../../scripts/unlock-page.ts";
    import "../../scripts/unlock-preview.js";
  </script>
</Layout>
