---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import MePersonalDashboard from "../../components/me/MePersonalDashboard";
import appConfig from "../../config/appConfig.json";
import { findServiceById, type FlatService } from "../../lib/services";

const articleEntries = await getCollection("articles", ({ data }) => !data.draft);
const sortedUnlock = articleEntries.sort((a, b) => {
  const da = a.data.updatedDate ?? a.data.pubDate;
  const db = b.data.updatedDate ?? b.data.pubDate;
  return db.getTime() - da.getTime();
});
const dashboardArticles = sortedUnlock.map((e) => ({
  slug: e.slug,
  title: e.data.title,
  pubDate: e.data.pubDate.toISOString(),
  tags: e.data.tags ?? [],
  difficultyLevel: e.data.difficultyLevel,
}));
const totalPublished = articleEntries.length;

const portalAccess = findServiceById("portal-access");
const phonePerspective = findServiceById("phone-perspective");

const fallbackPortalAccess = ({
  id: "portal-access",
  title: "מנוי ארכיון NeverMind",
  subtitle: "גישה מלאה · קצב שלך",
  description:
    "גישה לכל המאמרים והסרטונים - כולל הפודקאסט המלא. יותר מ-12,000 שעות שפותחות הכל: יחסים, אהבה, פחדים ומה שקורה באמת.",
  price_full: 175,
  payment_flow: "direct",
  payment_link: "https://mrng.to/by3pWXMyqz",
  payment_cta: "הצטרפות (175 ₪/חודש)",
  action_type: "payment",
  action_text: "הצטרפות (175 ₪/חודש)",
  visible: true,
  badges: ["מנוי הארכיון"],
  features: [],
  stageName: "אזור אישי",
  targetAudience: "מי שרוצה ללמוד בקצב שלו",
} as unknown as FlatService);

const fallbackPhonePerspective = ({
  id: "phone-perspective",
  title: "שיחת מיקוד 20 דקות",
  subtitle: "שיחה קצרה כדי לראות מה נכון עכשיו",
  description: "מדברים קצר. מבינים מה באמת קורה. נכנסים לצעד הבא בלי בלבול.",
  price_full: 450,
  action_type: "whatsapp",
  action_text: "אני רוצה להתקדם",
  visible: true,
  badges: [],
  features: [],
  stageName: "אזור אישי",
  targetAudience: "מי שצריך בהירות מהירה",
} as unknown as FlatService);

const archiveCard = portalAccess
  ? { ...portalAccess, title: "למידה עצמאית", badges: ["מנוי הארכיון"] }
  : fallbackPortalAccess;
const consultationCard = phonePerspective ?? fallbackPhonePerspective;

const whatsAppNumber =
  import.meta.env.PUBLIC_WHATSAPP_NUMBER ||
  import.meta.env.NEXT_PUBLIC_WHATSAPP_NUMBER ||
  appConfig.contact.whatsAppNumber;
const validCodesRaw =
  import.meta.env.PUBLIC_DASHBOARD_CODES ||
  import.meta.env.NEXT_PUBLIC_DASHBOARD_CODES ||
  "";
const whatsAppDigits = String(whatsAppNumber || "").replace(/\D/g, "");
---

<Layout title="לוח בקרה | אזור אישי" description="סיכום קריאה, המלצות ויומן תובנות. הנתונים נשמרים במכשיר וחלקם בשרת כשיש מועדון פעיל." noIndex={true}>
  <div class="min-h-[70vh]" style="background-color: #FAFAF8; color: #1A1A1A;">
    <section class="mx-auto max-w-4xl space-y-12 px-4 py-12 md:py-16">
      <p class="text-right text-sm font-medium" style="color: rgba(26, 26, 26, 0.55);">
        <a href="/me/" class="font-semibold underline underline-offset-4" style="color: #1A1A1A;">חזרה לאזור האישי</a>
      </p>

      <div
        id="unlock-unauthorized"
        class="space-y-10 rounded-[1.5rem] border px-6 py-10 text-right md:px-10"
        style="border-color: rgba(26, 26, 26, 0.1); background: #fff;"
      >
        <header class="space-y-4">
          <p class="text-sm font-medium" style="color: rgba(26, 26, 26, 0.55);">כניסה</p>
          <h1 class="text-[clamp(2rem,1.6rem+2vw,3.2rem)] font-semibold leading-tight tracking-tight" style="color: #1A1A1A;">המפתח שלך</h1>
          <p class="text-[clamp(1.05rem,1rem+0.2vw,1.15rem)] leading-relaxed" style="color: rgba(26, 26, 26, 0.72);">
            כאן הכל נהיה פשוט
          </p>
        </header>

        <ol class="space-y-2 text-[1.03rem] leading-relaxed" style="color: #1A1A1A;">
          <li>1. מדברים</li>
          <li>2. משלמים</li>
          <li>3. נכנסים</li>
        </ol>

        <div class="space-y-4">
          <label for="unlock-code-input" class="block text-sm font-medium" style="color: rgba(26, 26, 26, 0.66);">
            הקוד האישי שלך
          </label>
          <input
            id="unlock-code-input"
            type="password"
            autocomplete="off"
            placeholder="הכנס את הקוד שקיבלת"
            class="w-full rounded-full border px-5 py-3 text-right text-[1rem] outline-none transition"
            style="border-color: rgba(26, 26, 26, 0.16); background: #fff; color: #1A1A1A;"
          />
          <button
            id="unlock-enter"
            type="button"
            class="inline-flex min-h-[46px] items-center justify-center rounded-full px-8 py-2.5 text-sm font-semibold text-white transition hover:opacity-95"
            style="background-color: #0F172A;"
          >
            כניסה
          </button>
          <p id="unlock-error" class="hidden text-sm" style="color: #0F172A;">
            <a
              id="unlock-wa-link"
              href={`https://wa.me/${whatsAppDigits}`}
              class="underline underline-offset-4"
            >
              הקוד לא נכון. בוא נדבר בוואטסאפ
            </a>
          </p>
        </div>

        <div class="space-y-2 border-t pt-6 text-sm leading-relaxed" style="border-color: rgba(26, 26, 26, 0.1); color: rgba(26, 26, 26, 0.62);">
          <p>אתה מתחבר מ-IP: <span id="unlock-viewer-ip">בודק</span></p>
          <p>הקוד אישי. אסור להעביר אותו לאחרים</p>
        </div>
      </div>

      <div id="unlock-authorized" class="hidden space-y-10">
        <MePersonalDashboard client:load articles={dashboardArticles} totalPublished={totalPublished} whatsAppDigits={whatsAppDigits} />

        <nav class="flex flex-wrap justify-end gap-4 text-sm font-medium" style="color: rgba(26, 26, 26, 0.72);" aria-label="קישורים מהירים">
          <a href="/articles/" class="underline underline-offset-4" style="color: #1A1A1A;">מאמרים</a>
          <a href="/simulators/" class="underline underline-offset-4" style="color: #1A1A1A;">סימולטורים</a>
          <a href="/me/learning/" class="underline underline-offset-4" style="color: #1A1A1A;">לוח הלמידה</a>
          <a href="/me/settings/" class="underline underline-offset-4" style="color: #1A1A1A;">הגדרות</a>
        </nav>

        <section class="grid gap-6 lg:grid-cols-2">
          <ServiceCard service={archiveCard} />
          <ServiceCard service={consultationCard} />
        </section>

        <button id="unlock-logout" type="button" class="text-sm font-medium underline underline-offset-4" style="color: rgba(26, 26, 26, 0.72);">
          יציאה
        </button>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ whatsAppNumber, validCodesRaw }}>
    (() => {
      const storageKey = "nm_access_code";
      const unauthorized = document.getElementById("unlock-unauthorized");
      const authorized = document.getElementById("unlock-authorized");
      const input = document.getElementById("unlock-code-input");
      const enterButton = document.getElementById("unlock-enter");
      const errorLine = document.getElementById("unlock-error");
      const waLink = document.getElementById("unlock-wa-link");
      const logout = document.getElementById("unlock-logout");
      const viewerIp = document.getElementById("unlock-viewer-ip");

      const number = String(whatsAppNumber || "").trim();
      const validCodes = String(validCodesRaw || "")
        .split(",")
        .map((c) => c.trim())
        .filter(Boolean);

      const params = new URLSearchParams(window.location.search);
      const returnTo = params.get("returnTo");

      const showAuthorized = (on) => {
        if (!unauthorized || !authorized) return;
        unauthorized.classList.toggle("hidden", on);
        authorized.classList.toggle("hidden", !on);
      };

      const isCodeValid = (value) => {
        const clean = String(value || "").trim();
        if (!clean) return false;
        if (!validCodes.length) return true;
        return validCodes.includes(clean);
      };

      const fetchIp = async () => {
        if (!viewerIp) return;
        try {
          const res = await fetch("https://api.ipify.org?format=json");
          const data = await res.json();
          viewerIp.textContent = data?.ip ? String(data.ip) : "לא זוהה";
        } catch {
          viewerIp.textContent = "לא זוהה";
        }
      };

      const updateWhatsAppLink = () => {
        if (!waLink || !number) return;
        const message = "היי, הקוד לא עובד לי. אפשר לבדוק את זה יחד";
        waLink.setAttribute("href", `https://wa.me/${number.replace(/\D/g, "")}?text=${encodeURIComponent(message)}`);
      };

      const hasPremiumSession = () => {
        try {
          const raw = localStorage.getItem("nm-premium-access");
          if (!raw) return false;
          const parsed = JSON.parse(raw);
          const expiresAt = Date.parse(String(parsed?.expiresAt || ""));
          return Number.isFinite(expiresAt) && expiresAt > Date.now();
        } catch {
          return false;
        }
      };

      const goReturnPath = () => {
        if (!returnTo) return;
        if (!returnTo.startsWith("/")) return;
        window.location.href = returnTo;
      };

      const existing = localStorage.getItem(storageKey) || "";
      const alreadyAuthorized = isCodeValid(existing) || hasPremiumSession();
      showAuthorized(alreadyAuthorized);
      if (alreadyAuthorized) {
        goReturnPath();
      }

      fetchIp();
      updateWhatsAppLink();

      if (enterButton && input) {
        enterButton.addEventListener("click", () => {
          const code = String(input.value || "").trim();
          if (isCodeValid(code)) {
            localStorage.setItem(storageKey, code);
            if (errorLine) errorLine.classList.add("hidden");
            showAuthorized(true);
            goReturnPath();
            return;
          }
          if (errorLine) errorLine.classList.remove("hidden");
          showAuthorized(false);
        });
      }

      if (logout) {
        logout.addEventListener("click", () => {
          localStorage.removeItem(storageKey);
          localStorage.removeItem("nm-premium-access");
          window.location.reload();
        });
      }
    })();
  </script>
</Layout>
