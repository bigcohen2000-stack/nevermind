---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomeValueCards from "../components/home/HomeValueCards.astro";
import HomeSteps from "../components/home/HomeSteps.astro";
import HomeContact from "../components/home/HomeContact.astro";
import MinimalAudioPlayer from "../components/MinimalAudioPlayer.astro";
import { jsonLdForInlineScript } from "../lib/json-ld-inline";

const allArticles = await getCollection("articles", ({ data }) => data.draft !== true);
const sortedArticles = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const siteUrl = Astro.site?.toString() ?? "https://www.nevermind.co.il";
const siteUrlNoSlash = siteUrl.replace(/\/$/, "");
const homeArticleListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: sortedArticles.map((a, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "BlogPosting",
      headline: a.data.title,
      url: `${siteUrlNoSlash}/articles/${a.slug}/`,
      datePublished: new Date(a.data.pubDate).toISOString(),
      description: a.data.description,
    },
  })),
};

const valueCards = [
  {
    title: "עובדות לפני סיפור",
    body: "מפרידים בין מה שקרה לבין מה שסיפרת לעצמך על זה. זה מוריד רעש.",
  },
  {
    title: "שקט לפני החלטה",
    body: "לא ממהרים לסגור מעגל. נותנים למשפט הלא נוח להישמע בלי להילחץ לתשובה.",
  },
  {
    title: "גבול ברור",
    body: "יודעים מתי להפסיק לנבור ומתי לחזור ליום. זה לא כישלון. זה ניהול קשב.",
  },
];

const steps = [
  {
    title: "בוחרים נושא אחד",
    body: "לא רשימת ליקויים. נקודה אחת שמסבכת את המציאות אצלך עכשיו.",
  },
  {
    title: "כותבים במילים פשוטות",
    body: "מה ראית, מה ניסית, מה נשאר פתוח. בלי לשפוט את עצמך בזמן הכתיבה.",
  },
  {
    title: "בודקים מול השכל הישר",
    body: "המשפט עומד או נופל. אם הוא נשבר, מחפשים משפט אחר שמתאר את אותו מצב.",
  },
];

const demoAudio = (import.meta.env.PUBLIC_HOME_AUDIO_URL ?? "").trim();
---

<Layout
  title="NeverMind | הבנה לפני תגובה"
  description="דף הבית: שלושה עקרונות, שלושה צעדים, וקישורים לשירותים ולארכיון."
>
  <HomeHero
    title="חשיבה צלולה בלי רעש"
    subtitle="האתר בנוי כך שתוכל לקרוא לאט, לבדוק כל משפט, ולחזור ליום בלי להסביר למישהו אחר מה עבר בראש."
  />

  <HomeValueCards cards={valueCards} />

  <HomeSteps steps={steps} />

  {
    demoAudio ? (
      <section class="mx-auto max-w-2xl px-5 pb-12 sm:px-8 lg:px-12" aria-label="דוגמת האזנה">
        <MinimalAudioPlayer src={demoAudio} title="האזנה קצרה" />
      </section>
    ) : null
  }

  <HomeContact />

  <script is:inline type="application/ld+json" set:html={jsonLdForInlineScript(homeArticleListSchema)} />
</Layout>
