---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import TruthSlider from "../components/TruthSlider";
import { Star } from "lucide-react";
import ThoughtShiftProof from "../components/ThoughtShiftProof.astro";
import { resolveServiceAction, servicesHero, servicesStages, servicesThoughtShifts } from "../lib/services";

const allArticles = await getCollection("articles", ({ data }) => data.draft !== true);
const sortedArticles = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentArticles = sortedArticles.slice(0, 9);
const siteUrl = Astro.site?.toString() ?? "https://www.nevermind.co.il";
const stageCards = servicesStages
  .map((stage) => ({
    ...stage,
    primaryService: stage.services.find((service) => service.visible !== false),
  }))
  .filter((stage) => stage.primaryService);
---

<Layout
  title="NeverMind | הבנה, לא כלים"
  description="סולם ערך ברור: משיחת מיקוד קצרה ועד למנוי מרפסת ולמסלולי עומק מתמשכים."
>
  <section aria-labelledby="intent-title" class="mx-auto max-w-7xl space-y-12 px-5 pt-20 sm:px-8 lg:px-12">
    <header class="max-w-4xl space-y-5 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.26em] text-[#D42B2B]">NeverMind</p>
      <h1 id="intent-title" class="text-[clamp(2.2rem,1.7rem+2.4vw,3.8rem)] font-semibold leading-[1.08] text-neutral-900 dark:text-white">
        {servicesHero.title}
      </h1>
      <p class="max-w-3xl text-[clamp(1.05rem,0.98rem+0.5vw,1.3rem)] text-neutral-700 dark:text-neutral-300">
        {servicesHero.subtitle}
      </p>
      <div class="flex flex-wrap justify-end gap-3 pt-4">
        <a href="/services/" class="inline-flex items-center justify-center rounded-full bg-[#1A1A1A] px-5 py-3 text-sm font-semibold text-[#FAFAF8] transition hover:bg-black">לכל המסלולים</a>
        <a href="#stage-cards" class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white/80 px-5 py-3 text-sm font-semibold text-[#1A1A1A]/78 transition hover:bg-white">לראות את 5 השלבים</a>
      </div>
    </header>

    <section id="stage-cards" class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
      {stageCards.map((stage) => {
        const service = stage.primaryService!;
        const action = resolveServiceAction(service);
        return (
          <article class="rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 p-6 shadow-[0_24px_70px_rgba(26,26,26,0.06)] backdrop-blur-md text-right">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">{stage.stage_name}</p>
            <h2 class="mt-3 text-2xl font-semibold text-[#1A1A1A]">{service.title}</h2>
            <p class="mt-2 text-sm font-medium text-[#1A1A1A]/60">{stage.target_audience}</p>
            <p class="mt-4 text-sm leading-7 text-[#1A1A1A]/68">{service.subtitle}</p>
            <div class="mt-5 flex flex-wrap justify-end gap-2">
              {service.badges?.map((badge) => (
                <span class="rounded-full border border-[#D42B2B]/14 bg-[#FFF4F3] px-3 py-1 text-xs font-semibold text-[#D42B2B]">{badge}</span>
              ))}
            </div>
            <div class="mt-6 flex items-center justify-between gap-4">
              <span class="text-lg font-semibold text-[#1A1A1A]">{service.price_full.toLocaleString("he-IL")} ₪</span>
              <a
                href={action.href}
                target={action.external ? "_blank" : undefined}
                rel={action.external ? "noreferrer" : undefined}
                class="inline-flex items-center justify-center rounded-full bg-[#D42B2B] px-4 py-2 text-sm font-semibold text-[#FAFAF8] transition hover:bg-[#b82424]"
              >
                {service.action_text}
              </a>
            </div>
          </article>
        );
      })}
    </section>
  </section>

  <section aria-label="השוואת אמת" class="py-24 md:py-32">
    <TruthSlider client:visible />
  </section>

  <section class="mx-auto max-w-7xl border-t border-neutral-200 px-6 py-20 dark:border-neutral-800 md:py-24">
    <ThoughtShiftProof items={servicesThoughtShifts} heading="לפני ואחרי NeverMind" eyebrow="דפוס ישן מול דפוס חדש" />
  </section>

  <section id="articles" class="mx-auto max-w-7xl border-t border-neutral-200 px-6 py-20 dark:border-neutral-800 md:py-28">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-3xl font-bold text-neutral-900 dark:text-white md:text-4xl">מאמרים אחרונים</h2>
      <a href="/articles/" class="text-sm font-semibold text-[#D42B2B]">לכל המאמרים</a>
    </div>
    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 lg:gap-10">
      {recentArticles.map((article) => (
        <a href={`/articles/${article.slug}`} class="group block rounded-2xl border border-neutral-200 bg-white/70 p-6 backdrop-blur-md transition-all duration-300 hover:border-neutral-400 dark:border-neutral-800 dark:bg-neutral-900/70 dark:hover:border-neutral-500 md:p-8">
          <div class="mb-4 flex items-center gap-2 text-[#D42B2B]"><Star className="h-4 w-4" /><span class="text-xs font-semibold uppercase tracking-[0.16em]">חקירה שקטה</span></div>
          <h3 class="mb-4 text-xl font-bold text-neutral-900 decoration-neutral-400 underline-offset-4 group-hover:underline dark:text-white md:text-2xl">{article.data.title}</h3>
          <p class="mb-6 text-base text-neutral-600 dark:text-neutral-400">{article.data.description}</p>
          <span class="inline-block border-b border-neutral-900 pb-0.5 text-sm font-semibold text-neutral-900 dark:border-white dark:text-white">לקריאה שקטה →</span>
        </a>
      ))}
    </div>
  </section>

  <script type="application/ld+json" is:inline define:vars={{ articles: sortedArticles, siteUrl }}>
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "itemListElement": articles.map((a, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "BlogPosting",
          "headline": a.data.title,
          "url": `${siteUrl}/articles/${a.slug}`,
          "datePublished": a.data.pubDate,
          "description": a.data.description
        }
      }))
    }
  </script>
</Layout>



