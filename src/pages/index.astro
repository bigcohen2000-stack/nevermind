---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import LogicCanvas from "../components/LogicCanvas.astro";
import KnowledgeCenter from "../components/KnowledgeCenter.astro";
import EngagementSections from "../components/EngagementSections.astro";
import {
  resolveServiceAction,
  buildServiceReservationWhatsAppHref,
  findServiceById,
  servicesEngagementSections,
  servicesHero,
  servicesStages,
} from "../lib/services";
import ServicePricingBlock from "../components/ServicePricingBlock";
import { jsonLdForInlineScript } from "../lib/json-ld-inline";

const allArticles = await getCollection("articles", ({ data }) => data.draft !== true);
const sortedArticles = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentArticles = sortedArticles.slice(0, 9);
const featuredArticles = [...recentArticles]
  .sort(() => Math.random() - 0.5)
  .slice(0, 3)
  .map((article) => ({
    title: article.data.title,
    description: article.data.description,
    href: `/articles/${article.slug}/`,
  }));
const siteUrl = Astro.site?.toString() ?? "https://www.nevermind.co.il";
const siteUrlNoSlash = siteUrl.replace(/\/$/, "");
const homeArticleListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: sortedArticles.map((a, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "BlogPosting",
      headline: a.data.title,
      url: `${siteUrlNoSlash}/articles/${a.slug}/`,
      datePublished: new Date(a.data.pubDate).toISOString(),
      description: a.data.description,
    },
  })),
};
const balconyExperience = findServiceById("balcony-experience");
const balconyHasExtensions = Boolean(
  balconyExperience && Array.isArray(balconyExperience.extensions) && balconyExperience.extensions.length > 0
);
const balconyJson = balconyExperience ? JSON.stringify(balconyExperience) : "";
const balconyReserveHref = balconyExperience ? buildServiceReservationWhatsAppHref(balconyExperience) : "";
const balconyPayHref = balconyExperience ? resolveServiceAction(balconyExperience) : null;
const stageCards = servicesStages
  .map((stage) => ({
    ...stage,
    primaryService: stage.services.find((service) => service.visible !== false),
  }))
  .filter((stage) => stage.primaryService);
---

<Layout
  title="NeverMind | הבנה לפני תגובה"
  description="סולם ערך ברור: משיחת מיקוד קצרה עם בהירות מיידית ועד ליווי עומק במרחב האישי."
>
  <LogicCanvas />
  <KnowledgeCenter featured={featuredArticles} />

  <section
    aria-labelledby="intent-title"
    class="mx-auto max-w-7xl space-y-12 border-t border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[#FAFAF8] px-5 py-20 sm:px-8 sm:py-24 lg:px-12"
  >
    <header class="max-w-4xl space-y-5 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.26em] text-[var(--nm-accent)]">NeverMind</p>
      <h2 id="intent-title" class="text-[clamp(2.2rem,1.7rem+2.4vw,3.8rem)] font-semibold leading-[1.08] text-[var(--nm-fg)]">
        {servicesHero.title}
      </h2>
      <p class="max-w-3xl text-[clamp(1.05rem,0.98rem+0.5vw,1.3rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        {servicesHero.subtitle}
      </p>
      <div class="flex flex-wrap justify-end gap-3 pt-4">
        <a href="/services/" class="inline-flex items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">
          לכל המסלולים
        </a>
        <a href="#stage-cards" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/80 px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-white">
          לראות את 5 השלבים
        </a>
      </div>
    </header>

    <section id="stage-cards" class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
      {stageCards.map((stage) => {
        const service = stage.primaryService!;
        const action = resolveServiceAction(service);
        return (
          <article class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 p-6 text-right shadow-[0_24px_70px_rgba(26,26,26,0.06)] backdrop-blur-md">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">{stage.stage_name}</p>
            <h2 class="mt-3 text-2xl font-semibold text-[var(--nm-fg)]">{service.title}</h2>
            <p class="mt-2 text-sm font-medium text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">{stage.target_audience}</p>
            <p class="mt-4 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">{service.subtitle}</p>
            <div class="mt-5 flex flex-wrap justify-end gap-2">
              {service.badges?.map((badge) => (
                <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[var(--nm-tint)] px-3 py-1 text-xs font-semibold text-[var(--nm-accent)]">{badge}</span>
              ))}
            </div>
            <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between">
              <span class="price-tag text-lg font-semibold text-[var(--nm-fg)]">מחיר: {service.price_full.toLocaleString("he-IL")} ₪</span>
              <div class="flex flex-wrap items-center justify-end gap-2">
                <a
                  href={action.href}
                  target={action.external ? "_blank" : undefined}
                  rel={action.external ? "noreferrer" : undefined}
                  class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-4 py-2 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
                >
                  {action.label}
                </a>
                <a
                  href={buildServiceReservationWhatsAppHref(service)}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_14%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] hover:bg-[var(--nm-tint)]"
                >
                  שמירת מקום
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </section>
  </section>

  {balconyExperience && balconyJson && (balconyHasExtensions || (balconyPayHref && balconyReserveHref)) ? (
    <section
      id="balcony-experience"
      class="mx-auto max-w-7xl scroll-mt-[100px] border-t border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-16 sm:px-8 lg:px-12"
    >
      <div class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 text-right shadow-[0_24px_70px_rgba(26,26,26,0.06)] md:p-8">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--nm-accent)]">שלב 1</p>
        <h2 class="mt-2 text-[clamp(1.2rem,1.05rem+0.45vw,1.45rem)] font-semibold text-[var(--nm-fg)]">{balconyExperience.title}</h2>
        <p class="mt-2 text-sm leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">{balconyExperience.subtitle}</p>
        {balconyHasExtensions ? (
          <div class="mt-5">
            <ServicePricingBlock client:load serviceJson={balconyJson} layout="compact" />
          </div>
        ) : balconyPayHref && balconyReserveHref ? (
          <>
            <p class="mt-2 text-sm font-semibold text-[var(--nm-fg)]">
              מחיר: <span class="price-tag">{balconyExperience.price_full.toLocaleString("he-IL")} ₪</span>
            </p>
            <div class="mt-5 flex flex-wrap gap-2">
              <a
                href={balconyPayHref.href}
                target={balconyPayHref.external ? "_blank" : undefined}
                rel={balconyPayHref.external ? "noreferrer" : undefined}
                class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
              >
                {balconyPayHref.label}
              </a>
              <a
                href={balconyReserveHref}
                target="_blank"
                rel="noreferrer"
                class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-5 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-tint)]"
              >
                שמירת מקום
              </a>
            </div>
          </>
        ) : null}
      </div>
    </section>
  ) : null}

  <EngagementSections sections={servicesEngagementSections} />

  <section id="articles" class="mx-auto max-w-7xl border-t border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-6 py-20 md:py-28">
    <div class="flex items-end justify-between gap-4">
      <div class="space-y-2 text-right">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">ספריית המאמרים</p>
        <h2 class="text-3xl font-bold text-[var(--nm-fg)] md:text-4xl">מאמרים אחרונים</h2>
      </div>
      <a href="/articles/" class="text-sm font-semibold text-[var(--nm-accent)]">לכל המאמרים</a>
    </div>
    <p class="mt-4 max-w-3xl text-right text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">
      כל מאמר נועד לעשות דבר אחד: להפריד בין עובדה לפירוש, ולהחזיר בהירות במקום שבו נהיה רעש.
    </p>
    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 lg:gap-10">
      {recentArticles.map((article) => (
        <article class="h-full min-h-0">
          <a
            href={`/articles/${article.slug}`}
            title={`לקריאת המאמר: ${article.data.title}`}
            class="group flex h-full min-h-0 flex-col rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)]/90 p-6 backdrop-blur-md transition-all duration-300 hover:border-[color-mix(in_srgb,var(--nm-accent)_28%,transparent)] md:p-8"
          >
            <div class="mb-4 flex items-center gap-2 text-[var(--nm-accent)]">
              <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
              <span class="text-xs font-semibold uppercase tracking-[0.16em]">חקירה שקטה</span>
            </div>
            <h3 class="mb-4 text-xl font-bold text-[var(--nm-fg)] decoration-[color-mix(in_srgb,var(--nm-fg)_35%,transparent)] underline-offset-4 group-hover:underline md:text-2xl">{article.data.title}</h3>
            <p class="mb-6 flex-1 text-base text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">{article.data.description}</p>
            <span class="mt-auto inline-block border-b border-[var(--nm-fg)] pb-0.5 text-sm font-semibold text-[var(--nm-fg)]">לקריאה שקטה ←</span>
          </a>
        </article>
      ))}
    </div>
  </section>

  <section
    class="mx-auto max-w-7xl border-t border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-6 py-16 md:py-20"
    aria-labelledby="home-next-step"
  >
    <h2 id="home-next-step" class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--nm-accent)]">
      צעד הבא
  </h2>
    <p class="mt-4 max-w-3xl text-right text-[clamp(1.05rem,0.98rem+0.35vw,1.2rem)] font-medium leading-relaxed text-[var(--nm-fg)]">
      מיפוי מסלול: <a href="/services/" class="text-[var(--nm-accent)] underline-offset-4 hover:underline">שירותים</a>
      <span class="text-[color-mix(in_srgb,var(--nm-fg)_35%,var(--nm-bg))]"> · </span>
      <a href="/intake/" class="text-[var(--nm-accent)] underline-offset-4 hover:underline">טופס לפני שיחה</a>
      <span class="text-[color-mix(in_srgb,var(--nm-fg)_35%,var(--nm-bg))]"> · </span>
      <a href="/blog/" class="text-[var(--nm-accent)] underline-offset-4 hover:underline">מרכז הקריאה</a>
    </p>
    <p class="mt-6 max-w-3xl text-right text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
      איזו שאלה תשאיר פתוחה אחרי שתסיים כאן.
    </p>
  </section>

  <script is:inline type="application/ld+json" set:html={jsonLdForInlineScript(homeArticleListSchema)} />
</Layout>
