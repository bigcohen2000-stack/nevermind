---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="סימולטורים | אזור אישי" description="עמוד הסימולטורים באזור האישי.">
  <section class="mx-auto max-w-4xl space-y-5 px-4 py-16 text-right text-[var(--nm-fg)]">
    <p class="text-sm font-light text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">אזור אישי</p>
    <h1 class="text-[clamp(1.8rem,1.5rem+1.2vw,2.6rem)] font-light">הסימולטורים</h1>
    <p class="leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
      כאן יופיעו הסימולטורים. המקום שלך לתרגל לראות ולהבין דרך שאלות פשוטות.
    </p>
  </section>
</Layout>
