---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import appConfig from "../../config/appConfig.json";
import { jsonLdForInlineScript } from "../../lib/json-ld-inline";

const siteUrlRaw = typeof appConfig.site?.url === "string" ? appConfig.site.url.trim() : "https://www.nevermind.co.il";
const siteUrl = siteUrlRaw.replace(/\/+$/, "");
const siteTitle = typeof appConfig.site?.name === "string" ? appConfig.site.name : "NeverMind";

const EXCLUDE = new Set(["template", "decap-cms-setup"]);

const published = (await getCollection("articles", ({ data }) => data.draft !== true))
  .filter((a) => !EXCLUDE.has(a.slug))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const hubOrder = (a: (typeof published)[number]) => a.data.hubOrder ?? 99;

const startHere = published
  .filter((a) => a.data.hubPosition === "start")
  .sort((a, b) => hubOrder(a) - hubOrder(b));

const coreConcepts = published
  .filter((a) => a.data.hubPosition === "core")
  .sort((a, b) => hubOrder(a) - hubOrder(b));

const latestPinned = published
  .filter((a) => a.data.hubPosition === "latest")
  .sort((a, b) => hubOrder(a) - hubOrder(b))
  .slice(0, 6);

/** מניעת כפילות slug אם אותו מאמר גם ב־latest וגם ראשון בזרם הכרונולוגי */
function uniqueBySlug(entries: typeof published) {
  const seen = new Set<string>();
  const out: typeof published = [];
  for (const e of entries) {
    if (seen.has(e.slug)) continue;
    seen.add(e.slug);
    out.push(e);
  }
  return out;
}

const latestDisplay =
  latestPinned.length > 0
    ? (() => {
        const pinnedSlugs = new Set(latestPinned.map((a) => a.slug));
        const rest = published.filter((a) => !pinnedSlugs.has(a.slug));
        return uniqueBySlug([...latestPinned, ...rest]).slice(0, 6);
      })()
    : published.slice(0, 6);

const latestHasPinned = latestPinned.length > 0;

type LatestPoolItem = {
  slug: string;
  title: string;
  description: string;
  pub: string;
  tags: string[];
};

const latestPool: LatestPoolItem[] = published.map((a) => ({
  slug: a.slug,
  title: a.data.title,
  description: a.data.description,
  pub: new Date(a.data.pubDate).toISOString(),
  tags: Array.isArray(a.data.tags) ? a.data.tags : [],
}));

const topicOptions = Array.from(new Set(latestPool.flatMap((i) => i.tags))).sort((a, b) =>
  a.localeCompare(b, "he")
);

const pageTitle = "מרכז הקריאה";
const pageDescription =
  "מפת כניסה למאמרים: תצפית לפני הנחה, מושגי ליבה, ותצפיות עדכניות. כל קישור מוביל למאמר מלא בארכיון.";

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  description: pageDescription,
  url: `${siteUrl}/blog/`,
  inLanguage: "he-IL",
  isPartOf: {
    "@type": "WebSite",
    name: siteTitle,
    url: siteUrl,
  },
  about: {
    "@type": "Thing",
    name: "תצפית מול הנחה",
    description: "הפרדה בין מה שנצפה לבין מה שסופק כהסבר מראש, לפני סיכום או תגובה.",
  },
  publisher: {
    "@type": "Organization",
    name: siteTitle,
    url: siteUrl,
  },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: published.length,
    itemListElement: published.map((a, i) => ({
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "BlogPosting",
        headline: a.data.title,
        description: a.data.description,
        url: `${siteUrl}/articles/${a.slug}/`,
        datePublished: new Date(a.data.pubDate).toISOString(),
        inLanguage: "he-IL",
      },
    })),
  },
};

function formatHeDate(d: Date) {
  return d.toLocaleDateString("he-IL", { year: "numeric", month: "short", day: "numeric" });
}
---

<Layout title={pageTitle} description={pageDescription}>
  <div
    class="mx-auto max-w-7xl space-y-10 px-5 pb-[max(2rem,env(safe-area-inset-bottom,0px))] sm:px-6 md:space-y-14 lg:space-y-16 lg:px-4"
    data-nm-hub="reading"
  >
    <header class="space-y-5 border-b border-[color-mix(in_srgb,var(--nm-fg)_6%,transparent)] pb-10 text-right md:space-y-6 md:pb-12">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">NeverMind · מרכז הקריאה</p>
      <h1 class="text-[clamp(1.85rem,1.2rem+4.5vw,3.25rem)] font-semibold leading-[1.14] tracking-tight text-[var(--nm-fg)] md:leading-[1.1] md:tracking-normal">
        תצפית לפני הנחה
      </h1>
      <div class="max-w-3xl space-y-4 text-[clamp(1.02rem,0.96rem+0.35vw,1.15rem)] leading-[1.8] text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
        <p>
          המנגנון כאן פשוט: קודם רושמים מה נצפה בפועל. רק אחר כך בודקים אילו השלמות הוכנסו בלי בקשה. המאמרים לא
          מחליפים את התצפית שלך. הם נותנים כלים להפריד בין עובדה לפירוש כדי שהמסקנה לא תיבנה על רעש.
        </p>
        <p class="text-[color-mix(in_srgb,var(--nm-fg)_88%,var(--nm-bg))] font-medium leading-[1.8] text-[var(--nm-fg)]">
          איזה משפט אתה מוכן לבדוק היום לפני שאתה סוגר אותו כאמת מוחלטת.
        </p>
      </div>
      <aside
        class="max-w-3xl rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[color-mix(in_srgb,var(--nm-surface-muted)_55%,transparent)] px-5 py-4 text-right"
        aria-label="מסע בתוך הנפש"
      >
        <p class="text-sm font-semibold text-[var(--nm-fg)]">מסע בתוך הנפש</p>
        <p class="mt-1 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
          נושאים רגישים: מנגנונים, זהות, והפרדת עובדות - בלי דחיפה קלינית מיידית.
        </p>
        <a
          href="/journey/mental-health/"
          class="mt-3 inline-flex min-h-11 items-center font-semibold text-[var(--nm-accent)] underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]"
        >
          לעמוד המסע
        </a>
      </aside>
    </header>

    {
      startHere.length > 0 ? (
        <section class="space-y-5 md:space-y-6" aria-labelledby="blog-start-here">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <h2 id="blog-start-here" class="text-xl font-semibold text-[var(--nm-fg)] md:text-2xl">
              התחלה כאן
            </h2>
            <p class="max-w-xl text-right text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]">
              סדר קריאה מומלץ: מה ראית, מה הוספת, מה נשאר פתוח.
            </p>
          </div>
          <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" role="list">
            {startHere.map((article) => (
              <li>
                <a
                  href={`/articles/${article.slug}/`}
                  class="group [-webkit-tap-highlight-color:transparent] flex min-h-[11rem] flex-col rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_6%,transparent)] bg-[var(--nm-bg-canvas)] p-5 text-right transition-colors active:border-[color-mix(in_srgb,var(--nm-accent)_30%,transparent)] [@media(hover:hover)]:hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] md:min-h-[12rem] md:p-6"
                >
                  <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--nm-accent)]">נקודת כניסה</span>
                  <span class="mt-3 text-lg font-semibold leading-snug text-[var(--nm-fg)] [@media(hover:hover)]:group-hover:text-[var(--nm-accent)]">
                    {article.data.title}
                  </span>
                  <span class="mt-2 flex-1 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
                    {article.data.description}
                  </span>
                  <span class="mt-4 inline-flex min-h-11 items-center text-sm font-semibold text-[var(--nm-fg)] underline-offset-4 [@media(hover:hover)]:group-hover:underline">
                    למאמר המלא
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ) : null
    }

    {
      coreConcepts.length > 0 ? (
        <section class="space-y-5 md:space-y-6" aria-labelledby="blog-core">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <h2 id="blog-core" class="text-xl font-semibold text-[var(--nm-fg)] md:text-2xl">
              מושגי ליבה
            </h2>
            <p class="max-w-xl text-right text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]">
              מושגים שחוזרים ברוב הדיונים. כל כרטיס הוא כניסה לרשת, לא סיכום סופי.
            </p>
          </div>
          <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" role="list">
            {coreConcepts.map((article) => (
              <li>
                <a
                  href={`/articles/${article.slug}/`}
                  class="group [-webkit-tap-highlight-color:transparent] flex min-h-[11rem] flex-col rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_6%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_96%,transparent)] p-5 text-right transition-colors active:border-[color-mix(in_srgb,var(--nm-accent)_28%,transparent)] [@media(hover:hover)]:hover:border-[color-mix(in_srgb,var(--nm-accent)_20%,transparent)] md:min-h-[12rem] md:p-6"
                >
                  <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[color-mix(in_srgb,var(--nm-fg)_48%,var(--nm-bg))]">
                    ליבה
                  </span>
                  <span class="mt-3 text-base font-semibold leading-snug text-[var(--nm-fg)] [@media(hover:hover)]:group-hover:text-[var(--nm-accent)]">
                    {article.data.title}
                  </span>
                  <span class="mt-2 flex-1 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">
                    {article.data.description}
                  </span>
                  <span class="mt-4 inline-flex min-h-11 items-center text-sm font-semibold text-[var(--nm-accent)]">לקריאה ←</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ) : null
    }

    <section class="space-y-5 md:space-y-6" aria-labelledby="blog-latest">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <h2 id="blog-latest" class="text-xl font-semibold text-[var(--nm-fg)] md:text-2xl">
          תצפיות אחרונות
        </h2>
        <div class="flex flex-col items-stretch gap-3 sm:items-end">
          <a
            href="/articles/"
            class="inline-flex min-h-11 items-center text-sm font-semibold text-[var(--nm-accent)] underline-offset-4 [@media(hover:hover)]:hover:underline"
          >
            ארכיון מלא וסינון לפי נושא
          </a>
          <div
            class="flex flex-col gap-3 rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_6%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_88%,transparent)] p-3 sm:items-end"
            data-blog-latest-toolbar
          >
            <span id="blog-latest-filters-label" class="text-xs font-semibold text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">
              סידור הרשימה
            </span>
            <div
              role="group"
              aria-labelledby="blog-latest-filters-label"
              class="flex flex-wrap gap-2"
            >
              <button
                type="button"
                data-blog-latest-mode="date"
                aria-pressed="true"
                class="[-webkit-tap-highlight-color:transparent] min-h-11 min-w-11 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition-colors active:bg-[color-mix(in_srgb,var(--nm-fg)_6%,var(--nm-bg-canvas))] [@media(hover:hover)]:hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] aria-pressed:border-[var(--nm-accent)] aria-pressed:text-[var(--nm-accent)]"
              >
                לפי תאריך
              </button>
              <button
                type="button"
                data-blog-latest-mode="random"
                aria-pressed="false"
                class="[-webkit-tap-highlight-color:transparent] min-h-11 min-w-11 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition-colors active:bg-[color-mix(in_srgb,var(--nm-fg)_6%,var(--nm-bg-canvas))] [@media(hover:hover)]:hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] aria-pressed:border-[var(--nm-accent)] aria-pressed:text-[var(--nm-accent)]"
              >
                אקראי
              </button>
              <button
                type="button"
                data-blog-latest-mode="topic"
                aria-pressed="false"
                class="[-webkit-tap-highlight-color:transparent] min-h-11 min-w-11 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition-colors active:bg-[color-mix(in_srgb,var(--nm-fg)_6%,var(--nm-bg-canvas))] [@media(hover:hover)]:hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] aria-pressed:border-[var(--nm-accent)] aria-pressed:text-[var(--nm-accent)]"
              >
                לפי נושא
              </button>
            </div>
            <div data-blog-latest-topic-row class="hidden w-full sm:max-w-xs">
              <label class="flex flex-col gap-1 text-right text-xs font-medium text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">
                נושא מתוך התגיות
                <select
                  id="blog-latest-topic-select"
                  aria-label="סינון תצפיות לפי נושא"
                  class="min-h-11 w-full rounded-xl border border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] bg-[var(--nm-bg-canvas)] px-3 py-2 text-sm text-[var(--nm-fg)]"
                >
                  <option value="">בחר נושא</option>
                  {topicOptions.map((t) => (
                    <option value={t}>{t}</option>
                  ))}
                </select>
              </label>
            </div>
          </div>
        </div>
      </div>

      <p class="text-right text-xs text-[color-mix(in_srgb,var(--nm-fg)_48%,var(--nm-bg))]">
        {
          latestHasPinned
            ? "המאמרים המסומנים latest מופיעים ראשון. השאר משלים עד שישה לפי תאריך."
            : "ברירת מחדל: שישה אחרונים לפי תאריך פרסום. אפשר לערבב או לסנן לפי תגית מהרשימה."
        }
      </p>

      <div
        class="nm-blog-latest-body max-md:min-h-[min(36vh,14rem)] supports-[height:100svh]:max-md:min-h-[min(36svh,14rem)] supports-[contain:layout]:[contain:layout] md:min-h-[22rem] lg:min-h-[28rem]"
        data-blog-latest-body
      >
      <ul id="blog-latest-list" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3" role="list">
        {
          latestDisplay.map((article) => (
            <li data-article-slug={article.slug} class="min-h-0">
              <article class="flex h-full min-h-[11rem] flex-col rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_6%,transparent)] bg-[var(--nm-surface-muted)] p-5 text-right md:min-h-[12rem] md:p-6">
                <time
                  class="text-xs font-medium text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]"
                  datetime={new Date(article.data.pubDate).toISOString()}
                >
                  {formatHeDate(new Date(article.data.pubDate))}
                </time>
                <h3 class="mt-2 text-lg font-semibold leading-snug text-[var(--nm-fg)]">
                  <a
                    href={`/articles/${article.slug}/`}
                    class="[-webkit-tap-highlight-color:transparent] inline-flex min-h-11 w-full items-start py-1 text-[var(--nm-fg)] underline-offset-4 transition-colors active:text-[var(--nm-accent)] [@media(hover:hover)]:hover:text-[var(--nm-accent)] [@media(hover:hover)]:hover:underline"
                  >
                    {article.data.title}
                  </a>
                </h3>
                <p class="mt-2 flex-1 text-pretty text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
                  {article.data.description}
                </p>
              </article>
            </li>
          ))
        }
      </ul>
      <p
        id="blog-latest-empty"
        class="hidden min-h-[min(28vh,14rem)] flex-col items-center justify-center rounded-2xl border border-dashed border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] p-6 text-center text-sm text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))] supports-[height:100svh]:min-h-[min(28svh,14rem)] md:min-h-[20rem] lg:min-h-[26rem]"
        role="status"
      >
        אין מאמרים עם התגית הזו במאגר התצפיות. בחר נושא אחר או חזור ללפי תאריך.
      </p>
      </div>
    </section>

    <section
      class="rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_6%,transparent)] bg-[var(--nm-bg-canvas)] px-5 py-8 text-right sm:px-8"
      aria-labelledby="blog-next"
    >
      <h2 id="blog-next" class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--nm-accent)]">
        המשך מבנה
      </h2>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        רוצה רשימה כרונולוגית ותגיות:{" "}
        <a href="/articles/" class="font-semibold text-[var(--nm-accent)] underline-offset-4 [@media(hover:hover)]:hover:underline">
          עמוד המאמרים
        </a>
        . רוצה הגדרות קצרות לפני קריאה ארוכה:{" "}
        <a href="/glossary/" class="font-semibold text-[var(--nm-accent)] underline-offset-4 [@media(hover:hover)]:hover:underline">
          הגדרות מחדש
        </a>
        .
      </p>
    </section>
  </div>

  <script type="application/json" id="blog-latest-pool" is:inline set:html={jsonLdForInlineScript(latestPool)} />

  <script is:inline>
    (function () {
      function esc(s) {
        return String(s ?? "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      function parsePool() {
        const el = document.getElementById("blog-latest-pool");
        if (!el || !el.textContent) return [];
        try {
          const data = JSON.parse(el.textContent);
          return Array.isArray(data) ? data : [];
        } catch {
          return [];
        }
      }

      function formatHe(iso) {
        try {
          const d = new Date(iso);
          return d.toLocaleDateString("he-IL", { year: "numeric", month: "short", day: "numeric" });
        } catch {
          return "";
        }
      }

      function cardHtml(item) {
        const href = "/articles/" + esc(item.slug) + "/";
        return (
          '<li data-article-slug="' +
          esc(item.slug) +
          '" class="min-h-0"><article class="flex h-full min-h-[11rem] flex-col rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_6%,transparent)] bg-[var(--nm-surface-muted)] p-5 text-right md:min-h-[12rem] md:p-6">' +
          '<time class="text-xs font-medium text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]" datetime="' +
          esc(item.pub) +
          '">' +
          esc(formatHe(item.pub)) +
          "</time>" +
          '<h3 class="mt-2 text-lg font-semibold leading-snug text-[var(--nm-fg)]">' +
          '<a href="' +
          href +
          '" class="[-webkit-tap-highlight-color:transparent] inline-flex min-h-11 w-full items-start py-1 text-[var(--nm-fg)] underline-offset-4 transition-colors active:text-[var(--nm-accent)] [@media(hover:hover)]:hover:text-[var(--nm-accent)] [@media(hover:hover)]:hover:underline">' +
          esc(item.title) +
          "</a></h3>" +
          '<p class="mt-2 flex-1 text-pretty text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">' +
          esc(item.description) +
          "</p></article></li>"
        );
      }

      function shuffle(arr) {
        const a = arr.slice();
        for (let i = a.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          const t = a[i];
          a[i] = a[j];
          a[j] = t;
        }
        return a;
      }

      let mode = "date";
      let bound = false;

      function blogLatestSection() {
        return document.getElementById("blog-latest-list")?.closest("section[aria-labelledby='blog-latest']") ?? null;
      }

      function setPressed(m) {
        const sec = blogLatestSection();
        if (!sec) return;
        sec.querySelectorAll("[data-blog-latest-mode]").forEach((btn) => {
          if (!(btn instanceof HTMLButtonElement)) return;
          const on = btn.getAttribute("data-blog-latest-mode") === m;
          btn.setAttribute("aria-pressed", on ? "true" : "false");
        });
      }

      function render(pool, items) {
        const listEl = document.getElementById("blog-latest-list");
        const emptyEl = document.getElementById("blog-latest-empty");
        if (!listEl || !emptyEl) return;
        if (items.length === 0) {
          listEl.innerHTML = "";
          listEl.classList.add("hidden");
          emptyEl.classList.remove("hidden");
          emptyEl.classList.add("flex");
          return;
        }
        emptyEl.classList.add("hidden");
        emptyEl.classList.remove("flex");
        listEl.classList.remove("hidden");
        listEl.innerHTML = items.map(cardHtml).join("");
      }

      function byDate(pool) {
        const sorted = pool.slice().sort((a, b) => new Date(b.pub).getTime() - new Date(a.pub).getTime());
        return sorted.slice(0, 6);
      }

      function byRandom(pool) {
        return shuffle(pool).slice(0, 6);
      }

      function byTopic(pool, tag) {
        if (!tag) return byDate(pool);
        const filtered = pool.filter((p) => Array.isArray(p.tags) && p.tags.includes(tag));
        const sorted = filtered.sort((a, b) => new Date(b.pub).getTime() - new Date(a.pub).getTime());
        return sorted.slice(0, 6);
      }

      function apply() {
        const pool = parsePool();
        const sec = blogLatestSection();
        if (!sec || pool.length === 0) return;
        const topicRow = sec.querySelector("[data-blog-latest-topic-row]");
        const topicSelect = sec.querySelector("#blog-latest-topic-select");
        if (mode === "date") {
          render(pool, byDate(pool));
          if (topicRow instanceof HTMLElement) topicRow.classList.add("hidden");
        } else if (mode === "random") {
          render(pool, byRandom(pool));
          if (topicRow instanceof HTMLElement) topicRow.classList.add("hidden");
        } else {
          if (topicRow instanceof HTMLElement) topicRow.classList.remove("hidden");
          const tag = topicSelect instanceof HTMLSelectElement ? topicSelect.value : "";
          render(pool, byTopic(pool, tag));
        }
      }

      function init() {
        if (!document.getElementById("blog-latest-pool")) return;
        mode = "date";
        setPressed("date");
        const sec = blogLatestSection();
        if (sec) {
          const topicRow = sec.querySelector("[data-blog-latest-topic-row]");
          const topicSelect = sec.querySelector("#blog-latest-topic-select");
          if (topicRow instanceof HTMLElement) topicRow.classList.add("hidden");
          if (topicSelect instanceof HTMLSelectElement) topicSelect.value = "";
        }
      }

      function bindOnce() {
        if (bound) return;
        bound = true;
        document.addEventListener("click", (ev) => {
          const t = ev.target;
          if (!(t instanceof Element)) return;
          if (!document.getElementById("blog-latest-pool")) return;
          const sec = blogLatestSection();
          const btn = t.closest("[data-blog-latest-mode]");
          if (!btn || !sec || !sec.contains(btn)) return;
          const m = btn.getAttribute("data-blog-latest-mode");
          if (m !== "date" && m !== "random" && m !== "topic") return;
          mode = m;
          setPressed(mode);
          apply();
        });
        document.addEventListener("change", (ev) => {
          const t = ev.target;
          if (!(t instanceof HTMLSelectElement) || t.id !== "blog-latest-topic-select") return;
          if (!document.getElementById("blog-latest-pool")) return;
          if (mode === "topic") apply();
        });
        document.addEventListener("astro:page-load", init);
      }

      bindOnce();
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
      } else {
        init();
      }
    })();
  </script>

  <script is:inline type="application/ld+json" set:html={jsonLdForInlineScript(collectionPageSchema)} />
</Layout>
