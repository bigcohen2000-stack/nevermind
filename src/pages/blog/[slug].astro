---
import Layout from "../../layouts/Layout.astro";
import { BLOG_REDIRECTS } from "../../data/migration-map";

export function getStaticPaths() {
  const paths: { params: { slug: string } }[] = [];
  for (const dest of Object.values(BLOG_REDIRECTS)) {
    const trimmed = String(dest).replace(/^\/+|\/+$/g, "");
    const [root, slug] = trimmed.split("/");
    if (root !== "blog" || !slug) continue;
    paths.push({ params: { slug } });
  }
  return paths;
}

const slug = Astro.params.slug ?? "";
const titleHe = slug.replace(/-/g, " ");
const migrationStubPub = "2024-01-01";
---

<Layout
  title={`${titleHe} | בלוג`}
  description="עמוד בלוג שמור לאחר מיגרציה. להמשך קריאה בארכיון המאמרים."
  frontmatter={{
    title: titleHe,
    description:
      "עמוד בלוג שמור לאחר מיגרציה מווורדפרס. להמשך קריאה בארכיון המאמרים ובמרכז הידע.",
    pubDate: migrationStubPub,
    author: "השם לא משנה",
  }}
>
  <article class="mx-auto max-w-3xl space-y-6 px-4 py-14 text-right text-[var(--nm-fg)]">
    <h1 class="text-2xl font-semibold leading-snug md:text-3xl">{titleHe}</h1>
    <p class="text-[clamp(0.95rem,0.9rem+0.2vw,1.05rem)] leading-relaxed text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
      נתיב זה נשמר לפי אנליטיקס. התוכן המלא מוזמן דרך ארכיון המאמרים באנגלית, או דרך חיפוש במרכז הידע.
    </p>
    <p>
      <a
        href="/blog/"
        class="font-semibold text-[var(--nm-accent)] underline decoration-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)] underline-offset-2"
      >
        מעבר למרכז הקריאה
      </a>
    </p>
  </article>
</Layout>
