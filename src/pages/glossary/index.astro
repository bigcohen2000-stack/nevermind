---
import { getCollection } from "astro:content";
import { glossaryConcepts } from "../../data/glossary";
import { glossaryTagToTopicHref } from "../../data/glossary-topics";
import Layout from "../../layouts/Layout.astro";
import { getCanonicalArticleSlug } from "../../lib/articles";

const pageTitle = "מילון מושגים NeverMind | הגדרה, ההפך, דוגמה והמשך קריאה";
const pageDescription =
  "מילון המושגים של NeverMind. בכל מושג יש הגדרה פשוטה, הצד ההפוך, דוגמה יומיומית וקישור למאמר המשך.";

const entries = await getCollection("articles", ({ data }) => (data.draft === true ? false : true));
const featuredArticles = new Map<string, { href: string; title: string }>();

for (const concept of glossaryConcepts) {
  const match = entries
    .map((entry) => {
      const tags = Array.isArray(entry.data.tags) ? entry.data.tags : [];
      const haystack = `${entry.data.title} ${entry.data.description} ${tags.join(" ")}`.toLowerCase();
      const tagScore = tags.filter((tag) => concept.tags.includes(tag)).length * 3;
      const keywordScore = concept.keywords.filter((keyword) => haystack.includes(keyword.toLowerCase())).length;
      return {
        href: `/articles/${getCanonicalArticleSlug(entry)}/`,
        title: entry.data.title,
        score: tagScore + keywordScore,
      };
    })
    .filter((item) => item.score > 0)
    .sort((left, right) => right.score - left.score)[0];

  if (match) {
    featuredArticles.set(concept.slug, { href: match.href, title: match.title });
  }
}

const conceptSlugSet = new Set(glossaryConcepts.map((concept) => concept.slug));
const conceptTreeNodes = glossaryConcepts.map((concept) => ({
  id: concept.slug,
  label: concept.title,
  href: `/glossary/${concept.slug}/`,
}));
const conceptTreeEdges = glossaryConcepts.flatMap((concept) =>
  (concept.relatedConceptSlugs ?? [])
    .filter((relatedSlug) => conceptSlugSet.has(relatedSlug))
    .map((relatedSlug) => [concept.slug, relatedSlug].sort().join("::")),
);
const conceptTreeUniqueEdges = [...new Set(conceptTreeEdges)].map((value) => {
  const [from, to] = value.split("::");
  return { from, to };
});
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-6xl space-y-10 px-4 pb-20 text-[var(--nm-fg)]">
    <header class="space-y-4 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">מילון</p>
      <h1 class="text-[clamp(2.1rem,1.65rem+1.8vw,3.2rem)] font-semibold text-[var(--nm-fg)]">מילון המושגים של NeverMind</h1>
      <p class="max-w-4xl text-[clamp(1rem,0.95rem+0.25vw,1.14rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
        כאן כל מושג בנוי באותו סדר: הגדרה, הצד ההפוך, דוגמה יומיומית והמשך קריאה למאמר רלוונטי.
      </p>
      <div class="flex flex-wrap justify-end gap-3 text-sm font-semibold text-[var(--nm-accent)]">
        <a href="/articles/" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-5 py-3 transition hover:bg-[var(--nm-surface-muted)]">מאמרים</a>
        <a href="/me/learning/" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-5 py-3 transition hover:bg-[var(--nm-surface-muted)]">לוח הלמידה</a>
        <a href="/me/unlock/" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-5 py-3 transition hover:bg-[var(--nm-surface-muted)]">האזור השקט</a>
        <a href="/root-problem-tree/" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-5 py-3 transition hover:bg-[var(--nm-surface-muted)]">עץ שורש הבעיה</a>
      </div>
    </header>

    <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-5 shadow-[0_20px_60px_rgba(26,26,26,0.05)]">
      <div class="space-y-2 text-right">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">עץ מושגים אינטראקטיבי</p>
        <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">איך מושגים מחוברים אחד לשני</h2>
        <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
          כל מושג חדש שנכנס ל־`glossaryConcepts` מופיע אוטומטית גם כאן.
        </p>
      </div>
      <div class="mt-4 overflow-hidden rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-3">
        <svg
          data-concept-tree
          viewBox="0 0 1000 560"
          class="h-auto w-full"
          role="img"
          aria-label="תרשים מושגים אינטראקטיבי"
        ></svg>
      </div>
      <p data-concept-tree-caption class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">
        העבר עכבר או גע בצומת כדי לראות קשרים קרובים.
      </p>
    </section>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {glossaryConcepts.map((concept) => {
        const featuredArticle = featuredArticles.get(concept.slug);
        return (
          <article class="flex h-full flex-col rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 text-right shadow-[0_20px_60px_rgba(26,26,26,0.05)]">
            <div class="flex flex-1 flex-col gap-5 p-6">
              <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">{concept.title}</h2>

              <div class="space-y-2 rounded-[1.3rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
                <p class="text-sm font-semibold text-[var(--nm-fg)]">הגדרה</p>
                <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">{concept.definition}</p>
              </div>

              {concept.oppositeLink ? (
                <div class="space-y-2">
                  <p class="text-sm font-semibold text-[var(--nm-accent)]">ההפך</p>
                  <a href={concept.oppositeLink.href} class="block rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-accent)_16%,transparent)] bg-[var(--nm-tint)] px-4 py-3 transition hover:bg-white">
                    <p class="font-semibold text-[var(--nm-fg)]">{concept.oppositeLink.title.replace("הצד השני: ", "")}</p>
                    <p class="mt-1 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">{concept.oppositeLink.description}</p>
                  </a>
                </div>
              ) : null}

              {concept.dailyExample ? (
                <div class="space-y-2">
                  <p class="text-sm font-semibold text-[var(--nm-accent)]">דוגמה יומיומית</p>
                  <p class="rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
                    {concept.dailyExample}
                  </p>
                </div>
              ) : null}

              <div class="space-y-2">
                <p class="text-sm font-semibold text-[var(--nm-accent)]">המשך קריאה</p>
                {featuredArticle ? (
                  <a href={featuredArticle.href} class="block rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-3 transition hover:bg-[var(--nm-surface-muted)]">
                    <p class="font-semibold text-[var(--nm-fg)]">{featuredArticle.title}</p>
                    <p class="mt-1 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">מאמר פתוח שממשיך את הרעיון הזה.</p>
                  </a>
                ) : (
                  <a href={`/glossary/${concept.slug}/`} class="block rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-3 transition hover:bg-[var(--nm-surface-muted)]">
                    <p class="font-semibold text-[var(--nm-fg)]">לעמוד המלא של {concept.title}</p>
                    <p class="mt-1 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">הגדרה מלאה וקישורים קרובים.</p>
                  </a>
                )}
              </div>

              <a href={`/glossary/${concept.slug}/`} class="inline-flex min-h-[44px] items-center justify-end gap-2 font-semibold text-[var(--nm-accent)]">
                לפתוח את המושג
              </a>
            </div>

            <div class="flex flex-wrap justify-end gap-2 border-t border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] px-6 pb-6 pt-4 text-xs text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">
              {concept.tags.map((tag) => {
                const topicHref = glossaryTagToTopicHref[tag];
                const pillClass =
                  "rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-3 py-1 transition hover:border-[color-mix(in_srgb,var(--nm-accent)_28%,transparent)] hover:text-[var(--nm-accent)]";
                return topicHref ? (
                  <a href={topicHref} class={pillClass}>
                    {tag}
                  </a>
                ) : (
                  <span class={pillClass}>{tag}</span>
                );
              })}
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <script
    is:inline
    define:vars={{
      conceptTreeNodes,
      conceptTreeUniqueEdges,
    }}
  >
    document.addEventListener("astro:page-load", () => {
      const svg = document.querySelector("[data-concept-tree]");
      const caption = document.querySelector("[data-concept-tree-caption]");
      if (svg instanceof SVGElement === false) return;

      const width = 1000;
      const height = 560;
      const centerX = width / 2;
      const centerY = height / 2;
      const radius = Math.min(width, height) * 0.36;
      const nodes = Array.isArray(conceptTreeNodes) ? conceptTreeNodes : [];
      const edges = Array.isArray(conceptTreeUniqueEdges) ? conceptTreeUniqueEdges : [];

      const nodePosition = new Map();
      nodes.forEach((node, index) => {
        const angle = (Math.PI * 2 * index) / Math.max(1, nodes.length);
        nodePosition.set(node.id, {
          x: centerX + Math.cos(angle) * radius,
          y: centerY + Math.sin(angle) * radius,
        });
      });

      while (svg.firstChild) {
        svg.removeChild(svg.firstChild);
      }

      const linesLayer = document.createElementNS("http://www.w3.org/2000/svg", "g");
      const nodesLayer = document.createElementNS("http://www.w3.org/2000/svg", "g");
      svg.appendChild(linesLayer);
      svg.appendChild(nodesLayer);

      const lineElements = [];
      edges.forEach((edge) => {
        const from = nodePosition.get(edge.from);
        const to = nodePosition.get(edge.to);
        if (from == null || to == null) return;
        const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
        line.setAttribute("x1", String(from.x));
        line.setAttribute("y1", String(from.y));
        line.setAttribute("x2", String(to.x));
        line.setAttribute("y2", String(to.y));
        line.setAttribute("stroke", "rgba(26,26,26,0.14)");
        line.setAttribute("stroke-width", "2");
        line.setAttribute("data-edge", `${edge.from}::${edge.to}`);
        linesLayer.appendChild(line);
        lineElements.push(line);
      });

      nodes.forEach((node) => {
        const position = nodePosition.get(node.id);
        if (position == null) return;

        const link = document.createElementNS("http://www.w3.org/2000/svg", "a");
        link.setAttribute("href", node.href);
        link.setAttribute("data-node-id", node.id);

        const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
        circle.setAttribute("cx", String(position.x));
        circle.setAttribute("cy", String(position.y));
        circle.setAttribute("r", "35");
        circle.setAttribute("fill", "rgba(255,255,255,0.95)");
        circle.setAttribute("stroke", "rgba(26,26,26,0.18)");
        circle.setAttribute("stroke-width", "2");
        link.appendChild(circle);

        const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
        text.setAttribute("x", String(position.x));
        text.setAttribute("y", String(position.y + 5));
        text.setAttribute("text-anchor", "middle");
        text.setAttribute("font-size", "16");
        text.setAttribute("font-weight", "700");
        text.setAttribute("fill", "rgba(26,26,26,0.86)");
        text.textContent = node.label;
        link.appendChild(text);

        const activate = () => {
          let touched = 0;
          lineElements.forEach((lineElement) => {
            const key = String(lineElement.getAttribute("data-edge") ?? "");
            const active = key.includes(`${node.id}::`) || key.includes(`::${node.id}`);
            if (active) touched += 1;
            lineElement.setAttribute("stroke", active ? "rgba(212,43,43,0.7)" : "rgba(26,26,26,0.14)");
            lineElement.setAttribute("stroke-width", active ? "3" : "2");
          });
          if (caption instanceof HTMLElement) {
            caption.textContent = `${node.label}: ${touched} קשרים קרובים.`;
          }
        };

        link.addEventListener("mouseenter", activate);
        link.addEventListener("focus", activate);
        link.addEventListener("touchstart", activate, { passive: true });
        nodesLayer.appendChild(link);
      });
    });
  </script>
</Layout>
