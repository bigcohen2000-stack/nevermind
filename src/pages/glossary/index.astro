---
import Layout from "../../layouts/Layout.astro";
import { glossaryConcepts } from "../../data/glossary";

const pageTitle = "הגדרות מחדש";
const pageDescription =
  "כדי להבין אחד את השני באמת, חייבים להסכים על משמעות המילים. כאן נמצא ההסבר הפשוט והנקי למושגים שאנחנו משתמשים בהם, בלי כוונה נסתרת.";
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-6xl space-y-10 px-4 pb-20 text-[var(--nm-fg)]">
    <header class="space-y-4 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">מילון</p>
      <h1 class="text-[clamp(2.2rem,1.7rem+2vw,3.4rem)] font-semibold text-[var(--nm-fg)]">הגדרות מחדש</h1>
      <p class="max-w-4xl text-[clamp(1rem,0.95rem+0.35vw,1.18rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
        כדי להבין אחד את השני באמת, חייבים להסכים על משמעות המילים. כאן נמצא ההסבר הפשוט והנקי למושגים שאנחנו משתמשים בהם, בלי כוונה נסתרת.
      </p>
      <p>
        <a
          href="/glossary/ego/"
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]"
        >
          התחל ממה זה אגו?
        </a>
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {glossaryConcepts.map((concept) => (
        <a
          href={`/glossary/${concept.slug}/`}
          class="group flex h-full flex-col justify-between gap-5 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 p-6 text-right shadow-[0_20px_60px_rgba(26,26,26,0.05)] transition duration-300 hover:translate-y-[-2px] hover:bg-white"
        >
          <div class="space-y-3">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">מושג יסוד</p>
            <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">{concept.title}</h2>
            <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">{concept.summary}</p>
          </div>
          <div class="space-y-3">
            <div class="flex flex-wrap justify-end gap-2 text-xs text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">
              {concept.tags.map((tag) => (
                <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-3 py-1">{tag}</span>
              ))}
            </div>
            {concept.oppositeLink && (
              <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">
                ההפך שעוזר לראות ברור יותר:
                <span class="font-semibold text-[var(--nm-accent)]"> {concept.oppositeLink.title.replace("הצד השני: ", "")}</span>
              </p>
            )}
            <span class="inline-flex items-center justify-end gap-2 text-sm font-semibold text-[var(--nm-accent)]">
              פתח את המושג
              <span aria-hidden="true">←</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>


