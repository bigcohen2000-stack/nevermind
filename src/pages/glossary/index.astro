---
import Layout from "../../layouts/Layout.astro";
import { glossaryConcepts } from "../../data/glossary";

const pageTitle = "מושגי יסוד";
const pageDescription = "המושגים הבסיסיים של NeverMind במקום אחד: הגדרות קצרות, קישורים חכמים, וכניסה להעמקה דרך מאמרים ודפי נושא.";
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-6xl space-y-10 px-4 pb-20 text-[#1A1A1A]">
    <header class="space-y-4 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">Glossary</p>
      <h1 class="text-[clamp(2.2rem,1.7rem+2vw,3.4rem)] font-semibold text-[#1A1A1A]">מנוע מושגי יסוד</h1>
      <p class="max-w-4xl text-[clamp(1rem,0.95rem+0.35vw,1.18rem)] leading-8 text-[#1A1A1A]/70">
        כאן מרכזים את שפת העבודה של NeverMind. כל מושג הוא דלת קצרה: הגדרה חדה, למה זה משנה, ולאן להמשיך כדי להעמיק בלי ללכת לאיבוד.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {glossaryConcepts.map((concept) => (
        <a
          href={`/glossary/${concept.slug}/`}
          class="group flex h-full flex-col justify-between gap-5 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 p-6 text-right shadow-[0_20px_60px_rgba(26,26,26,0.05)] transition duration-300 hover:translate-y-[-2px] hover:bg-white"
        >
          <div class="space-y-3">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">מושג יסוד</p>
            <h2 class="text-2xl font-semibold text-[#1A1A1A]">{concept.title}</h2>
            <p class="text-sm leading-7 text-[#1A1A1A]/68">{concept.summary}</p>
          </div>
          <div class="space-y-3">
            <div class="flex flex-wrap justify-end gap-2 text-xs text-[#1A1A1A]/55">
              {concept.tags.map((tag) => (
                <span class="rounded-full border border-[#1A1A1A]/10 bg-[#FAFAF8] px-3 py-1">{tag}</span>
              ))}
            </div>
            {concept.oppositeLink && (
              <p class="text-sm leading-7 text-[#1A1A1A]/58">
                הצד השני של המטבע:
                <span class="font-semibold text-[#D42B2B]"> {concept.oppositeLink.title.replace("הצד השני: ", "")}</span>
              </p>
            )}
            <span class="inline-flex items-center justify-end gap-2 text-sm font-semibold text-[#D42B2B]">
              להעמקה שקטה
              <span aria-hidden="true">←</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

