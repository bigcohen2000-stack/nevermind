---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { glossaryConcepts, type GlossaryConcept, type GlossaryLink } from "../../data/glossary";

const topicMap = {
  "חופש": "/topics/freedom/",
  "מכניקת מחשבה": "/topics/thought-mechanics/",
  "העצמי": "/topics/self/",
  "בהירות": "/topics/clarity/",
  "בחירה": "/topics/choice/",
} as const;

type RelatedArticle = {
  href: string;
  title: string;
  description: string;
  score: number;
};

export async function getStaticPaths() {
  return glossaryConcepts.map((concept) => ({
    params: { term: concept.slug },
    props: { concept },
  }));
}

const { concept } = Astro.props as { concept: GlossaryConcept };
const entries = await getCollection("articles", ({ data }) => data.draft !== true);

const relatedArticles: RelatedArticle[] = entries
  .map((entry) => {
    const tags = Array.isArray(entry.data.tags) ? entry.data.tags : [];
    const haystack = `${entry.data.title} ${entry.data.description} ${tags.join(" ")}`.toLowerCase();
    const tagScore = tags.filter((tag) => concept.tags.includes(tag)).length * 3;
    const keywordScore = concept.keywords.filter((keyword) => haystack.includes(keyword.toLowerCase())).length;
    const score = tagScore + keywordScore;

    return {
      href: `/articles/${entry.id.replace(/\.mdx$/, "")}`,
      title: entry.data.title,
      description: entry.data.description,
      score,
    };
  })
  .filter((article) => article.score > 0)
  .sort((left, right) => right.score - left.score)
  .slice(0, 3);

const fallbackLinks: GlossaryLink[] = [];
for (const tag of concept.tags) {
  const topicHref = topicMap[tag as keyof typeof topicMap];
  if (!topicHref) continue;
  fallbackLinks.push({
    href: topicHref,
    title: `נושא: ${tag}`,
    description: `המשך חקירה דרך כל המאמרים שמשויכים ל-${tag}.`,
  });
}
for (const link of concept.relatedLinks) {
  if (!fallbackLinks.some((item) => item.href === link.href)) {
    fallbackLinks.push(link);
  }
}
if (!fallbackLinks.some((item) => item.href === "/articles/")) {
  fallbackLinks.push({
    href: "/articles/",
    title: "כל המאמרים",
    description: "ספריית המאמרים המלאה להעמקה נוספת מעבר למושג הבסיסי הזה.",
  });
}

const relatedLinks = [
  ...relatedArticles.map((article) => ({ href: article.href, title: article.title, description: article.description })),
  ...fallbackLinks.filter((link) => !relatedArticles.some((article) => article.href === link.href)),
].slice(0, 5);

const otherConcepts = glossaryConcepts
  .filter((item) => item.slug !== concept.slug)
  .filter((item) => item.tags.some((tag) => concept.tags.includes(tag)) || item.keywords.some((keyword) => concept.keywords.includes(keyword)))
  .slice(0, 3);

const pageTitle = `${concept.title} | מושגי יסוד`;
const pageDescription = concept.summary;
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-5xl space-y-10 px-4 pb-20 text-[#1A1A1A]">
    <header class="rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 px-6 py-8 text-right shadow-[0_20px_60px_rgba(26,26,26,0.05)] md:px-8">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">מושג יסוד</p>
      <h1 class="mt-3 text-[clamp(2.1rem,1.6rem+2vw,3.2rem)] font-semibold text-[#1A1A1A]">{concept.title}</h1>
      <p class="mt-4 max-w-3xl text-[clamp(1rem,0.95rem+0.35vw,1.18rem)] leading-8 text-[#1A1A1A]/70">{concept.summary}</p>
      <div class="mt-5 flex flex-wrap justify-end gap-2 text-xs text-[#1A1A1A]/55">
        {concept.tags.map((tag) => (
          <span class="rounded-full border border-[#1A1A1A]/10 bg-[#FAFAF8] px-3 py-1">{tag}</span>
        ))}
      </div>
    </header>

    <section class="grid gap-6 md:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <article class="space-y-6 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 p-6 text-right shadow-[0_20px_60px_rgba(26,26,26,0.05)]">
        <div class="space-y-3">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">הגדרה קצרה</p>
          <p class="text-[clamp(1rem,0.95rem+0.35vw,1.16rem)] leading-8 text-[#1A1A1A]/74">{concept.definition}</p>
        </div>
        <div class="space-y-3 border-t border-[#1A1A1A]/10 pt-5">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">למה זה משנה</p>
          <p class="text-[clamp(1rem,0.95rem+0.35vw,1.16rem)] leading-8 text-[#1A1A1A]/74">{concept.whyItMatters}</p>
        </div>
      </article>

      <div class="space-y-4">
        {concept.oppositeLink && (
          <aside class="rounded-[2rem] border border-[#D42B2B]/14 bg-[#FFF4F3] p-6 text-right shadow-[0_16px_40px_rgba(212,43,43,0.08)]">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">הצד השני של המטבע</p>
            <h2 class="mt-3 text-2xl font-semibold text-[#1A1A1A]">{concept.oppositeLink.title}</h2>
            <p class="mt-3 text-sm leading-7 text-[#1A1A1A]/68">{concept.oppositeLink.description}</p>
            <a href={concept.oppositeLink.href} class="mt-5 inline-flex items-center rounded-full border border-[#D42B2B]/14 bg-white px-4 py-2 text-sm font-semibold text-[#D42B2B] transition hover:bg-[#FFF4F3]">
              לעבור לצד השני
            </a>
          </aside>
        )}

        <aside class="space-y-4 rounded-[2rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-6 text-right">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">ראה גם</p>
          <div class="space-y-3">
            {relatedLinks.map((link) => (
              <a href={link.href} class="block rounded-[1.4rem] border border-[#1A1A1A]/10 bg-white px-4 py-4 transition hover:bg-[#FFF4F3]">
                <p class="font-semibold text-[#1A1A1A]">{link.title}</p>
                <p class="mt-2 text-sm leading-7 text-[#1A1A1A]/64">{link.description}</p>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </section>

    {otherConcepts.length > 0 && (
      <section class="space-y-4 text-right">
        <div class="space-y-2">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">מושגים קרובים</p>
          <h2 class="text-2xl font-semibold text-[#1A1A1A]">אם הגעת לכאן, כנראה שתרצה להמשיך גם לכאן</h2>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {otherConcepts.map((item) => (
            <a href={`/glossary/${item.slug}/`} class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-white/82 p-5 transition hover:translate-y-[-2px] hover:bg-white">
              <h3 class="text-xl font-semibold text-[#1A1A1A]">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-[#1A1A1A]/66">{item.summary}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </section>
</Layout>

