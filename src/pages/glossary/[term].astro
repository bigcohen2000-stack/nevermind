---
import { getCollection } from "astro:content";
import { DirectLink } from "../../components/ui/DirectLink";
import appConfig from "../../config/appConfig.json";
import { glossaryConcepts, type GlossaryConcept, type GlossaryLink, glossaryMap } from "../../data/glossary";
import { glossaryTagToTopicHref } from "../../data/glossary-topics";
import Layout from "../../layouts/Layout.astro";
import { getCanonicalArticleSlug } from "../../lib/articles";

type RelatedArticle = {
  href: string;
  title: string;
  description: string;
  score: number;
};

export async function getStaticPaths() {
  return glossaryConcepts.map((concept) => ({
    params: { term: concept.slug },
    props: { concept },
  }));
}

const { concept } = Astro.props as { concept: GlossaryConcept };
const entries = await getCollection("articles", ({ data }) => data.draft !== true);

const relatedArticles: RelatedArticle[] = entries
  .map((entry) => {
    const tags = Array.isArray(entry.data.tags) ? entry.data.tags : [];
    const haystack = `${entry.data.title} ${entry.data.description} ${tags.join(" ")}`.toLowerCase();
    const tagScore = tags.filter((tag) => concept.tags.includes(tag)).length * 3;
    const keywordScore = concept.keywords.filter((keyword) => haystack.includes(keyword.toLowerCase())).length;
    const score = tagScore + keywordScore;

    return {
      href: `/articles/${getCanonicalArticleSlug(entry)}/`,
      title: entry.data.title,
      description: entry.data.description,
      score,
    };
  })
  .filter((article) => article.score > 0)
  .sort((left, right) => right.score - left.score)
  .slice(0, 3);

const fallbackLinks: GlossaryLink[] = [];
for (const tag of concept.tags) {
  const topicHref = glossaryTagToTopicHref[tag];
  if (!topicHref) continue;
  fallbackLinks.push({
    href: topicHref,
    title: `נושא: ${tag}`,
    description: `המשך חקירה דרך כל המאמרים ששייכים ל-${tag}.`,
  });
}
for (const link of concept.relatedLinks) {
  if (!fallbackLinks.some((item) => item.href === link.href)) {
    fallbackLinks.push(link);
  }
}
if (!fallbackLinks.some((item) => item.href === "/articles/")) {
  fallbackLinks.push({
    href: "/articles/",
    title: "כל המאמרים",
    description: "מעבר לספריית המאמרים המלאה כדי להמשיך לחקור.",
  });
}

const relatedLinks = [
  ...relatedArticles.map((article) => ({
    href: article.href,
    title: article.title,
    description: article.description,
  })),
  ...fallbackLinks.filter((link) => !relatedArticles.some((article) => article.href === link.href)),
].slice(0, 5);

const explicitRelatedConcepts = (concept.relatedConceptSlugs ?? [])
  .map((slug) => glossaryMap[slug])
  .filter((item): item is GlossaryConcept => Boolean(item) && item.slug !== concept.slug);

const fallbackOtherConcepts = glossaryConcepts
  .filter((item) => item.slug !== concept.slug)
  .filter(
    (item) =>
      item.tags.some((tag) => concept.tags.includes(tag)) ||
      item.keywords.some((keyword) => concept.keywords.includes(keyword))
  )
  .slice(0, 3);

const otherConcepts = [...explicitRelatedConcepts, ...fallbackOtherConcepts].filter(
  (item, index, array) => array.findIndex((candidate) => candidate.slug === item.slug) === index
).slice(0, 3);

const pageTitle = `${concept.title} | מילון המושגים של השם לא משנה`;
const pageDescription = `${concept.summary} הגדרה, ההפך, דוגמה יומיומית, וקישורים להמשך קריאה.`;
const relatedSearchHref = `/services/?q=${encodeURIComponent(concept.title)}&topic=${encodeURIComponent(concept.title)}`;
const isFactVsInterpretation = concept.slug === "fact-vs-interpretation";
const factRows = [
  { fact: "הוא לא ענה לי יומיים.", interpretation: "הוא מזלזל בי." },
  { fact: "הפגישה נדחתה לשבוע הבא.", interpretation: "זה אומר שאני לא חשוב." },
  { fact: "הלב דופק מהר לפני שיחה.", interpretation: "אני לא מסוגל לעמוד בזה." },
  { fact: "יש לי משימה ולא התחלתי.", interpretation: "אני עצלן ואין לי משמעת." },
];
---

<Layout title={pageTitle} description={pageDescription} breadcrumbCurrentLabel={concept.title}>
  <section class="mx-auto max-w-5xl space-y-10 px-4 pb-20 text-[var(--nm-fg)]">
    <header class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/86 px-6 py-8 text-right shadow-[0_20px_60px_rgba(26,26,26,0.05)] md:px-8">
      <p class="text-sm font-semibold text-[var(--nm-accent)]">מושג יסוד</p>
      <h1 class="mt-3 text-[clamp(2.1rem,1.6rem+2vw,3.2rem)] font-semibold text-[var(--nm-fg)]">{concept.title}</h1>
      <p class="mt-4 max-w-3xl text-[clamp(1rem,0.95rem+0.35vw,1.18rem)] leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
        {concept.summary}
      </p>
      <div class="mt-5 flex flex-wrap justify-end gap-3">
        <a
          href={relatedSearchHref}
          class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
        >
          עוד על {concept.title}
        </a>
        <a href="/glossary/" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          חזרה למילון
        </a>
        <a href="/me/learning/" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
          לוח הלמידה
        </a>
      </div>
      <div class="mt-5 flex flex-wrap justify-end gap-2 text-xs text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">
        {concept.tags.map((tag) => {
          const topicHref = glossaryTagToTopicHref[tag];
          const pillClass =
            "inline-flex min-h-[32px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-3 py-1 transition hover:border-[color-mix(in_srgb,var(--nm-accent)_28%,transparent)] hover:text-[var(--nm-accent)]";
          return topicHref ? (
            <a href={topicHref} class={pillClass}>{tag}</a>
          ) : (
            <span class={pillClass}>{tag}</span>
          );
        })}
      </div>
    </header>

    <section class="grid gap-6 md:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)]">
      <article class="space-y-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/86 p-6 text-right shadow-[0_20px_60px_rgba(26,26,26,0.05)]">
        {isFactVsInterpretation ? (
          <>
            <div class="space-y-3">
              <p class="text-sm font-semibold text-[var(--nm-accent)]">הגדרה</p>
              <p class="text-[clamp(1rem,0.95rem+0.35vw,1.16rem)] leading-[1.75] text-[var(--nm-fg)]/80">
                עובדה היא משהו שאפשר לצלם, להקליט, או למדוד. פירוש הוא מה שהמוח אומר שהעובדה אומרת.
              </p>
            </div>
            <div class="space-y-3 border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pt-5">
              <p class="text-sm font-semibold text-[var(--nm-accent)]">למה זה משנה</p>
              <p class="text-[clamp(1rem,0.95rem+0.35vw,1.16rem)] leading-[1.75] text-[var(--nm-fg)]/80">
                ברגע שהפירוש מתחפש לעובדה, כל התגובה כבר מרגישה מוצדקת. ההפרדה מחזירה בדיקה במקום סערה.
              </p>
            </div>
            <div class="space-y-4 border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pt-5">
              <p class="text-sm font-semibold text-[var(--nm-accent)]">דוגמה יומיומית</p>
              <div class="overflow-x-auto">
                <table class="min-w-full border-separate border-spacing-0 overflow-hidden rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] text-sm">
                  <thead>
                    <tr class="bg-[var(--nm-surface-muted)] text-[var(--nm-fg)]">
                      <th class="border-b border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-3 text-right font-semibold">עובדה</th>
                      <th class="border-b border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-3 text-right font-semibold">פירוש</th>
                    </tr>
                  </thead>
                  <tbody>
                    {factRows.map((row) => (
                      <tr class="align-top odd:bg-white even:bg-[color-mix(in_srgb,var(--nm-bg-canvas)_96%,white)]">
                        <td class="border-b border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] px-4 py-3 leading-[1.7]">{row.fact}</td>
                        <td class="border-b border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] px-4 py-3 leading-[1.7]">{row.interpretation}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </>
        ) : (
          <>
            <div class="space-y-3">
              <p class="text-sm font-semibold text-[var(--nm-accent)]">הגדרה</p>
              <p class="text-[clamp(1rem,0.95rem+0.35vw,1.16rem)] leading-[1.75] text-[var(--nm-fg)]/80">{concept.definition}</p>
            </div>
            <div class="space-y-3 border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pt-5">
              <p class="text-sm font-semibold text-[var(--nm-accent)]">למה זה משנה</p>
              <p class="text-[clamp(1rem,0.95rem+0.35vw,1.16rem)] leading-[1.75] text-[var(--nm-fg)]/80">{concept.whyItMatters}</p>
            </div>
            {concept.dailyExample ? (
              <div class="space-y-3 border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pt-5">
                <p class="text-sm font-semibold text-[var(--nm-accent)]">דוגמה יומיומית</p>
                <p class="rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4 text-[clamp(1rem,0.95rem+0.35vw,1.12rem)] leading-[1.75] text-[var(--nm-fg)]/80">
                  {concept.dailyExample}
                </p>
              </div>
            ) : null}
          </>
        )}
      </article>

      <div class="space-y-4">
        {concept.oppositeLink ? (
          <aside class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[var(--nm-tint)] p-6 text-right shadow-[0_16px_40px_rgba(212,43,43,0.08)]">
            <p class="text-sm font-semibold text-[var(--nm-accent)]">ההפך שמחדד</p>
            <h2 class="mt-3 text-2xl font-semibold text-[var(--nm-fg)]">{concept.oppositeLink.title}</h2>
            <p class="mt-3 text-sm leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">{concept.oppositeLink.description}</p>
            <a href={concept.oppositeLink.href} class="mt-5 inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-white px-4 py-2 text-sm font-semibold text-[var(--nm-accent)] transition hover:bg-[var(--nm-tint)]">
              לעבור לצד השני
            </a>
          </aside>
        ) : null}

        <aside class="space-y-4 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-6 text-right">
          <p class="text-sm font-semibold text-[var(--nm-accent)]">להמשך</p>
          <div class="space-y-3">
            {relatedLinks.map((link) => (
              <a href={link.href} class="block rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-4 transition hover:bg-[var(--nm-tint)]">
                <p class="font-semibold text-[var(--nm-fg)]">{link.title}</p>
                <p class="mt-2 text-sm leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">{link.description}</p>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </section>

    {otherConcepts.length > 0 ? (
      <section class="space-y-4 text-right">
        <div class="space-y-2">
          <p class="text-sm font-semibold text-[var(--nm-accent)]">מושג קרוב</p>
          <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">אפשר להמשיך מכאן לעוד שכבה אחת</h2>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {otherConcepts.map((item) => (
            <a href={`/glossary/${item.slug}/`} class="rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/86 p-5 transition hover:translate-y-[-2px] hover:bg-white">
              <h3 class="text-xl font-semibold text-[var(--nm-fg)]">{item.title}</h3>
              <p class="mt-3 text-sm leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">{item.summary}</p>
            </a>
          ))}
        </div>
      </section>
    ) : null}

    <div class="flex justify-end border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pt-10" aria-label="פתיחת שיחה אחרי קריאה">
      <DirectLink client:load whatsAppNumber={appConfig.contact.whatsAppNumber} fallbackEmail={appConfig.contact.email} />
    </div>
  </section>
</Layout>
