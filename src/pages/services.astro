---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import FloatingCTA from "../components/FloatingCTA.astro";
import ThoughtShiftProof from "../components/ThoughtShiftProof.astro";
import {
  buildWhatsAppHref,
  flattenVisibleServices,
  formatMoney,
  servicesAddOns,
  servicesHero,
  servicesPaymentMethods,
  servicesStages,
  servicesTaxLabel,
  servicesThoughtShifts,
  servicesTrust,
} from "../lib/services";

const stageCards = servicesStages
  .map((stage) => ({
    ...stage,
    primaryService: stage.services.find((service) => service.visible !== false),
  }))
  .filter((stage) => stage.primaryService);

const addon = servicesAddOns[0];
const subscriptionService = flattenVisibleServices().find((service) => service.id === "merpeset-subscription");
const floatingPrimaryHref = subscriptionService
  ? buildWhatsAppHref("שלום! הבנתי שאתה רוצה להתחיל מסלול מרפסת. לפני שנקבע – אני שולח לך את כל הפרטים + תאריכים פנויים. מתאים לך שאשלח?")
  : buildWhatsAppHref("שלום, אני רוצה להבין איזה מסלול מתאים לי כרגע.");
---

<Layout
  title="שירותים ומחירים | השם לא משנה"
  description="5 מסלולים ברורים, סולם ערך נקי, ומעבר ישיר לוואטסאפ או להמשך סגירה בלי הודעות מיותרות."
>
  <section class="mx-auto max-w-7xl space-y-16 px-4 pb-20 text-[#1A1A1A]">
    <header class="max-w-4xl space-y-5 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.26em] text-[#D42B2B]">Masterclass Services</p>
      <h1 class="text-[clamp(2.6rem,2rem+2.3vw,4.6rem)] font-semibold leading-[1.04]">{servicesHero.title}</h1>
      <p class="max-w-3xl text-[clamp(1rem,0.95rem+0.3vw,1.2rem)] leading-8 text-[#1A1A1A]/72">{servicesHero.subtitle}</p>
    </header>

    <section class="grid gap-8">
      {stageCards.map((stage) => (
        <div class="space-y-5 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 p-6 shadow-[0_24px_80px_rgba(26,26,26,0.05)]">
          <div class="space-y-2 text-right">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">{stage.stage_name}</p>
            <h2 class="text-[clamp(1.8rem,1.4rem+1vw,2.6rem)] font-semibold text-[#1A1A1A]">{stage.target_audience}</h2>
          </div>

          <div class="grid gap-6 xl:grid-cols-1">
            {stage.services.filter((service) => service.visible !== false).map((service) => (
              <ServiceCard
                service={{ ...service, stageName: stage.stage_name, targetAudience: stage.target_audience }}
                disclaimer={servicesTrust.disclaimer}
              />
            ))}
          </div>
        </div>
      ))}
    </section>

    {addon ? (
      <section class="rounded-[2rem] border border-[#D42B2B]/14 bg-[#FFF4F3] px-6 py-8 shadow-[0_24px_80px_rgba(212,43,43,0.08)]">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <div class="space-y-3 text-right">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">Add-on מומלץ</p>
            <h2 class="text-2xl font-semibold text-[#1A1A1A]">{addon.title}</h2>
            <p class="max-w-2xl text-sm leading-7 text-[#1A1A1A]/72">{addon.description}</p>
          </div>
          <div class="space-y-2 text-right">
            <p class="text-3xl font-semibold text-[#1A1A1A]">{formatMoney(addon.price_full)}</p>
            <a
              href={buildWhatsAppHref(`שלום, אני רוצה להוסיף ${addon.title} למסלול שלי. ראיתי שזה ${formatMoney(addon.price_full)} כולל מע״מ.`)}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-full bg-[#D42B2B] px-5 py-3 text-sm font-semibold text-[#FAFAF8] transition hover:bg-[#b82424]"
            >
              {addon.action_text}
            </a>
          </div>
        </div>
      </section>
    ) : null}

    <ThoughtShiftProof items={servicesThoughtShifts} heading="לא עדות כללית. שינוי לוגי שאפשר לראות." eyebrow="לפני ואחרי הייעוץ" />

    <section class="rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 px-6 py-10 shadow-[0_24px_80px_rgba(26,26,26,0.05)]">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div class="space-y-3 text-right">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">Payment</p>
          <h2 class="text-2xl font-semibold text-[#1A1A1A]">תשלום, מסמכים וסגירה נקייה</h2>
          <p class="text-sm leading-7 text-[#1A1A1A]/68">
            כל המחירים שמופיעים כאן הם {servicesTaxLabel}. אפשר לסגור דרך וואטסאפ או לקבל פרטי תשלום והמשך.
          </p>
        </div>
        <div class="grid gap-3 text-right sm:grid-cols-2">
          {servicesPaymentMethods.map((method) => (
            <div class="rounded-[1.3rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-3">
              <p class="text-sm font-semibold text-[#1A1A1A]">{method.icon} {method.name}</p>
              <p class="mt-1 text-xs leading-6 text-[#1A1A1A]/60">{method.note}</p>
            </div>
          ))}
        </div>
      </div>
      <p class="mt-6 border-t border-[#1A1A1A]/10 pt-4 text-sm leading-7 text-[#1A1A1A]/58">{servicesTrust.disclaimer}</p>
    </section>
  </section>

  <FloatingCTA
    primaryHref={floatingPrimaryHref}
    primaryLabel="להתחיל מנוי מרפסת"
    secondaryHref="#merpeset-subscription"
    secondaryLabel="לקפוץ ישר לשלב 3"
  />
</Layout>



