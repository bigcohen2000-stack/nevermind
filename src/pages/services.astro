---
import Layout from "../layouts/Layout.astro";
import { glossaryConcepts } from "../data/glossary";
import appConfig from "../config/appConfig.json";
import {
  servicesHero,
  servicesContentGapMessage,
  flattenVisibleServices,
  resolveServiceAction,
  formatMoney,
  buildServiceReservationWhatsAppHref,
} from "../lib/services";
import { ArchiveSearchFloatingInput } from "../components/ArchiveSearchFloatingInput";
import { DirectLink } from "../components/ui/DirectLink";
import ServicePricingBlock from "../components/ServicePricingBlock";
import ServicesPricingStickyBar from "../components/ServicesPricingStickyBar";
import TopicQueryLandingBanner from "../components/TopicQueryLandingBanner";
import PremiumClubGate from "../components/PremiumClubGate.astro";

const services = flattenVisibleServices();
const popularTags = glossaryConcepts.slice(0, 6).map((c) => ({
  label: c.title,
  searchQuery: (c.keywords && c.keywords[0]) || c.title,
}));
const waNumber = String(appConfig.contact.whatsAppNumber ?? "").replace(/\D/g, "");
---

<Layout
  title="מרחב גילוי"
  description="חיפוש בארכיון התכנים ודרכים להעמיק בשיחה, בלי אשף שלבים."
>
  <TopicQueryLandingBanner client:visible />
  <section class="mx-auto max-w-7xl space-y-12 px-4 pb-28 pt-16 text-[var(--nm-fg)] md:pb-20 md:py-20">
    <nav
      aria-label="קפיצה לחלקי העמוד"
      class="flex flex-wrap items-center justify-center gap-2 border-b border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pb-6 text-sm font-semibold text-[var(--nm-accent)]"
    >
      <a href="#discovery-results" class="rounded-full px-3 py-1.5 hover:bg-[var(--nm-tint)]">גילוי</a>
      <span class="text-[color-mix(in_srgb,var(--nm-fg)_30%,var(--nm-bg))]" aria-hidden="true">·</span>
      <a href="#pricing" class="rounded-full px-3 py-1.5 hover:bg-[var(--nm-tint)]">מחירון</a>
      <span class="text-[color-mix(in_srgb,var(--nm-fg)_30%,var(--nm-bg))]" aria-hidden="true">·</span>
      <a href="/intake/" class="rounded-full px-3 py-1.5 hover:bg-[var(--nm-tint)]">לפני שיחה</a>
    </nav>

    <ServicesPricingStickyBar client:idle />

    <header class="space-y-8 text-center">
      <h1 class="text-[clamp(2rem,1.5rem+2.2vw,3.5rem)] font-semibold leading-[1.08] tracking-tight">
        {servicesHero.title}
      </h1>
      <p class="mx-auto max-w-2xl text-[clamp(1rem,0.95rem+0.25vw,1.15rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        {servicesHero.subtitle}
      </p>

      <div class="mx-auto grid max-w-5xl gap-6 text-right lg:grid-cols-[minmax(0,1fr)_minmax(16rem,22rem)] lg:items-start lg:gap-8">
        <div class="space-y-3">
          <p class="text-[clamp(1rem,0.95rem+0.3vw,1.12rem)] font-semibold leading-7 text-[var(--nm-fg)]">
            יש משהו שמעסיק אותך? בוא נראה מה יש לנו בארכיון על זה.
          </p>
          <ArchiveSearchFloatingInput
            client:load
            id="discovery-search"
            label="למשל: בהירות, זוגיות, לחץ"
            pagefindInput={true}
            className="shadow-[0_20px_50px_color-mix(in_srgb,var(--nm-fg)_5%,transparent)]"
          />
        </div>
        <div
          id="discovery-idle"
          class="rounded-3xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_94%,transparent)] px-5 py-6 text-right lg:px-6 lg:py-7"
        >
          <p class="text-base font-semibold text-[var(--nm-fg)]">בחר נושא וקבל כיוון</p>
          <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
            כאן יופיעו תוצאות מהארכיון. אפשר להתחיל מהחיפוש למעלה או ללחוץ על אחת התגיות למטה.
          </p>
        </div>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-2">
        <span class="w-full text-center text-sm text-[color-mix(in_srgb,var(--nm-fg)_45%,var(--nm-bg))] sm:w-auto">נושאים מהגלוסר:</span>
        {
          popularTags.map(({ label, searchQuery }) => (
            <button
              type="button"
              data-discovery-tag={searchQuery}
              class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_90%,transparent)] px-3 py-1.5 text-sm font-semibold text-[var(--nm-accent)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] hover:bg-[var(--nm-surface-muted)]"
            >
              {label}
            </button>
          ))
        }
      </div>
    </header>

    <div id="discovery-results" class="grid grid-cols-1 gap-12 lg:grid-cols-2">
      <div class="space-y-6">
        <div class="border-b border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pb-3">
          <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--nm-fg)_45%,var(--nm-bg))]">
            מהארכיון
          </h2>
        </div>
        <p id="discovery-archive-status" class="hidden text-sm text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]"></p>
        <div id="discovery-archive-list" class="space-y-3"></div>
      </div>
      <div
        id="discovery-gap"
        class="hidden rounded-3xl border-2 border-dashed border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_96%,transparent)] px-6 py-10 text-center"
      >
        <p id="discovery-gap-text" class="text-lg leading-8 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]"></p>
        <a
          id="discovery-gap-wa"
          href={`https://wa.me/${waNumber}`}
          class="mt-8 inline-flex min-h-[48px] items-center justify-center gap-2 rounded-full bg-[var(--nm-inverse)] px-8 py-3 text-sm font-semibold text-white transition hover:bg-[var(--nm-inverse-hover)]"
        >
          נדבר על זה בוואטסאפ
        </a>
    </div>
  </div>

    <div class="mx-auto max-w-3xl">
      <PremiumClubGate />
    </div>

    <div id="pricing" class="scroll-mt-28 space-y-6" tabindex="-1">
      <div class="border-b border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pb-3">
        <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--nm-accent)]">
          רוצה לפרק את זה יחד?
        </h2>
        <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
          אלו הדרכים שבהן אנחנו יכולים לשבת על זה.
        </p>
      </div>
      <div class="grid gap-4">
        {
          services.map((service) => {
            const action = resolveServiceAction(service);
            const note = service.friendly_note?.trim() || service.subtitle || "";
            const hasExt = Array.isArray(service.extensions) && service.extensions.length > 0;
            const serviceJson = JSON.stringify(service);
            return (
              <div
                id={service.id}
                data-nm-service-card
                class="group rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 shadow-[0_12px_32px_color-mix(in_srgb,var(--nm-fg)_4%,transparent)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)]"
              >
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <h3 class="text-lg font-semibold text-[var(--nm-fg)]">{service.title}</h3>
                  {hasExt ? null : (
                    <span class="text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">
                      {formatMoney(service.price_full)}
                    </span>
                  )}
                </div>
                {note ? (
                  <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">{note}</p>
                ) : null}
                {hasExt ? (
                  <div class="mt-5">
                    <ServicePricingBlock client:visible serviceJson={serviceJson} layout="compact" />
                  </div>
                ) : (
                  <div class="mt-5 flex flex-wrap items-center justify-end gap-2">
                    <a
                      href={action.href}
                      {...(action.external ? { target: "_blank", rel: "noreferrer" } : {})}
                      class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-4 py-2 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
                    >
                      {action.label}
                    </a>
                    <a
                      href={buildServiceReservationWhatsAppHref(service)}
                      target="_blank"
                      rel="noreferrer"
                      class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-tint)]"
                    >
                      שיריון מקום
                    </a>
                  </div>
                )}
              </div>
            );
          })
        }
      </div>
      <div class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-6 text-right">
        <p class="text-sm font-semibold text-[var(--nm-fg)]">ממשיכים בלי סינון אוטומטי</p>
        <p class="mt-2 text-sm leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          בוחרים טופס התאמה, עמוד קביעה, או יצירת קשר ישירה.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a
            href="/intake/"
            class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]"
          >
            טופס לפני שיחה
          </a>
          <a
            href="/book/"
            class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
          >
            קביעת שיחה
          </a>
          <a
            href="/contact/"
            class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
          >
            יצירת קשר
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto flex max-w-7xl justify-end px-4 pb-16" aria-label="פתיחת שיחה אחרי קריאה">
    <DirectLink
      client:idle
      whatsAppNumber={appConfig.contact.whatsAppNumber}
      fallbackEmail={appConfig.contact.email}
    />
  </div>

  <section
    class="mx-auto max-w-7xl border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 pb-24 text-[var(--nm-fg)]"
    aria-labelledby="services-next-step"
  >
    <h2 id="services-next-step" class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--nm-accent)]">
      צעד הבא
    </h2>
    <p class="mt-4 max-w-3xl text-right text-[clamp(1.05rem,0.98rem+0.35vw,1.2rem)] font-medium leading-relaxed">
      אחרי שמצאת נושא או מסלול: <a href="/intake/" class="text-[var(--nm-accent)] underline-offset-4 hover:underline">טופס לפני שיחה</a>
      <span class="text-[color-mix(in_srgb,var(--nm-fg)_35%,var(--nm-bg))]"> · </span>
      <a href="/book/" class="text-[var(--nm-accent)] underline-offset-4 hover:underline">קביעת שיחה</a>
    </p>
    <p class="mt-6 max-w-3xl text-right text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
      איזה חוסר התאמה בין עובדה לפירוש תרצה לבדוק קודם.
    </p>
  </section>

  <div
    id="services-discovery-config"
    data-content-gap-message={servicesContentGapMessage}
    data-wa-number={waNumber}
    hidden
  ></div>

  <script>
    import "../scripts/services-ui.js";
  </script>
</Layout>


