---
import Layout from "../layouts/Layout.astro";
import { glossaryConcepts } from "../data/glossary";
import appConfig from "../config/appConfig.json";
import {
  servicesContentGapMessage,
  flattenVisibleServices,
  formatMoney,
  buildServiceReservationWhatsAppHref,
  buildWhatsAppHref,
  buildServiceDisplayActionLabel,
  formatAvailabilityLine,
  assertServicePricingConsistency,
} from "../lib/services";
import { ArchiveSearchFloatingInput } from "../components/ArchiveSearchFloatingInput";
import { DirectLink } from "../components/ui/DirectLink";
import ServicePricingBlock from "../components/ServicePricingBlock";
import ServicesPricingStickyBar from "../components/ServicesPricingStickyBar";
import TopicQueryLandingBanner from "../components/TopicQueryLandingBanner";
import PremiumClubGate from "../components/PremiumClubGate.astro";

const services = flattenVisibleServices();
assertServicePricingConsistency(services);

const popularTags = glossaryConcepts.slice(0, 6).map((c) => ({
  label: c.title,
  searchQuery: (c.keywords && c.keywords[0]) || c.title,
}));
const waNumber = String(appConfig.contact.whatsAppNumber ?? "").replace(/\D/g, "");
const joinClubHref = "/me/unlock/";
const joinClubWaHref = buildWhatsAppHref(
  "היי, הגעתי מדף השירותים. רוצה להבין איך מצטרפים ל-NeverMind ומה נפתח אחרי ההצטרפות."
);

const guideById = {
  "phone-perspective": {
    title: "שיחת פוקוס",
    kicker: "סדר מהיר בלי להעמיס",
    fit: "מתאים כשיש משהו שמטריד עכשיו וצריך לעשות סדר בלי לפתוח את כל החיים בבת אחת.",
    receive: [
      "פירוק מהיר של מה שמפעיל אותך עכשיו",
      "הבדלה בין עובדה, פירוש ותגובה",
      "כיוון ברור להמשך בלי רעש מסביב",
    ],
    icons: ["📞 טלפון", "🎥 וידאו", "🕒 20-60 דקות"],
    primaryHref: "/book/",
    primaryLabel: "קביעת שיחה",
    trust: "לא צריך להגיע מוכן. מספיק להביא את מה שמציק עכשיו.",
  },
  "personal-clinic": {
    title: "מפגש עומק",
    kicker: "זמן ושקט למי שלא רוצה למהר",
    fit: "מתאים כשיש שכבות עמוקות יותר, או כשמרגישים ששיחה קצרה לא תספיק כדי לראות מה באמת קורה.",
    receive: [
      "זמן ארוך יותר בלי לחץ זמן",
      "מרחב שקט שמאפשר לראות מה יושב מתחת לסיפור",
      "אפשרות להמשיך עד שמרגישים בהירות ולא רק הקלה רגעית",
    ],
    icons: ["📍 פרונטלי", "🚗 אפשר להגיע אליך", "🎧 אפשר להוסיף תיעוד"],
    primaryHref: "/book/",
    primaryLabel: "קביעת שיחה",
    trust: "זה לא צריך להרגיש דרמטי. זה פשוט מרחב רגוע יותר לעבודה עמוקה.",
  },
  "balcony-experience": {
    title: "נוכחות באולפן",
    kicker: "לראות איך שאלות של אחרים נוגעות גם בך",
    fit: "מתאים למי שרוצה לראות איך שאלות של אחרים משתקפות עליו, בלי להיות לבד מול הדבר שהוא בודק.",
    receive: [
      "נוכחות בשיחה חיה באולפן קטן ושקט",
      "אפשר לראות איך מנגנונים חוזרים בין אנשים שונים",
      "חוויה שמחברת בין הקשבה, קצב וקצת אומץ שקט",
    ],
    icons: ["🎙️ פודקאסט", "👥 קבוצה קטנה", "🕒 45-90 דקות"],
    primaryHref: "/book/",
    primaryLabel: "שריון מקום",
    trust: "לא חייבים לדבר הרבה כדי להרגיש את הערך. לפעמים מספיק להיות שם.",
  },
  "portal-access": {
    title: "מנוי ארכיון",
    kicker: "לחקור לבד, בקצב שלך",
    fit: "מתאים למי שרוצה לחקור לבד, לחזור לטקסטים בזמן שלו, ולהיכנס לעומק בלי לקבוע שיחה כל פעם מחדש.",
    receive: [
      "סרטון מלא בכל מאמר שנפתח למנויים",
      "תכנים שלא נכון לפרסם בפומבי",
      "גישה לקבוצה השקטה, לעץ שורש הבעיה ולספרייה האסורה",
    ],
    icons: ["📚 גישה מלאה", "🎬 סרטון בכל מאמר", "🔒 תכנים למנויים בלבד"],
    primaryHref: "/me/unlock/",
    primaryLabel: "בקשה להצטרף",
    trust: "המנוי לא נועד לייצר לחץ. הוא פשוט פותח את כל מה שלא נכנס לעמוד פתוח רגיל.",
  },
} as const;

const orderedIds = ["phone-perspective", "personal-clinic", "balcony-experience", "portal-access"];
const featuredServices = orderedIds
  .map((id) => {
    const service = services.find((item) => item.id === id);
    const guide = guideById[id as keyof typeof guideById];
    if (!service || !guide) return null;
    return {
      ...guide,
      service,
      reservationHref: buildServiceReservationWhatsAppHref(service),
      actionLabel: buildServiceDisplayActionLabel(service),
      availabilityLine: formatAvailabilityLine(service),
      priceLead:
        id === "portal-access"
          ? `${formatMoney(service.price_full)} לחודש`
          : `מ-${formatMoney(service.price_full)}`,
      hasExtensions: Array.isArray(service.extensions) && service.extensions.length > 0,
    };
  })
  .filter((item): item is NonNullable<typeof item> => item !== null);

const premiumFutureTags = [
  "אלוהים",
  "דת",
  "הכל אחד",
  "מיניות",
  "אילומינטי",
  "הדרכת הורים",
  "פחדים עמוקים",
  "זהות",
  "משמעות",
];

const membersOnlyItems = [
  "סרטונים מלאים",
  "תכנים שלא מפורסמים בפומבי",
  "גישה לקבוצה השקטה",
  "גישה לעומק ולספרייה האסורה",
  "גישה לעץ שורש הבעיה",
  "גישה להקלטות ולפירוק מלא של מאמרים",
];

const trustCards = [
  {
    title: "למי זה מתאים",
    body: "למי שמרגיש שיש רעש פנימי, למי שמחפש בהירות, ולמי שרוצה להבין מה מפעיל אותו בלי סיסמאות ובלי הצגות.",
  },
  {
    title: "מה לא תמצא כאן",
    body: "לא טיפול, לא מוטיבציה, לא הרגעה, ולא פתרונות מהירים. כן בדיקה אמיתית של מה שקורה בפנים.",
  },
  {
    title: "למה יש מנוי",
    body: "כדי לאפשר יצירה שקטה, עצמאית, בלי פרסומות, בלי רעש ובלי תלות בגופים חיצוניים.",
  },
  {
    title: "יושרה פשוטה",
    body: "אין הפתעות. אין מניפולציות. אין שיווק אגרסיבי. הפרטים שלכם נשארים רק אצלנו. אנחנו לא עושים איתם שום דבר אחר.",
  },
];

const faqItems = [
  {
    question: "האם זה טיפול",
    answer: "לא. זו בדיקה שקטה של מה קורה אצלך, דרך שיחה, הקשבה והפרדה בין מה שקרה לבין מה שנבנה סביבו.",
  },
  {
    question: "האם זה אנונימי",
    answer: "אפשר להתחיל בשיחה ישירה ופשוטה. אם צריך דיסקרטיות, מדברים על זה מראש ומתאימים את הדרך הנכונה.",
  },
  {
    question: "האם יש התחייבות",
    answer: "לא. אפשר להתחיל משיחה אחת, ממפגש אחד, או ממנוי חודשי, ולראות אם זה נכון לך.",
  },
  {
    question: "האם אפשר לבטל",
    answer: "כן. אם בחרת במנוי, אפשר לעצור אותו. אם בחרת בשיחה, מתאמים מראש מה נכון ואיך ממשיכים.",
  },
  {
    question: "צריך רקע קודם כדי להבין את NeverMind",
    answer: "לא. כל טקסט כאן נכתב כדי להיות מובן גם בלי רקע קודם. מתחילים ממה שמטריד עכשיו.",
  },
];

const archivePreviewItems = [
  {
    title: "איך להבדיל בין עובדה לפירוש",
    body: "המקום שבו רוב הבלבול מתחיל, והמקום שבו הסדר מתחיל לחזור.",
    href: "/blog/איך-להבדיל-בין-עובדה-לפירוש/",
  },
  {
    title: "מהו אגו באמת",
    body: "לא הסבר פילוסופי כבד, אלא בדיקה פשוטה של מי מדבר בתוך הראש שלך.",
    href: "/blog/מהו-אגו-באמת/",
  },
  {
    title: "למה אני מרגיש לבד",
    body: "שאלה שנראית אישית מאוד, אבל יושבת על מנגנון שאפשר לראות בעיניים נקיות.",
    href: "/blog/למה-אני-מרגיש/",
  },
];
---

<Layout
  title="שירותים ומסלולים"
  description="הדרכים שבהן אפשר לעבוד יחד ב-NeverMind: שיחת פוקוס, מפגש עומק, נוכחות באולפן ומנוי ארכיון. כל מסלול כתוב בפשטות, עם מחיר ברור ודרך המשך רגועה."
  faqItems={faqItems}
  breadcrumbCurrentLabel="שירותים"
>
  <TopicQueryLandingBanner client:visible />

  <section class="mx-auto max-w-7xl space-y-14 px-4 pb-28 pt-14 text-[var(--nm-fg)] md:pb-24 md:pt-18">
    <ServicesPricingStickyBar client:idle />

    <header class="space-y-8 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[linear-gradient(180deg,color-mix(in_srgb,var(--nm-bg-canvas)_96%,white),color-mix(in_srgb,var(--nm-surface-muted)_76%,white))] px-6 py-8 text-center shadow-[0_20px_70px_color-mix(in_srgb,var(--nm-fg)_5%,transparent)] md:px-8 md:py-10">
      <div class="space-y-4">
        <p class="text-sm font-semibold tracking-[0.18em] text-[var(--nm-accent)]">שירותים</p>
        <h1 class="text-[clamp(2.2rem,1.6rem+2.2vw,4rem)] font-semibold leading-[1.06] tracking-tight">
          הדרכים שבהן אפשר לעבוד יחד
        </h1>
        <p class="mx-auto max-w-3xl text-[clamp(1rem,0.96rem+0.28vw,1.15rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          אם משהו בפנים לא יושב, לא חייבים לנחש מה נכון לבחור. כאן רואים ארבע דרכים פשוטות להמשיך: שיחה קצרה, מפגש עומק, נוכחות באולפן, או מנוי ארכיון למי שרוצה לחקור לבד.
        </p>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href={joinClubHref}
          class="inline-flex min-h-[52px] w-full items-center justify-center rounded-full bg-[var(--nm-accent)] px-7 py-3 text-base font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)] sm:w-auto"
        >
          רוצה להצטרף ל-NeverMind
        </a>
        <a
          href="#tracks"
          class="inline-flex min-h-[52px] w-full items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-7 py-3 text-base font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)] sm:w-auto"
        >
          מה מתאים לי עכשיו
        </a>
      </div>

      <nav class="flex flex-wrap items-center justify-center gap-3 text-sm font-semibold text-[var(--nm-accent)]">
        <a href="/articles/" class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-2 transition hover:bg-[var(--nm-surface-muted)]">מאמרים פתוחים</a>
        <a href="/glossary/" class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-2 transition hover:bg-[var(--nm-surface-muted)]">מילון המושגים</a>
        <a href="/me/learning/" class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-2 transition hover:bg-[var(--nm-surface-muted)]">לוח הלמידה</a>
        <a href={joinClubHref} class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-2 transition hover:bg-[var(--nm-surface-muted)]">המועדון</a>
      </nav>

      <div class="grid gap-4 text-right md:grid-cols-[minmax(0,1fr)_minmax(16rem,20rem)]">
        <div class="rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-5 shadow-[0_14px_36px_color-mix(in_srgb,var(--nm-fg)_4%,transparent)]">
          <p class="text-base font-semibold text-[var(--nm-fg)]">כדאי להתקין את NeverMind כאפליקציה</p>
          <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
            גישה מהירה, בלי לחפש בדפדפן, ובלי הסחות בדרך. אם הדפדפן שלך תומך בזה, הצעת התקנה תיפתח מיד.
          </p>
          <button
            type="button"
            id="services-install-trigger"
            class="mt-4 inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
          >
            התקנה
          </button>
        </div>

        <div class="rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-5 shadow-[0_14px_36px_color-mix(in_srgb,var(--nm-fg)_4%,transparent)]">
          <p class="text-base font-semibold text-[var(--nm-fg)]">מה מקבלים כאן כבר מהתחלה</p>
          <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
            עמוד ברור, מחירים גלויים, כפתורים פשוטים, ודרך המשך שלא לוחצת עליך. גם אם עוד לא בחרת, כבר אפשר להבין מה נכון לבדוק קודם.
          </p>
          <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">
            הפרטים שלכם נשארים רק אצלנו. אנחנו לא עושים איתם שום דבר אחר.
          </p>
        </div>
      </div>
    </header>

    <section id="tracks" class="scroll-mt-28 space-y-6" tabindex="-1">
      <div class="text-right">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--nm-accent)]">ארבעה מסלולים</p>
        <h2 class="mt-2 text-[clamp(1.6rem,1.35rem+1vw,2.5rem)] font-semibold">לא צריך לבחור לפי ניחוש</h2>
        <p class="mt-3 max-w-3xl text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
          כל כרטיס כאן עונה על שלוש שאלות פשוטות: למי זה מתאים, מה מקבלים, ואיך ממשיכים מכאן בלי בלבול.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-2 2xl:grid-cols-4">
        {
          featuredServices.map((item) => (
            <article
              id={item.service.id}
              class="flex h-full flex-col rounded-[1.7rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 p-5 shadow-[0_16px_44px_color-mix(in_srgb,var(--nm-fg)_5%,transparent)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] hover:shadow-[0_20px_54px_color-mix(in_srgb,var(--nm-fg)_7%,transparent)]"
            >
              <div class="flex flex-wrap items-center justify-between gap-2">
                <p class="text-xs font-semibold tracking-[0.16em] text-[var(--nm-accent)]">{item.kicker}</p>
                <span class="rounded-full bg-[var(--nm-tint)] px-3 py-1 text-sm font-semibold text-[var(--nm-fg)]">{item.priceLead}</span>
              </div>

              <h3 class="mt-3 text-2xl font-semibold text-[var(--nm-fg)]">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">{item.fit}</p>

              <div class="mt-4 flex flex-wrap gap-2 text-sm">
                {item.icons.map((line) => (
                  <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-3 py-1.5 text-[var(--nm-fg)]">{line}</span>
                ))}
              </div>

              <div class="mt-5 space-y-3">
                <div>
                  <p class="text-sm font-semibold text-[var(--nm-fg)]">מה מקבלים</p>
                  <ul class="mt-2 space-y-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
                    {item.receive.map((line) => (
                      <li class="flex gap-2"><span aria-hidden="true" class="text-[var(--nm-accent)]">•</span><span>{line}</span></li>
                    ))}
                  </ul>
                </div>

                <div class="rounded-[1.15rem] bg-[var(--nm-surface-muted)] px-4 py-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
                  <p class="font-semibold text-[var(--nm-fg)]">למה לבחור במסלול הזה</p>
                  <p class="mt-1">{item.trust}</p>
                </div>

                {item.availabilityLine ? (
                  <p class="text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">{item.availabilityLine}</p>
                ) : null}
                {item.service.price_note ? (
                  <p class="text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">{item.service.price_note}</p>
                ) : null}
              </div>

              {item.service.id === "portal-access" ? (
                <div class="mt-5 rounded-[1.15rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_94%,white)] px-4 py-4">
                  <p class="text-sm font-semibold text-[var(--nm-fg)]">מה נפתח רק למנויים</p>
                  <ul class="mt-2 space-y-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
                    {membersOnlyItems.map((line) => (
                      <li class="flex gap-2"><span aria-hidden="true" class="text-[var(--nm-accent)]">•</span><span>{line}</span></li>
                    ))}
                  </ul>
                </div>
              ) : null}

              <div class="mt-auto pt-5">
                <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap">
                  <a
                    href={item.primaryHref}
                    class="inline-flex min-h-[46px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)] sm:flex-1"
                  >
                    {item.primaryLabel}
                  </a>
                  <a
                    href={item.reservationHref}
                    target="_blank"
                    rel="noreferrer"
