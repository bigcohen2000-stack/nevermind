---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import FloatingCTA from "../components/FloatingCTA.astro";
import ThoughtShiftProof from "../components/ThoughtShiftProof.astro";
import {
  buildServicePreStartWhatsAppHref,
  buildWhatsAppHref,
  disclaimerLong,
  disclaimerShort,
  flattenVisibleServices,
  formatMoney,
  resolveServiceAction,
  type StageService,
  servicesAddOns,
  servicesAuthoritySection,
  servicesHero,
  servicesPaymentMethods,
  servicesStages,
  servicesTaxLabel,
  servicesThoughtShifts,
} from "../lib/services";

const stageCards = servicesStages
  .map((stage) => ({
    ...stage,
    primaryService: stage.services.find((service) => service.visible !== false),
  }))
  .filter((stage) => stage.primaryService);

const addon = servicesAddOns[0];
const addonPreStartWaHref = addon ? buildServicePreStartWhatsAppHref(addon.title) : "";
const subscriptionService = flattenVisibleServices().find((service) => service.id === "retainer-subscription");
const subscriptionAction = subscriptionService ? resolveServiceAction(subscriptionService) : null;
const authorityServices = (servicesAuthoritySection?.services ?? []).filter((service) => service.visible !== false);
const floatingPrimaryHref = subscriptionService
  ? subscriptionAction?.href ?? buildWhatsAppHref("שלום, אני רוצה להבין איזה מסלול מתאים לי כרגע.")
  : buildWhatsAppHref("שלום, אני רוצה להבין איזה מסלול מתאים לי כרגע.");
---

<Layout
  title="שירותים ומחירים | השם לא משנה"
  description="5 מסלולים ברורים, סולם ערך נקי, ומעבר ישיר לוואטסאפ או להמשך סגירה בלי הודעות מיותרות."
>
  <section class="mx-auto max-w-7xl space-y-16 px-4 pb-20 text-[var(--nm-fg)]">
    <header class="max-w-4xl space-y-5 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.26em] text-[var(--nm-accent)]">מסלולי העבודה</p>
      <h1 class="text-[clamp(2.6rem,2rem+2.3vw,4.6rem)] font-semibold leading-[1.04]">{servicesHero.title}</h1>
      <p class="max-w-3xl text-[clamp(1rem,0.95rem+0.3vw,1.2rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">{servicesHero.subtitle}</p>
    </header>

    <section class="grid gap-8">
      {stageCards.map((stage) => (
        <div class="space-y-5 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 p-6 shadow-[0_24px_80px_rgba(26,26,26,0.05)]">
          <div class="space-y-2 text-right">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">{stage.stage_name}</p>
            <h2 class="text-[clamp(1.8rem,1.4rem+1vw,2.6rem)] font-semibold text-[var(--nm-fg)]">{stage.target_audience}</h2>
          </div>

          <div class="grid gap-6 xl:grid-cols-1">
            {stage.services.filter((service) => service.visible !== false).map((service: StageService) => (
              <ServiceCard
                service={{
                  ...service,
                  social_proof: service.social_proof ?? stage.social_proof ?? null,
                  stageName: stage.stage_name,
                  targetAudience: stage.target_audience,
                }}
              />
            ))}
          </div>
        </div>
      ))}
    </section>

    {authorityServices.length ? (
      <section class="space-y-5 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 p-6 shadow-[0_24px_80px_rgba(26,26,26,0.05)]">
        <div class="space-y-2 text-right">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">סמכות והשפעה</p>
          <h2 class="text-[clamp(1.8rem,1.4rem+1vw,2.6rem)] font-semibold text-[var(--nm-fg)]">
            {servicesAuthoritySection?.title || "בניית סמכות אישית"}
          </h2>
          {servicesAuthoritySection?.subtitle ? (
            <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">{servicesAuthoritySection.subtitle}</p>
          ) : null}
        </div>
        <div class="grid gap-6 xl:grid-cols-1">
          {authorityServices.map((service) => (
            <ServiceCard
              service={{
                ...service,
                stageName: "סמכות והשפעה",
                targetAudience: servicesAuthoritySection?.subtitle ?? "מי שרוצה לבנות נוכחות מקצועית",
              }}
            />
          ))}
        </div>
      </section>
    ) : null}

    {addon ? (
      <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[var(--nm-tint)] px-6 py-8 shadow-[0_24px_80px_color-mix(in_srgb,var(--nm-accent)_10%,transparent)]">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <div class="space-y-3 text-right">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">תוספת מומלצת</p>
            <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">{addon.title}</h2>
            <p class="max-w-2xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">{addon.description}</p>
          </div>
          <div class="space-y-2 text-right">
            <p class="text-3xl font-semibold text-[var(--nm-fg)]">{formatMoney(addon.price_full)}</p>
            <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-stretch sm:justify-start sm:gap-2">
              <a
                href={
                  typeof addon.payment_link === "string" && addon.payment_link.trim()
                    ? addon.payment_link.trim()
                    : buildWhatsAppHref(`שלום, אני רוצה להוסיף ${addon.title} למסלול שלי. ראיתי שזה ${formatMoney(addon.price_full)} כולל מע״מ.`)
                }
                target="_blank"
                rel="noreferrer"
                class="inline-flex min-h-[2.75rem] items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
              >
                {addon.action_text}
              </a>
              <a
                href={addonPreStartWaHref}
                target="_blank"
                rel="noreferrer"
                class="inline-flex min-h-[2.75rem] items-center justify-center rounded-full border-2 border-[var(--nm-fg)] bg-transparent px-5 py-3 text-sm font-medium text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
              >
                שאלה לפני שמתחילים?
              </a>
            </div>
            <p class="text-center text-xs text-[color-mix(in_srgb,var(--nm-fg)_50%,var(--nm-bg))] md:text-right">
              {disclaimerShort}
            </p>
          </div>
        </div>
      </section>
    ) : null}

    <ThoughtShiftProof items={servicesThoughtShifts} heading="לא עדות כללית. שינוי לוגי שאפשר לראות." eyebrow="לפני ואחרי הייעוץ" />

    <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 px-6 py-10 shadow-[0_24px_80px_rgba(26,26,26,0.05)]">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div class="space-y-3 text-right">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">תשלום וסליקה</p>
          <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">תשלום, מסמכים וסגירה נקייה</h2>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
            כל המחירים שמופיעים כאן הם {servicesTaxLabel}. אפשר לסגור דרך וואטסאפ או לקבל פרטי תשלום והמשך.
          </p>
        </div>
        <div class="grid gap-3 text-right sm:grid-cols-2">
          {servicesPaymentMethods.map((method) => (
            <div class="rounded-[1.3rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3">
              <p class="text-sm font-semibold text-[var(--nm-fg)]">{method.icon} {method.name}</p>
              <p class="mt-1 text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">{method.note}</p>
            </div>
          ))}
        </div>
      </div>
      <p class="mt-6 whitespace-pre-line border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pt-4 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">
        {disclaimerLong}
      </p>
    </section>
  </section>

  <FloatingCTA
    primaryHref={floatingPrimaryHref}
    primaryLabel="להתחיל מנוי מרפסת"
    secondaryHref="#retainer-subscription"
    secondaryLabel="לקפוץ ישר לשלב 3"
  />

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      document.querySelectorAll("[data-service-cta]").forEach((btn) => {
        if (!(btn instanceof HTMLAnchorElement)) return;
        if (btn.dataset.nmNotifyBound === "1") return;
        btn.dataset.nmNotifyBound = "1";
        btn.addEventListener("click", () => {
          const serviceId = btn.dataset.serviceId ?? "";
          const serviceTitle = btn.dataset.serviceTitle ?? "";
          const flow = btn.dataset.flow ?? "";
          const formData = new FormData();
          formData.append("access_key", "94b32b6c-7590-4ac6-b8b4-1bc73dd2e5c8");
          formData.append("subject", `NeverMind - עניין ב: ${serviceTitle}`);
          formData.append("message", `שירות: ${serviceId}\nזרימה: ${flow}\nזמן: ${new Date().toISOString()}`);
          void fetch("https://api.web3forms.com/submit", { method: "POST", body: formData }).catch(() => {});
        });
      });
    });
  </script>
</Layout>





