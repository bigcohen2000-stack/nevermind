---
import Layout from "../layouts/Layout.astro";
import servicesConfig from "../config/services.json";
import ServiceCard from "../components/ServiceCard.astro";
import FloatingCTA from "../components/FloatingCTA.astro";

type Service = (typeof servicesConfig.services)[number];
type PaymentMethod = (typeof servicesConfig.payment_methods)[number];

const currency = servicesConfig.currency;
const taxLabel = servicesConfig.tax_label;
const paymentMethods = servicesConfig.payment_methods as PaymentMethod[];
const services = servicesConfig.services as Service[];
const serviceMap = new Map(services.map((service) => [service.id, service]));
const formatMoney = (value: number) => `${Math.round(value).toLocaleString("he-IL")} ${currency}`;
const grossPrice = (service: Service, multiplier = 1) =>
  Math.round(service.basePrice * multiplier * (1 + service.taxPercent / 100));
const vatAmount = (service: Service, multiplier = 1) =>
  Math.round(service.basePrice * multiplier * (service.taxPercent / 100));
const podcastView = serviceMap.get("podcast-view");
const learningGroup = serviceMap.get("learning-group");
const phoneCall = serviceMap.get("phone-20min");
const meeting = serviceMap.get("meeting-30min");
const terraceSubscription = serviceMap.get("terrace-subscription");
const documentation = serviceMap.get("memory-documentation");
const spotlightServices = [podcastView, learningGroup, phoneCall, terraceSubscription, documentation].filter(
  Boolean
) as Service[];
const buildWhatsAppHref = (service: Service, detail: string) => {
  const message = `היי, אני רוצה לקבוע ${service.title}. ${detail}`;
  return `${service.actionLink}?text=${encodeURIComponent(message)}`;
};
const floatingPrimaryHref = meeting
  ? buildWhatsAppHref(
      meeting,
      `אני רוצה לקבוע פגישה מהירה. אפשר להתחיל מ-30 דקות במחיר ${formatMoney(grossPrice(meeting))} כולל מע״מ.`
    )
  : "https://wa.me/972555634035";
---

<Layout
  title="שירותים ומחירים | השם לא משנה"
  description="עמוד שירותים חד, ברור ואינטראקטיבי לבחירת מסלול, משך מפגש ותוספים לפני מעבר לוואטסאפ."
>
  <section class="mx-auto max-w-7xl space-y-16 px-4 pb-20 text-[#1A1A1A]">
    <header class="max-w-4xl space-y-5 text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.26em] text-[#D42B2B]">Masterclass Services</p>
      <h1 class="text-[clamp(2.6rem,2rem+2.3vw,4.6rem)] font-semibold leading-[1.04]">שירותים ומחירים בלי הודעות הלוך ושוב</h1>
      <p class="max-w-3xl text-[clamp(1rem,0.95rem+0.3vw,1.2rem)] leading-8 text-[#1A1A1A]/72">
        כל מסלול כתוב נקי: מה זה, כמה זה עולה, ומה קורה אם אתה רוצה להעמיק. המחירים נשמרים בקובץ אחד,
        וכל לחיצה שולחת לוואטסאפ עם הקשר ברור מראש.
      </p>
    </header>

    <section class="grid gap-6 xl:grid-cols-2">
      {spotlightServices.map((service) => (
        <ServiceCard
          service={service}
          currency={currency}
          taxLabel={taxLabel}
          badge={service.id === "learning-group" ? "הכי מבוקש" : undefined}
          note={service.id === "learning-group" ? "נותרו 2 מקומות לסבב הקרוב." : undefined}
          ctaMessage={`המחיר הבסיסי הוא ${formatMoney(service.basePrice)} ${taxLabel}${service.id === "terrace-subscription" ? " לחודש" : ""}.`}
        />
      ))}

      {meeting && documentation && (
        <article
          id={meeting.id}
          data-service-card={meeting.id}
          class="rounded-[2rem] border border-[#1A1A1A]/10 bg-white/85 p-7 shadow-[0_24px_80px_rgba(26,26,26,0.06)] xl:col-span-2"
        >
          <div class="grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
            <div class="space-y-5 text-right">
              <div class="space-y-3">
                <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">Interactive Pricing</p>
                <h2 class="text-3xl font-semibold text-[#1A1A1A]">{meeting.title}</h2>
                <p class="text-base leading-8 text-[#1A1A1A]/70">{meeting.description}</p>
              </div>

              <label class="block space-y-4">
                <span class="text-sm font-semibold text-[#1A1A1A]">משך המפגש</span>
                <input
                  id="meeting-duration"
                  type="range"
                  min="30"
                  max="180"
                  step="30"
                  value="60"
                  class="h-2 w-full cursor-pointer appearance-none rounded-full bg-[#1A1A1A]/10 accent-[#D42B2B]"
                />
              </label>

              <div class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-5 py-4 text-right">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">משך נבחר</p>
                <p id="meeting-duration-label" class="mt-2 text-2xl font-semibold text-[#1A1A1A]">60 דקות</p>
                <p class="mt-2 text-sm leading-7 text-[#1A1A1A]/64">
                  המחיר מחושב לפי חצי שעה בסיסית של {formatMoney(meeting.basePrice)} לפני מע״מ.
                </p>
              </div>
            </div>

            <div class="space-y-5">
              <div class="rounded-[1.6rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">סה״כ משוער</p>
                <p id="meeting-total-gross" class="mt-3 text-4xl font-semibold text-[#1A1A1A]">
                  {formatMoney(grossPrice(meeting, 2))}
                </p>
                <p id="meeting-total-breakdown" class="mt-2 text-sm leading-7 text-[#1A1A1A]/64">
                  {formatMoney(meeting.basePrice * 2)} לפני מע״מ + {formatMoney(vatAmount(meeting, 2))} מע״מ
                </p>
              </div>

              <label class="block rounded-[1.6rem] border border-[#D42B2B]/14 bg-[#FFF4F3] p-5 text-right">
                <span class="flex items-center justify-between gap-4">
                  <span>
                    <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">Upsell חכם</span>
                    <span class="mt-2 block text-lg font-semibold text-[#1A1A1A]">הוסף {documentation.title}</span>
                    <span class="mt-2 block text-sm leading-7 text-[#1A1A1A]/70">{documentation.description}</span>
                  </span>
                  <input id="meeting-documentation-addon" type="checkbox" class="h-5 w-5 accent-[#D42B2B]" />
                </span>
                <span class="mt-4 block text-sm font-semibold text-[#1A1A1A]">
                  {formatMoney(documentation.basePrice)} לפני מע״מ או {formatMoney(grossPrice(documentation))} כולל מע״מ
                </span>
              </label>

              <a
                id="meeting-book-link"
                href={buildWhatsAppHref(meeting, `בחרתי 60 דקות במחיר ${formatMoney(grossPrice(meeting, 2))} כולל מע״מ.`)}
                target="_blank"
                rel="noreferrer"
                class="inline-flex w-full items-center justify-center rounded-full bg-[#D42B2B] px-5 py-4 text-sm font-semibold text-[#FAFAF8] transition hover:bg-[#b82424]"
              >
                לתיאום בוואטסאפ
              </a>
            </div>
          </div>
        </article>
      )}
    </section>

    <section class="rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 px-6 py-10 shadow-[0_24px_80px_rgba(26,26,26,0.05)]">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div class="space-y-3 text-right">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">Payment</p>
          <h2 class="text-2xl font-semibold text-[#1A1A1A]">תשלום, חשבונית וסגירה נקייה</h2>
          <p class="text-sm leading-7 text-[#1A1A1A]/68">
            כל המחירים במערכת נשמרים לפני מע״מ, והסכום הכולל מחושב עבורך אוטומטית כבר בתוך העמוד והוואטסאפ.
          </p>
        </div>
        <div class="flex flex-wrap justify-end gap-3 text-sm font-semibold text-[#1A1A1A]">
          {paymentMethods.map((method) => (
            <span class="rounded-full border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-2">
              {method.icon} {method.name}
            </span>
          ))}
        </div>
      </div>
    </section>
  </section>

  <FloatingCTA
    primaryHref={floatingPrimaryHref}
    primaryLabel="לתיאום מהיר בוואטסאפ"
    secondaryHref={meeting ? `#${meeting.id}` : "/services/"}
    secondaryLabel="לקפוץ לפגישה אישית"
  />

  <script is:inline define:vars={{ meeting, documentation, currency }}>
    document.addEventListener("astro:page-load", () => {
      const slider = document.getElementById("meeting-duration");
      const durationLabel = document.getElementById("meeting-duration-label");
      const totalLabel = document.getElementById("meeting-total-gross");
      const breakdownLabel = document.getElementById("meeting-total-breakdown");
      const bookLink = document.getElementById("meeting-book-link");
      const documentationAddon = document.getElementById("meeting-documentation-addon");
      if (!(slider instanceof HTMLInputElement)) return;
      if (!(durationLabel instanceof HTMLElement)) return;
      if (!(totalLabel instanceof HTMLElement)) return;
      if (!(breakdownLabel instanceof HTMLElement)) return;
      if (!(bookLink instanceof HTMLAnchorElement)) return;
      if (!(documentationAddon instanceof HTMLInputElement)) return;
      if (!meeting) return;

      const highlightServiceCard = () => {
        const params = new URLSearchParams(window.location.search);
        const target = params.get("service") || window.location.hash.replace(/^#/, "");
        if (!target) return;
        const cards = document.querySelectorAll("[data-service-card]");
        cards.forEach((card) => {
          if (!(card instanceof HTMLElement)) return;
          const active = card.dataset.serviceCard === target;
          card.classList.toggle("ring-2", active);
          card.classList.toggle("ring-[#D42B2B]/35", active);
          card.classList.toggle("border-[#D42B2B]/30", active);
        });
      };

      const money = (value) => `${Math.round(Number(value)).toLocaleString("he-IL")} ${currency}`;
      const gross = (base) => Math.round(base * (1 + Number(meeting.taxPercent || 0) / 100));
      const documentationGross = documentation ? Math.round(Number(documentation.basePrice) * (1 + Number(documentation.taxPercent || 0) / 100)) : 0;

      const render = () => {
        const duration = Number(slider.value || 30);
        const units = duration / 30;
        const base = Number(meeting.basePrice || 0) * units;
        const addonBase = documentationAddon.checked && documentation ? Number(documentation.basePrice || 0) : 0;
        const subtotal = base + addonBase;
        const total = documentationAddon.checked ? gross(base) + documentationGross : gross(base);
        const notes = [];
        if (documentationAddon.checked && documentation) {
          notes.push(`כולל ${documentation.title}`);
        }

        durationLabel.textContent = `${duration} דקות`;
        totalLabel.textContent = money(total);
        breakdownLabel.textContent = `${money(subtotal)} לפני מע״מ, עם חישוב מס אוטומטי`;
        const detail = `בחרתי ${duration} דקות במחיר ${money(total)} כולל מע״מ${notes.length ? `, ${notes.join(", ")}` : ""}.`;
        bookLink.href = `${meeting.actionLink}?text=${encodeURIComponent(`היי, אני רוצה לקבוע ${meeting.title}. ${detail}`)}`;
      };

      slider.addEventListener("input", render);
      documentationAddon.addEventListener("change", render);
      highlightServiceCard();
      render();
    });
  </script>
</Layout>
