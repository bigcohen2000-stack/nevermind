---
import Layout from "../layouts/Layout.astro";
import { glossaryConcepts } from "../data/glossary";
import appConfig from "../config/appConfig.json";
import EngagementSections from "../components/EngagementSections.astro";
import {
  servicesHero,
  servicesContentGapMessage,
  servicesEngagementSections,
  flattenVisibleServices,
  resolveServiceAction,
  formatMoney,
} from "../lib/services";
import { ArchiveSearchFloatingInput } from "../components/ArchiveSearchFloatingInput";
import { DirectLink } from "../components/ui/DirectLink";
import Gatekeeper from "../components/Gatekeeper.astro";

const services = flattenVisibleServices();
const popularTags = glossaryConcepts.slice(0, 6).map((c) => ({
  label: c.title,
  searchQuery: (c.keywords && c.keywords[0]) || c.title,
}));
const waNumber = String(appConfig.contact.whatsAppNumber ?? "").replace(/\D/g, "");
---

<Layout
  title="מרחב גילוי | NeverMind"
  description="חיפוש בארכיון התכנים ודרכים להעמיק בשיחה, בלי אשף שלבים."
>
  <section class="mx-auto max-w-6xl space-y-12 px-4 py-16 text-[var(--nm-fg)] md:py-20">
    <header class="space-y-8 text-center">
      <h1 class="text-[clamp(2rem,1.5rem+2.2vw,3.5rem)] font-semibold leading-[1.08] tracking-tight">
        {servicesHero.title}
      </h1>
      <p class="mx-auto max-w-2xl text-[clamp(1rem,0.95rem+0.25vw,1.15rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        {servicesHero.subtitle}
      </p>

      <div class="mx-auto max-w-2xl space-y-3 text-right">
        <p class="text-[clamp(1rem,0.95rem+0.3vw,1.12rem)] font-semibold leading-7 text-[var(--nm-fg)]">
          יש משהו שמעסיק אותך? בוא נראה מה יש לנו בארכיון על זה.
        </p>
        <ArchiveSearchFloatingInput
          client:load
          id="discovery-search"
          label="למשל: בהירות, זוגיות, לחץ"
          className="shadow-[0_20px_50px_color-mix(in_srgb,var(--nm-fg)_5%,transparent)]"
        />
      </div>

      <div class="flex flex-wrap items-center justify-center gap-2">
        <span class="w-full text-center text-sm text-[color-mix(in_srgb,var(--nm-fg)_45%,var(--nm-bg))] sm:w-auto">נושאים מהגלוסר:</span>
        {
          popularTags.map(({ label, searchQuery }) => (
            <button
              type="button"
              data-discovery-tag={searchQuery}
              class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_90%,transparent)] px-3 py-1.5 text-sm font-semibold text-[var(--nm-accent)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] hover:bg-[var(--nm-surface-muted)]"
            >
              {label}
            </button>
          ))
        }
      </div>
    </header>

    <div id="discovery-results" class="grid grid-cols-1 gap-12 lg:grid-cols-2">
      <div class="space-y-6">
        <div class="border-b border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pb-3">
          <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-[color-mix(in_srgb,var(--nm-fg)_45%,var(--nm-bg))]">
            מהארכיון
          </h2>
        </div>
        <div
          id="discovery-idle"
          class="rounded-3xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_94%,transparent)] px-6 py-8 text-right"
        >
          <p class="text-lg font-semibold text-[var(--nm-fg)]">בחר נושא וקבל כיוון</p>
          <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
            כאן יופיעו תוצאות מהארכיון. אפשר להתחיל מהחיפוש למעלה או ללחוץ על אחת התגיות.
          </p>
        </div>
        <p id="discovery-archive-status" class="hidden text-sm text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]"></p>
        <div id="discovery-archive-list" class="space-y-3"></div>
      </div>
      <div
        id="discovery-gap"
        class="hidden rounded-3xl border-2 border-dashed border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_96%,transparent)] px-6 py-10 text-center"
      >
        <p id="discovery-gap-text" class="text-lg leading-8 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]"></p>
        <a
          id="discovery-gap-wa"
          href={`https://wa.me/${waNumber}`}
          class="mt-8 inline-flex min-h-[48px] items-center justify-center gap-2 rounded-full bg-[var(--nm-inverse)] px-8 py-3 text-sm font-semibold text-white transition hover:bg-[var(--nm-inverse-hover)]"
        >
          נדבר על זה בוואטסאפ
        </a>
      </div>
    </div>

    <div id="pricing" class="space-y-6">
      <div class="border-b border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pb-3">
        <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--nm-accent)]">
          רוצה לפרק את זה יחד?
        </h2>
        <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
          אלו הדרכים שבהן אנחנו יכולים לשבת על זה.
        </p>
      </div>
      <div class="grid gap-4">
        {
          services.map((service) => {
            const action = resolveServiceAction(service);
            const note = service.friendly_note?.trim() || service.subtitle || "";
            return (
              <div
                id={service.id}
                class="group rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 shadow-[0_12px_32px_color-mix(in_srgb,var(--nm-fg)_4%,transparent)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)]"
              >
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <h3 class="text-lg font-semibold text-[var(--nm-fg)]">{service.title}</h3>
                  <span class="text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">
                    {formatMoney(service.price_full)}
                  </span>
                </div>
                {note ? (
                  <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">{note}</p>
                ) : null}
                <a
                  href={action.href}
                  {...(action.external ? { target: "_blank", rel: "noreferrer" } : {})}
                  class="mt-5 inline-flex min-h-[44px] items-center gap-2 text-sm font-bold text-[var(--nm-accent)] underline-offset-4 transition group-hover:underline"
                >
                  {action.label}
                </a>
              </div>
            );
          })
        }
      </div>
      <Gatekeeper
        phone={appConfig.contact.whatsAppNumber}
        fallbackHref="/articles/"
        fallbackLabel="חזרה לארכיון"
      />
    </div>
  </section>

  <div class="mx-auto flex max-w-6xl justify-end px-4 pb-16" aria-label="פתיחת שיחה אחרי קריאה">
    <DirectLink
      client:load
      whatsAppNumber={appConfig.contact.whatsAppNumber}
      fallbackEmail={appConfig.contact.email}
    />
  </div>

  <script
    define:vars={{
      contentGapMessage: servicesContentGapMessage,
      waNumber,
    }}
  >
    import { runPagefindSearch } from "../lib/pagefind-client";

    const MIN_LEN = 2;
    const DEBOUNCE_MS = 320;
    const LIMIT = 6;

    function escapeHtml(text) {
      return String(text ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    function waHrefForTopic(topic) {
      const t = String(topic || "").trim() || "הנושא שחיפשתי";
      const body = `היי, חיפשתי באתר על ${t} ולא מצאתי, אשמח לדבר על זה.`;
      return `https://wa.me/${waNumber}?text=${encodeURIComponent(body)}`;
    }

    document.addEventListener("astro:page-load", () => {
      const input = document.getElementById("discovery-search");
      const resultsEl = document.getElementById("discovery-results");
      const gapEl = document.getElementById("discovery-gap");
      const gapText = document.getElementById("discovery-gap-text");
      const gapWa = document.getElementById("discovery-gap-wa");
      const listEl = document.getElementById("discovery-archive-list");
      const statusEl = document.getElementById("discovery-archive-status");
      const idleEl = document.getElementById("discovery-idle");

      if (
        !(input instanceof HTMLInputElement) ||
        !(resultsEl instanceof HTMLElement) ||
        !(gapEl instanceof HTMLElement) ||
        !(gapText instanceof HTMLElement) ||
        !(gapWa instanceof HTMLAnchorElement) ||
        !(listEl instanceof HTMLElement) ||
        !(statusEl instanceof HTMLElement) ||
        !(idleEl instanceof HTMLElement)
      ) {
        return;
      }

      let debounceTimer = 0;
      let requestId = 0;

      function showIdle() {
        idleEl.classList.remove("hidden");
        gapEl.classList.add("hidden");
        listEl.innerHTML = "";
        statusEl.classList.add("hidden");
        statusEl.textContent = "";
      }

      async function runQuery(raw) {
        const q = raw.trim();
        if (q.length < MIN_LEN) {
          showIdle();
          return;
        }

        const myId = ++requestId;
        idleEl.classList.add("hidden");
        gapEl.classList.add("hidden");
        statusEl.classList.remove("hidden");
        statusEl.textContent = "מחפשים בארכיון...";
        listEl.innerHTML = "";

        let rows = [];
        try {
          rows = await runPagefindSearch(q, LIMIT);
        } catch {
          rows = [];
        }

        if (myId !== requestId) return;

        statusEl.classList.add("hidden");
        statusEl.textContent = "";

        if (rows.length === 0) {
          gapEl.classList.remove("hidden");
          gapText.textContent = contentGapMessage;
          gapWa.href = waHrefForTopic(q);
          listEl.innerHTML = "";
          return;
        }

        gapEl.classList.add("hidden");
        listEl.innerHTML = rows
          .map(
            (r) => `<a href="${escapeHtml(r.url)}" class="block rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_88%,transparent)] px-4 py-4 text-right transition hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] hover:bg-[var(--nm-surface-muted)]"><p class="font-semibold text-[var(--nm-fg)]">${escapeHtml(r.title)}</p><div class="mt-1 text-sm leading-6 text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]">${r.excerpt}</div></a>`
          )
          .join("");
      }

      function scheduleRun() {
        window.clearTimeout(debounceTimer);
        debounceTimer = window.setTimeout(() => runQuery(input.value), DEBOUNCE_MS);
      }

      input.addEventListener("input", scheduleRun);
      input.addEventListener("search", scheduleRun);

      document.querySelectorAll("[data-discovery-tag]").forEach((btn) => {
        btn.addEventListener("click", () => {
          if (!(btn instanceof HTMLElement)) return;
          const tag = btn.dataset.discoveryTag || "";
          input.value = tag;
          window.clearTimeout(debounceTimer);
          void runQuery(tag);
        });
      });

      const params = new URLSearchParams(window.location.search);
      const fromUrl = (params.get("topic") || params.get("q") || "").trim();
      if (fromUrl.length >= MIN_LEN) {
        input.value = fromUrl;
        window.clearTimeout(debounceTimer);
        void runQuery(fromUrl);
      } else {
        showIdle();
      }
    });
  </script>
</Layout>
