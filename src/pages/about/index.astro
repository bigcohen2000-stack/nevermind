---
import Layout from "../../layouts/Layout.astro";
import {
  aboutExtraMethodFaq,
  aboutMethodFaq,
  aboutPageFaqForSchema,
  aboutPracticalFaq,
} from "../../data/about-method-faq";
---

<Layout
  title="שיטת NEVERMIND | NeverMind"
  description="איך השיטה עובדת: לא עוד טכניקה — הסרת בלבול, איחוד מה שעובד, והמשך עד השורש. שאלות ותשובות מלאות על NeverMind."
  faqItems={aboutPageFaqForSchema}
>
  <div class="mx-auto max-w-6xl space-y-16 px-4 py-14 text-right text-[var(--nm-fg)] md:space-y-20">
    <header class="space-y-5">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--nm-accent)]">שיטת NEVERMIND</p>
      <h1 class="text-[clamp(2rem,1.4rem+2.2vw,3.4rem)] font-light leading-tight">כאן הכל נהיה פשוט</h1>
      <p class="max-w-3xl text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        דף אחד שמסביר את השיטה בלי רעש. קוראים. בודקים. מחליטים אם זה מתאים.
      </p>
    </header>

    <section aria-labelledby="method-core" class="space-y-6 rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white p-6 md:p-8">
      <h2 id="method-core" class="text-[clamp(1.35rem,1.15rem+0.6vw,1.85rem)] font-semibold leading-snug">
        מה NeverMind עושה בפועל
      </h2>
      <div class="space-y-5 text-[clamp(1rem,0.95rem+0.2vw,1.12rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
        <p>
          שיטת NeverMind <strong class="font-semibold text-[var(--nm-fg)]">לא מוסיפה עוד טכניקה</strong>
          — היא מסירה את כל מה שמבלבל אותך.
        </p>
        <p>
          היא מאחדת את מה שעובד בכל גישה אחרת, וממשיכה עד השורש. כאן תבין למה גישה שחסרה בה נקודה אחת כבר לא יכולה להיות
          הכי טובה בשבילך, ולמה NeverMind בנויה כרצף בלי חורים שמפילים באמצע.
          <strong class="font-semibold text-[var(--nm-fg)]">
            NeverMind היא השיטה היחידה שלא חסר בה שום חלק, ולכן היא עובדת תמיד
          </strong>
          כשאתה הולך איתה עד הסוף ולא עוצר באמצע.
        </p>
        <p class="border-r-4 border-[var(--nm-accent)] pr-4 text-[var(--nm-fg)]">
          כולם מחפשים שיטה נכונה. NeverMind מראה שאין שיטה אחת שסוגרת הכול — יש אמת אחת שמאחדת את כל מה ששם עבד באמת.
        </p>
      </div>
    </section>

    <section aria-labelledby="about-personal" class="space-y-4 rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 text-right">
      <h2 id="about-personal" class="text-[clamp(1.35rem,1.15rem+0.6vw,1.75rem)] font-semibold">
        מי עומד מאחורי המסלול
      </h2>
      <p class="text-sm leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_76%,var(--nm-bg))]">
        זה לא סיפור חיים ארוך. זה עיקרון: מרחב שבו אפשר לפרק את מה שמסתובב בראש בלי לשחק חכם. אם זה נשמע לך נכון, אפשר להמשיך דרך ארכיון או דרך שיחה ממוקדת.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="/library/"
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]"
        >
          לספרייה
        </a>
        <a
          href="/book/"
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
        >
          קביעת שיחה
        </a>
      </div>
    </section>

    <section aria-labelledby="process-map" class="space-y-7">
      <h2 id="process-map" class="text-[clamp(1.5rem,1.25rem+1vw,2rem)] font-light">איך זה עובד</h2>
      <div class="grid gap-4 md:grid-cols-5">
        <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white p-5">
          <h3 class="text-lg font-semibold">בלבול</h3>
          <p class="mt-2 text-sm leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">מרגישים שמשהו תקוע ולא מבינים למה.</p>
        </article>
        <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white p-5">
          <h3 class="text-lg font-semibold">בהירות</h3>
          <p class="mt-2 text-sm leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">מפסיקים את הרעש ורואים מה באמת קורה.</p>
        </article>
        <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white p-5">
          <h3 class="text-lg font-semibold">הבנה</h3>
          <p class="mt-2 text-sm leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">הכל נהיה פשוט. רואים את הסיפור שסיפרנו לעצמנו.</p>
        </article>
        <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white p-5">
          <h3 class="text-lg font-semibold">פעולה</h3>
          <p class="mt-2 text-sm leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">עושים את הצעד הנכון בלי מאמץ מיותר.</p>
        </article>
        <article class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white p-5">
          <h3 class="text-lg font-semibold">קשר אישי</h3>
          <p class="mt-2 text-sm leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">כשאתה רואה נכון, גם האנשים סביבך משתנים.</p>
        </article>
      </div>
    </section>

    <section aria-labelledby="daily-principle" class="space-y-4">
      <h2 id="daily-principle" class="text-[clamp(1.4rem,1.2rem+0.8vw,1.9rem)] font-light">משהו קטן להיום</h2>
      <article class="rounded-[1.8rem] border-2 border-[var(--nm-accent)] bg-white p-6">
        <p class="text-[clamp(1.15rem,1.05rem+0.3vw,1.35rem)] leading-9">אל תחפש להרגיש טוב יותר. תחפש לראות מה נכון.</p>
      </article>
    </section>

    <section aria-labelledby="reversal-question" class="space-y-5">
      <h2 id="reversal-question" class="text-[clamp(1.4rem,1.2rem+0.8vw,1.9rem)] font-light">שאלה שהופכת הכל</h2>
      <p id="reversal-question-text" class="max-w-3xl text-[clamp(1.5rem,1.2rem+1vw,2.2rem)] font-light leading-tight">
        מה אם הבעיה היא בכלל הפתרון?
      </p>
      <button
        id="next-reversal-question"
        type="button"
        class="inline-flex min-h-[46px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-7 py-2.5 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
      >
        תן לי שאלה אחרת
      </button>
    </section>

    <section id="nm-about-faq" aria-labelledby="faq-method-heading" class="scroll-mt-28 space-y-6">
      <div class="space-y-2">
        <h2 id="faq-method-heading" class="text-[clamp(1.5rem,1.25rem+1vw,2rem)] font-semibold">
          שאלות ותשובות על השיטה
        </h2>
        <p class="max-w-3xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">
          כל מה שביקשת לדעת לפני שמחליטים. חסר משהו?
          <a href="/contact/" class="font-semibold text-[var(--nm-accent)] underline-offset-2 hover:underline">יצירת קשר</a>
          .
        </p>
      </div>
      <div class="space-y-3">
        {
          aboutMethodFaq.map((item) => (
            <details class="group rounded-[1.25rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white p-4 open:bg-[var(--nm-bg-canvas)] md:p-5">
              <summary class="cursor-pointer list-none text-right text-base font-semibold text-[var(--nm-fg)] marker:content-none [&::-webkit-details-marker]:hidden">
                <span class="inline-flex w-full items-start justify-between gap-3">
                  <span class="min-w-0 flex-1 leading-snug">{item.question}</span>
                  <span
                    class="mt-0.5 shrink-0 text-[var(--nm-accent)] transition group-open:rotate-180"
                    aria-hidden="true"
                  >
                    ▼
                  </span>
                </span>
              </summary>
              <p class="mt-4 border-t border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pt-4 text-sm leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
                {item.answer}
              </p>
            </details>
          ))
        }
      </div>
    </section>

    <section aria-labelledby="faq-extra-heading" class="space-y-4">
      <h2 id="faq-extra-heading" class="text-[clamp(1.35rem,1.15rem+0.6vw,1.75rem)] font-semibold">עוד נקודות שעולות הרבה</h2>
      <div class="space-y-3">
        {
          aboutExtraMethodFaq.map((item) => (
            <details class="group rounded-[1.25rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white p-4 open:bg-[var(--nm-bg-canvas)] md:p-5">
              <summary class="cursor-pointer list-none text-right text-base font-semibold text-[var(--nm-fg)] marker:content-none [&::-webkit-details-marker]:hidden">
                <span class="inline-flex w-full items-start justify-between gap-3">
                  <span class="min-w-0 flex-1 leading-snug">{item.question}</span>
                  <span class="mt-0.5 shrink-0 text-[var(--nm-accent)] transition group-open:rotate-180" aria-hidden="true">
                    ▼
                  </span>
                </span>
              </summary>
              <p class="mt-4 border-t border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pt-4 text-sm leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
                {item.answer}
              </p>
            </details>
          ))
        }
      </div>
    </section>

    <section id="nm-about-faq-practical" aria-labelledby="faq-practical-heading" class="scroll-mt-28 space-y-4">
      <h2 id="faq-practical-heading" class="text-[clamp(1.35rem,1.15rem+0.6vw,1.75rem)] font-semibold">
        שאלות מעשיות (מסלול ופרטיות)
      </h2>
      <div class="space-y-3">
        {
          aboutPracticalFaq.map((item) => (
            <details class="group rounded-[1.25rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 open:bg-white md:p-5">
              <summary class="cursor-pointer list-none text-right text-base font-semibold text-[var(--nm-fg)] marker:content-none [&::-webkit-details-marker]:hidden">
                <span class="inline-flex w-full items-start justify-between gap-3">
                  <span class="min-w-0 flex-1 leading-snug">{item.question}</span>
                  <span class="mt-0.5 shrink-0 text-[var(--nm-accent)] transition group-open:rotate-180" aria-hidden="true">
                    ▼
                  </span>
                </span>
              </summary>
              <p class="mt-4 border-t border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pt-4 text-sm leading-[var(--line-height-ui)] text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
                {item.answer}
              </p>
            </details>
          ))
        }
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const questions = [
        "מה אם הבעיה היא בכלל הפתרון?",
        "מה אם אתה לא צריך להחליט עכשיו?",
        "מה יקרה אם תפסיק לנסות לתקן?",
        "מה הדבר הכי פשוט שאתה יכול לעשות ברגע זה?",
        "מה אם אתה כבר יודע את התשובה ומפחד להודות בה?",
        "מה אתה מרוויח מזה שזה נשאר תקוע?",
        "מה משתנה אם אתה מפסיק להילחם במה שכבר קרה?",
      ];
      let idx = 0;
      const textEl = document.getElementById("reversal-question-text");
      const btn = document.getElementById("next-reversal-question");
      if (!textEl || !btn) return;
      btn.addEventListener("click", () => {
        idx = (idx + 1) % questions.length;
        textEl.textContent = questions[idx];
      });
    })();
  </script>
</Layout>
