---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import VideoPlayer from "../../components/VideoPlayer.astro";
import MethodCard from "../../components/methodology/MethodCard.astro";
import MethodFaq from "../../components/methodology/MethodFaq.astro";
import MethodTextBlock from "../../components/methodology/MethodTextBlock.astro";
import {
  aboutExtraMethodFaq,
  aboutMethodFaq,
  aboutPracticalFaq,
  masterPhilosophyClosingQuestion,
  masterPhilosophyMetaDescription,
  masterPhilosophyParagraphs,
} from "../../data/methodology/content";
import {
  joinBenefits,
  afterJoinSteps,
  fitList,
  notHereList,
  premiumTags,
  preJoinFaq,
} from "../../data/methodology/metadata";
import { getCanonicalArticleHref, getCanonicalArticleSlug } from "../../lib/articles";

const joinHref = "/premium-access/";
const quietJoinHref = "/premium-access/";

const articleEntries = await getCollection("articles", ({ data }) => !data.draft);
const previewArticles = [...articleEntries]
  .sort((a, b) => {
    const aTime = Date.parse((a.data.updatedDate ?? a.data.pubDate).toISOString());
    const bTime = Date.parse((b.data.updatedDate ?? b.data.pubDate).toISOString());
    return bTime - aTime;
  })
  .slice(0, 4)
  .map((entry) => ({
    slug: getCanonicalArticleSlug(entry),
    href: getCanonicalArticleHref(entry),
    title: entry.data.title,
    excerpt: String(entry.data.description || "").trim(),
  }));

const faqForPage = [
  ...preJoinFaq,
  ...aboutMethodFaq,
  ...aboutExtraMethodFaq,
  ...aboutPracticalFaq,
];
---

<Layout
  title="מה זה NeverMind"
  description={masterPhilosophyMetaDescription}
  faqItems={faqForPage}
>
  <div class="mx-auto max-w-6xl space-y-16 px-4 py-14 text-right text-[var(--nm-fg)] md:space-y-20" role="main">
    <header class="about-hero-fade rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] bg-[var(--nm-bg-canvas)] px-6 py-20 text-center shadow-[0_20px_60px_rgba(26,26,26,0.04)] md:px-10 md:py-24" aria-labelledby="hero-heading">
      <div class="mx-auto max-w-4xl space-y-5">
        <p class="text-sm font-semibold tracking-[0.12em] text-[var(--nm-accent)]">מה זה NeverMind</p>
        <h1 id="hero-heading" aria-label="NeverMind שיטה שמפרידה בין עובדה פירוש ותגובה" class="text-[clamp(3rem,2.2rem+3vw,4rem)] font-[350] leading-[1.08] tracking-[-0.04em] text-[#1A1A1A]">
          NeverMind - דרך פשוטה שמפרידה בין עובדה, פירוש ותגובה, כדי שתראה את השקט שכבר יש בך.
          <span class="sr-only">שיטה</span>
        </h1>
        <p class="mx-auto max-w-3xl text-[clamp(1rem,0.96rem+0.3vw,1.18rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_74%,var(--nm-bg))]">
          מה הדבר שהכי קשה לך להפריד כרגע - העובדה, הפירוש או התגובה שלך?
        </p>
      </div>
    </header>

    <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-6 py-8 text-center shadow-[0_20px_60px_rgba(26,26,26,0.05)] md:px-10" aria-labelledby="join-heading">
      <div class="mx-auto max-w-3xl space-y-5">
        <h2 id="join-heading" class="text-[clamp(1.8rem,1.45rem+1vw,2.6rem)] font-semibold tracking-[-0.03em]">רוצה להצטרף</h2>
        <p class="text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          גישה לכל הסרטונים, התכנים המלאים, והקבוצה השקטה.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
          <a href={joinHref} class="inline-flex min-h-[52px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-8 py-3 text-base font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">
            בקשה להצטרף
          </a>
          <a href={quietJoinHref} class="inline-flex min-h-[52px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_14%,transparent)] px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
            הצטרפות שקטה
          </a>
        </div>
        <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]">
          אין הפתעות. אין מניפולציות. אין שיווק אגרסיבי. רק תוכן אמיתי.
        </p>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)]">
      <article class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 lg:p-8">
        <div class="space-y-4">
          <p class="text-sm font-semibold text-[var(--nm-accent)]">מה נפתח אחרי הצטרפות</p>
          <h2 class="text-[clamp(1.55rem,1.35rem+0.7vw,2.05rem)] font-semibold">מה מחכה לך בפנים</h2>
          <p class="max-w-3xl text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_74%,var(--nm-bg))]">
            זה לא רעיון כללי. זה מרחב מסודר שנפתח צעד אחרי צעד, בלי רעש ובלי עומס.
          </p>
        </div>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          {joinBenefits.map((item) => (
            <div class="rounded-[1.35rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-4 py-4 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_76%,var(--nm-bg))]">
              {item}
            </div>
          ))}
        </div>
      </article>

      <article class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 p-6 shadow-[0_20px_60px_rgba(26,26,26,0.05)] lg:p-8">
        <div class="space-y-4">
          <p class="text-sm font-semibold text-[var(--nm-accent)]">כדאי להתקין את האפליקציה</p>
          <h2 class="text-[clamp(1.45rem,1.3rem+0.6vw,1.95rem)] font-semibold">גישה מהירה, בלי דפדפן, בלי הסחות</h2>
          <p class="text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_74%,var(--nm-bg))]">
            זה עובד כמו אפליקציה רגילה. נכנסים מהר, חוזרים בדיוק לאיפה שהיית, ונשארים קרובים לתוכן.
          </p>
          <div class="flex flex-wrap justify-end gap-3 pt-1">
            <button id="about-install-app" type="button" class="inline-flex min-h-[48px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-6 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">
              התקנה
            </button>
            <a href="/me/" class="inline-flex min-h-[48px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_14%,transparent)] px-5 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
              מעבר לאזור האישי
            </a>
          </div>
          <p id="about-install-help" class="min-h-[1.75rem] text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]" aria-live="polite"></p>
        </div>
      </article>
    </section>

    <section class="grid gap-6 lg:grid-cols-2">
      <article class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 p-6 shadow-[0_20px_60px_rgba(26,26,26,0.05)] lg:p-8">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">בכל מאמר יש סרטון</p>
        <h2 class="mt-3 text-[clamp(1.45rem,1.3rem+0.6vw,1.95rem)] font-semibold">הסבר קצר, מדויק, שרואים בו את הדברים בזמן אמת</h2>
        <MethodTextBlock text="לא רק לקרוא. גם לראות, לשמוע, ולעקוב אחרי הדרך שבה הדברים נפתחים בפועל." icon="🎥" />
      </article>

      <article class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 lg:p-8">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">יש תכנים שלא יכולים להיות פומביים</p>
        <h2 class="mt-3 text-[clamp(1.45rem,1.3rem+0.6vw,1.95rem)] font-semibold">נושאים רגישים, עמוקים, או כאלה שלא מתאימים לרשת פתוחה</h2>
        <MethodTextBlock text="הם זמינים רק למנויים. לא כי צריך לעשות מזה סוד, אלא כי לא כל דבר שייך למרחב פתוח ורועש." icon="🔒" />
      </article>
    </section>

    <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 lg:p-8">
      <div class="space-y-4">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">בקרוב בפרימיום</p>
        <h2 class="text-[clamp(1.5rem,1.35rem+0.7vw,2rem)] font-semibold">יש כאן עולם שלם שנפתח בהדרגה</h2>
        <MethodTextBlock text="כאן רואים רק את הכיוון. בפנים נפתחים נושאים שלא מתאימים להצגה מלאה בחוץ." icon="🌟" />
      </div>
      <div class="mt-5 flex flex-wrap justify-end gap-3">
        {premiumTags.map((tag) => (
          <span class="inline-flex items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white/90 px-4 py-2 text-sm font-medium text-[var(--nm-fg)]">
            {tag}
          </span>
        ))}
      </div>
    </section>

    <section class="grid gap-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 p-6 shadow-[0_20px_60px_rgba(26,26,26,0.05)] lg:grid-cols-[minmax(0,1fr)_minmax(0,0.95fr)] lg:p-8">
      <div class="space-y-4">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">הקבוצה השקטה</p>
        <h2 class="text-[clamp(1.5rem,1.35rem+0.7vw,2rem)] font-semibold">מקום נקי, בלי רעש, בלי דיונים, בלי ויכוחים</h2>
        <p class="text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_74%,var(--nm-bg))]">
          רק תכנים, מחשבות, והעמקה. מקום שמאפשר להישאר קרוב בלי להיבלע בעודף דעות.
        </p>
        <p class="text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_74%,var(--nm-bg))]">
          יש כאן גם סיבה פשוטה למה יש מנוי: כדי לאפשר יצירה שקטה, עצמאית, בלי פרסומות, בלי רעש, ובלי תלות בגופים חיצוניים.
        </p>
      </div>
      <div class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-5">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">אחרי ההצטרפות</p>
        <ol class="mt-4 space-y-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
          {afterJoinSteps.map((step, index) => (
            <li class="flex items-start justify-end gap-3">
              <span class="min-w-0 flex-1">{step}</span>
              <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[color-mix(in_srgb,var(--nm-accent)_10%,white)] text-xs font-semibold text-[var(--nm-accent)]">{index + 1}</span>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="space-y-4 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 lg:p-8" aria-labelledby="about-story-heading">
      <h2 id="about-story-heading" class="text-sm font-semibold text-[var(--nm-accent)]">
        מה קורה בפנים כשבודקים באמת
      </h2>
      <div class="max-w-3xl space-y-4 text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
        {masterPhilosophyParagraphs.map((para) => (
          <p>{para}</p>
        ))}
        <p class="font-medium text-[var(--nm-fg)]">{masterPhilosophyClosingQuestion}</p>
      </div>
    </section>

    <section class="grid gap-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 p-6 shadow-[0_20px_60px_rgba(26,26,26,0.05)] lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)] lg:p-8">
      <div class="space-y-4">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">איך זה נראה בפועל</p>
        <h2 class="text-[clamp(1.5rem,1.3rem+0.8vw,2rem)] font-semibold">שלושה חלקים פשוטים: עובדה, פירוש, תגובה</h2>
        <p class="text-[clamp(1rem,0.96rem+0.2vw,1.1rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
          מה קרה באמת, מה סיפרת לעצמך על זה, ואיך זה הזיז אותך מבפנים. כשמפרידים ביניהם, נהיה קל יותר לראות מה אמיתי ומה רק הרגל ישן.
        </p>
      </div>

      <div class="grid gap-3">
        <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4">
          <h3 class="text-lg font-semibold">עובדה</h3>
          <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">מה קרה, בלי תוספת של משמעויות.</p>
        </article>
        <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4">
          <h3 class="text-lg font-semibold">פירוש</h3>
          <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">מה אמרת לעצמך שזה אומר עליך, על אחרים, או על העתיד.</p>
        </article>
        <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4">
          <h3 class="text-lg font-semibold">תגובה</h3>
          <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">מה הגוף והלב עשו אחרי שהפירוש נתפס כאמת.</p>
        </article>
      </div>
      <p class="col-span-full text-[clamp(1rem,0.96rem+0.2vw,1.1rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] lg:col-span-2">
        מה מבין השלושה הכי קשה לך לראות כרגע בלי להתערבב בו?
      </p>
    </section>

    <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 lg:p-8">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1fr)]">
        <figure class="mx-auto w-full max-w-sm overflow-hidden rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] shadow-[0_18px_48px_rgba(26,26,26,0.07)] lg:mx-0">
          <img
            src="/uploads/nevermind-yakir.webp"
            alt="האדם שמוביל את NeverMind"
            width={640}
            height={800}
            class="aspect-[4/5] w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <div class="space-y-4">
          <p class="text-sm font-semibold text-[var(--nm-accent)]">מאחורי האתר</p>
          <h2 class="text-[clamp(1.5rem,1.3rem+0.8vw,2rem)] font-semibold">השם לא משנה</h2>
          <MethodTextBlock text="התוכן כאן נשען על אותו קו בדיקה שמופיע גם בשיחות: לראות מה באמת קורה בפנים בלי לקשט אותו." icon="🔍" />
          <MethodTextBlock text="אם משהו כאן נוגע בנקודה אמיתית, אפשר להמשיך דרך הספרייה, דרך בקשה להצטרפות, או דרך שיחה קצרה." icon="📞" />
          <div class="flex flex-wrap justify-end gap-3 pt-2">
            <a href="/library/" class="inline-flex min-h-[44px] items-center rounded-full bg-[var(--nm-inverse)] px-5 py-2.5 text-base font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">מעבר לספרייה</a>
            <a href={joinHref} class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-2.5 text-base font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">בקשה להצטרף</a>
          </div>
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-2">
      <MethodCard title="למי NeverMind מתאים" items={fitList} />
      <MethodCard title="מה לא תמצא כאן" items={notHereList} />
    </section>

    <section class="space-y-4">
      <h2 class="text-[clamp(1.45rem,1.25rem+0.7vw,1.9rem)] font-semibold">איך זה נראה בזמן אמת</h2>
      <VideoPlayer youtubeId="lPSE9xQaNHw" title="איך NeverMind נראה בזמן אמת" />
      <p class="max-w-3xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        זה המקום לראות איך רעיון הופך לבדיקה ממשית, בלי לעגל פינות ובלי להסתתר מאחורי מילים גדולות.
      </p>
    </section>

    <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 p-6 shadow-[0_20px_60px_rgba(26,26,26,0.05)] lg:p-8">
      <div class="space-y-4">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">טעימה מהתוכן</p>
        <h2 class="text-[clamp(1.45rem,1.3rem+0.7vw,2rem)] font-semibold">כמה מאמרים פתוחים שמראים את הכיוון</h2>
        <p class="max-w-3xl text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_74%,var(--nm-bg))]">
          אפשר להיכנס כבר עכשיו. אם תרצה להמשיך מעבר לזה, המשך הקריאה מחכה למנויים.
        </p>
      </div>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {previewArticles.map((article) => (
          <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-5">
            <h3 class="text-lg font-semibold text-[var(--nm-fg)]">{article.title}</h3>
            <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
              {article.excerpt || "הכיוון מתחיל כאן, וההמשך נפתח למנויים."}
            </p>
            <div class="mt-4 flex flex-wrap justify-end gap-3">
              <a href={`/articles/${article.slug}/`} class="text-sm font-semibold text-[var(--nm-accent)] underline underline-offset-4">לקריאה פתוחה</a>
              <span class="text-sm text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">המשך קריאה למנויים</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-6 lg:p-8">
      <div class="space-y-4">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">שאלות נפוצות לפני הצטרפות</p>
        <h2 class="text-[clamp(1.45rem,1.3rem+0.7vw,2rem)] font-semibold">כמה דברים שכדאי לדעת לפני שנכנסים</h2>
      </div>
      <MethodFaq faqs={preJoinFaq} class="mt-5" />
    </section>

    <section id="nm-about-faq" class="space-y-4">
      <div class="space-y-2">
        <h2 class="text-[clamp(1.45rem,1.25rem+0.7vw,1.9rem)] font-semibold">עוד שאלות שחוזרות על עצמן</h2>
        <p class="max-w-3xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">
          אם חסר משהו, אפשר לעבור ל<a href="/contact/" class="font-semibold text-[var(--nm-accent)] underline underline-offset-2 transition-colors hover:no-underline">יצירת קשר</a>.
        </p>
      </div>

      <MethodFaq faqs={[...aboutMethodFaq, ...aboutExtraMethodFaq, ...aboutPracticalFaq]} />
    </section>

    <section class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-6 py-8 text-center shadow-[0_20px_60px_rgba(26,26,26,0.05)] md:px-10">
      <div class="mx-auto max-w-3xl space-y-5">
        <h2 class="text-[clamp(1.8rem,1.45rem+1vw,2.5rem)] font-semibold tracking-[-0.03em]">אם זה מרגיש נכון, אפשר להיכנס בשקט</h2>
        <p class="text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          בקשה להצטרף פותחת גישה לכל הסרטונים, לתכנים המלאים, ולעולם שלא נראה מבחוץ.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
          <a href={joinHref} class="inline-flex min-h-[52px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-8 py-3 text-base font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">
            בקשה להצטרף
          </a>
          <a href={quietJoinHref} class="inline-flex min-h-[52px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_14%,transparent)] px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">
            הצטרפות שקטה
          </a>
        </div>
      </div>
    </section>
  </div>

  <style>
    .about-hero-fade {
      opacity: 0;
      transform: translateY(18px);
      animation: about-hero-fade-up 800ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    @keyframes about-hero-fade-up {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .about-hero-fade {
        opacity: 1;
        transform: none;
        animation: none;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const installButton = document.getElementById("about-install-app");
      const helpLine = document.getElementById("about-install-help");

      installButton?.addEventListener("click", () => {
        const nativeInstallButton = document.getElementById("nm-pwa-install-action");
        const nativeRoot = document.getElementById("nm-pwa-install-root");

        if (nativeInstallButton instanceof HTMLButtonElement && nativeRoot instanceof HTMLElement && !nativeRoot.classList.contains("hidden")) {
          nativeInstallButton.click();
          if (helpLine instanceof HTMLElement) {
            helpLine.textContent = "";
          }
          return;
        }

        if (helpLine instanceof HTMLElement) {
          helpLine.textContent = "אם כפתור ההתקנה לא נפתח, אפשר לשמור את האתר למסך הבית דרך תפריט הדפדפן.";
        }
      });
    })();
  </script>
</Layout>
