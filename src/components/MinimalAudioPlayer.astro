---
/**
 * נגן אודיו מינימלי: כפתורי נגן/השהה/סרגל התקדמות, ללא ספריית חיצונית.
 */
interface Props {
  src: string;
  title?: string;
}

const { src, title = "הקלטה" } = Astro.props;
const safeSrc = String(src ?? "").trim();
---

{
  safeSrc ? (
    <div class="nm-audio-player not-prose rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-4 text-right shadow-[0_8px_28px_rgba(15,23,42,0.05)]" dir="rtl">
      <p class="text-sm font-medium text-[var(--nm-fg)]">{title}</p>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        <audio
          class="nm-audio-player__el sr-only"
          preload="metadata"
          controlslist="nodownload"
          data-nm-audio-el
        >
          <source src={safeSrc} type="audio/mpeg" />
          <source src={safeSrc} type="audio/mp4" />
        </audio>
        <button
          type="button"
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-bg-canvas)] text-[var(--nm-fg)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]"
          data-nm-audio-toggle
          aria-label="נגן או השהה"
        >
          <span data-nm-audio-icon-play class="inline" aria-hidden="true">
            ▶
          </span>
          <span data-nm-audio-icon-pause class="hidden" aria-hidden="true">
            ❚❚
          </span>
        </button>
        <div class="relative h-2 min-w-[min(100%,12rem)] flex-1 rounded-full bg-[color-mix(in_srgb,var(--nm-fg)_10%,var(--nm-bg))]" data-nm-audio-bar-wrap>
          <div
            class="pointer-events-none absolute inset-y-0 start-0 rounded-full bg-[var(--nm-accent)] transition-[width] duration-150 ease-out"
            data-nm-audio-progress
            style="width: 0%"
          />
        </div>
        <span class="text-xs tabular-nums text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]" data-nm-audio-time>
          0:00 / 0:00
        </span>
      </div>
    </div>
  ) : null
}

<script>
  function formatTime(sec: number) {
    if (!Number.isFinite(sec) || sec < 0) return "0:00";
    const m = Math.floor(sec / 60);
    const s = Math.floor(sec % 60);
    return `${m}:${s.toString().padStart(2, "0")}`;
  }

  function bindAudioPlayer(root: Element) {
    if (!(root instanceof HTMLElement)) return;
    const audio = root.querySelector<HTMLAudioElement>("[data-nm-audio-el]");
    const btn = root.querySelector<HTMLButtonElement>("[data-nm-audio-toggle]");
    const progress = root.querySelector<HTMLElement>("[data-nm-audio-progress]");
    const timeEl = root.querySelector<HTMLElement>("[data-nm-audio-time]");
    const bar = root.querySelector<HTMLElement>("[data-nm-audio-bar-wrap]");
    const iconPlay = root.querySelector<HTMLElement>("[data-nm-audio-icon-play]");
    const iconPause = root.querySelector<HTMLElement>("[data-nm-audio-icon-pause]");
    if (!audio || !btn) return;
    const audioEl = audio;
    const btnEl = btn;
    if (btnEl.dataset.nmAudioBound === "1") return;
    btnEl.dataset.nmAudioBound = "1";

    function syncTime() {
      const d = audioEl.duration;
      const t = audioEl.currentTime;
      if (progress instanceof HTMLElement) {
        const pct = Number.isFinite(d) && d > 0 ? (t / d) * 100 : 0;
        progress.style.width = `${pct}%`;
      }
      if (timeEl) {
        timeEl.textContent = `${formatTime(t)} / ${Number.isFinite(d) ? formatTime(d) : "0:00"}`;
      }
    }

    function setPlaying(p: boolean) {
      if (iconPlay) iconPlay.classList.toggle("hidden", p);
      if (iconPause) iconPause.classList.toggle("hidden", !p);
      btnEl.setAttribute("aria-pressed", p ? "true" : "false");
    }

    btnEl.addEventListener("click", () => {
      if (audioEl.paused) {
        audioEl.play().catch(() => {});
      } else {
        audioEl.pause();
      }
    });

    audioEl.addEventListener("play", () => setPlaying(true));
    audioEl.addEventListener("pause", () => setPlaying(false));
    audioEl.addEventListener("timeupdate", syncTime);
    audioEl.addEventListener("loadedmetadata", syncTime);

    if (bar instanceof HTMLElement) {
      bar.addEventListener(
        "click",
        (e) => {
          const d = audioEl.duration;
          if (!Number.isFinite(d) || d <= 0) return;
          const rect = bar.getBoundingClientRect();
          const ratio = Math.min(1, Math.max(0, (e.clientX - rect.left) / rect.width));
          audioEl.currentTime = ratio * d;
        },
        { passive: true }
      );
    }

    setPlaying(!audioEl.paused);
    syncTime();
  }

  function initAudioPlayers() {
    document.querySelectorAll(".nm-audio-player").forEach(bindAudioPlayer);
  }

  initAudioPlayers();
  document.addEventListener("astro:page-load", initAudioPlayers);
</script>
