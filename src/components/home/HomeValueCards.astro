---
type Card = { title: string; body: string };

interface Props {
  cards: Card[];
}

const { cards } = Astro.props;
---

<section class="mx-auto max-w-6xl px-5 pb-20 sm:px-8 lg:px-12" aria-labelledby="home-values-heading">
  <h2 id="home-values-heading" class="sr-only">שלושה עקרונות</h2>
  <ul class="grid gap-6 md:grid-cols-3" role="list">
    {
      cards.map((card) => (
        <li>
          <article
            class="group flex h-full flex-col rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-7 shadow-[0_8px_32px_rgba(15,23,42,0.04)] transition-shadow duration-300 hover:shadow-[0_16px_48px_rgba(15,23,42,0.08)] motion-reduce:transition-none"
          >
            <h3 class="text-lg font-semibold text-[var(--nm-fg)]">{card.title}</h3>
            <p class="mt-3 flex-1 text-[var(--nm-text-body)] leading-relaxed text-[color-mix(in_srgb,var(--nm-fg)_76%,var(--nm-bg))]">
              {card.body}
            </p>
          </article>
        </li>
      ))
    }
  </ul>
</section>
