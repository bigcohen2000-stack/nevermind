---
/**
 * סימולציה ויזואלית קומפקטית של אמצעי תשלום (טקסט + צורה מינימלית).
 */
---

<div class="flex flex-wrap items-center justify-end gap-2 sm:gap-2.5" aria-label="אמצעי תשלום נפוצים">
  <span
    class="inline-flex h-9 min-w-[3.25rem] items-center justify-center rounded-lg border border-[color-mix(in_srgb,#1A1A1A_14%,transparent)] bg-white px-2 text-[0.65rem] font-extrabold tracking-tight text-[#1A1F71] shadow-sm"
    title="Visa"
  >
    VISA
  </span>
  <span
    class="inline-flex h-9 items-center justify-center gap-0.5 rounded-lg border border-[color-mix(in_srgb,#1A1A1A_14%,transparent)] bg-white px-2 shadow-sm"
    title="Mastercard"
    aria-hidden="true"
  >
    <span class="size-3.5 rounded-full bg-[#EB001B]"></span>
    <span class="-ms-2 size-3.5 rounded-full bg-[#F79E1B] opacity-95"></span>
  </span>
  <span
    class="inline-flex h-9 min-w-[2.75rem] items-center justify-center rounded-lg border border-transparent bg-[#00C853] px-2 text-xs font-bold tracking-tight text-white shadow-sm"
    title="Bit"
  >
    bit
  </span>
  <span
    class="inline-flex h-9 items-center justify-center rounded-lg border border-[color-mix(in_srgb,#1A1A1A_14%,transparent)] bg-black px-2.5 text-[0.65rem] font-semibold tracking-tight text-white shadow-sm"
    title="Apple Pay"
  >
    Pay
  </span>
  <span
    class="inline-flex h-9 min-w-[4rem] items-center justify-center rounded-lg border border-[color-mix(in_srgb,#1A1A1A_14%,transparent)] bg-white px-2 text-[0.6rem] font-bold leading-none text-[#003087] shadow-sm"
    title="PayPal"
  >
    PayPal
  </span>
</div>
