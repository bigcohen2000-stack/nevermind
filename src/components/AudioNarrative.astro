---
/**
 * נגן אודיו מקומי — תואם NeverMind, בלי תלות חיצונית.
 */
interface Props {
  src: string;
  title?: string;
}

const { src, title = "הקראת המאמר" } = Astro.props;
const labelId = `audio-narrative-${Math.random().toString(36).slice(2, 10)}`;
---

<div
  class="overflow-hidden rounded-2xl border border-[#1A1A1A]/10 bg-white/70 p-4 text-right shadow-sm backdrop-blur-md dark:border-white/10 dark:bg-neutral-900/60"
  dir="rtl"
>
  <p id={labelId} class="text-sm font-semibold text-[#1A1A1A] [letter-spacing:0] dark:text-[#FAFAF8]">
    {title}
  </p>
  <audio
    class="mt-3 w-full accent-[#1A1A1A] text-[#1A1A1A] dark:accent-[#FAFAF8]"
    controls
    src={src}
    aria-labelledby={labelId}
  >
    הדפדפן שלך לא תומך בהשמעת אודיו.
  </audio>
</div>
