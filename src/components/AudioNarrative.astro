---
/**
 * נגן אודיו מקומי - תואם NeverMind, בלי תלות חיצונית.
 */
interface Props {
  src: string;
  title?: string;
}

const { src, title = "הקראת המאמר" } = Astro.props;
const labelId = `audio-narrative-${Math.random().toString(36).slice(2, 10)}`;
---

<div
  class="overflow-hidden rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)]/85 p-4 text-right shadow-sm backdrop-blur-md"
  dir="rtl"
>
  <p id={labelId} class="text-sm font-semibold text-[var(--nm-fg)] [letter-spacing:0]">
    {title}
  </p>
  <audio
    class="mt-3 w-full accent-[var(--nm-accent)] text-[var(--nm-fg)]"
    controls
    src={src}
    aria-labelledby={labelId}
  >
    הדפדפן שלך לא תומך בהשמעת אודיו.
  </audio>
</div>
