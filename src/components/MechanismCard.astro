---
interface Props {
  title: string;
  body: string;
  icon?: "root" | "magnifier" | "track" | "opposite" | "link";
  href?: string;
}

const { title, body, icon = "root", href } = Astro.props as Props;

const iconMarkupByName = {
  root: `<path d="M12 4.5c0 1.8-1.5 3.3-3.3 3.3S5.4 6.3 5.4 4.5 6.9 1.2 8.7 1.2 12 2.7 12 4.5Zm7.2 3.4c0 1.8-1.5 3.3-3.3 3.3s-3.3-1.5-3.3-3.3 1.5-3.3 3.3-3.3 3.3 1.5 3.3 3.3ZM9.4 7.6v4.1c0 1.8-1.4 3.2-3.2 3.2H4.8M15.9 11.1v4.1c0 1.8-1.4 3.2-3.2 3.2h-1.4M8.7 18.4v4.4"/>`,
  magnifier: `<circle cx="10.2" cy="10.2" r="5.8"/><path d="m14.6 14.6 5 5"/>`,
  track: `<path d="M4 17.5h4.6l2.3-6.2 2.3 3 2.1-5.8L20 17.5"/><path d="M4 6.5h5.5"/><path d="M4 10.5h3.3"/>`,
  opposite: `<path d="M7 7h10"/><path d="m13 3 4 4-4 4"/><path d="M17 17H7"/><path d="m11 13-4 4 4 4"/>`,
  link: `<path d="M9.5 14.5 7.4 16.6a3 3 0 1 1-4.2-4.2l3.5-3.5a3 3 0 0 1 4.2 0"/><path d="m14.5 9.5 2.1-2.1a3 3 0 1 1 4.2 4.2l-3.5 3.5a3 3 0 0 1-4.2 0"/><path d="m8.7 15.3 6.6-6.6"/>`,
} as const;

const iconMarkup = iconMarkupByName[icon] ?? iconMarkupByName.root;
---

{
  href ? (
    <a class="nm-mechanism-card" href={href} dir="rtl">
      <span class="nm-mechanism-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={iconMarkup} />
      </span>
      <span class="nm-mechanism-card__copy">
        <span class="nm-mechanism-card__title">{title}</span>
        <span class="nm-mechanism-card__body">{body}</span>
      </span>
    </a>
  ) : (
    <section class="nm-mechanism-card" dir="rtl">
      <span class="nm-mechanism-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={iconMarkup} />
      </span>
      <span class="nm-mechanism-card__copy">
        <span class="nm-mechanism-card__title">{title}</span>
        <span class="nm-mechanism-card__body">{body}</span>
      </span>
    </section>
  )
}

<style>
  .nm-mechanism-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.95rem;
    align-items: start;
    border: 1px solid color-mix(in srgb, var(--nm-fg) 10%, transparent);
    border-radius: 1.3rem;
    background: color-mix(in srgb, white 78%, var(--nm-bg));
    box-shadow: 0 16px 36px color-mix(in srgb, var(--nm-fg) 6%, transparent);
    padding-inline: 1rem;
    padding-block: 1rem;
    text-align: right;
    text-decoration: none;
    color: inherit;
  }

  .nm-mechanism-card__icon {
    display: grid;
    place-items: center;
    inline-size: 2.65rem;
    block-size: 2.65rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--nm-accent) 12%, white);
    color: color-mix(in srgb, var(--nm-accent) 74%, var(--nm-fg));
  }

  .nm-mechanism-card__icon svg {
    inline-size: 1.28rem;
    block-size: 1.28rem;
  }

  .nm-mechanism-card__copy {
    display: grid;
    gap: 0.28rem;
    min-inline-size: 0;
  }

  .nm-mechanism-card__title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.45;
    color: var(--nm-fg);
  }

  .nm-mechanism-card__body {
    font-size: 0.98rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--nm-fg) 82%, var(--nm-bg));
  }

  a.nm-mechanism-card:hover {
    background: color-mix(in srgb, white 90%, var(--nm-tint));
    transform: translateY(-1px);
  }

  @media (max-width: 40rem) {
    .nm-mechanism-card {
      padding-inline: 0.9rem;
      padding-block: 0.9rem;
    }
  }
</style>
