---
import type { EngagementSectionsMap } from "../lib/services";

interface Props {
  sections: EngagementSectionsMap;
}

const { sections } = Astro.props;
const cards: { key: "studio" | "talk" | "archive"; data: EngagementSectionsMap["studio"] }[] = [
  { key: "studio", data: sections.studio },
  { key: "talk", data: sections.talk },
  { key: "archive", data: sections.archive },
];
---

<section
  class="mx-auto max-w-7xl space-y-8 border-t border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-5 py-16 sm:px-8 lg:px-12"
  aria-label="ארבע דרכי המשך"
  dir="rtl"
>
  <div class="grid gap-6 md:grid-cols-3">
    {
      cards.map(({ key, data }) => (
        <article
          class:list={[
            "flex flex-col rounded-[1.75rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-6 text-right shadow-[0_18px_48px_rgba(26,26,26,0.05)]",
            key === "studio" && "studio-section",
            key === "talk" && "talk-section",
            key === "archive" && "archive-section",
          ]}
          data-section={key}
        >
          <h2 class="text-lg font-semibold text-[var(--nm-fg)]">{data.title}</h2>
          <p class="body-text mt-3 flex-1 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">{data.body}</p>
          <a
            href={data.ctaHref}
            class="mt-5 inline-flex min-h-[44px] w-full items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_24%,transparent)] hover:bg-[var(--nm-tint)]"
          >
            {data.ctaLabel}
          </a>
        </article>
      ))
    }
  </div>
</section>
