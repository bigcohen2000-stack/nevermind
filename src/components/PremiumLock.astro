---
import appConfig from "../config/appConfig.json";

interface Props {
  title?: string;
  description?: string;
  buttonLabel?: string;
  whatsappMessage?: string;
}

const {
  title = "נהנית משני מאמרי המתנה שלך?",
  description = "כדי להמשיך לקרוא תכני פרימיום של NeverMind שלח לי הודעה אישית בוואטסאפ.",
  buttonLabel = "לפתוח וואטסאפ",
  whatsappMessage = "היי, קראתי את המאמר ואני רוצה להמשיך לתוכן הפרימיום של NeverMind."
} = Astro.props;

const whatsappHref = `https://wa.me/${appConfig.contact.whatsAppNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<section data-premium-lock class="nm-premium-lock not-prose my-10 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/94 p-6 text-right shadow-[0_24px_70px_rgba(26,26,26,0.08)]">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">Premium</p>
  <h2 class="mt-3 text-[clamp(1.4rem,1.1rem+0.8vw,1.9rem)] font-semibold text-[#1A1A1A]">{title}</h2>
  <p class="mt-3 text-[1rem] leading-8 text-[#1A1A1A]/70">{description}</p>
  <div class="mt-5 flex justify-end">
    <a
      href={whatsappHref}
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center rounded-full bg-[#D42B2B] px-5 py-3 text-sm font-semibold text-[#FAFAF8] transition hover:bg-[#b82424]"
    >
      {buttonLabel}
    </a>
  </div>
</section>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const locks = Array.from(document.querySelectorAll("[data-premium-lock]"));
    locks.forEach((lock) => {
      if (!(lock instanceof HTMLElement)) return;
      if (lock.dataset.premiumLockInitialized === "true") return;

      const parent = lock.parentElement;
      if (!(parent instanceof HTMLElement)) return;

      const hiddenNodes = [];
      let sibling = lock.nextElementSibling;
      while (sibling) {
        const next = sibling.nextElementSibling;
        hiddenNodes.push(sibling);
        sibling = next;
      }

      if (hiddenNodes.length === 0) {
        lock.dataset.premiumLockInitialized = "true";
        return;
      }

      const previewShell = document.createElement("section");
      previewShell.className = "nm-premium-lock__preview mt-4 overflow-hidden rounded-[2rem] border border-[#1A1A1A]/10 bg-[#FAFAF8]";

      const inner = document.createElement("div");
      inner.className = "nm-premium-lock__preview-inner max-h-64 overflow-hidden px-6 py-5";
      hiddenNodes.forEach((node) => inner.appendChild(node));

      const fade = document.createElement("div");
      fade.className = "nm-premium-lock__fade h-24 bg-gradient-to-t from-[#FAFAF8] to-transparent";

      previewShell.appendChild(inner);
      previewShell.appendChild(fade);
      lock.insertAdjacentElement("afterend", previewShell);
      lock.dataset.premiumLockInitialized = "true";
    });
  });
</script>

<style>
  .nm-premium-lock__preview-inner {
    filter: blur(10px);
    opacity: 0.72;
    pointer-events: none;
    user-select: none;
  }
</style>
