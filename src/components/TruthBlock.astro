---
/**
 * בלוק היפוך: microdata Answer (או Question + acceptedAnswer), העתקה, פעימה בכניסה למסך.
 */
interface Props {
  label?: string;
  /** כשמוגדר, נוספת מעטפת Question; ה־aside הוא acceptedAnswer (מבנה המלצת עשירות) */
  questionForSchema?: string;
  /** כשה־slot ריק, מוצג טקסט זה בתוך itemprop="text" (למשל מ־originalInsight בפרונט־מאטר) */
  originalInsightFallback?: string;
}

const { label, questionForSchema, originalInsightFallback } = Astro.props;
const qaName = typeof questionForSchema === "string" ? questionForSchema.trim() : "";
const useQuestionShell = qaName.length > 0;
const fallbackText =
  typeof originalInsightFallback === "string" ? originalInsightFallback.trim() : "";
const slotHtml = await Astro.slots.render("default");
const textOnly = slotHtml.replace(/<[^>]*>/g, "").replace(/&nbsp;/g, " ").trim();
const slotEmpty = textOnly.length === 0;
const showInsightFallback = slotEmpty && fallbackText.length > 0;

const asideClass =
  "truth-block-aside relative rounded-lg border border-[#1a1a1a] border-r-[3px] border-r-[#D42B2B] bg-[#FAFAF8] px-4 pb-4 pt-12 text-right shadow-sm sm:px-5 sm:pb-5 sm:pt-12";

const copyBtnClass =
  "group absolute top-2.5 start-2.5 z-10 inline-flex items-center gap-1.5 rounded-full border-2 border-[#D42B2B] bg-white px-3 py-1.5 text-[0.72rem] font-bold tracking-tight text-[#1a1a1a] shadow-sm transition hover:bg-[#D42B2B] hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-1 focus-visible:outline-[#D42B2B]";
---

<div class="relative my-8" data-truth-block>
  {
    useQuestionShell ? (
      <div itemscope itemtype="https://schema.org/Question">
        <span class="sr-only" itemprop="name">
          {qaName}
        </span>
        <aside itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer" class:list={[asideClass]} dir="rtl">
          <button type="button" data-truth-copy-btn class:list={[copyBtnClass]} aria-label="העתק לחיים את התובנה מהבלוק">
            <svg class="size-3.5 shrink-0 opacity-80 group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <span data-truth-copy-label>העתק לחיים</span>
          </button>
          {label ? (
            <p class="mb-2 text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-[#D42B2B]">{label}</p>
          ) : null}
          <div
            itemprop="text"
            class="text-[0.95rem] font-medium leading-[1.75] text-[#1a1a1a] [&_p]:m-0 [&_p+p]:mt-2"
          >
            {showInsightFallback ? <p class="m-0">{fallbackText}</p> : <Fragment set:html={slotHtml} />}
          </div>
        </aside>
      </div>
    ) : (
      <aside itemscope itemtype="https://schema.org/Answer" class:list={[asideClass]} dir="rtl">
        <button type="button" data-truth-copy-btn class:list={[copyBtnClass]} aria-label="העתק לחיים את התובנה מהבלוק">
          <svg class="size-3.5 shrink-0 opacity-80 group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          <span data-truth-copy-label>העתק לחיים</span>
        </button>
        {label ? (
          <p class="mb-2 text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-[#D42B2B]">{label}</p>
        ) : null}
        <div
          itemprop="text"
          class="text-[0.95rem] font-medium leading-[1.75] text-[#1a1a1a] [&_p]:m-0 [&_p+p]:mt-2"
        >
          {showInsightFallback ? <p class="m-0">{fallbackText}</p> : <Fragment set:html={slotHtml} />}
        </div>
      </aside>
    )
  }
</div>

<style is:global>
  @keyframes nm-truth-pulse {
    0% {
      transform: scale(1);
    }
    40% {
      transform: scale(1.02);
    }
    100% {
      transform: scale(1);
    }
  }

  .truth-block-aside.nm-truth-pulse {
    animation: nm-truth-pulse 0.65s ease-out 1;
    transform-origin: center center;
  }
</style>

<script>
  function initTruthBlocks() {
    document.querySelectorAll<HTMLElement>("[data-truth-block]").forEach((root) => {
      if (root.dataset.truthInit === "true") return;
      root.dataset.truthInit = "true";

      const aside = root.querySelector<HTMLElement>(".truth-block-aside");
      const btn = root.querySelector<HTMLButtonElement>("[data-truth-copy-btn]");
      const textEl = root.querySelector<HTMLElement>('[itemprop="text"]');

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && aside) {
              aside.classList.add("nm-truth-pulse");
              observer.disconnect();
            }
          });
        },
        { threshold: 0.22, rootMargin: "0px 0px -8% 0px" }
      );
      if (aside) observer.observe(aside);

      btn?.addEventListener("click", async () => {
        const t = textEl?.innerText?.trim() ?? "";
        if (!t) return;
        const labelEl = btn.querySelector<HTMLElement>("[data-truth-copy-label]");
        const prevLabel = labelEl?.textContent ?? "";
        try {
          await navigator.clipboard.writeText(t);
          if (labelEl) labelEl.textContent = "הועתק";
          window.setTimeout(() => {
            if (labelEl && prevLabel) labelEl.textContent = prevLabel;
          }, 1800);
        } catch {
          window.prompt("העתק טקסט", t);
        }
      });
    });
  }

  initTruthBlocks();
  document.addEventListener("astro:page-load", initTruthBlocks);
</script>
