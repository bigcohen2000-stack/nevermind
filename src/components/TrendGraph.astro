---
/**
 * Lightweight trend bars — pure CSS (Tailwind + scoped keyframes).
 * Data: src/data/trends.json  [{ "label": string, "value": number 0–100 }]
 */
import trendsRaw from "../data/trends.json";

type TrendItem = { label: string; value: number };

const trends = trendsRaw as TrendItem[];
const clamped = trends.map((t) => ({
  label: t.label,
  value: Math.min(100, Math.max(0, Number(t.value) || 0)),
}));
const maxValue = Math.max(0, ...clamped.map((t) => t.value));
let assignedHot = false;
const items = clamped.map((t) => {
  const isHot = !assignedHot && t.value === maxValue && maxValue > 0;
  if (isHot) assignedHot = true;
  return { ...t, isHot };
});

const { title = "מגמות בקהילה", subtitle = "לפי שאלות ופניות אחרונות (אינדיקטיבי)" } = Astro.props;
---

<section
  class="rounded-[1.75rem] border border-[color-mix(in_srgb,var(--nm-fg-secondary)_14%,transparent)] bg-[var(--nm-bg-canvas)] p-6 text-right shadow-sm sm:p-8"
  dir="rtl"
  aria-labelledby="trend-graph-heading"
>
  <header class="mb-6 space-y-1">
    <h2 id="trend-graph-heading" class="text-lg font-semibold text-[var(--nm-fg-secondary)] sm:text-xl">
      {title}
    </h2>
    <p class="text-sm text-[color-mix(in_srgb,var(--nm-fg-secondary)_70%,var(--nm-bg))]">{subtitle}</p>
  </header>

  <ul class="flex flex-col gap-5" role="list">
    {
      items.map((item, index) => (
        <li class="grid gap-2">
          <div class="flex items-baseline justify-between gap-3 text-sm">
            <span
              class:list={[
                "font-medium text-[var(--nm-fg-secondary)]",
                item.isHot && "font-semibold text-[var(--nm-accent)]",
              ]}
            >
              {item.label}
              {item.isHot && (
                <span class="me-1.5 inline-block rounded border border-[color-mix(in_srgb,var(--nm-accent)_25%,transparent)] bg-[color-mix(in_srgb,var(--nm-accent)_8%,var(--nm-bg-canvas))] px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-[var(--nm-accent)]">
                  חם
                </span>
              )}
            </span>
            <span
              class:list={[
                "tabular-nums text-[var(--nm-fg-secondary)]/75",
                item.isHot && "font-semibold text-[var(--nm-accent)]",
              ]}
            >
              {item.value}%
            </span>
          </div>
          <div
            class="h-[2px] w-full overflow-hidden rounded-full bg-[color-mix(in_srgb,var(--nm-fg)_12%,var(--nm-bg-canvas))]"
            aria-hidden="true"
          >
            <div
              class:list={[
                "trend-bar-fill h-[2px] rounded-full",
                item.isHot ? "bg-[var(--nm-accent)]" : "bg-[color-mix(in_srgb,var(--nm-fg)_45%,var(--nm-bg-canvas))]",
              ]}
              style={`width: ${item.value}%; animation-delay: ${index * 75}ms;`}
            />
          </div>
        </li>
      ))
    }
  </ul>
</section>

<style>
  @keyframes trend-bar-scale-x {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }

  .trend-bar-fill {
    transform-origin: right center;
    transform: scaleX(0);
    animation: trend-bar-scale-x 0.75s ease-out forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .trend-bar-fill {
      animation: none;
      transform: scaleX(1);
    }
  }
</style>
