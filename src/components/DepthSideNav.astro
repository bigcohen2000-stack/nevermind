---
type DepthKey = "beginner" | "advanced" | "deep";

interface DepthItem {
  key: DepthKey;
  label: string;
  href?: string;
  tone: string;
}

interface Props {
  currentKey: DepthKey;
  items: DepthItem[];
}

const { currentKey, items } = Astro.props as Props;
---

<section class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-5 shadow-[0_18px_60px_rgba(26,26,26,0.06)]" aria-label="ניווט לפי רמות עומק">
  <div class="space-y-2 text-right">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">רמות עומק</p>
    <h2 class="text-[1.2rem] font-semibold text-[var(--nm-fg)]">בחר שכבה</h2>
  </div>

  <nav class="mt-4 space-y-2 text-right" aria-label="ניווט עומק">
    {items.map((item) => {
      const active = item.key === currentKey;
      const shared = "flex items-center justify-between gap-3 rounded-2xl px-4 py-3 transition hover:bg-white";
      const activeClass = `${item.tone}`;
      const inactiveClass = "bg-white/70 border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)]";
      const className = `${shared} ${active ? activeClass : inactiveClass}`;

      return item.href ? (
        <a href={item.href} class={className} aria-current={active ? "page" : undefined}>
          <span class="font-semibold">{item.label}</span>
          <span class="text-sm font-semibold text-[var(--nm-accent)]" aria-hidden="true">
            {active ? "כאן" : "→"}
          </span>
        </a>
      ) : (
        <div class={className} aria-current={active ? "page" : undefined}>
          <span class="font-semibold">{item.label}</span>
          <span class="text-sm font-semibold text-[var(--nm-accent)]" aria-hidden="true">
            כאן
          </span>
        </div>
      );
    })}
  </nav>
</section>

