---
interface Props {
  title: string;
  items: string[];
  class?: string;
}

const { title, items, class: className = "" } = Astro.props;
---

<div class={`rounded-[var(--nm-radius-lg)] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 p-6 shadow-[var(--nm-shadow-md)] ${className}`}>
  <h3 class="text-[clamp(1.45rem,1.3rem+0.6vw,1.95rem)] font-semibold">{title}</h3>
  <ul class="mt-4 space-y-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
    {items.map((item) => (
      <li class="rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3">{item}</li>
    ))}
  </ul>
</div>