---
interface Props {
  title?: string;
  intro?: string;
  items?: string[];
  closing?: string;
}

const {
  title = "למי זה לא מתאים",
  intro = "הבלוק הזה לא נועד להרחיק. הוא נועד לחסוך לך כניסה למסלול שלא באמת מתאים למה שאתה צריך עכשיו.",
  items = [
    "למי שמחפש מישהו שירגיע אותו בלי לגעת במבנה החשיבה עצמו.",
    "למי שרוצה תשובה נעימה יותר מהאמת שהוא כבר רואה אבל לא רוצה לפגוש.",
    "למי שמעדיף להישאר בשלב איסוף המידע ולא מוכן עדיין לבחור כיוון ברור.",
  ],
  closing = "אם אחד מהסעיפים האלה פוגש אותך, עדיף לעצור כאן ולא לדחוף בכוח. לפעמים הצעד הנכון הוא עוד לא ייעוץ, אלא מוכנות לפגוש עובדה בלי לברוח לפירוש.",
} = Astro.props;
---

<section class="not-prose rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/84 px-6 py-8 text-right text-[var(--nm-fg)] shadow-[0_18px_60px_rgba(26,26,26,0.05)] md:px-10">
  <div class="space-y-3">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">Reverse CTA</p>
    <h2 class="text-[clamp(1.8rem,1.45rem+0.9vw,2.5rem)] font-semibold leading-[1.1]">{title}</h2>
    <p class="max-w-3xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">{intro}</p>
  </div>

  <div class="mt-6 grid gap-4 md:grid-cols-3">
    {items.map((item, index) => (
      <article class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">0{index + 1}</p>
        <p class="mt-3 text-sm leading-7 text-[var(--nm-fg)]/74">{item}</p>
      </article>
    ))}
  </div>

  <p class="mt-6 border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pt-4 text-sm leading-7 text-[var(--nm-fg)]/62">{closing}</p>
</section>
