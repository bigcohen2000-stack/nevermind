---
interface Props {
  claim?: string;
  title?: string;
}

const { claim = "צריך ביטחון עצמי כדי להצליח", title = "הפרכה" } = Astro.props as Props;
---

<aside
  class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-accent)_20%,transparent)] bg-[#FFF7F6] p-[clamp(1.25rem,2vw,2rem)] shadow-[0_18px_45px_rgba(26,26,26,0.05)]"
  role="note"
  aria-label={title}
>
  <p class="text-[clamp(0.8rem,0.76rem+0.2vw,0.95rem)] font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">
    {title}
  </p>
  <h3 class="mt-3 text-[clamp(1.15rem,1.05rem+0.45vw,1.5rem)] font-semibold leading-tight text-[var(--nm-fg)]">
    {claim}
  </h3>
  <div class="mt-4 space-y-3 text-[clamp(1rem,0.95rem+0.25vw,1.1rem)] leading-[1.85] text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
    <slot />
  </div>
</aside>
