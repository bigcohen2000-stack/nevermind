---
import siteSettings from "../config/siteSettings.json";

const banner = siteSettings.whisperBanner;
const dismissKey = "nm-whisper-banner-dismissed-at";
---

<aside
  data-whisper-banner
  data-dismiss-key={dismissKey}
  data-banner-enabled={String(Boolean(banner.enabled))}
  data-banner-message={banner.message}
  data-banner-cta-label={banner.ctaLabel}
  data-banner-cta-href={banner.ctaHref}
  data-banner-dismiss-hours={String(banner.dismissHours || 24)}
  data-banner-contextual-offers={JSON.stringify(banner.contextualOffers || [])}
  class="fixed inset-x-0 top-7 z-[96] hidden border-b border-[rgba(26,26,26,0.08)] bg-[#FAFAF8]/98 text-[#1A1A1A] shadow-[0_10px_30px_rgba(26,26,26,0.08)] backdrop-blur-md"
>
  <div class="mx-auto flex min-h-[3.25rem] max-w-7xl flex-wrap items-center justify-center gap-3 px-4 py-2 text-center text-sm leading-6 sm:flex-nowrap">
    <p data-whisper-message class="font-medium text-[#1A1A1A]">{banner.message}</p>
    <a
      data-whisper-cta
      href={banner.ctaHref}
      class="inline-flex min-h-[44px] shrink-0 items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-[#1A1A1A] px-4 py-2 text-sm font-semibold text-[#FAFAF8] transition hover:bg-[#2A2A2A] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
    >
      {banner.ctaLabel}
    </a>
    <button
      type="button"
      data-whisper-close
      aria-label="סגור את הודעת הפס העליון"
      class="absolute left-4 top-1/2 inline-flex -translate-y-1/2 items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-white/70 px-2.5 py-1 text-xs font-semibold text-[#1A1A1A]/72 transition-colors duration-200 hover:bg-white hover:text-[#1A1A1A] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
    >
      סגור
    </button>
  </div>
</aside>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const STORAGE_KEY = "nm-site-settings-overrides";
    const CLUB_SESSION_KEY = "nm_club_session";
    const banner = document.querySelector("[data-whisper-banner]");
    const body = document.body;
    if (!(banner instanceof HTMLElement) || !body) {
      if (body) body.dataset.whisperBannerState = "hidden";
      return;
    }

    const messageNode = banner.querySelector("[data-whisper-message]");
    const ctaNode = banner.querySelector("[data-whisper-cta]");
    const closeButton = banner.querySelector("[data-whisper-close]");
    if (!(messageNode instanceof HTMLElement) || !(ctaNode instanceof HTMLAnchorElement)) {
      body.dataset.whisperBannerState = "hidden";
      return;
    }

    const dismissKey = banner.dataset.dismissKey || "nm-whisper-banner-dismissed-at";

    const readOverrides = () => {
      try {
        return JSON.parse(window.localStorage.getItem(STORAGE_KEY) || "null");
      } catch {
        return null;
      }
    };

    const defaults = {
      enabled: banner.dataset.bannerEnabled === "true",
      message: banner.dataset.bannerMessage || "",
      ctaLabel: banner.dataset.bannerCtaLabel || "",
      ctaHref: banner.dataset.bannerCtaHref || "/",
      dismissHours: Math.max(1, Number(banner.dataset.bannerDismissHours || 24)),
      contextualOffers: (() => {
        try {
          return JSON.parse(banner.dataset.bannerContextualOffers || "[]");
        } catch {
          return [];
        }
      })(),
    };

    const readClubSession = () => {
      try {
        const raw = window.localStorage.getItem(CLUB_SESSION_KEY);
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        if (!parsed || typeof parsed !== "object") return null;
        const memberName = String(parsed.memberName || "").trim();
        const expiresAt = String(parsed.expiresAt || "").trim();
        const expiresTs = Date.parse(expiresAt);
        if (!memberName || !Number.isFinite(expiresTs) || expiresTs <= Date.now()) {
          window.localStorage.removeItem(CLUB_SESSION_KEY);
          return null;
        }
        return {
          memberName,
          expiresAt: new Date(expiresTs).toISOString(),
        };
      } catch {
        return null;
      }
    };

    const buildPersonalizedBanner = () => {
      const session = readClubSession();
      if (!session) return null;
      const hour = new Date().getHours();
      const greeting =
        hour < 5 ? "לילה שקט" : hour < 12 ? "בוקר טוב" : hour < 18 ? "צהריים טובים" : "ערב טוב";
      return {
        message: `ברוכים הבאים ${session.memberName}. ${greeting}. אזור הלמידה פתוח כאן עכשיו.`,
        ctaLabel: "לאזור האישי",
        ctaHref: "/me/",
        forceShow: true,
      };
    };

    const hideBanner = (persist, dismissWindowMs) => {
      banner.style.display = "none";
      body.dataset.whisperBannerState = "hidden";
      if (persist) {
        window.localStorage.setItem(dismissKey, String(Date.now()));
      }
      if (typeof dismissWindowMs === "number") {
        banner.dataset.dismissWindow = String(dismissWindowMs);
      }
    };

    const findContextualOffer = () => {
      const params = new URLSearchParams(window.location.search);
      const hash = window.location.hash.replace(/^#/, "");
      const serviceId = params.get("service") || hash;
      if (!serviceId) return null;
      return defaults.contextualOffers.find((offer) => offer.serviceId === serviceId) || null;
    };

    const applyBannerSettings = () => {
      const override = readOverrides()?.whisperBanner || {};
      const current = {
        ...defaults,
        ...override,
      };
      const personalized = buildPersonalizedBanner();
      const contextualOffer = findContextualOffer();

      const dismissHours = Math.max(1, Number(current.dismissHours || 24));
      const dismissWindowMs = dismissHours * 60 * 60 * 1000;
      banner.dataset.dismissWindow = String(dismissWindowMs);
      messageNode.textContent =
        personalized?.message || contextualOffer?.message || current.message || defaults.message;
      ctaNode.textContent =
        personalized?.ctaLabel || contextualOffer?.ctaLabel || current.ctaLabel || defaults.ctaLabel;
      ctaNode.href =
        personalized?.ctaHref || contextualOffer?.ctaHref || current.ctaHref || defaults.ctaHref || "/";

      if (!current.enabled) {
        hideBanner(false, dismissWindowMs);
        return;
      }

      if (personalized?.forceShow) {
        banner.style.display = "block";
        body.dataset.whisperBannerState = "shown";
        return;
      }

      const lastDismissed = Number(window.localStorage.getItem(dismissKey) || 0);
      if (lastDismissed && Date.now() - lastDismissed < dismissWindowMs) {
        hideBanner(false, dismissWindowMs);
        return;
      }

      banner.style.display = "block";
      body.dataset.whisperBannerState = "shown";
    };

    applyBannerSettings();

    const onClose = () => {
      const dismissWindow = Number(banner.dataset.dismissWindow || 86400000);
      hideBanner(true, dismissWindow);
    };

    if (closeButton instanceof HTMLButtonElement) {
      closeButton.onclick = onClose;
    }

    const onSettingsUpdated = () => {
      applyBannerSettings();
    };

    window.addEventListener("nm-site-settings-updated", onSettingsUpdated);
    window.addEventListener("nm-club-session-changed", onSettingsUpdated);
    window.addEventListener("storage", (event) => {
      if (event.key === CLUB_SESSION_KEY || event.key === dismissKey || event.key === null) {
        applyBannerSettings();
      }
    });
  });
</script>
