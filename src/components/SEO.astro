---
/**
 * NeverMind SEO — canonical, OG/Twitter, JSON-LD (Schema.org)
 * קלט מ-migration-map; JSON-LD כטקסט מסונן (לא משפיע על INP לעומת בלוק סקריפט חיצוני)
 */
import appConfig from "../config/appConfig.json";
import {
  SITE_NAME,
  TITLE_TEMPLATE,
  DEFAULT_DESCRIPTION,
  OG_IMAGE_DEFAULT,
} from "../data/migration-map";
import { jsonLdForInlineScript } from "../lib/json-ld-inline";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: "website" | "article" | "product";
  price?: string;
  datePublished?: string;
}

const siteUrl = String(appConfig.site?.url ?? "https://www.nevermind.co.il").trim();
const siteUrlSlash = siteUrl.endsWith("/") ? siteUrl : `${siteUrl}/`;

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = OG_IMAGE_DEFAULT,
  canonical,
  type = "website",
  price,
  datePublished,
} = Astro.props;

const trimMetaDescription = (value: string) => {
  const normalized = String(value || "")
    .trim()
    .replace(/\s+/g, " ");
  if (normalized.length <= 155) return normalized;
  return `${normalized.slice(0, 152).trimEnd()}...`;
};

const metaDescription = trimMetaDescription(description);
const rawTitle = String(title || "").trim();
const formattedTitle = TITLE_TEMPLATE.replace("%s", rawTitle.length > 0 ? rawTitle : SITE_NAME);

const resolvedPageUrl =
  Astro.site != null
    ? new URL(Astro.url.pathname, Astro.site).toString()
    : new URL(Astro.url.pathname, siteUrl).toString();

const canonicalURL =
  typeof canonical === "string" && canonical.trim().length > 0 ? canonical.trim() : resolvedPageUrl;

function resolveAbsoluteImage(href: string): string {
  const t = href.trim();
  if (t.startsWith("http://") || t.startsWith("https://")) return t;
  return new URL(t.replace(/^\//, ""), siteUrlSlash).toString();
}

const ogImageAbsolute = resolveAbsoluteImage(image);

type JsonLdRecord = Record<string, unknown>;

let jsonLd: JsonLdRecord;

if (type === "article") {
  jsonLd = {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: rawTitle,
    description: metaDescription,
    image: ogImageAbsolute,
    ...(datePublished ? { datePublished } : {}),
    author: {
      "@type": "Person",
      name: "השם לא משנה",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": canonicalURL,
    },
  };
} else if (type === "product" && price) {
  jsonLd = {
    "@context": "https://schema.org",
    "@type": "Product",
    name: rawTitle,
    description: metaDescription,
    image: ogImageAbsolute,
    offers: {
      "@type": "Offer",
      price,
      priceCurrency: "ILS",
      availability: "https://schema.org/InStock",
      url: canonicalURL,
    },
  };
} else {
  jsonLd = {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: SITE_NAME,
    image: ogImageAbsolute,
    url: siteUrl.replace(/\/$/, "") || siteUrl,
  };
}

const ogType = type === "article" ? "article" : type === "product" ? "product" : "website";

const jsonLdHtml = jsonLdForInlineScript(jsonLd);
---

<title>{formattedTitle}</title>
<meta name="description" content={metaDescription} />
<link rel="canonical" href={canonicalURL} />

<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content="he_IL" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={ogImageAbsolute} />

<script is:inline type="application/ld+json" set:html={jsonLdHtml}></script>
