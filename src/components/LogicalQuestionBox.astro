---
import { buildArticleContextWhatsAppHref } from "../lib/services";
import { microPosts } from "../data/microPosts";
import BigQuestionLayout from "./BigQuestionLayout.astro";
import FormAntispamFields from "./FormAntispamFields.astro";
import { FloatingInput } from "./ui/FloatingInput";

interface GlossaryTerm {
  term: string;
  definition: string;
}

interface Props {
  pageTitle: string;
  pageUrl: string;
  web3formsKey: string;
  tags?: string[];
  articleTitle?: string;
  glossaryTerms?: GlossaryTerm[];
}

const { pageTitle, pageUrl, web3formsKey, tags = [], articleTitle = "", glossaryTerms } = Astro.props as Props;
const recentMicroPosts = microPosts.slice(0, 3);
const contextWaHref = buildArticleContextWhatsAppHref({ tags, articleTitle: articleTitle || pageTitle });
---

<aside class="space-y-5 lg:sticky lg:top-28">
  <section class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-5 shadow-[0_18px_60px_rgba(26,26,26,0.06)]">
    <div class="space-y-3 text-right">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">שאלה לוגית</p>
      <h2 class="text-[1.35rem] font-semibold text-[var(--nm-fg)]">שאל שאלה לוגית</h2>
      <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
        לפעמים מספיק משפט אחד מדויק כדי לפתוח כיוון חדש. אם השאלה שלך תיגע בנקודה חיה, היא יכולה להפוך למיקרו־פוסט קצר באתר.
      </p>
    </div>

    <div class="mt-5">
      <BigQuestionLayout tags={tags} articleTitle={articleTitle || pageTitle} glossaryTerms={glossaryTerms} />
    </div>

    <form
      data-logical-question-form
      data-nm-antispam
      class="mt-5 space-y-4 text-right"
      action="https://api.web3forms.com/submit"
      method="POST"
    >
      <input type="hidden" name="access_key" value={web3formsKey} />
      <input type="hidden" name="subject" value="שאלה לוגית חדשה מ-NeverMind" />
      <input type="hidden" name="source_page" value={pageTitle} />
      <input type="hidden" name="source_url" value={pageUrl} />
      <input type="text" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <FormAntispamFields />

      <FloatingInput
        client:load
        id="logical-name"
        name="name"
        label="שם פרטי"
        dir="rtl"
        hideValidation={true}
        className="[&_.nm-floating-control]:bg-[var(--nm-surface-muted)]"
      />
      <FloatingInput
        client:load
        id="logical-email"
        name="email"
        label="אימייל לחזרה"
        type="email"
        required
        dir="rtl"
        className="[&_.nm-floating-control]:bg-[var(--nm-surface-muted)]"
      />
      <FloatingInput
        client:load
        id="logical-phone"
        name="phone"
        label="טלפון לחזרה"
        type="tel"
        required
        pattern="^0[0-9]{8,9}$"
        dir="rtl"
        className="[&_.nm-floating-control]:bg-[var(--nm-surface-muted)]"
      />
      <FloatingInput
        client:load
        id="logical-question"
        name="message"
        label="השאלה שלך"
        multiline
        rows={5}
        maxLength={320}
        required
        dir="rtl"
        className="[&_.nm-floating-control]:bg-[var(--nm-surface-muted)]"
      />

      <div class="flex flex-wrap gap-3">
        <button
          type="submit"
          class="inline-flex flex-1 items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition-colors duration-200 hover:bg-[var(--nm-accent-hover)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
        >
          שלח שאלה קצרה
        </button>
        <a
          href={contextWaHref}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-[#25D366] px-5 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:bg-[#1FAE55] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#25D366]"
        >
          או שלח בוואטסאפ
        </a>
      </div>

      <p data-logical-question-status aria-live="polite" class="text-sm text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))] opacity-0 transition-opacity duration-300">
        נשלח - אני בדרך כלל חוזר ממש מהר. אם השאלה תיבחר, תופיע תשובה קצרה באתר.
      </p>
      <div data-nm-logical-form-return class="hidden pt-2 text-right">
        <a
          data-nm-return-cta-link
          href="/articles/"
          class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_28%,transparent)] bg-[var(--nm-tint)] px-4 py-2 text-sm font-semibold text-[var(--nm-accent)] transition hover:bg-[var(--nm-tint-hover)]"
        >
          חזור לארכיון
        </a>
      </div>
    </form>
  </section>

  <section class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-5 text-right">
    <div class="space-y-2">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">מיקרו־פוסטים</p>
      <h3 class="text-xl font-semibold text-[var(--nm-fg)]">תשובות קצרות אחרונות</h3>
    </div>
    <div class="mt-4 space-y-3">
      {recentMicroPosts.map((post) => (
        <a
          href={`/questions/#${post.slug}`}
          class="block rounded-[1.3rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-4 transition hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] hover:bg-[var(--nm-tint-hover)]"
        >
          <p class="text-sm font-semibold leading-7 text-[var(--nm-fg)]">{post.question}</p>
          <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">{post.answer}</p>
        </a>
      ))}
    </div>
    <a href="/questions/" class="mt-4 inline-flex text-sm font-semibold text-[var(--nm-accent)] transition hover:opacity-75">
      לכל המיקרו־פוסטים
    </a>
  </section>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      if (window.__nmLogicalQuestionCleanup) window.__nmLogicalQuestionCleanup();

      const form = document.querySelector("[data-logical-question-form]");
      const status = document.querySelector("[data-logical-question-status]");
      if (!(form instanceof HTMLFormElement) || !(status instanceof HTMLElement)) return;

      if (typeof window.__nmStampFormAntispam === "function") {
        window.__nmStampFormAntispam(form);
      }

      const logicalReturn = document.querySelector("[data-nm-logical-form-return]");
      const logicalReturnLink = document.querySelector("[data-nm-return-cta-link]");

      const handleSubmit = async (event) => {
        event.preventDefault();
        const formData = new FormData(form);
        const phoneValue = String(formData.get("phone") || "").trim();
        if (!/^0[0-9]{8,9}$/.test(phoneValue)) {
          status.textContent = "מספר הטלפון לא תקין. כתוב מספר ישראלי שמתחיל ב-0.";
          status.classList.add("opacity-100");
          return;
        }

        const msg = String(formData.get("message") || "").trim();
        const read = window.__nmReadAntispamFromForm;
        const validate = window.__nmValidateAntispamFields;
        if (typeof read === "function" && typeof validate === "function") {
          const as = read(form);
          const check = validate({ ...as, messageTexts: [msg, phoneValue] });
          if (!check.ok) {
            status.textContent = check.userMessage;
            status.classList.add("opacity-100");
            return;
          }
        }

        try {
          const response = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            body: formData,
          });

          status.textContent = response.ok
            ? "נשלח - אני בדרך כלל חוזר ממש מהר. אם השאלה תיבחר, תופיע תשובה קצרה באתר."
            : "נראה שלא עבר הפעם. אפשר לנסות שוב או לשלוח בוואטסאפ.";
          status.classList.add("opacity-100");

          if (response.ok) {
            form.reset();
            if (logicalReturn instanceof HTMLElement && logicalReturnLink instanceof HTMLAnchorElement) {
              if (typeof window.__nmFillReturnLink === "function") {
                window.__nmFillReturnLink(logicalReturnLink);
              }
              logicalReturn.classList.remove("hidden");
            }
          }
        } catch {
          status.textContent = "נראה שלא עבר הפעם. אפשר לנסות שוב או לשלוח בוואטסאפ.";
          status.classList.add("opacity-100");
        }
      };

      form.addEventListener("submit", handleSubmit);

      window.__nmLogicalQuestionCleanup = () => {
        form.removeEventListener("submit", handleSubmit);
      };
    });
  </script>
</aside>
