---
import { buildArticleContextWhatsAppHref } from "../lib/services";
import { microPosts } from "../data/microPosts";
import BigQuestionLayout from "./BigQuestionLayout.astro";

interface GlossaryTerm {
  term: string;
  definition: string;
}

interface Props {
  pageTitle: string;
  tags?: string[];
  articleTitle?: string;
  glossaryTerms?: GlossaryTerm[];
}

const { pageTitle, tags = [], articleTitle = "", glossaryTerms } = Astro.props as Props;
const recentMicroPosts = microPosts.slice(0, 3);
const contextWaHref = buildArticleContextWhatsAppHref({ tags, articleTitle: articleTitle || pageTitle });
---

<aside class="space-y-5 lg:sticky lg:top-28">
  <section
    class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-5 shadow-[0_18px_60px_rgba(26,26,26,0.06)]"
    aria-labelledby="nm-contextual-components-heading"
  >
    <div class="space-y-4 text-right">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">רכיבים לפי הקשר</p>
      <h2 id="nm-contextual-components-heading" class="text-[1.2rem] font-semibold leading-snug text-[var(--nm-fg)]">
        יצירת רכיבים חכמים <span class="text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">(Contextual Components)</span>
      </h2>
      <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        אם מכניסים טקסט מאמר ובוחנים את המודל: &quot;צור שאלת לוגיקה שמתאימה בדיוק לפסקה השלישית&quot; — התוצאה חדה יותר משאלה גנרית על כל הטקסט.
      </p>
      <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        כאן התפקיד הוא לאסוף טקסט גולמי, הערות ובקשות, לעבור דרך קבינט המומחים, ולייצר קובץ MDX סופי נקי. הרכיב <code class="rounded bg-[var(--nm-surface-muted)] px-1.5 py-0.5 text-[0.8em]">מעבר למילים</code> יושב היכן שהקריאה נסדקת והקורא הכי סקרן להמשיך — לא שבירה אקראית באמצע פסקה.
      </p>
      <div class="space-y-3 rounded-[1.25rem] border border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] bg-[var(--nm-surface-muted)]/60 p-4 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
        <p>
          <strong class="text-[var(--nm-fg)]">שלב 1 · איסוף וביקורת:</strong>
          סריקת כל הטקסט והבקשות. כל רעיון שחזר מטיוטה — נכנס פנימה בלי להשמיט.
        </p>
        <p>
          <strong class="text-[var(--nm-fg)]">שלב 2 · קבינט:</strong>
          Copy: תובנה מרכזית והיפוכים, בלי מילים ריקות. SEO: <span class="whitespace-nowrap">questionForSchema</span> מדויק מהטקסט. מיקום רכיב מעבר המילים בנקודת הסדק הנכונה.
        </p>
        <p>
          <strong class="text-[var(--nm-fg)]">שלב 3 · MDX:</strong>
          Frontmatter תקני, פסקאות קצרות, מרווח קריאה, שפה ישירה.
        </p>
      </div>
    </div>

    <div class="mt-5 border-t border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] pt-5">
      <BigQuestionLayout tags={tags} articleTitle={articleTitle || pageTitle} glossaryTerms={glossaryTerms} />
    </div>

    <div class="mt-5 flex flex-wrap gap-2">
      <a
        href={contextWaHref}
        target="_blank"
        rel="noreferrer"
        class="inline-flex min-h-[44px] flex-1 items-center justify-center rounded-full bg-[#25D366] px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-[#1FAE55] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#25D366]"
      >
        להמשיך את השיחה בוואטסאפ
      </a>
      <a
        href="/services/"
        class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-4 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-tint)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
      >
        למרחב הגילוי
      </a>
    </div>
  </section>

  <section class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-5 text-right">
    <div class="space-y-2">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">מיקרו־פוסטים</p>
      <h3 class="text-xl font-semibold text-[var(--nm-fg)]">תשובות קצרות אחרונות</h3>
    </div>
    <div class="mt-4 space-y-3">
      {recentMicroPosts.map((post) => (
        <a
          href={`/questions/#${post.slug}`}
          class="block rounded-[1.3rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-4 py-4 transition hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] hover:bg-[var(--nm-tint-hover)]"
        >
          <p class="text-sm font-semibold leading-7 text-[var(--nm-fg)]">{post.question}</p>
          <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">{post.answer}</p>
        </a>
      ))}
    </div>
    <a href="/questions/" class="mt-4 inline-flex text-sm font-semibold text-[var(--nm-accent)] transition hover:opacity-75">
      לכל המיקרו־פוסטים
    </a>
  </section>
</aside>
