---
import VideoPlayer from "./VideoPlayer.astro";

interface Props {
  youtubeId: string;
  title: string;
  isPremium: boolean;
  videoSummaryPoints?: string[];
}

const { youtubeId, title, isPremium, videoSummaryPoints = [] } = Astro.props;
const points = Array.isArray(videoSummaryPoints)
  ? videoSummaryPoints.map((p) => String(p).trim()).filter(Boolean)
  : [];
const lockSrc = "/images/lock-nevermind-club.png";
---

{
  isPremium ? (
    <div
      class="nm-article-video-gate mb-8 overflow-hidden rounded-[1.35rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)]"
      data-nm-article-video-gate
      data-nm-video-premium="true"
    >
      <div
        class="nm-article-video-locked relative"
        data-nm-article-video-locked
      >
        <div class="relative aspect-video w-full bg-black/90">
          <img
            src={lockSrc}
            alt="הסרטון מיועד לחברי המועדון. הטקסט למטה נשאר זמין."
            width={1280}
            height={720}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
          <div class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center gap-3 bg-black/35 px-4 text-center">
            <span class="text-4xl" aria-hidden="true">
              🔒
            </span>
            <p class="max-w-md text-base font-semibold leading-snug text-white drop-shadow-sm">
              הסרטון מיועד לחברי המועדון. הטקסט של המאמר נשאר פתוח.
            </p>
            <p class="pointer-events-auto flex flex-wrap items-center justify-center gap-2 text-sm">
              <a
                href="/premium-access/"
                class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-2.5 font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
              >
                הצטרפות וגישה
              </a>
              <a
                href="/services/"
                class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-white/70 bg-white/15 px-5 py-2.5 font-semibold text-white backdrop-blur-sm transition hover:bg-white/25"
              >
                מסלולים
              </a>
            </p>
          </div>
        </div>
      </div>

      <div class="nm-article-video-unlocked hidden" data-nm-article-video-unlocked>
        <VideoPlayer youtubeId={youtubeId} title={title} videoSummaryPoints={points} />
      </div>

      <script is:inline>
        (function () {
          const KEY = "nm_club_session";
          const readClub = () => {
            try {
              const raw = window.localStorage.getItem(KEY);
              if (!raw) return null;
              const data = JSON.parse(raw);
              if (!data || typeof data !== "object") return null;
              const expiresAt = String(data.expiresAt || "").trim();
              if (!expiresAt) return null;
              const ts = Date.parse(expiresAt);
              if (Number.isNaN(ts) || ts < Date.now()) return null;
              return data;
            } catch {
              return null;
            }
          };
          const apply = () => {
            const root = document.querySelector("[data-nm-article-video-gate][data-nm-video-premium='true']");
            if (!root) return;
            const locked = root.querySelector("[data-nm-article-video-locked]");
            const unlocked = root.querySelector("[data-nm-article-video-unlocked]");
            if (!(locked instanceof HTMLElement) || !(unlocked instanceof HTMLElement)) return;
            const ok = readClub() !== null;
            if (ok) {
              locked.classList.add("hidden");
              locked.setAttribute("aria-hidden", "true");
              unlocked.classList.remove("hidden");
            } else {
              locked.classList.remove("hidden");
              locked.removeAttribute("aria-hidden");
              unlocked.classList.add("hidden");
            }
          };
          apply();
          window.addEventListener("nm-club-session-changed", apply);
          window.addEventListener("storage", (e) => {
            if (e.key === KEY || e.key === null) apply();
          });
        })();
      </script>
    </div>
  ) : (
    <div class="mb-8">
      <VideoPlayer youtubeId={youtubeId} title={title} videoSummaryPoints={points} />
    </div>
  )
}
