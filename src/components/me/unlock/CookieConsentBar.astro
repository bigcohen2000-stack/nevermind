---
const {
  text = "ניתן לאשר cookies למדידה בסיסית, או להמשיך ללא מדידה.",
} = Astro.props;
---

<div id="unlock-cookie-bar" class="hidden fixed inset-x-0 bottom-4 z-[95] px-4">
  <div class="mx-auto max-w-3xl rounded-full border-[0.5px] border-[rgba(26,26,26,0.1)] bg-[rgba(250,250,248,0.82)] px-4 py-3 shadow-[0_16px_40px_rgba(26,26,26,0.08)] backdrop-blur-md dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(26,26,26,0.84)]">
    <div class="flex flex-col gap-3 text-right sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-[rgba(26,26,26,0.68)] dark:text-[rgba(250,250,248,0.7)]">{text}</p>
      <div class="flex items-center justify-end gap-4 text-sm">
        <button id="unlock-cookie-decline" type="button" class="text-[rgba(26,26,26,0.72)] transition hover:text-[#D42B2B] dark:text-[rgba(250,250,248,0.72)] dark:hover:text-[#ff8a8a]">בלי מדידה</button>
        <button id="unlock-cookie-accept" type="button" class="text-[#1A1A1A] transition hover:text-[#D42B2B] dark:text-[#FAFAF8] dark:hover:text-[#ff8a8a]">אישור מדידה</button>
      </div>
    </div>
  </div>
</div>
