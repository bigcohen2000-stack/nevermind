---
const { text = "קוד אישי בלבד — לשימושך הבלעדי" } = Astro.props;
---

<div class="inline-flex items-center rounded-full border-[0.5px] border-[rgba(212,43,43,0.16)] bg-[rgba(212,43,43,0.05)] px-3 py-1 text-[12px] font-medium text-[#D42B2B] dark:border-[rgba(212,43,43,0.22)] dark:bg-[rgba(212,43,43,0.08)] dark:text-[#ff8a8a]">
  {text}
</div>
