---
export type UnlockNavItem = {
  id: string;
  href: string;
  label: string;
  description: string;
  premium?: boolean;
  locked?: boolean;
};

const { items = [] } = Astro.props as { items?: UnlockNavItem[] };
---

<div class="grid grid-cols-2 gap-3 sm:grid-cols-3 xl:grid-cols-4" aria-label="ניווט מהיר">
  {items.map((item, index) => (
    <a
      href={item.href}
      data-unlock-card
      data-locked={item.locked ? "true" : "false"}
      class:list={[
        "group relative overflow-hidden rounded-[24px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/72 p-4 text-right shadow-[0_16px_40px_rgba(26,26,26,0.04)] backdrop-blur-md transition duration-300 hover:border-[rgba(212,43,43,0.2)] dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.04)] dark:hover:border-[rgba(212,43,43,0.25)]",
        item.locked && "unlock-card--locked",
      ]}
      style={`animation-delay:${index * 80}ms;`}
      aria-disabled={item.locked ? "true" : "false"}
    >
      <div class="flex items-start justify-between gap-3">
        <div class="space-y-2">
          <p class="text-base font-semibold text-[#1A1A1A] dark:text-[#FAFAF8]">{item.label}</p>
          <p class="text-sm leading-6 text-[rgba(26,26,26,0.62)] dark:text-[rgba(250,250,248,0.62)]">{item.description}</p>
        </div>
        {item.premium ? (
          <span class="mt-0.5 inline-flex h-7 w-7 items-center justify-center rounded-full border-[0.5px] border-[rgba(26,26,26,0.08)] bg-[rgba(26,26,26,0.04)] text-[#1A1A1A] dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(250,250,248,0.06)] dark:text-[#FAFAF8]">
            <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.35">
              <rect x="3.25" y="7" width="9.5" height="6" rx="1.8"></rect>
              <path d="M5.5 7V5.85A2.5 2.5 0 0 1 8 3.35a2.5 2.5 0 0 1 2.5 2.5V7"></path>
            </svg>
          </span>
        ) : null}
      </div>
      <div class="mt-5 flex items-center justify-between text-xs text-[rgba(26,26,26,0.48)] dark:text-[rgba(250,250,248,0.5)]">
        <span>{item.premium ? "גישה פרימיום" : "גישה פתוחה"}</span>
        <span>{item.locked ? "נעול" : "זמין"}</span>
      </div>
    </a>
  ))}
</div>
