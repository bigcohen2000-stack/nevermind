---
const {
  status = "פעיל",
  lastConnection = "ממתין",
  analyticsStatus = "Cloudflare פעיל",
} = Astro.props;
---

<section data-unlock-vitals class="rounded-[28px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/60 p-5 shadow-[0_20px_50px_rgba(26,26,26,0.05)] backdrop-blur-md dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)]">
  <div class="space-y-4 text-right">
    <div class="flex items-center justify-between gap-3">
      <div>
        <p class="text-xs tracking-[0.18em] text-[rgba(26,26,26,0.42)] dark:text-[rgba(250,250,248,0.46)]">מצב גישה</p>
        <h2 class="mt-2 text-xl font-semibold text-[#1A1A1A] dark:text-[#FAFAF8]">מצב החשבון</h2>
      </div>
      <div class="h-11 w-11 rounded-[16px] border-[0.5px] border-[rgba(26,26,26,0.08)] bg-[linear-gradient(180deg,rgba(255,255,255,0.8),rgba(250,250,248,0.4))] shadow-[inset_0_1px_0_rgba(255,255,255,0.9)] dark:border-[rgba(250,250,248,0.12)] dark:bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.02))]"></div>
    </div>

    <dl class="grid gap-3 text-sm">
      <div class="rounded-[20px] border-[0.5px] border-[rgba(26,26,26,0.08)] bg-[rgba(250,250,248,0.78)] px-4 py-3 dark:border-[rgba(250,250,248,0.1)] dark:bg-[rgba(255,255,255,0.03)]">
        <dt class="text-[rgba(26,26,26,0.48)] dark:text-[rgba(250,250,248,0.5)]">סטטוס</dt>
        <dd data-vital-status class="mt-1 font-medium text-[#1A1A1A] dark:text-[#FAFAF8]">{status}</dd>
      </div>
      <div class="rounded-[20px] border-[0.5px] border-[rgba(26,26,26,0.08)] bg-[rgba(250,250,248,0.78)] px-4 py-3 dark:border-[rgba(250,250,248,0.1)] dark:bg-[rgba(255,255,255,0.03)]">
        <dt class="text-[rgba(26,26,26,0.48)] dark:text-[rgba(250,250,248,0.5)]">חיבור אחרון</dt>
        <dd data-vital-connection class="mt-1 font-medium text-[#1A1A1A] dark:text-[#FAFAF8]">{lastConnection}</dd>
      </div>
      <div class="rounded-[20px] border-[0.5px] border-[rgba(26,26,26,0.08)] bg-[rgba(250,250,248,0.78)] px-4 py-3 dark:border-[rgba(250,250,248,0.1)] dark:bg-[rgba(255,255,255,0.03)]">
        <dt class="text-[rgba(26,26,26,0.48)] dark:text-[rgba(250,250,248,0.5)]">מדידת אתר</dt>
        <dd data-vital-analytics class="mt-1 font-medium text-[#1A1A1A] dark:text-[#FAFAF8]">{analyticsStatus}</dd>
      </div>
    </dl>
  </div>
</section>
