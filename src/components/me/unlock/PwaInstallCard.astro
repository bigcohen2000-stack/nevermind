---
const {
  title = "התקנה למסך הראשי",
  body = "אם תרצה, אפשר להוסיף את הפורטל למסך הראשי לגישה מהירה ושקטה.",
} = Astro.props;
---

<section id="unlock-pwa-card" class="hidden rounded-[28px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/72 p-5 shadow-[0_20px_50px_rgba(26,26,26,0.05)] backdrop-blur-md dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)]">
  <div class="flex items-start gap-4 text-right">
    <div class="flex h-14 w-14 items-center justify-center rounded-[18px] border-[0.5px] border-[rgba(26,26,26,0.08)] bg-[linear-gradient(180deg,#f6f2ef_0%,#ffffff_100%)] shadow-[0_10px_24px_rgba(26,26,26,0.08),inset_0_1px_0_rgba(255,255,255,0.88)] dark:border-[rgba(250,250,248,0.12)] dark:bg-[linear-gradient(180deg,rgba(255,255,255,0.1),rgba(255,255,255,0.03))]">
      <div class="h-8 w-8 rounded-[12px] bg-[linear-gradient(135deg,#D42B2B_0%,rgba(212,43,43,0.35)_100%)]"></div>
    </div>
    <div class="min-w-0 flex-1 space-y-2">
      <p class="text-xs tracking-[0.18em] text-[rgba(26,26,26,0.42)] dark:text-[rgba(250,250,248,0.46)]">PWA</p>
      <h3 class="text-lg font-semibold text-[#1A1A1A] dark:text-[#FAFAF8]">{title}</h3>
      <p class="text-sm leading-6 text-[rgba(26,26,26,0.62)] dark:text-[rgba(250,250,248,0.62)]">{body}</p>
      <button id="unlock-pwa-install" type="button" class="inline-flex min-h-[40px] items-center rounded-full border-[0.5px] border-[rgba(26,26,26,0.12)] px-4 py-2 text-sm font-medium text-[#1A1A1A] transition hover:border-[rgba(212,43,43,0.2)] dark:border-[rgba(250,250,248,0.14)] dark:text-[#FAFAF8] dark:hover:border-[rgba(212,43,43,0.25)]">
        Install
      </button>
    </div>
  </div>
</section>
