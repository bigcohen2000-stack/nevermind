---
interface Props {
  summary: string;
}

const { summary } = Astro.props;
---

<section class="rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[var(--nm-tint)] px-5 py-5 text-right shadow-[0_18px_50px_rgba(212,43,43,0.08)]">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">בשורה התחתונה</p>
  <p class="mt-3 text-[clamp(1rem,0.96rem+0.3vw,1.16rem)] font-medium leading-8 text-[var(--nm-fg)]">{summary}</p>
</section>
