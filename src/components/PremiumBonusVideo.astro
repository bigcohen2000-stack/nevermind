---
import VideoPlayer from "./VideoPlayer.astro";

interface Props {
  youtubeId: string;
  title: string;
  unlockHref: string;
  helperText: string;
}

const { youtubeId, title, unlockHref, helperText } = Astro.props;
---

<section
  class="mx-auto max-w-[72ch] space-y-4 rounded-[1.35rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[color-mix(in_srgb,var(--nm-surface-muted)_88%,white)] p-5 text-right shadow-sm md:p-6"
  aria-label="הרחבה מצולמת לבעלי גישה"
  data-premium-bonus-root
>
  <h2 class="text-[clamp(1.05rem,1rem+0.25vw,1.2rem)] font-semibold text-[var(--nm-fg)]">המשך: טיפ מצולם</h2>

  <div data-premium-bonus-locked class="space-y-3">
    <p class="text-[clamp(0.95rem,0.9rem+0.2vw,1.05rem)] leading-7 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
      מעבר לגוף המאמר יש כאן סרטון קצר על ניסוח, אמת במילים, ושאלות שמחשיפות הנחה. התוכן נפתח רק כשיש סשן פרימיום פעיל
      (קוד גישה).
    </p>
    <p class="text-sm leading-6 text-[color-mix(in_srgb,var(--nm-fg)_65%,var(--nm-bg))]">{helperText}</p>
    <a
      href={unlockHref}
      class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]"
    >
      פתיחת גישה
    </a>
  </div>

  <div data-premium-bonus-unlocked class="space-y-3" hidden>
    <p class="text-sm font-medium text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">צפייה זמינה לסשן פעיל.</p>
    <VideoPlayer youtubeId={youtubeId} title={title} videoSummaryPoints={[]} />
  </div>
</section>
