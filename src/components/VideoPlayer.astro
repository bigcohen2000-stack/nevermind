---
/**
 * נגן YouTube מבוסס lite-youtube-embed (תמונה + iframe רק אחרי לחיצה).
 * מתחת: "סיכום מהיר" — נקודות מתמלול (מ-frontmatter).
 */
import "lite-youtube-embed/src/lite-yt-embed.css";

interface Props {
  youtubeId: string;
  title?: string;
  /** נקודות מרכזיות מהתמלול / הערות וידאו */
  videoSummaryPoints?: string[];
}

const { youtubeId, title = "סרטון וידאו", videoSummaryPoints = [] } = Astro.props;
const points = videoSummaryPoints.map((p) => String(p).trim()).filter(Boolean);
const playLabel = `הפעלת וידאו: ${title}`;
---

<div class="nm-video-player text-right" dir="rtl">
  <div
    class="overflow-hidden rounded-2xl border border-[#1A1A1A]/10 bg-black shadow-sm dark:border-white/10"
  >
    <lite-youtube
      class="nm-lite-youtube"
      videoid={youtubeId}
      playlabel={playLabel}
      title={title}
      params="rel=0&modestbranding=1"></lite-youtube>
  </div>

  {
    points.length > 0 && (
      <details class="nm-video-summary group mt-4 rounded-2xl border border-[#1A1A1A]/10 bg-white/80 text-right shadow-sm open:border-[#1A1A1A]/18 dark:border-white/10 dark:bg-white/5">
        <summary class="cursor-pointer list-none rounded-2xl px-4 py-3 text-[clamp(1rem,0.95rem+0.25vw,1.15rem)] font-semibold leading-[1.8] text-[#1A1A1A] transition-colors marker:content-none dark:text-[#FAFAF8] [&::-webkit-details-marker]:hidden">
          <span class="inline-flex w-full items-center justify-between gap-3">
            <span>סיכום מהיר — עיקרי מה שנאמר בסרטון</span>
            <span
              class="text-sm font-normal text-[#1A1A1A]/50 transition group-open:rotate-180 dark:text-white/50"
              aria-hidden="true"
            >
              ▼
            </span>
          </span>
        </summary>
        <div class="border-t border-[#1A1A1A]/10 px-4 pb-4 pt-2 dark:border-white/10">
          <ul
            class="list-disc space-y-2 pr-5 text-[clamp(1rem,0.95rem+0.2vw,1.12rem)] leading-[1.8] text-[#1A1A1A]/88 dark:text-[#FAFAF8]/88"
          >
            {points.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </div>
      </details>
    )}
  </div>

<style is:global>
  .nm-video-player lite-youtube.nm-lite-youtube {
    max-width: 100%;
    margin-inline: auto;
  }
</style>

<script>
  import "lite-youtube-embed/src/lite-yt-embed.js";
</script>
