---
const { title = "פינת הספקן" } = Astro.props;
---
<aside
  class="rounded-2xl border border-[#D42B2B]/18 bg-[#FFF4F3] p-[clamp(1.25rem,2vw,2rem)] shadow-sm"
  role="note"
  aria-label={title}
>
  <p class="text-[clamp(0.8rem,0.76rem+0.2vw,0.95rem)] font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">
    פינת הספקן
  </p>
  <h3 class="mt-3 text-[clamp(1.15rem,1.05rem+0.45vw,1.5rem)] font-semibold leading-tight text-[#1A1A1A]">
    {title}
  </h3>
  <div class="mt-4 text-[clamp(1rem,0.95rem+0.25vw,1.1rem)] leading-[1.85] text-[#1A1A1A]/78">
    <slot />
  </div>
</aside>
