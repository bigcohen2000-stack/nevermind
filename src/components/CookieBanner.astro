---
---

<div
  id="nm-cookie-banner"
  class="fixed inset-x-0 bottom-0 z-[92] hidden border-t border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-bg-canvas)]/95 px-4 py-4 shadow-[0_-8px_32px_color-mix(in_srgb,var(--nm-fg)_10%,transparent)] backdrop-blur-md md:px-6"
  role="dialog"
  aria-modal="false"
  aria-labelledby="nm-cookie-banner-title"
  aria-describedby="nm-cookie-banner-desc"
  data-nm-cookie-banner
>
  <div class="mx-auto flex max-w-4xl flex-col gap-4 text-right md:flex-row md:items-center md:justify-between">
    <div class="min-w-0 space-y-1">
      <p id="nm-cookie-banner-title" class="text-sm font-semibold text-[var(--nm-fg)]">
        עוגיות ואנליטיקה
      </p>
      <p
        id="nm-cookie-banner-desc"
        class="text-[clamp(0.85rem,0.82rem+0.15vw,0.95rem)] leading-relaxed text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]"
      >
        אפשר לאשר טעינה של Google Analytics 4 לספירת ביקורים. בלי אישור לא נטען קוד מעקב. הבחירה נשמרת במכשיר (localStorage).
      </p>
    </div>
    <div class="flex shrink-0 flex-wrap justify-end gap-2">
      <button
        type="button"
        class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_14%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
        data-nm-cookie-decline
      >
        דחה
      </button>
      <button
        type="button"
        class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
        data-nm-cookie-accept
      >
        אשר
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const KEY = "nm-cookie-consent";
    const show = () => {
      const el = document.querySelector("[data-nm-cookie-banner]");
      if (el) el.classList.remove("hidden");
    };
    const hide = () => {
      const el = document.querySelector("[data-nm-cookie-banner]");
      if (el) el.classList.add("hidden");
    };
    const loadGaIfNeeded = () => {
      try {
        if (localStorage.getItem(KEY) !== "accepted") return;
      } catch {
        return;
      }
      window.dispatchEvent(new CustomEvent("nm-cookie-accepted"));
    };
    const bind = () => {
      const root = document.querySelector("[data-nm-cookie-banner]");
      if (!root || root.getAttribute("data-nm-cookie-bound") === "1") return;
      root.setAttribute("data-nm-cookie-bound", "1");
      const accept = root.querySelector("[data-nm-cookie-accept]");
      const decline = root.querySelector("[data-nm-cookie-decline]");
      accept?.addEventListener("click", () => {
        try {
          localStorage.setItem(KEY, "accepted");
        } catch {
          /* ignore */
        }
        hide();
        window.dispatchEvent(new CustomEvent("nm-cookie-accepted"));
      });
      decline?.addEventListener("click", () => {
        try {
          localStorage.setItem(KEY, "declined");
        } catch {
          /* ignore */
        }
        hide();
      });
    };
    const run = () => {
      bind();
      let v = null;
      try {
        v = localStorage.getItem(KEY);
      } catch {
        v = null;
      }
      if (v === "accepted") {
        hide();
        loadGaIfNeeded();
        return;
      }
      if (v === "declined") {
        hide();
        return;
      }
      show();
    };
    run();
    document.addEventListener("astro:page-load", run);
  })();
</script>
