---
/**
 * כרטיס מאמר: תג רמה + זמן קריאה בפינה, טיזר פרימיום למתקדמים/עומק.
 */
import { MIND_SHIFT_INACTIVE_HEX, MIND_SHIFT_SCALE_HEX } from "../data/mind-shift-scale";

export type DifficultyKey = "beginner" | "advanced" | "deep";

type Props = {
  slug: string;
  title: string;
  description: string;
  tagsCsv: string;
  transitionId: string;
  difficultyKey: DifficultyKey;
  readingMinutes: number;
  isPremium?: boolean;
  /** 1–5: עוצמת שינוי תפיסתי */
  mindShiftIntensity?: number;
  /** ISO YYYY-MM-DD לסימון עדכון/פרסום בכרטיס */
  contentFreshnessIso?: string;
  /** true אם התאריך הוא עדכון (לא פרסום ראשון) */
  contentFreshnessIsUpdate?: boolean;
};

const {
  slug,
  title,
  description,
  tagsCsv,
  transitionId,
  difficultyKey,
  readingMinutes,
  isPremium = false,
  mindShiftIntensity,
  contentFreshnessIso = "",
  contentFreshnessIsUpdate = false,
} = Astro.props;

const freshnessDate =
  typeof contentFreshnessIso === "string" && /^\d{4}-\d{2}-\d{2}$/.test(contentFreshnessIso.trim())
    ? contentFreshnessIso.trim()
    : "";
const freshnessLabel = contentFreshnessIsUpdate ? "עודכן" : "פורסם";

/** ממוצע ייחוס לפס מלא (למשל 5 דק׳ = 100%) */
const READING_BASELINE_MINUTES = 5;
const readingBarPercent = Math.min(100, Math.round((readingMinutes / READING_BASELINE_MINUTES) * 100));

const difficultyLabel: Record<DifficultyKey, string> = {
  beginner: "מתחילים",
  advanced: "מתקדמים",
  deep: "חקירה עמוקה",
};

/** פסטל רגוע: מתחילים רך, מתקדמים/עומק מעט חזק יותר בלי להתחרות באדום המותג */
const difficultyBadgeClass: Record<DifficultyKey, string> = {
  beginner:
    "border border-[#c8e6d8] bg-[#f3faf6] text-[#2a4d3d] ring-0 shadow-none",
  advanced:
    "border border-[#b9d4ea] bg-[#f0f7fc] text-[#254a63] ring-0 shadow-none",
  deep:
    "border border-[#cfc6e8] bg-[#f5f2fb] text-[#3d3558] ring-0 shadow-none",
};

const readingBadgeClass =
  "border border-[#e5e1dc] bg-[#faf9f7] text-[#5a5652] ring-0 shadow-none";

const showPremiumTeaser = difficultyKey === "advanced" || difficultyKey === "deep";
---

<div
  data-article-card
  data-tags={tagsCsv}
  data-difficulty={difficultyKey}
  data-premium={isPremium ? "true" : "false"}
  class:list={[
    "article-card group relative overflow-hidden rounded-lg border border-[#1A1A1A]/10 bg-white p-6 pb-5 pt-14 transition-all hover:border-[#D42B2B]/30 sm:pt-[3.25rem]",
    difficultyKey === "deep"
      ? "motion-safe:hover:-translate-y-0.5 motion-safe:hover:shadow-[0_28px_72px_rgba(26,26,26,0.2)]"
      : "motion-safe:hover:shadow-lg",
  ]}
>
  <div
    class="absolute top-3 start-3 z-10 flex max-w-[calc(100%-1.5rem)] flex-wrap items-center justify-end gap-2"
    dir="rtl"
    aria-label={`רמת עומק: ${difficultyLabel[difficultyKey]}, זמן קריאה משוער`}
  >
    <span
      class:list={[
        "inline-flex items-center rounded-full px-2.5 py-1 text-[0.7rem] font-semibold tracking-tight",
        difficultyBadgeClass[difficultyKey],
      ]}
    >
      {difficultyLabel[difficultyKey]}
    </span>
    <span
      class:list={[
        "inline-flex items-center rounded-full px-2.5 py-1 text-[0.7rem] font-medium tracking-tight",
        readingBadgeClass,
      ]}
    >
      {readingMinutes} דק׳ קריאה
    </span>
    {mindShiftIntensity != null && mindShiftIntensity >= 1 && mindShiftIntensity <= 5 ? (
      <span
        class="inline-flex items-center gap-1 rounded-full border border-[#1A1A1A]/12 bg-white/90 px-2 py-1 text-[0.65rem] font-semibold text-[#3d3558]"
        title={`שינוי תפיסתי: ${mindShiftIntensity}/5`}
        aria-label={`עוצמת שינוי תפיסתי ${mindShiftIntensity} מתוך 5`}
      >
        <span aria-hidden="true">⚡</span>
        <span class="flex gap-0.5" aria-hidden="true">
          {[1, 2, 3, 4, 5].map((step) => (
            <span
              class="h-1.5 w-2.5 shrink-0 rounded-[3px] border border-[#1A1A1A]/8 shadow-[inset_0_1px_0_rgba(255,255,255,0.35)]"
              style={`background-color: ${step <= mindShiftIntensity ? MIND_SHIFT_SCALE_HEX[step - 1] : MIND_SHIFT_INACTIVE_HEX}; opacity: ${step <= mindShiftIntensity ? 1 : 0.55};`}
            />
          ))}
        </span>
      </span>
    ) : null}
    {freshnessDate ? (
      <time
        class="inline-flex items-center rounded-full border border-[#e5e1dc] bg-[#faf9f7] px-2 py-1 text-[0.65rem] font-medium tabular-nums text-[#5a5652]"
        datetime={freshnessDate}
        title={`${freshnessLabel} ${freshnessDate}`}
      >
        {freshnessLabel} {freshnessDate}
      </time>
    ) : null}
  </div>

  <div class="mb-2 flex flex-wrap items-baseline justify-between gap-x-3 gap-y-2" dir="rtl">
    <h2
      transition:name={`article-${transitionId}`}
      class="min-w-0 flex-1 text-xl font-bold leading-snug text-[#1A1A1A] transition-colors group-hover:text-[#D42B2B]"
    >
      {title}
    </h2>
    {isPremium ? (
      <span
        class="inline-flex shrink-0 items-center gap-1 rounded-full border border-[color-mix(in_srgb,#D42B2B_28%,#e8e0e0)] bg-gradient-to-l from-[#fff6f6] to-white px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-[#9a1f1f] shadow-[inset_0_1px_0_rgba(255,255,255,0.85)] ring-1 ring-[color-mix(in_srgb,#D42B2B_12%,transparent)]"
        title="תוכן מועדון"
      >
        <svg class="size-3.5 shrink-0 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
          />
        </svg>
        Premium
      </span>
    ) : null}
  </div>

  {
    description && (
      <p class="mb-3 line-clamp-2 text-sm text-gray-600">{description}</p>
    )
  }

  {
    showPremiumTeaser && (
      <p class="mb-4 text-right text-[0.8125rem] leading-relaxed text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">
        החלק הזה הוא רק השער. לפירוק העמוק של המנגנון במועדון NeverMind —{" "}
        <a
          href="/premium"
          class="font-semibold text-[var(--nm-accent)] underline decoration-[color-mix(in_srgb,var(--nm-accent)_35%,transparent)] underline-offset-2 transition hover:decoration-[var(--nm-accent)]"
        >
          רוצה להעמיק? הצטרף לתכני מועדון ה-NeverMind
        </a>
      </p>
    )
  }

  <a
    href={`/articles/${slug}`}
    aria-label={`התחל מסלול: ${title}`}
    class="inline-flex min-h-[44px] min-w-[44px] items-center font-bold text-[#D42B2B]"
  >
    התחל מסלול: {title} ←
  </a>

  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-[3px] bg-[#ebe8e4]"
    dir="ltr"
    role="progressbar"
    aria-valuemin={0}
    aria-valuemax={100}
    aria-valuenow={readingBarPercent}
    aria-label={`זמן קריאה משוער ${readingMinutes} דקות, יחס לממוצע ${READING_BASELINE_MINUTES} דקות`}
    title={`${readingMinutes} דק׳ קריאה · יחס לממוצע ${READING_BASELINE_MINUTES} דק׳`}
  >
    <div
      class="h-full rounded-e-sm bg-gradient-to-l from-[#D42B2B] to-[color-mix(in_srgb,#D42B2B_75%,#1a1a1a)] motion-safe:transition-[width] motion-safe:duration-500 motion-safe:ease-out group-hover:from-[#c52626] group-hover:to-[#D42B2B]"
      style={`width: ${readingBarPercent}%`}
    />
  </div>
</div>
