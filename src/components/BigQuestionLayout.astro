---
/**
 * בלוק "שאלה גדולה" — היררכיה שטוחה, פונט גדול, מודולים: הפכים, מילון (dfn), מילוי + וואטסאפ.
 */
import WhatsAppButton from "./WhatsAppButton.astro";
import appConfig from "../config/appConfig.json";
import { buildArticleReadContextLine } from "../lib/services";

export interface GlossaryTerm {
  term: string;
  definition: string;
}

interface Props {
  tags: string[];
  articleTitle?: string;
  /** מונחים פשוטים להסבר ב-hover — אופציונלי */
  glossaryTerms?: GlossaryTerm[];
}

const { tags, articleTitle = "", glossaryTerms } = Astro.props;

const defaultGlossary: GlossaryTerm[] = [
  {
    term: "נקודה חיה",
    definition: "משהו שכואב או מפחיד עכשיו, לא רק רעיון יפה על הדף.",
  },
  {
    term: "הפך",
    definition: "מה הייתי חושב אם הייתי הופך את המשפט בראש — כמו לראות את אותו חדר מחלון אחר.",
  },
];

const terms = glossaryTerms?.length ? glossaryTerms : defaultGlossary;

const waPhone = appConfig.contact.whatsAppNumber;
const readContextLine = buildArticleReadContextLine({ tags, articleTitle });
---

<section
  class="bq-root text-right text-[clamp(1.05rem,1rem+0.35vw,1.2rem)] leading-[1.8] text-[var(--nm-fg)] dark:text-[var(--nm-fg)] [letter-spacing:0]"
  aria-labelledby="bq-heading"
>
  <h2 id="bq-heading" class="text-[clamp(1.35rem,1.15rem+1vw,1.75rem)] font-semibold text-[var(--nm-fg)] dark:text-[var(--nm-inverse-fg)] [letter-spacing:0]">
    עצור רגע לפני ששולחים שאלה
  </h2>

  <p class="mt-3 max-w-prose">
    אני לא בודק אותך כאן. אני רק מזמין אותך לנסח לעצמך בבהירות — כמו לדבר בקול רגוע לפני שאתה שולח הודעה.
  </p>

  <!-- Method of Opposites -->
  <div
    class="bq-opposites mt-8 overflow-hidden rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] shadow-sm dark:border-white/10"
    role="region"
    aria-label="תרגיל שאל את ההפך"
  >
    <p class="border-b border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3 text-center text-[clamp(0.95rem,0.9rem+0.2vw,1.05rem)] font-semibold text-[var(--nm-fg)] dark:border-white/10 dark:bg-[#111] dark:text-[var(--nm-inverse-fg)]">
      שאל את ההפך
    </p>
    <div class="grid md:grid-cols-2">
      <div
        class="bq-opposites__red min-h-[9rem] border-b border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] p-5 md:border-b-0 md:border-e dark:border-white/10"
        style="background: linear-gradient(165deg, rgba(249, 115, 22, 0.14) 0%, rgba(249, 115, 22, 0.06) 100%);"
      >
        <p class="text-[0.7rem] font-bold uppercase text-[#B91C1C] [letter-spacing:0] dark:text-[#FCA5A5]">מה נוטה לצאת ממני</p>
        <p class="mt-3">
          איזה משפט אני אומר לעצמי כשאני לחוץ? מה אני מנסה להגן עליו כשאני כועס או נסוג?
        </p>
      </div>
      <div
        class="bq-opposites__navy min-h-[9rem] p-5"
        style="background: linear-gradient(165deg, rgba(29, 53, 87, 0.16) 0%, rgba(29, 53, 87, 0.06) 100%);"
      >
        <p class="text-[0.7rem] font-bold uppercase text-[var(--nm-fg-secondary)] [letter-spacing:0] dark:text-[#93C5FD]">מה קורה אם הופכים</p>
        <p class="mt-3">
          אם הייתי אומר את ההפך בקול שקט — מה היה משתנה? לא צריך תשובה נכונה; צריך כיוון אחר לנסות.
        </p>
      </div>
    </div>
  </div>

  <!-- Glossary (dfn + CSS tooltip) -->
  <div class="mt-8 rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/60 px-4 py-5 dark:border-white/10 dark:bg-white/5">
    <p class="mb-3 text-[clamp(1rem,0.95rem+0.2vw,1.1rem)] font-medium text-[color-mix(in_srgb,var(--nm-fg)_90%,var(--nm-bg))] dark:text-[var(--nm-inverse-fg)]/90">
      שני מילים שעוזרות לי לא לאבד את עצמי בטקסט:
    </p>
    <ul class="flex flex-wrap gap-x-3 gap-y-2">
      {terms.map((item) => (
        <li>
          <dfn
            class="bq-dfn"
            tabindex="0"
            data-def={item.definition}
            title={item.definition}
          >
            {item.term}
          </dfn>
        </li>
      ))}
    </ul>
  </div>

  <!-- Fill-in-the-blanks → WhatsApp -->
  <form
    class="bq-fill mt-8 space-y-4 rounded-2xl border border-[#128C7E]/25 bg-[#F0FDF4]/70 p-5 dark:border-[#128C7E]/35 dark:bg-[#14532D]/25"
    data-bq-fill-form
    dir="rtl"
  >
    <p class="text-[clamp(1rem,0.95rem+0.25vw,1.15rem)] font-medium text-[#064E3B] dark:text-[#A7F3D0]">
      משפט אחד בשבילך — בלי טפסים ומיילים, רק שיחה בוואטסאפ כשתרצה:
    </p>
    <p class="text-[color-mix(in_srgb,var(--nm-fg)_85%,var(--nm-bg))] dark:text-[var(--nm-inverse-fg)]/85">
      אם הייתי מפסיק/ת לפחד מ־
      <input
        data-bq-fear
        type="text"
        name="fear_blank"
        autocomplete="off"
        placeholder="למשל: להישאר בלי תשובה"
        class="mx-1 inline-block min-w-[8rem] max-w-full rounded-lg border border-[color-mix(in_srgb,var(--nm-fg)_15%,transparent)] bg-white/90 px-2 py-1 text-[1em] text-[var(--nm-fg)] placeholder:text-[color-mix(in_srgb,var(--nm-fg)_40%,var(--nm-bg))] focus:border-[#128C7E]/50 focus:outline-none focus:ring-2 focus:ring-[#128C7E]/20 dark:border-white/15 dark:bg-[#0a0a0a] dark:text-[var(--nm-inverse-fg)]"
      />
      , הייתי
      <input
        data-bq-would
        type="text"
        name="would_blank"
        autocomplete="off"
        placeholder="למשל: מבקש/ת עזרה אחת קטנה"
        class="mx-1 inline-block min-w-[8rem] max-w-full rounded-lg border border-[color-mix(in_srgb,var(--nm-fg)_15%,transparent)] bg-white/90 px-2 py-1 text-[1em] text-[var(--nm-fg)] placeholder:text-[color-mix(in_srgb,var(--nm-fg)_40%,var(--nm-bg))] focus:border-[#128C7E]/50 focus:outline-none focus:ring-2 focus:ring-[#128C7E]/20 dark:border-white/15 dark:bg-[#0a0a0a] dark:text-[var(--nm-inverse-fg)]"
      />
      .
    </p>
    <button
      type="button"
      data-bq-fill-submit
      data-label-pending="מלאו את שני הריבועים — ואז נפתחת שיחה מיידית עם יקיר"
      data-label-ready="שלח ליקיר לקבלת תובנה"
      disabled
      class="bq-fill-wa-btn w-full rounded-full px-5 py-3 text-[clamp(1rem,0.95rem+0.2vw,1.1rem)] font-semibold transition-colors duration-200 md:w-auto [letter-spacing:0]"
    >
      מלאו את שני הריבועים — ואז נפתחת שיחה מיידית עם יקיר
    </button>
  </form>

  <!-- Context WhatsApp -->
  <div class="mt-8 rounded-2xl border border-[#128C7E]/20 bg-[#DCFCE7]/35 p-5 dark:border-[#128C7E]/30 dark:bg-[#14532D]/20">
    <p class="mb-4 text-[clamp(1rem,0.95rem+0.2vw,1.1rem)] font-medium text-[var(--nm-fg)] dark:text-[var(--nm-inverse-fg)]/90">
      או שאפשר פשוט לפתוח שיחה — וברירת המחדל כבר תזכיר לי
      <span class="font-semibold text-[#075E54] dark:text-[#6EE7B7]">איזה נושא קראת</span>.
    </p>
    <WhatsAppButton variant="inline" tags={tags} articleTitle={articleTitle} />
  </div>
</section>

<style is:global>
  /* מוגבל לתוך .bq-root — tooltips ל-dfn */
  .bq-root .bq-dfn {
    position: relative;
    cursor: help;
    font-style: normal;
    font-weight: 600;
    color: #0f766e;
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 4px;
  }

  .dark .bq-root .bq-dfn {
    color: #6ee7b7;
  }

  .bq-root .bq-dfn::after {
    content: attr(data-def);
    position: absolute;
    z-index: 30;
    right: 0;
    bottom: calc(100% + 10px);
    width: min(18rem, 70vw);
    padding: 0.65rem 0.85rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(26, 26, 26, 0.12);
    background: rgba(255, 255, 255, 0.98);
    color: #1a1a1a;
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.65;
    text-align: right;
    box-shadow: 0 12px 40px rgba(26, 26, 26, 0.12);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.18s ease,
      visibility 0.18s ease;
  }

  .dark .bq-root .bq-dfn::after {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(23, 23, 23, 0.98);
    color: #f5f5f5;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
  }

  .bq-root .bq-dfn:hover::after,
  .bq-root .bq-dfn:focus-visible::after {
    opacity: 1;
    visibility: visible;
  }

  .bq-root .bq-fill-wa-btn {
    background-color: #128c7e;
    color: #ffffff;
    opacity: 0.48;
    cursor: not-allowed;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .bq-root .bq-fill-wa-btn:not(:disabled) {
    opacity: 1;
    cursor: pointer;
  }

  .bq-root .bq-fill-wa-btn:not(:disabled):hover {
    background-color: #0f766e;
  }

  .bq-root .bq-fill-wa-btn:not(:disabled):focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px rgba(18, 140, 126, 0.38);
  }
</style>

<script is:inline define:vars={{ waPhone, readContextLine }}>
  document.addEventListener("astro:page-load", () => {
    if (window.__bqFillCleanup) window.__bqFillCleanup();

    const form = document.querySelector("[data-bq-fill-form]");
    const btn = document.querySelector("[data-bq-fill-submit]");
    const fear = document.querySelector("[data-bq-fear]");
    const would = document.querySelector("[data-bq-would]");
    if (!(form instanceof HTMLFormElement) || !(btn instanceof HTMLButtonElement)) return;
    if (!(fear instanceof HTMLInputElement) || !(would instanceof HTMLInputElement)) return;

    const labelPending = btn.dataset.labelPending || "";
    const labelReady = btn.dataset.labelReady || "";

    const syncButton = () => {
      const ok = fear.value.trim().length > 0 && would.value.trim().length > 0;
      btn.disabled = !ok;
      btn.textContent = ok ? labelReady : labelPending;
    };

    const onClick = () => {
      if (btn.disabled) return;
      const a = fear.value.trim();
      const b = would.value.trim();
      const line = `אם הייתי מפסיק/ת לפחד מ־${a}, הייתי ${b}.`;
      const full = `היי יקיר,\n${readContextLine}\n\n${line}\n\nרציתי תובנה קצרה על המשפט הזה — אפשר להמשיך כאן בשיחה.`;
      const url = `https://wa.me/${waPhone}?text=${encodeURIComponent(full)}`;
      window.open(url, "_blank", "noopener,noreferrer");
    };

    syncButton();
    fear.addEventListener("input", syncButton);
    would.addEventListener("input", syncButton);
    btn.addEventListener("click", onClick);
    window.__bqFillCleanup = () => {
      btn.removeEventListener("click", onClick);
      fear.removeEventListener("input", syncButton);
      would.removeEventListener("input", syncButton);
    };
  });
</script>
