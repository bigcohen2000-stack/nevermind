---
const reportEndpoint = "/api/forms/submit";
const pulseEndpoint = "/api/site/pulse";
const whatsAppDigits = String(Astro.props.whatsAppNumber ?? "").replace(/\D/g, "");
---

<script is:inline define:vars={{ reportEndpoint, pulseEndpoint, whatsAppDigits }}>
  (() => {
    const config = {
      reportEndpoint: typeof reportEndpoint === "string" ? reportEndpoint : "/api/forms/submit",
      pulseEndpoint: typeof pulseEndpoint === "string" ? pulseEndpoint : "/api/site/pulse",
      whatsAppDigits: typeof whatsAppDigits === "string" ? whatsAppDigits : "",
    };

    if (window.__nmIntegrityBooted) {
      window.__nmIntegrityOnRoute?.();
      return;
    }
    window.__nmIntegrityBooted = true;

    const state = {
      revealTimer: null,
      pulseTimer: null,
      lastFocused: null,
      lastSelection: "",
      ui: null,
      ready: false,
    };

    const BRAND_THANKS = "תודה. אתה עוזר לנו לראות את האמת בצורה ברורה יותר. האתר נבנה בסיוע בינה מלאכותית על ידי יקיר כהן, והדיוק שלך עוזר לכולם.";

    const shouldSkipPath = () => /^\/(admin|dashboard|api)(\/|$)/.test(window.location.pathname || "");

    const readSelection = () => {
      try {
        const text = String(window.getSelection?.()?.toString?.() || "").replace(/\s+/g, " ").trim();
        return text.slice(0, 400);
      } catch {
        return "";
      }
    };

    const readContext = () => ({
      url: window.location.href,
      selection: readSelection(),
      note: state.ui?.note instanceof HTMLTextAreaElement ? state.ui.note.value.trim() : "",
    });

    const trackEvent = (name, params = {}) => {
      window.dispatchEvent(new CustomEvent("nm-analytics", { detail: { name, params } }));
    };

    const grantDeepAccess = () => {
      try {
        const now = Date.now();
        const expiresAt = new Date(now + 24 * 60 * 60 * 1000).toISOString();
        window.localStorage.setItem(
          "nm-premium-access",
          JSON.stringify({
            source: "integrity-report",
            grantedAt: new Date(now).toISOString(),
            expiresAt,
          })
        );
        window.dispatchEvent(new CustomEvent("nm-club-session-changed"));
      } catch {
        /* ignore */
      }
    };

    const ensureStyles = () => {
      if (document.getElementById("nm-integrity-style")) return;
      const style = document.createElement("style");
      style.id = "nm-integrity-style";
      style.textContent = `
        .nm-integrity-root {
          position: fixed;
          right: 1rem;
          bottom: 1rem;
          z-index: 70;
          display: flex;
          flex-direction: column;
          align-items: flex-end;
          gap: 0.75rem;
          pointer-events: none;
        }
        .nm-integrity-root[hidden] {
          display: none;
        }
        .nm-integrity-pulse,
        .nm-integrity-button,
        .nm-integrity-panel,
        .nm-integrity-toast {
          pointer-events: auto;
        }
        .nm-integrity-pulse {
          min-height: 2.5rem;
          max-width: min(18rem, calc(100vw - 2rem));
          border-radius: 999px;
          border: 0.5px solid rgba(26, 26, 26, 0.1);
          background: rgba(250, 250, 248, 0.96);
          color: #1A1A1A;
          padding: 0.6rem 0.9rem;
          box-shadow: 0 14px 32px rgba(26, 26, 26, 0.08);
          display: none;
          align-items: center;
          gap: 0.65rem;
          font-size: 0.78rem;
          line-height: 1.4;
          backdrop-filter: blur(18px);
        }
        .nm-integrity-pulse.is-visible {
          display: inline-flex;
        }
        .nm-integrity-pulse strong {
          font-weight: 600;
        }
        .nm-integrity-button {
          width: 48px;
          height: 48px;
          border-radius: 999px;
          border: 0.5px solid rgba(26, 26, 26, 0.12);
          background: #FAFAF8;
          color: #1A1A1A;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          font-size: 0.82rem;
          font-weight: 600;
          box-shadow: 0 14px 36px rgba(26, 26, 26, 0.12);
          opacity: 0;
          transform: translateY(10px);
          transition: opacity 220ms ease, transform 220ms ease, border-color 220ms ease;
        }
        .nm-integrity-button.is-visible {
          opacity: 1;
          transform: translateY(0);
        }
        .nm-integrity-button:hover,
        .nm-integrity-button:focus-visible {
          border-color: rgba(212, 43, 43, 0.2);
          outline: none;
        }
        .nm-integrity-overlay {
          position: fixed;
          inset: 0;
          z-index: 80;
          display: none;
          align-items: center;
          justify-content: center;
          background: rgba(26, 26, 26, 0.24);
          backdrop-filter: blur(10px);
          padding: 1rem;
        }
        .nm-integrity-overlay.is-open {
          display: flex;
        }
        .nm-integrity-panel {
          width: min(32rem, 100%);
          border-radius: 1.75rem;
          border: 0.5px solid rgba(26, 26, 26, 0.1);
          background: rgba(250, 250, 248, 0.98);
          color: #1A1A1A;
          box-shadow: 0 24px 70px rgba(26, 26, 26, 0.14);
          padding: 1.1rem;
        }
        .nm-integrity-panel h2 {
          margin: 0;
          font-size: 1.2rem;
          line-height: 1.3;
        }
        .nm-integrity-copy {
          margin: 0.45rem 0 0;
          font-size: 0.92rem;
          line-height: 1.75;
          color: rgba(26, 26, 26, 0.72);
        }
        .nm-integrity-field {
          display: grid;
          gap: 0.35rem;
        }
        .nm-integrity-field-label {
          font-size: 0.76rem;
          color: rgba(26, 26, 26, 0.62);
        }
        .nm-integrity-preview,
        .nm-integrity-note {
          width: 100%;
          border-radius: 1rem;
          border: 0.5px solid rgba(26, 26, 26, 0.1);
          background: rgba(255, 255, 255, 0.72);
          color: #1A1A1A;
          padding: 0.85rem 0.95rem;
          font: inherit;
          line-height: 1.7;
          resize: none;
        }
        .nm-integrity-preview {
          min-height: 4.5rem;
        }
        .nm-integrity-note {
          min-height: 5.6rem;
        }
        .nm-integrity-url {
          border-radius: 999px;
          border: 0.5px solid rgba(26, 26, 26, 0.1);
          background: rgba(26, 26, 26, 0.04);
          padding: 0.55rem 0.85rem;
          font-size: 0.8rem;
          line-height: 1.5;
          word-break: break-all;
        }
        .nm-integrity-actions {
          display: flex;
          flex-wrap: wrap;
          justify-content: flex-end;
          gap: 0.65rem;
        }
        .nm-integrity-action,
        .nm-integrity-close,
        .nm-integrity-deep-link {
          min-height: 44px;
          border-radius: 999px;
          border: 0.5px solid rgba(26, 26, 26, 0.12);
          background: transparent;
          color: #1A1A1A;
          padding: 0.7rem 1rem;
          font: inherit;
          font-size: 0.92rem;
          font-weight: 600;
        }
        .nm-integrity-action[data-kind="primary"],
        .nm-integrity-deep-link {
          border-color: rgba(212, 43, 43, 0.18);
          background: rgba(212, 43, 43, 0.06);
          color: #D42B2B;
        }
        .nm-integrity-status,
        .nm-integrity-thanks {
          font-size: 0.86rem;
          line-height: 1.7;
          color: rgba(26, 26, 26, 0.72);
        }
        .nm-integrity-thanks {
          display: none;
          padding-top: 0.35rem;
        }
        .nm-integrity-thanks.is-visible {
          display: block;
        }
        .nm-integrity-toast {
          display: none;
          max-width: min(20rem, calc(100vw - 2rem));
          border-radius: 1.1rem;
          border: 0.5px solid rgba(26, 26, 26, 0.1);
          background: rgba(250, 250, 248, 0.98);
          padding: 0.8rem 0.95rem;
          font-size: 0.82rem;
          line-height: 1.65;
          box-shadow: 0 16px 40px rgba(26, 26, 26, 0.12);
        }
        .nm-integrity-toast.is-visible {
          display: block;
        }
        @media (max-width: 640px) {
          .nm-integrity-root {
            right: 0.75rem;
            bottom: 0.75rem;
          }
          .nm-integrity-panel {
            border-radius: 1.35rem;
            padding: 0.95rem;
          }
          .nm-integrity-pulse {
            max-width: calc(100vw - 1.5rem);
          }
        }
        @media (prefers-reduced-motion: reduce) {
          .nm-integrity-button {
            transition: none;
          }
        }
      `;
      document.head.appendChild(style);
    };

    const ensureUi = () => {
      if (state.ui) return state.ui;
      ensureStyles();

      const root = document.createElement("div");
      root.className = "nm-integrity-root";
      root.hidden = true;

      const pulse = document.createElement("div");
      pulse.className = "nm-integrity-pulse";
      pulse.setAttribute("aria-live", "polite");
      pulse.innerHTML = '<strong>כרגע באתר</strong><span data-pulse-body>ממתין לעדכון</span>';

      const button = document.createElement("button");
      button.type = "button";
      button.className = "nm-integrity-button";
      button.textContent = "דיוק";
      button.setAttribute("aria-label", "דיווח על טעות בטקסט");

      const toast = document.createElement("div");
      toast.className = "nm-integrity-toast";
      toast.setAttribute("aria-live", "polite");

      const overlay = document.createElement("div");
      overlay.className = "nm-integrity-overlay";
      overlay.innerHTML = `
        <section class="nm-integrity-panel" role="dialog" aria-modal="true" aria-labelledby="nm-integrity-title">
          <div style="display:grid;gap:1rem;">
            <header style="display:grid;gap:0.4rem;">
              <h2 id="nm-integrity-title">דיווח על טעות בטקסט</h2>
              <p class="nm-integrity-copy">אם משהו לא יושב נכון, אפשר לשלוח לנו את הקישור ואת הקטע שסומן. כך הדיוק של האתר נשמר שקט וברור.</p>
            </header>

            <div class="nm-integrity-field">
              <span class="nm-integrity-field-label">העמוד</span>
              <div class="nm-integrity-url" data-integrity-url></div>
            </div>

            <div class="nm-integrity-field">
              <span class="nm-integrity-field-label">הקטע שסומן</span>
              <div class="nm-integrity-preview" data-integrity-selection></div>
            </div>

            <label class="nm-integrity-field">
              <span class="nm-integrity-field-label">מה נכון יותר, אם תרצה לכתוב</span>
              <textarea class="nm-integrity-note" data-integrity-note placeholder="אפשר לכתוב תיקון קצר או הקשר"></textarea>
            </label>

            <div class="nm-integrity-actions">
              <button type="button" class="nm-integrity-action" data-kind="primary" data-integrity-wa>שלח בוואטסאפ</button>
              <button type="button" class="nm-integrity-action" data-integrity-email>שלח במייל</button>
              <button type="button" class="nm-integrity-close" data-integrity-close>סגור</button>
            </div>

            <p class="nm-integrity-status" data-integrity-status>${BRAND_THANKS}</p>
            <div class="nm-integrity-thanks" data-integrity-thanks>
              <p style="margin:0;">תודה על הדיווח ❤️ פתחנו לך גישה זמנית לארכיון העומק.</p>
              <div style="display:flex;justify-content:flex-end;padding-top:0.65rem;">
                <a class="nm-integrity-deep-link" href="/forbidden-library/">פתח את ארכיון העומק</a>
              </div>
            </div>
          </div>
        </section>
      `;

      root.append(pulse, button, toast);
      document.body.append(root, overlay);

      state.ui = {
        root,
        pulse,
        pulseBody: pulse.querySelector("[data-pulse-body]"),
        button,
        toast,
        overlay,
        panel: overlay.querySelector(".nm-integrity-panel"),
        url: overlay.querySelector("[data-integrity-url]"),
        selection: overlay.querySelector("[data-integrity-selection]"),
        note: overlay.querySelector("[data-integrity-note]"),
        status: overlay.querySelector("[data-integrity-status]"),
        thanks: overlay.querySelector("[data-integrity-thanks]"),
        close: overlay.querySelector("[data-integrity-close]"),
        email: overlay.querySelector("[data-integrity-email]"),
        wa: overlay.querySelector("[data-integrity-wa]"),
      };

      button.addEventListener("click", () => openModal());
      overlay.addEventListener("click", (event) => {
        if (event.target === overlay) closeModal();
      });
      state.ui.close?.addEventListener("click", closeModal);
      state.ui.wa?.addEventListener("click", () => {
        void sendViaWhatsApp();
      });
      state.ui.email?.addEventListener("click", () => {
        void sendViaEmail();
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && overlay.classList.contains("is-open")) {
          closeModal();
        }
      });

      return state.ui;
    };

    const setButtonVisible = (visible) => {
      const ui = ensureUi();
      ui.root.hidden = shouldSkipPath();
      if (shouldSkipPath()) {
        ui.button.classList.remove("is-visible");
        return;
      }
      ui.button.classList.toggle("is-visible", visible);
    };

    const showToast = (message) => {
      const ui = ensureUi();
      ui.toast.textContent = message;
      ui.toast.classList.add("is-visible");
      window.clearTimeout(ui.toastTimer);
      ui.toastTimer = window.setTimeout(() => {
        ui.toast.classList.remove("is-visible");
      }, 3200);
    };

    const updateModalContext = () => {
      const ui = ensureUi();
      const context = readContext();
      ui.url.textContent = context.url;
      ui.selection.textContent = context.selection || "לא סומן קטע. אפשר גם לפתוח את החלון בלי סימון.";
      state.lastSelection = context.selection;
    };

    const openModal = () => {
      if (shouldSkipPath()) return;
      const ui = ensureUi();
      state.lastFocused = document.activeElement;
      updateModalContext();
      ui.overlay.classList.add("is-open");
      ui.thanks.classList.remove("is-visible");
      ui.note?.focus();
    };

    const closeModal = () => {
      const ui = ensureUi();
      ui.overlay.classList.remove("is-open");
      if (state.lastFocused instanceof HTMLElement) {
        state.lastFocused.focus({ preventScroll: true });
      }
    };

    const buildMessage = () => {
      const { url, selection, note } = readContext();
      const selectionLine = selection ? `הקטע שסומן: ${selection}` : "לא סומן קטע";
      const noteLine = note ? `הערה: ${note}` : "";
      return [
        "היי, מצאתי משהו שכדאי לבדוק ב-NeverMind.",
        `עמוד: ${url}`,
        selectionLine,
        noteLine,
      ]
        .filter(Boolean)
        .join("\n");
    };

    const markThanks = (channel) => {
      const ui = ensureUi();
      grantDeepAccess();
      ui.thanks.classList.add("is-visible");
      showToast("הגישה הזמנית לארכיון העומק נפתחה.");
      window.__nmAnnounce?.("תודה על הדיווח");
      trackEvent("integrity_report_submit", {
        channel,
        page_path: window.location.pathname,
      });
    };

    const sendViaWhatsApp = async () => {
      if (!config.whatsAppDigits) {
        showToast("חיבור הוואטסאפ לא זמין כרגע.");
        return;
      }
      const message = buildMessage();
      const url = `https://wa.me/${encodeURIComponent(config.whatsAppDigits)}?text=${encodeURIComponent(message)}`;
      window.open(url, "_blank", "noopener,noreferrer");
      markThanks("whatsapp");
      closeModal();
    };

    const sendViaEmail = async () => {
      const ui = ensureUi();
      const message = buildMessage();
      const form = new FormData();
      form.set("subject", "דיווח דיוק מהאתר");
      form.set("from_name", "דיווח דיוק");
      form.set("message", `${message}\n\n${BRAND_THANKS}`);
      form.set("page_url", window.location.href);
      form.set("selected_text", readContext().selection || "");
      form.set("botcheck", "");

      const emailButton = ui.email;
      if (emailButton instanceof HTMLButtonElement) {
        emailButton.disabled = true;
      }

      try {
        const response = await fetch(config.reportEndpoint, {
          method: "POST",
          body: form,
        });
        const payload = await response.json().catch(() => null);
        if (!response.ok || payload?.ok !== true) {
          throw new Error("submit_failed");
        }
        markThanks("email");
        closeModal();
      } catch {
        showToast("לא הצלחנו לשלוח את הדיווח כרגע.");
      } finally {
        if (emailButton instanceof HTMLButtonElement) {
          emailButton.disabled = false;
        }
      }
    };

    const refreshPulse = async () => {
      const ui = ensureUi();
      if (shouldSkipPath()) {
        ui.pulse.classList.remove("is-visible");
        return;
      }
      try {
        const response = await fetch(config.pulseEndpoint, {
          headers: { accept: "application/json" },
          cache: "no-store",
        });
        const payload = await response.json().catch(() => null);
        if (!response.ok || !payload?.ok) {
          ui.pulse.classList.remove("is-visible");
          return;
        }
        const activeNow = Number(payload.activeNow) || 0;
        const recentRequests = Number(payload.recentRequests) || 0;
        ui.pulseBody.textContent = `${activeNow} · ${payload.mood || "תנועה חיה"}`;
        ui.pulse.title = `לפי ${recentRequests} בקשות ב-${payload.windowMinutes || 3} הדקות האחרונות`;
        ui.pulse.classList.add("is-visible");
      } catch {
        ui.pulse.classList.remove("is-visible");
      }
    };

    const scheduleReveal = () => {
      window.clearTimeout(state.revealTimer);
      state.revealTimer = window.setTimeout(() => {
        if (!readSelection()) {
          setButtonVisible(true);
        }
      }, 8000);
    };

    const onSelectionChange = () => {
      const selection = readSelection();
      if (selection) {
        state.lastSelection = selection;
        setButtonVisible(true);
        if (state.ui?.overlay?.classList.contains("is-open")) {
          updateModalContext();
        }
      }
    };

    const onRoute = () => {
      const ui = ensureUi();
      ui.root.hidden = shouldSkipPath();
      if (shouldSkipPath()) {
        closeModal();
        ui.pulse.classList.remove("is-visible");
        ui.button.classList.remove("is-visible");
        return;
      }
      if (ui.note instanceof HTMLTextAreaElement) {
        ui.note.value = "";
      }
      scheduleReveal();
      void refreshPulse();
    };

    window.__nmIntegrityOnRoute = onRoute;
    document.addEventListener("selectionchange", onSelectionChange);
    document.addEventListener("astro:page-load", onRoute);
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible") {
        void refreshPulse();
      }
    });

    state.pulseTimer = window.setInterval(() => {
      void refreshPulse();
    }, 45000);

    ensureUi();
    onRoute();
  })();
</script>
