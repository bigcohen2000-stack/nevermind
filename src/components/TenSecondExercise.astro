---
interface Props {
  text: string;
}

const { text } = Astro.props as Props;
const cleanText = String(text || "").trim();
---

<section
  class="mx-auto max-w-[72ch] rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[color-mix(in_srgb,var(--nm-tint)_22%,transparent)] px-5 py-4 text-right shadow-sm"
  aria-label="תרגיל 10 שניות"
>
  <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">תרגיל 10 שניות</p>
  <h2 class="mt-2 text-[clamp(1.2rem,1.05rem+0.45vw,1.45rem)] font-semibold text-[var(--nm-fg)]">
    עכשיו. בלי נאום.
  </h2>
  <p class="mt-3 text-[clamp(0.98rem,0.93rem+0.2vw,1.08rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_88%,var(--nm-bg))]">
    10 שניות. קח נשימה. כתוב לעצמך את המשפט הזה:
  </p>
  {cleanText ? (
    <div class="mt-3 rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white/75 px-4 py-3">
      <p class="leading-8 text-[var(--nm-fg)]">{cleanText}</p>
    </div>
  ) : null}
</section>

