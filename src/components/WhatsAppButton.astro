---
import appConfig from "../config/appConfig.json";
import { buildArticleContextLeadMessage } from "../lib/services";

export interface Props {
  /** ождд ееаисаф бмй + (мощм 9725...) */
  phone?: string;
  /** оъек frontmatter — ъв шащеп мичси дмйг */
  tags?: string[];
  /** аефцйермй б-MDX: реща бочен отшк tags */
  topic?: string;
  /** леъшъ оаош мвйбей */
  articleTitle?: string;
  /** fab = цу; inline = бъек дъелп */
  variant?: "fab" | "inline";
  /** ичси млфъеш б-inline */
  label?: string;
}

const {
  phone = appConfig.contact.whatsAppNumber,
  tags = [],
  topic = "",
  articleTitle = "",
  variant = "fab",
  label = "щмз дегтд мйчйш бееаисаф",
} = Astro.props;

const leadMessage = buildArticleContextLeadMessage({ tags, topic, articleTitle });

const baseWa = `https://wa.me/${phone}`;
const hrefWithText = `${baseWa}?text=${encodeURIComponent(leadMessage)}`;
const prefillEncoded = encodeURIComponent(leadMessage);
---

{
  variant === "inline" ? (
    <a
      href={hrefWithText}
      target="_blank"
      rel="noreferrer"
      class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-[#128C7E]/30 bg-[#25D366]/15 px-5 py-3 text-sm font-semibold text-[#075E54] transition-colors hover:bg-[#25D366]/25 [letter-spacing:0]"
      aria-label={label}
    >
      <span aria-hidden="true">??</span>
      {label}
    </a>
  ) : (
    <a
      data-whatsapp
      data-wa-base={baseWa}
      data-wa-prefill={prefillEncoded}
      href={hrefWithText}
      target="_blank"
      rel="noreferrer"
      aria-label="йцйшъ чщш бееаисаф"
      class="fixed bottom-6 left-6 z-40 flex h-10 w-10 items-center justify-center rounded-full bg-white/70 shadow-sm backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-500"
    >
      <span class="block h-2 w-2 rounded-full bg-[#1A1A1A]/45" />
    </a>
  )
}

{variant === "fab" && (
  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      if (window.__nmWhatsappCleanup) {
        window.__nmWhatsappCleanup();
      }

      const whatsappButton = document.querySelector("[data-whatsapp]");
      const base = whatsappButton?.getAttribute("data-wa-base") ?? "";
      const prefillAttr = whatsappButton?.getAttribute("data-wa-prefill") ?? "";

      const updateWhatsappVisibility = () => {
        if (!whatsappButton) return;
        const doc = document.documentElement;
        const scrollTop = doc.scrollTop || document.body.scrollTop;
        const scrollHeight = doc.scrollHeight - doc.clientHeight;
        const progress = scrollHeight > 0 ? scrollTop / scrollHeight : 0;
        const shouldShow = progress >= 0.5;

        whatsappButton.classList.toggle("opacity-100", shouldShow);
        whatsappButton.classList.toggle("pointer-events-auto", shouldShow);
      };

      const updateWhatsappHref = () => {
        if (!whatsappButton || !base) return;
        let message = "";
        try {
          message = prefillAttr ? decodeURIComponent(prefillAttr) : "";
        } catch {
          message = "";
        }
        if (!message) {
          const rawTitle = document.title ? document.title.split("|")[0].trim() : "NeverMind";
          const pageTitle = rawTitle || "NeverMind";
          message = `дйй, двтъй одтоег ${pageTitle}, еащоз мбгеч йзг од рлеп лап.`;
        }
        const encoded = encodeURIComponent(message);
        whatsappButton.setAttribute("href", `${base}?text=${encoded}`);
      };

      updateWhatsappHref();
      document.addEventListener("scroll", updateWhatsappVisibility, { passive: true });
      updateWhatsappVisibility();

      window.__nmWhatsappCleanup = () => {
        document.removeEventListener("scroll", updateWhatsappVisibility);
      };
    });
  </script>
)}
