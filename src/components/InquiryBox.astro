---
const { title = "שאלת חקירה" } = Astro.props;
---
<aside
  class="rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/70 p-[clamp(1.25rem,2vw,2rem)] shadow-sm backdrop-blur-md"
  role="note"
  aria-label={title}
>
  <p class="text-[clamp(0.85rem,0.8rem+0.25vw,1rem)] text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">
    {title}
  </p>
  <div
    class="mt-3 text-[clamp(1rem,0.95rem+0.3vw,1.2rem)] leading-[1.8] text-[var(--nm-fg)]/75"
  >
    <slot />
  </div>
</aside>
