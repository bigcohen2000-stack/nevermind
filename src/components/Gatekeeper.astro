---
import appConfig from "../config/appConfig.json";
import { FloatingInput } from "./ui/FloatingInput";

interface Props {
  phone?: string;
  fallbackHref?: string;
  fallbackLabel?: string;
}

const {
  phone = appConfig.contact.whatsAppNumber,
  fallbackHref = "/articles/",
  fallbackLabel = "חזרה לארכיון",
} = Astro.props;

const goals = [
  { id: "clarity", label: "בהירות", hint: "מה נכון לראות עכשיו בלי רעש", score: 24, reason: "כשהמטרה היא להפריד עובדה מפירוש ולהחזיר מבנה." },
  { id: "decision", label: "החלטה", hint: "מה אתה דוחה ומתי אתה זז", score: 22, reason: "כשאתה רוצה תנועה במקום עוד עיבוד בלי פעולה." },
  { id: "business", label: "תוכן והשפעה", hint: "מוצר תוכן שמחזיק מעמד", score: 26, reason: "כשאתה צריך תיעוד או מסגרת לבניית סמכות דרך תוכן." },
  { id: "not-sure", label: "לא בטוח עדיין", hint: "צריך מסגרת בדיקה קצרה", score: 6, reason: "כשיש סימנים אבל אין החלטה. עדיין לא צריך להתחייב." },
];

const budgets = [
  { id: "under-500", label: "עד 500 ₪", score: 2, reason: "מתאים לשלב בדיקה קצר. תנועה קטנה לפני התחייבות." },
  { id: "500-1500", label: "500–1,500 ₪", score: 12, reason: "מתאים למסגרת מצומצמת שמחזירה בהירות." },
  { id: "1500-3000", label: "1,500–3,000 ₪", score: 24, reason: "מתאים לעומק משמעותי עם פעולה ברורה." },
  { id: "3000-plus", label: "3,000+ ₪", score: 28, reason: "מתאים למסלול עם השפעה חיצונית או תוצר תוכן." },
];

const stages = [
  { id: "browsing", label: "רק בודק כיוון", score: 4, reason: "צריך לנקות רעש לפני החלטה. עדיין לא חייבים לבחור מסלול מלא." },
  { id: "active", label: "כבר בפעולה", score: 20, reason: "יש רצון לתרגם תובנה לפעולה. עכשיו צריך מבנה נכון." },
  { id: "urgent", label: "דחוף עכשיו", score: 24, reason: "הזמן לוחץ. צריך מיקוד שמייצר תנועה מהירה." },
];

const maxScore =
  Math.max(...goals.map((goal) => goal.score)) +
  Math.max(...budgets.map((budget) => budget.score)) +
  Math.max(...stages.map((stage) => stage.score));
---

<section
  data-gatekeeper
  data-phone={phone}
  data-fallback-href={fallbackHref}
  data-fallback-label={fallbackLabel}
  data-max-score={maxScore}
  class="mx-auto max-w-3xl rounded-[2.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)]/90 p-6 shadow-[0_30px_90px_color-mix(in_srgb,var(--nm-fg)_8%,transparent)] backdrop-blur-md md:p-8"
>
  <header class="space-y-4 text-right">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-[var(--nm-accent)]">Gatekeeper</p>
    <h1 class="text-[clamp(2rem,1.4rem+2vw,3.3rem)] font-semibold leading-[1.05] text-[var(--nm-fg)]">בוא נבדוק אם זו השיחה הנכונה עכשיו.</h1>
    <p class="max-w-2xl text-[1rem] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
      שלושה סימונים קצרים. בסוף תקבל כיוון פעולה אחד שתוכל לבדוק כבר עכשיו.
    </p>
  </header>

  <div class="mt-8 flex gap-2" aria-hidden="true">
    <span data-step-dot="1" class="h-1 flex-1 rounded-full bg-[var(--nm-accent)]"></span>
    <span data-step-dot="2" class="h-1 flex-1 rounded-full bg-[var(--nm-inverse)]/10"></span>
    <span data-step-dot="3" class="h-1 flex-1 rounded-full bg-[var(--nm-inverse)]/10"></span>
  </div>

  <div class="mt-8 space-y-8">
    <section data-step-panel="1" class="space-y-6">
      <div class="space-y-2 text-right">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">שלב 1 מתוך 3</p>
        <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">מה המטרה שלך בשיחה?</h2>
      </div>

      <FloatingInput
        client:load
        id="nm-gatekeeper-name"
        name="gatekeeper_name"
        label="איך לפנות אליך בשם"
        dataNameInput={true}
        hideValidation={true}
        className="[&_.nm-floating-control]:bg-[var(--nm-surface-muted)]"
      />


      <div class="space-y-3 text-right">
        <p class="text-sm font-semibold text-[var(--nm-fg)]">מה אתה רוצה להשיג?</p>
        <div class="grid gap-3">
          {goals.map((goal) => (
            <button
              type="button"
              data-goal={goal.label}
              data-goal-id={goal.id}
              data-goal-score={goal.score}
              data-goal-reason={goal.reason}
              class="gate-option rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-5 py-4 text-right transition hover:border-[color-mix(in_srgb,var(--nm-accent)_28%,transparent)] hover:bg-[var(--nm-bg-canvas)]"
            >
              <span class="block text-base font-semibold text-[var(--nm-fg)]">{goal.label}</span>
              <span class="mt-1 block text-sm leading-7 text-[var(--nm-fg)]/62">{goal.hint}</span>
            </button>
          ))}
        </div>
      </div>
    </section>

    <section data-step-panel="2" class="hidden space-y-6">
      <div class="space-y-2 text-right">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">שלב 2 מתוך 3</p>
        <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">איך נראה התקציב שאתה מחפש?</h2>
      </div>
      <div class="grid gap-3 text-right">
        {budgets.map((budget) => (
          <button
            type="button"
            data-budget={budget.label}
            data-budget-id={budget.id}
            data-budget-score={budget.score}
            data-budget-reason={budget.reason}
            class="gate-option rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-5 py-4 text-right transition hover:border-[color-mix(in_srgb,var(--nm-accent)_28%,transparent)] hover:bg-[var(--nm-bg-canvas)]"
          >
            <span class="block text-base font-semibold text-[var(--nm-fg)]">{budget.label}</span>
          </button>
        ))}
      </div>
      <button type="button" data-back-step="1" class="text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))] transition hover:text-[var(--nm-fg)]">חזרה לשלב 1</button>
    </section>

    <section data-step-panel="3" class="hidden space-y-6">
      <div class="space-y-2 text-right">
        <p class="text-sm font-semibold text-[var(--nm-accent)]">שלב 3 מתוך 3</p>
        <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">מה הקצב שאתה צריך עכשיו?</h2>
      </div>
      <div class="grid gap-3 text-right">
        {stages.map((stage) => (
          <button
            type="button"
            data-stage={stage.label}
            data-stage-id={stage.id}
            data-stage-score={stage.score}
            data-stage-reason={stage.reason}
            class="gate-option rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-5 py-4 text-right transition hover:border-[color-mix(in_srgb,var(--nm-accent)_28%,transparent)] hover:bg-[var(--nm-bg-canvas)]"
          >
            <span class="block text-base font-semibold text-[var(--nm-fg)]">{stage.label}</span>
          </button>
        ))}
      </div>
      <button type="button" data-back-step="2" class="text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))] transition hover:text-[var(--nm-fg)]">חזרה לשלב 2</button>
    </section>

    <section data-result-panel class="hidden rounded-[1.8rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-6 text-right">
      <p data-result-badge class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">תוצאה</p>
      <div class="mt-4 overflow-hidden rounded-full bg-[var(--nm-inverse)]/8">
        <div data-score-bar class="h-2 w-0 rounded-full bg-[var(--nm-accent)] transition-all duration-500"></div>
      </div>
      <p data-score-text class="mt-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]"></p>
      <h2 data-result-title class="mt-3 text-2xl font-semibold text-[var(--nm-fg)]"></h2>
      <p data-result-text class="mt-3 max-w-2xl text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]"></p>
      <ul data-reasons-list class="mt-5 space-y-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]"></ul>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:justify-end">
        <a data-whatsapp-link target="_blank" rel="noreferrer" class="hidden items-center justify-center rounded-full bg-[var(--nm-inverse)] px-6 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">פתיחת שיחה בוואטסאפ</a>
        <a data-fallback-link class="hidden items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-6 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">חזרה לארכיון לפי סימנים</a>
        <button type="button" data-reset-gatekeeper class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-6 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">איפוס</button>
      </div>
    </section>
  </div>
</section>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const root = document.querySelector("[data-gatekeeper]");
    if (!(root instanceof HTMLElement)) return;

    const state = {
      step: 1,
      name: "",
      goal: "",
      goalId: "",
      goalScore: 0,
      goalReason: "",
      budget: "",
      budgetId: "",
      budgetScore: 0,
      budgetReason: "",
      stage: "",
      stageId: "",
      stageScore: 0,
      stageReason: "",
    };

    const phone = root.dataset.phone || "972555634035";
    const fallbackHref = root.dataset.fallbackHref || "/articles/";
    const fallbackLabel = root.dataset.fallbackLabel || "חזרה לארכיון";
    const maxScore = Number(root.dataset.maxScore || 78);
    const nameInput = root.querySelector("[data-name-input]");
    const panels = Array.from(root.querySelectorAll("[data-step-panel]"));
    const dots = Array.from(root.querySelectorAll("[data-step-dot]"));
    const resultPanel = root.querySelector("[data-result-panel]");
    const resultBadge = root.querySelector("[data-result-badge]");
    const scoreBar = root.querySelector("[data-score-bar]");
    const scoreText = root.querySelector("[data-score-text]");
    const resultTitle = root.querySelector("[data-result-title]");
    const resultText = root.querySelector("[data-result-text]");
    const reasonsList = root.querySelector("[data-reasons-list]");
    const whatsappLink = root.querySelector("[data-whatsapp-link]");
    const fallbackLink = root.querySelector("[data-fallback-link]");
    const resetButton = root.querySelector("[data-reset-gatekeeper]");

    const setStep = (step) => {
      state.step = step;
      panels.forEach((panel) => {
        if (!(panel instanceof HTMLElement)) return;
        panel.classList.toggle("hidden", panel.dataset.stepPanel !== String(step));
      });
      dots.forEach((dot, index) => {
        if (!(dot instanceof HTMLElement)) return;
        dot.classList.toggle("bg-[var(--nm-accent)]", index < step);
        dot.classList.toggle("bg-[var(--nm-inverse)]/10", index >= step);
      });
      if (resultPanel instanceof HTMLElement) resultPanel.classList.add("hidden");
    };

    const getScore = () => state.goalScore + state.budgetScore + state.stageScore;

    const getTier = () => {
      const score = getScore();
      if (score >= 52) return "fit";
      if (score >= 35) return "partial";
      return "not-fit";
    };

    const buildWhatsAppHref = () => {
      const safeName = state.name || "אורח";
      const text = `Hi, I'm ${safeName}, I'm interested in ${state.goal} and I'm at the ${state.stage} stage.`;
      return `https://wa.me/${phone}?text=${encodeURIComponent(text)}`;
    };

    const renderReasons = () => {
      if (!(reasonsList instanceof HTMLElement)) return;
      const reasons = [state.goalReason, state.budgetReason, state.stageReason].filter(Boolean);
      reasonsList.innerHTML = reasons
        .map((reason) => `<li class="rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] bg-[color-mix(in_srgb,var(--nm-bg-canvas)_88%,transparent)] px-4 py-3">${reason}</li>`)
        .join("");
    };

    const showResult = () => {
      panels.forEach((panel) => panel instanceof HTMLElement && panel.classList.add("hidden"));
      dots.forEach((dot) => {
        if (!(dot instanceof HTMLElement)) return;
        dot.classList.remove("bg-[var(--nm-accent)]");
        dot.classList.add("bg-[var(--nm-inverse)]/10");
      });

      if (!(resultPanel instanceof HTMLElement) || !(resultBadge instanceof HTMLElement) || !(scoreBar instanceof HTMLElement) || !(scoreText instanceof HTMLElement) || !(resultTitle instanceof HTMLElement) || !(resultText instanceof HTMLElement) || !(whatsappLink instanceof HTMLAnchorElement) || !(fallbackLink instanceof HTMLAnchorElement)) {
        return;
      }

      resultPanel.classList.remove("hidden");
      const score = getScore();
      const tier = getTier();
      const scorePercent = Math.max(0, Math.min(100, (score / maxScore) * 100));
      scoreBar.style.width = `${scorePercent}%`;
      scoreText.textContent = `ציון התאמה: ${score} / ${maxScore}`;
      renderReasons();

      if (tier === "fit") {
        resultBadge.textContent = "תוצאה מלאה";
        resultTitle.textContent = "התאמה טובה עכשיו.";
        resultText.textContent = "�����, ������ ����� ��� ����� ������ ��� ����� ����� ���� ������� ��� ����� ��� �� ����� ���� �� �����.";
        whatsappLink.href = buildWhatsAppHref();
        whatsappLink.classList.remove("hidden");
        whatsappLink.classList.add("inline-flex");
        fallbackLink.classList.add("hidden");
        fallbackLink.classList.remove("inline-flex");
        resultText.textContent = "הבחירות שלך מצביעות על התאמה לפעולה עכשיו. לחץ על פתיחת שיחה בוואטסאפ כדי להתקדם עם צעד אחד.";
        return;
      }

      if (tier === "partial") {
        resultBadge.textContent = "תוצאה חלקית";
        resultTitle.textContent = "זה יכול להתאים, אבל לא בדיוק עכשיו.";
        resultText.textContent = "���� �� ����� ����� ����. ���� ����� ���� ��� ���� ����, ��� �� ���� ����, ����� ����� ����� �� ����.";
        fallbackLink.href = fallbackHref;
        fallbackLink.textContent = fallbackLabel;
        fallbackLink.classList.remove("hidden");
        fallbackLink.classList.add("inline-flex");
        whatsappLink.classList.add("hidden");
        whatsappLink.classList.remove("inline-flex");
        resultText.textContent =
          "יש התאמה לכיוון. אם מתאים לך לחדד ולסדר מבנה לפני פעולה, חזור לארכיון או חזור לסימון מחדש.";
        return;
      }

      resultBadge.textContent = "לא מתאים כרגע";
      resultTitle.textContent = "כנראה עדיין לא זה הזמן.";
      resultText.textContent = "�� �� ���� ���� �����. �� �� ���� ����� ���� ������ ������ ���� �� ������ ���� ���� ���� ����� �����.";
      fallbackLink.href = fallbackHref;
      fallbackLink.textContent = fallbackLabel;
      fallbackLink.classList.remove("hidden");
      fallbackLink.classList.add("inline-flex");
      whatsappLink.classList.add("hidden");
      whatsappLink.classList.remove("inline-flex");
      resultText.textContent =
        "הסימונים שלך מראים מצב שמקדים הבהרה לפני פעולה. כרגע לך על חזרה לארכיון או חזור לסימון מחדש.";
    };

    root.querySelectorAll("[data-goal-id]").forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLElement)) return;
        state.name = nameInput instanceof HTMLInputElement ? nameInput.value.trim() : "";
        state.goal = button.dataset.goal || "";
        state.goalId = button.dataset.goalId || "";
        state.goalScore = Number(button.dataset.goalScore || 0);
        state.goalReason = button.dataset.goalReason || "";
        setStep(2);
      });
    });

    root.querySelectorAll("[data-budget-id]").forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLElement)) return;
        state.budget = button.dataset.budget || "";
        state.budgetId = button.dataset.budgetId || "";
        state.budgetScore = Number(button.dataset.budgetScore || 0);
        state.budgetReason = button.dataset.budgetReason || "";
        setStep(3);
      });
    });

    root.querySelectorAll("[data-stage-id]").forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLElement)) return;
        state.stage = button.dataset.stage || "";
        state.stageId = button.dataset.stageId || "";
        state.stageScore = Number(button.dataset.stageScore || 0);
        state.stageReason = button.dataset.stageReason || "";
        showResult();
      });
    });

    root.querySelectorAll("[data-back-step]").forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLElement)) return;
        const target = Number(button.dataset.backStep || 1);
        setStep(target);
      });
    });

    resetButton?.addEventListener("click", () => {
      state.step = 1;
      state.name = "";
      state.goal = "";
      state.goalId = "";
      state.goalScore = 0;
      state.goalReason = "";
      state.budget = "";
      state.budgetId = "";
      state.budgetScore = 0;
      state.budgetReason = "";
      state.stage = "";
      state.stageId = "";
      state.stageScore = 0;
      state.stageReason = "";
      if (nameInput instanceof HTMLInputElement) nameInput.value = "";
      if (reasonsList instanceof HTMLElement) reasonsList.innerHTML = "";
      if (scoreBar instanceof HTMLElement) scoreBar.style.width = "0%";
      setStep(1);
    });
  });
</script>

