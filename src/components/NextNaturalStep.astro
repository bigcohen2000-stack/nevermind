---
interface NextTarget {
  kind: "article" | "service";
  href: string;
  title: string;
  description: string;
  label?: string;
}

interface Props {
  heading?: string;
  currentDifficultyLabel: string;
  next: NextTarget;
  secondary?: NextTarget[];
}

const { heading = "השלב הבא שלך", currentDifficultyLabel, next, secondary = [] } = Astro.props as Props;
---

<section class="mx-auto max-w-[72ch] space-y-4" aria-label="המשך טבעי">
  <div class="space-y-2 text-right">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">המשך טבעי</p>
    <h2 class="text-[clamp(1.4rem,1.15rem+1vw,2rem)] font-semibold text-[var(--nm-fg)]">{heading}</h2>
    <p class="text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] text-[var(--nm-fg)]/65">
      לפי רמת העומק: {currentDifficultyLabel}
    </p>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <a
      href={next.href}
      class="group flex h-full flex-col justify-between gap-3 rounded-3xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/75 px-5 py-4 text-right shadow-sm transition-all duration-500 hover:-translate-y-[2px] hover:bg-white"
      aria-label={`המשך: ${next.title}`}
    >
      <div class="space-y-2">
        {next.label ? (
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">{next.label}</p>
        ) : null}
        <span class="font-semibold text-[var(--nm-fg)]">{next.title}</span>
        <span class="block text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">{next.description}</span>
      </div>
      <span class="inline-flex items-center justify-end gap-2 text-sm font-semibold text-[var(--nm-accent)] transition group-hover:opacity-90">
        המשך עכשיו <span aria-hidden="true">→</span>
      </span>
    </a>

    {secondary.length > 0 ? (
      <div class="space-y-3 md:col-span-2 lg:col-span-1">
        {secondary.slice(0, 2).map((s) => (
          <a
            href={s.href}
            class="flex items-start justify-between gap-3 rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/70 px-4 py-3 text-right transition hover:bg-white"
            aria-label={`אפשרות נוספת: ${s.title}`}
          >
            <span class="min-w-0 flex-1 overflow-hidden">
              {s.label ? (
                <span class="block text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">
                  {s.label}
                </span>
              ) : null}
              <span class="block truncate font-semibold text-[var(--nm-fg)]">{s.title}</span>
              <span class="block text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">{s.description}</span>
            </span>
            <span aria-hidden="true" class="text-[var(--nm-accent)]">
              →
            </span>
          </a>
        ))}
      </div>
    ) : null}
  </div>
</section>

