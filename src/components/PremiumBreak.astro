---
interface Props {
  servicesHref?: string;
  archiveHref?: string;
}

const { servicesHref = "/services/", archiveHref = "/articles/" } = Astro.props;
---

<section
  class="nm-premium-break my-10 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)]/95 p-8 text-right shadow-[0_22px_48px_color-mix(in_srgb,var(--nm-fg)_5%,transparent)] sm:p-10"
  aria-labelledby="nm-words-break-heading"
>
  <div class="nm-premium-break__fog" aria-hidden="true"></div>
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">מעבר למילים</p>
  <h2 id="nm-words-break-heading" class="mt-2 text-lg font-semibold text-[var(--nm-fg)]">
    המקום שלי מחכה לך לחקירה שקטה
  </h2>
  <p class="mt-3 text-[clamp(1rem,0.95rem+0.2vw,1.1rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
    מה שמעבר נבנה כשיש מקום לשבת עם זה. אפשר להמשיך כאן או ללכת לעומק לבד בארכיון.
  </p>
  <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end">
    <a
      href={servicesHref}
      class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-6 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
      aria-label="להמשיך את השיחה במסלול האישי במקום שלי"
    >
      להמשיך את השיחה במקום שלי
    </a>
    <a
      href={archiveHref}
      class="inline-flex min-h-[44px] items-center justify-center rounded-full border-2 border-[color-mix(in_srgb,var(--nm-fg)_28%,transparent)] bg-[color-mix(in_srgb,var(--nm-surface-muted)_55%,transparent)] px-6 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_96%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]"
      aria-label="מעבר לארכיון מאמרים להעמקה עצמאית"
    >
      להעמיק בחקירה עצמאית
    </a>
  </div>
</section>

<style>
  .nm-premium-break {
    position: relative;
    overflow: hidden;
  }

  .nm-premium-break__fog {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    height: 7rem;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--nm-bg-canvas) 95%, transparent),
      color-mix(in srgb, var(--nm-bg-canvas) 0%, transparent)
    );
    backdrop-filter: blur(7px);
    pointer-events: none;
  }
</style>
