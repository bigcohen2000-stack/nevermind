---
/**
 * Logic Canvas — בנטו בדף הבית: מסלולי Clarity, ציטוט, וידאו, מגמות, שאלה פתוחה.
 */
import TrendGraph from "./TrendGraph.astro";
import VideoPlayer from "./VideoPlayer.astro";
import defaultCanvas from "../config/homeCanvas.json";
import clarityPathsFile from "../config/clarityPaths.json";

export interface HomeCanvasConfig {
  heroEyebrow?: string;
  heroTitle?: string;
  heroSubtitle?: string;
  dailyQuote: { text: string; attribution?: string };
  featuredVideo: { youtubeId: string; title?: string; videoSummaryPoints?: string[] };
  showTrendGraph: boolean;
  openQuestion: { text: string; href?: string };
}

interface Props {
  canvas?: HomeCanvasConfig;
}

const { canvas: canvasProp } = Astro.props;
const canvas = (canvasProp ?? defaultCanvas) as HomeCanvasConfig;

const paths = clarityPathsFile.paths;
const videoId = String(canvas.featuredVideo?.youtubeId ?? "").trim();
const videoTitle = canvas.featuredVideo?.title ?? "סרטון מומלץ";
const videoPoints = Array.isArray(canvas.featuredVideo?.videoSummaryPoints)
  ? canvas.featuredVideo.videoSummaryPoints
  : [];
---

<section class="mx-auto max-w-7xl space-y-10 px-5 pt-16 sm:px-8 lg:px-12" aria-labelledby="logic-canvas-title" dir="rtl">
  <header class="max-w-4xl space-y-3 text-right">
    {
      canvas.heroEyebrow && (
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">{canvas.heroEyebrow}</p>
      )
    }
    <h1
      id="logic-canvas-title"
      class="text-[clamp(2rem,1.6rem+2vw,3.4rem)] font-semibold leading-[1.08] text-neutral-900 dark:text-white"
    >
      {canvas.heroTitle}
    </h1>
    {
      canvas.heroSubtitle && (
        <p class="max-w-3xl text-[clamp(1.05rem,0.98rem+0.5vw,1.25rem)] leading-relaxed text-neutral-700 dark:text-neutral-300">
          {canvas.heroSubtitle}
        </p>
      )
    }
  </header>

  <div class="space-y-4">
    <h2 class="text-right text-lg font-semibold text-[#1D3557] dark:text-[#FAFAF8]">איך אתה מרגיש עכשיו?</h2>
    <p class="text-right text-sm text-[#1D3557]/70 dark:text-neutral-400">ארבעה מסלולי קריאה קצרים — שלושה מאמרים בכל אחד.</p>
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {
        paths.map((p) => (
          <a
            href={`/journey/${p.id}`}
            class="group flex flex-col rounded-[1.5rem] border border-[#1D3557]/14 bg-white/90 p-5 text-right shadow-[0_18px_50px_rgba(29,53,87,0.07)] transition hover:border-[#D42B2B]/35 hover:shadow-[0_22px_60px_rgba(212,43,43,0.12)] dark:border-white/10 dark:bg-neutral-900/75"
          >
            <span class="text-3xl" aria-hidden="true">
              {p.emoji}
            </span>
            <span class="mt-3 text-base font-semibold text-[#1D3557] group-hover:text-[#D42B2B] dark:text-[#FAFAF8]">{p.title}</span>
            <span class="mt-2 text-sm leading-6 text-[#1D3557]/65 dark:text-neutral-400">{p.shortDescription}</span>
            <span class="mt-4 text-sm font-semibold text-[#D42B2B]">למסלול ←</span>
          </a>
        ))
      }
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-8">
    <div
      class:list={[
        "flex flex-col justify-center rounded-[1.75rem] border border-[#1D3557]/12 bg-white p-6 text-right shadow-sm dark:border-white/10 dark:bg-neutral-900/80 lg:min-h-[220px] lg:p-10",
        videoId ? "lg:col-span-6" : "lg:col-span-12",
      ]}
    >
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">ציטוט היום</p>
      <blockquote class="mt-4 text-[clamp(1.15rem,1rem+0.6vw,1.45rem)] font-medium leading-[1.75] text-[#1D3557] dark:text-[#FAFAF8]">
        {canvas.dailyQuote.text}
      </blockquote>
      {
        canvas.dailyQuote.attribution && (
          <footer class="mt-4 text-sm text-[#1D3557]/60 dark:text-neutral-400">— {canvas.dailyQuote.attribution}</footer>
        )
      }
    </div>

    {
      videoId && (
        <div class="rounded-[1.75rem] border border-[#1A1A1A]/10 bg-white/90 p-4 dark:border-white/10 dark:bg-neutral-900/70 lg:col-span-6">
          <VideoPlayer youtubeId={videoId} title={videoTitle} videoSummaryPoints={videoPoints} />
        </div>
      )
    }

    {
      canvas.showTrendGraph && (
        <div class="lg:col-span-6">
          <TrendGraph />
        </div>
      )
    }

    <div
      class="flex flex-col justify-center rounded-[1.75rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-6 text-right dark:border-white/10 dark:bg-neutral-900/80 lg:col-span-6 lg:p-8"
    >
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#1A1A1A]/55 dark:text-neutral-400">שאלה פתוחה</p>
      <p class="mt-3 text-[clamp(1.05rem,0.98rem+0.35vw,1.2rem)] font-medium leading-relaxed text-[#1A1A1A] dark:text-[#FAFAF8]">
        {canvas.openQuestion.text}
      </p>
      {
        canvas.openQuestion.href && (
          <a
            href={canvas.openQuestion.href}
            class="mt-5 inline-flex w-fit rounded-full border border-[#1A1A1A]/15 bg-white px-4 py-2 text-sm font-semibold text-[#1A1A1A]/80 transition hover:bg-white dark:border-white/15 dark:bg-neutral-800 dark:text-[#FAFAF8]/88"
          >
            להמשך
          </a>
        )
      }
    </div>
  </div>
</section>
