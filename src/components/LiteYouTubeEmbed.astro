---
interface Props {
  youtubeId: string;
  title?: string;
}

const { youtubeId, title = "סרטון וידאו" } = Astro.props;
const thumbnail = `https://i.ytimg.com/vi/${youtubeId}/hqdefault.jpg`;
const embedUrl = `https://www.youtube-nocookie.com/embed/${youtubeId}?autoplay=1&rel=0`;
---

<div class="overflow-hidden rounded-2xl border border-white/70 bg-white/70 shadow-sm backdrop-blur-md">
  <div class="relative aspect-[16/9]">
    <button
      type="button"
      class="group absolute inset-0 block w-full overflow-hidden bg-[#1A1A1A] text-right"
      data-lite-youtube
      data-embed-url={embedUrl}
      data-title={title}
      aria-label={`הפעלת וידאו: ${title}`}
    >
      <img
        src={thumbnail}
        alt={title}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover opacity-90 transition-transform duration-500 group-hover:scale-[1.02]"
      />
      <span class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A]/50 via-transparent to-transparent"></span>
      <span class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-4 p-5 text-white">
        <span class="text-[clamp(0.95rem,0.9rem+0.25vw,1.1rem)] font-medium">{title}</span>
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-white/40 bg-white/15 backdrop-blur-sm">
          <span class="mr-[-2px] block h-0 w-0 border-y-[8px] border-y-transparent border-r-0 border-l-[14px] border-l-white"></span>
        </span>
      </span>
    </button>
  </div>
</div>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-lite-youtube]").forEach((button) => {
      if (button.dataset.bound === "true") {
        return;
      }

      const onClick = () => {
        const iframe = document.createElement("iframe");
        iframe.className = "absolute inset-0 h-full w-full";
        iframe.src = button.dataset.embedUrl || "";
        iframe.title = button.dataset.title || "סרטון וידאו";
        iframe.loading = "eager";
        iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
        iframe.allowFullscreen = true;
        iframe.referrerPolicy = "strict-origin-when-cross-origin";
        button.replaceWith(iframe);
      };

      button.addEventListener("click", onClick, { once: true });
      button.dataset.bound = "true";
    });
  });
</script>
