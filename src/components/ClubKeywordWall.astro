---
import siteSettings from "../config/siteSettings.json";

type Wall = {
  enabled?: boolean;
  matchPhrases?: string[];
  title?: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
};

const wall = (siteSettings as { clubKeywordWall?: Wall }).clubKeywordWall;
const enabled = Boolean(wall?.enabled && Array.isArray(wall?.matchPhrases) && wall.matchPhrases.length > 0);
const phrasesJson = JSON.stringify(wall?.matchPhrases ?? []);
---

{
  enabled ? (
    <div
      id="nm-club-keyword-wall"
      class="fixed inset-x-0 bottom-0 z-[48] hidden translate-y-full opacity-0 transition-[opacity,transform] duration-300 ease-out"
      role="region"
      aria-live="polite"
      aria-label="הצעה להמשך קריאה במסלול המלא"
      data-nm-club-keyword-wall
      data-phrases={phrasesJson}
      data-title={wall?.title ?? ""}
      data-body={wall?.body ?? ""}
      data-cta-label={wall?.ctaLabel ?? ""}
      data-cta-href={wall?.ctaHref ?? "/premium-access/"}
    >
      <div class="pointer-events-auto mx-auto mb-[max(0.75rem,env(safe-area-inset-bottom))] max-w-4xl px-3 pb-3 sm:px-4">
        <div class="flex flex-col gap-3 rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4 shadow-[0_-12px_40px_color-mix(in_srgb,var(--nm-fg)_10%,transparent)] sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-6">
          <div class="min-w-0 text-right">
            <p class="text-sm font-semibold text-[var(--nm-accent)]">{wall?.title}</p>
            <p class="mt-1 text-sm leading-relaxed text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))]">
              {wall?.body}
            </p>
          </div>
          <div class="flex shrink-0 flex-wrap items-center justify-end gap-2">
            <a
              href={wall?.ctaHref ?? "/premium-access/"}
              class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-on-accent)] no-underline transition hover:bg-[var(--nm-accent-hover)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]"
            >
              {wall?.ctaLabel}
            </a>
            <button
              type="button"
              id="nm-club-keyword-wall-dismiss"
              class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_14%,transparent)] bg-transparent px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]"
            >
              סגירה
            </button>
          </div>
        </div>
      </div>
    </div>
  ) : null
}

{
  enabled ? (
    <script>
      import "../scripts/club-keyword-wall.ts";
    </script>
  ) : null
}
