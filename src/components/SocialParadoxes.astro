---
/**
 * שלושה משפטי שיתוף (פרדוקסים) בסגנון מחולל הפרדוקסים הפנימי.
 */
interface Props {
  items: string[];
  heading?: string;
}
const { items, heading = "שלושה פרדוקסים לשיתוף" } = Astro.props;
const list = Array.isArray(items) ? items.filter((s) => typeof s === "string" && s.trim()).slice(0, 3) : [];
---

{
  list.length > 0 && (
    <section
      class="mx-auto max-w-[72ch] rounded-[var(--nm-radius-md)] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[color-mix(in_srgb,var(--nm-surface-muted)_88%,white)] p-6 text-right shadow-[var(--nm-shadow-md)]"
      aria-label={heading}
    >
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">שיתוף מהיר</p>
      <h2 class="mt-2 text-[clamp(1.15rem,1rem+0.5vw,1.35rem)] font-semibold text-[var(--nm-fg)]">{heading}</h2>
      <ul class="mt-5 space-y-4">
        {list.map((text, i) => (
          <li class="rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] bg-white/90 px-4 py-3">
            <p class="text-xs font-semibold text-[color-mix(in_srgb,var(--nm-fg)_45%,var(--nm-bg))]">פרדוקס {i + 1}</p>
            <p class="mt-2 text-[clamp(1rem,0.96rem+0.2vw,1.12rem)] leading-8 text-[var(--nm-fg)]">{text}</p>
          </li>
        ))}
      </ul>
    </section>
  )
}
