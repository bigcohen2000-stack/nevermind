---
/**
 * וידג'ט נגישות קל־משקל — Vanilla JS + localStorage.
 * לא נטען כ־React; לא פוגע ב־PageSpeed.
 */
---

<div class="pointer-events-none fixed bottom-6 right-6 z-[70] flex flex-col items-end gap-2">
  <div
    id="nm-a11y-panel"
    class="pointer-events-auto hidden w-[min(18rem,92vw)] rounded-2xl border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-bg-canvas)] p-4 text-right shadow-lg"
    role="region"
    aria-label="הגדרות נגישות"
    hidden
  >
    <p class="text-sm font-semibold text-[var(--nm-fg)]">נגישות</p>
    <fieldset class="mt-3 space-y-2 border-0 p-0">
      <legend class="sr-only">גודל טקסט</legend>
      <p class="text-xs text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">גודל טקסט</p>
      <div class="flex flex-wrap justify-end gap-2">
        <button type="button" data-nm-a11y-font="base" class="rounded-full border px-3 py-1.5 text-xs font-semibold">רגיל</button>
        <button type="button" data-nm-a11y-font="lg" class="rounded-full border px-3 py-1.5 text-xs font-semibold">גדול</button>
        <button type="button" data-nm-a11y-font="xl" class="rounded-full border px-3 py-1.5 text-xs font-semibold">גדול מאוד</button>
      </div>
    </fieldset>
    <label class="mt-3 flex cursor-pointer items-center justify-between gap-2 text-sm text-[var(--nm-fg)]">
      <span>ניגודיות גבוהה</span>
      <input id="nm-a11y-contrast" type="checkbox" class="h-4 w-4 accent-[var(--nm-accent)]" />
    </label>
    <label class="mt-2 flex cursor-pointer items-center justify-between gap-2 text-sm text-[var(--nm-fg)]">
      <span>הדגשת קישורים</span>
      <input id="nm-a11y-links" type="checkbox" class="h-4 w-4 accent-[var(--nm-accent)]" />
    </label>
    <a
      href="/accessibility/"
      class="mt-3 block text-center text-xs font-semibold text-[var(--nm-accent)] underline underline-offset-2"
    >
      הצהרת נגישות
    </a>
  </div>
  <button
    type="button"
    id="nm-a11y-toggle"
    class="pointer-events-auto flex h-12 w-12 items-center justify-center rounded-full border-2 border-[var(--nm-fg)] bg-[var(--nm-bg-canvas)] text-lg font-bold text-[var(--nm-fg)] shadow-md transition hover:bg-[var(--nm-surface-muted)]"
    aria-expanded="false"
    aria-controls="nm-a11y-panel"
    title="נגישות"
  >
    <span aria-hidden="true">A</span>
    <span class="sr-only">פתח תפריט נגישות</span>
  </button>
</div>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const KEY_FONT = "nm-a11y-font";
    const KEY_CONTRAST = "nm-a11y-contrast";
    const KEY_LINKS = "nm-a11y-links";
    const root = document.documentElement;
    const panel = document.getElementById("nm-a11y-panel");
    const toggle = document.getElementById("nm-a11y-toggle");
    const contrastCb = document.getElementById("nm-a11y-contrast");
    const linksCb = document.getElementById("nm-a11y-links");

    const applyFont = (v) => {
      root.removeAttribute("data-nm-a11y-font");
      if (v === "lg" || v === "xl") root.setAttribute("data-nm-a11y-font", v);
      try {
        localStorage.setItem(KEY_FONT, v || "base");
      } catch {}
    };

    const applyContrast = (on) => {
      if (on) root.setAttribute("data-nm-a11y-contrast", "high");
      else root.removeAttribute("data-nm-a11y-contrast");
      try {
        localStorage.setItem(KEY_CONTRAST, on ? "1" : "0");
      } catch {}
    };

    const applyLinks = (on) => {
      if (on) root.setAttribute("data-nm-a11y-links", "on");
      else root.removeAttribute("data-nm-a11y-links");
      try {
        localStorage.setItem(KEY_LINKS, on ? "1" : "0");
      } catch {}
    };

    try {
      const f = localStorage.getItem(KEY_FONT);
      if (f === "lg" || f === "xl") applyFont(f);
      if (localStorage.getItem(KEY_CONTRAST) === "1") {
        applyContrast(true);
        if (contrastCb instanceof HTMLInputElement) contrastCb.checked = true;
      }
      if (localStorage.getItem(KEY_LINKS) === "1") {
        applyLinks(true);
        if (linksCb instanceof HTMLInputElement) linksCb.checked = true;
      }
    } catch {}

    document.querySelectorAll("[data-nm-a11y-font]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const v = btn.getAttribute("data-nm-a11y-font") || "base";
        applyFont(v === "base" ? "" : v);
      });
    });

    if (contrastCb instanceof HTMLInputElement) {
      contrastCb.addEventListener("change", () => applyContrast(contrastCb.checked));
    }
    if (linksCb instanceof HTMLInputElement) {
      linksCb.addEventListener("change", () => applyLinks(linksCb.checked));
    }

    const closePanel = () => {
      if (!panel || !toggle) return;
      panel.classList.add("hidden");
      panel.hidden = true;
      toggle.setAttribute("aria-expanded", "false");
    };

    if (toggle && panel) {
      toggle.addEventListener("click", () => {
        const open = !panel.classList.contains("hidden");
        if (open) closePanel();
        else {
          panel.classList.remove("hidden");
          panel.hidden = false;
          toggle.setAttribute("aria-expanded", "true");
        }
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && panel && !panel.classList.contains("hidden")) {
          closePanel();
          toggle?.focus();
        }
      });
    }
  });
</script>
