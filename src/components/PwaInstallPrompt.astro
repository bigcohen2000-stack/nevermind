---
/**
 * כפתור התקנת PWA בולט — מוצג כשהדפדפן מדווח על beforeinstallprompt.
 */
---

<div
  id="nm-pwa-install-root"
  class="fixed inset-x-0 bottom-0 z-[47] hidden translate-y-full opacity-0 transition-[opacity,transform] duration-300 ease-out"
  role="region"
  aria-label="התקנת אפליקציה"
  data-nm-pwa-install
>
  <div class="mx-auto mb-[max(0.5rem,env(safe-area-inset-bottom))] max-w-lg px-3 pb-2 sm:px-4">
    <div class="flex flex-wrap items-center justify-between gap-3 rounded-[1.35rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-3 shadow-[0_-10px_36px_color-mix(in_srgb,var(--nm-fg)_8%,transparent)] sm:px-5">
      <p class="min-w-0 flex-1 text-right text-sm font-medium leading-snug text-[var(--nm-fg)]">
        להתקין את NeverMind על המסך הראשי — גישה מהירה בלי לחפש בדפדפן.
      </p>
      <div class="flex shrink-0 flex-wrap items-center justify-end gap-2">
        <button
          type="button"
          id="nm-pwa-install-action"
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]"
        >
          התקנה
        </button>
        <button
          type="button"
          id="nm-pwa-install-dismiss"
          class="inline-flex min-h-[44px] items-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_14%,transparent)] bg-transparent px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]"
        >
          לא עכשיו
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import "../scripts/pwa-install-prompt.ts";
</script>
