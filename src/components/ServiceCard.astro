---
import {
  disclaimerShort,
  featureIcons,
  formatAvailabilityLine,
  formatMoney,
  getNetPrice,
  getVatAmount,
  resolveServiceAction,
  type FlatService,
} from "../lib/services";
import AvailabilityBadge from "./AvailabilityBadge.astro";

interface Props {
  service: FlatService;
}

const { service } = Astro.props;
const action = resolveServiceAction(service);
const netPrice = getNetPrice(service.price_full, 18);
const vatAmount = getVatAmount(service.price_full, 18);
const availabilityLine = formatAvailabilityLine(service);
const hasStructuredAvailability = Boolean(
  service.availability &&
    typeof service.availability.spots_left === "number" &&
    typeof service.availability.updated_at === "string" &&
    service.availability.updated_at.trim()
);
const socialProof =
  typeof service.social_proof === "string" && service.social_proof.trim() ? service.social_proof.trim() : null;
const installmentsLabel =
  typeof service.installments?.label === "string" && service.installments.label.trim()
    ? service.installments.label.trim()
    : null;
const normalizedFeatures = (service.features ?? [])
  .map((feature) =>
    typeof feature === "string"
      ? { text: feature, icon: "default" }
      : { text: feature?.text?.trim() || "", icon: feature?.icon?.trim() || "default" }
  )
  .filter((feature) => feature.text);
---

<article
  id={service.id}
  data-service-card={service.id}
  class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-7 shadow-[0_24px_80px_rgba(26,26,26,0.06)] transition"
>
  <div class="space-y-3 text-right">
    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">{service.stageName}</p>
        <h2 class="text-3xl font-semibold text-[var(--nm-fg)]">{service.title}</h2>
        <p class="text-sm font-medium text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">{service.subtitle}</p>
      </div>
      {service.badges?.length ? (
        <div class="flex flex-wrap justify-end gap-2">
          {service.badges.map((badge: string) => (
            <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[var(--nm-tint)] px-3 py-1 text-xs font-semibold text-[var(--nm-accent)]">
              {badge}
            </span>
          ))}
        </div>
      ) : null}
    </div>

    {
      socialProof ? (
        <div class="flex items-start gap-2 border-r-2 border-[color-mix(in_srgb,var(--nm-accent)_30%,transparent)] pr-3 pt-1 text-right">
          <span class="shrink-0 pt-0.5 text-[var(--nm-accent)]" aria-hidden="true">
            ✓
          </span>
          <p class="text-sm text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]">{socialProof}</p>
        </div>
      ) : null
    }

    <p class="text-base leading-8 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">{service.description}</p>

    {
      availabilityLine ? (
        <div class="pt-1">
          {hasStructuredAvailability ? (
            <p
              class="text-xs font-semibold text-[var(--nm-accent)]"
              data-nm-availability=""
              data-spots={String(service.availability!.spots_left)}
              data-updated-at={service.availability!.updated_at.trim()}
              data-label={service.availability!.label?.trim() || "נותרו"}
            >
              {availabilityLine}
            </p>
          ) : (
            <AvailabilityBadge text={availabilityLine} />
          )}
        </div>
      ) : null
    }
  </div>

  {
    normalizedFeatures.length ? (
      <ul class="mt-6 space-y-2 text-right text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
        {normalizedFeatures.map((feature) => (
          <li class="flex items-start gap-2 rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3">
            <span class="mt-0.5 shrink-0 text-[var(--nm-accent)]" aria-hidden="true">
              {featureIcons[feature.icon] ?? featureIcons.default}
            </span>
            <span>{feature.text}</span>
          </li>
        ))}
      </ul>
    ) : null
  }

  <div class="mt-8 grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
    <div class="text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">כולל מע״מ</p>
      <p class="mt-2 text-4xl font-semibold text-[var(--nm-fg)]">{formatMoney(service.price_full)}</p>
      <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
        {formatMoney(netPrice)} לפני מע״מ + {formatMoney(vatAmount)} מע״מ
      </p>
    </div>

    <a
      href={action.href}
      target={action.external ? "_blank" : undefined}
      rel={action.external ? "noreferrer" : undefined}
      data-service-cta=""
      data-service-id={service.id}
      data-service-title={service.title}
      data-flow={action.flow}
      class="inline-flex items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition-colors duration-200 hover:bg-[var(--nm-accent-hover)]"
    >
      {action.label}
    </a>
  </div>

  {
    installmentsLabel ? (
      <p class="mt-2 text-center text-xs text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">{installmentsLabel}</p>
    ) : null
  }

  <p class="mt-3 text-center text-xs text-[color-mix(in_srgb,var(--nm-fg)_50%,var(--nm-bg))]">
    {disclaimerShort}
  </p>
</article>
