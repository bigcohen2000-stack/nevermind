---
import {
  buildServicePreStartWhatsAppHref,
  disclaimerShort,
  featureIcons,
  formatAvailabilityLine,
  formatMoney,
  getNetPrice,
  getVatAmount,
  resolveServiceAction,
  type FlatService,
} from "../lib/services";
import AvailabilityBadge from "./AvailabilityBadge.astro";
import ServicePricingBlock from "./ServicePricingBlock";
import ServiceProposalWhatsAppCta from "./ServiceProposalWhatsAppCta";

interface Props {
  service: FlatService;
}

const { service } = Astro.props;
const action = resolveServiceAction(service);
const preStartWhatsAppHref = buildServicePreStartWhatsAppHref(service.title);
const netPrice = getNetPrice(service.price_full, 18);
const vatAmount = getVatAmount(service.price_full, 18);
const availabilityLine = formatAvailabilityLine(service);
const hasStructuredAvailability = Boolean(
  service.availability &&
    typeof service.availability.spots_left === "number" &&
    typeof service.availability.updated_at === "string" &&
    service.availability.updated_at.trim()
);
const socialProof =
  typeof service.social_proof === "string" && service.social_proof.trim() ? service.social_proof.trim() : null;
const installmentsLabel =
  typeof service.installments?.label === "string" && service.installments.label.trim()
    ? service.installments.label.trim()
    : null;
const normalizedFeatures = (service.features ?? [])
  .map((feature) =>
    typeof feature === "string"
      ? { text: feature, icon: "default" }
      : { text: feature?.text?.trim() || "", icon: feature?.icon?.trim() || "default" }
  )
  .filter((feature) => feature.text);
const hasServiceExtensions = Array.isArray(service.extensions) && service.extensions.length > 0;
const serviceJson = JSON.stringify(service);
---

<article
  id={service.id}
  data-service-card={service.id}
  data-nm-service-card
  class="flex h-full flex-col rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92 p-6 text-right shadow-[0_24px_70px_rgba(26,26,26,0.06)]"
>
  <div class="space-y-4">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div class="min-w-0 flex-1 space-y-2">
        <p class="text-xs font-semibold text-[var(--nm-accent)]">{service.stageName}</p>
        <h2 class="text-[clamp(1.45rem,1.25rem+0.7vw,2rem)] font-semibold leading-[1.25] text-[var(--nm-fg)]">{service.title}</h2>
        <p class="text-sm font-medium leading-[1.6] text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]">{service.subtitle}</p>
      </div>
      {service.badges?.length ? (
        <div class="flex flex-wrap justify-end gap-2">
          {service.badges.map((badge: string) => (
            <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[var(--nm-tint)] px-3 py-1 text-xs font-semibold text-[var(--nm-accent)]">
              {badge}
            </span>
          ))}
        </div>
      ) : null}
    </div>

    {socialProof ? (
      <div class="rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] bg-[var(--nm-tint)] px-4 py-3">
        <p class="text-sm leading-[1.7] text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">{socialProof}</p>
      </div>
    ) : null}

    <p class="text-base leading-[1.75] text-[color-mix(in_srgb,var(--nm-fg)_74%,var(--nm-bg))]">{service.description}</p>

    {availabilityLine ? (
      <div>
        {hasStructuredAvailability ? (
          <p
            class="text-xs font-semibold text-[var(--nm-accent)]"
            data-nm-availability=""
            data-spots={String(service.availability?.spots_left ?? "")}
            data-updated-at={service.availability?.updated_at?.trim() ?? ""}
            data-label={service.availability!.label?.trim() || "נותרו"}
          >
            {availabilityLine}
          </p>
        ) : (
          <AvailabilityBadge text={availabilityLine} />
        )}
      </div>
    ) : null}
  </div>

  {normalizedFeatures.length ? (
    <ul class="mt-6 grid gap-3 text-sm leading-[1.7] text-[color-mix(in_srgb,var(--nm-fg)_74%,var(--nm-bg))]">
      {normalizedFeatures.map((feature) => (
        <li class="flex items-start gap-2 rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3">
          <span class="mt-0.5 shrink-0 text-[var(--nm-accent)]" aria-hidden="true">
            {featureIcons[feature.icon] ?? featureIcons.default}
          </span>
          <span>{feature.text}</span>
        </li>
      ))}
    </ul>
  ) : null}

  <div class="mt-auto pt-8">
    {hasServiceExtensions ? (
      <ServicePricingBlock client:load serviceJson={serviceJson} layout="full" />
    ) : (
      <div class="space-y-5 rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4">
        <div class="space-y-2">
          <p class="text-xs font-semibold text-[var(--nm-accent)]">כולל מע״מ</p>
          <p class="text-[clamp(2rem,1.6rem+0.9vw,2.65rem)] font-semibold leading-none text-[var(--nm-fg)]">{formatMoney(service.price_full)}</p>
          <p class="text-sm leading-[1.6] text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]">
            {formatMoney(netPrice)} לפני מע״מ + {formatMoney(vatAmount)} מע״מ
          </p>
        </div>

        <div class="grid gap-2">
          <a
            href={action.href}
            {...(action.external ? { target: "_blank", rel: "noreferrer" } : {})}
            data-service-cta=""
            data-service-id={service.id}
            data-service-title={service.title}
            data-flow={action.kind === "payment" ? "payment-first" : "whatsapp-first"}
            class="inline-flex min-h-[48px] w-full items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
          >
            {action.label || "אני רוצה להתחיל"}
          </a>

          <div class="w-full">
            <ServiceProposalWhatsAppCta client:load serviceJson={serviceJson} />
          </div>

          <a
            href={preStartWhatsAppHref}
            target="_blank"
            rel="noreferrer"
            class="inline-flex min-h-[48px] w-full items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_14%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-bg-canvas)]"
          >
            יש לי שאלה לפני
          </a>
        </div>
      </div>
    )}
  </div>

  {installmentsLabel ? (
    <p class="mt-3 text-center text-xs text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">{installmentsLabel}</p>
  ) : null}

  <p class="mt-3 text-center text-xs leading-[1.6] text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">
    {disclaimerShort}
  </p>
</article>
