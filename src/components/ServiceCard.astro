---
import { formatMoney, getNetPrice, getVatAmount, resolveServiceAction, type FlatService } from "../lib/services";
import AvailabilityBadge from "./AvailabilityBadge.astro";

interface Props {
  service: FlatService;
  disclaimer?: string;
}

const { service, disclaimer } = Astro.props;
const action = resolveServiceAction(service);
const netPrice = getNetPrice(service.price_full, 18);
const vatAmount = getVatAmount(service.price_full, 18);
---

<article
  id={service.id}
  data-service-card={service.id}
  class="rounded-[2rem] border border-[#1A1A1A]/10 bg-white/88 p-7 shadow-[0_24px_80px_rgba(26,26,26,0.06)] transition"
>
  <div class="space-y-3 text-right">
    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">{service.stageName}</p>
        <h2 class="text-3xl font-semibold text-[#1A1A1A]">{service.title}</h2>
        <p class="text-sm font-medium text-[#1A1A1A]/60">{service.subtitle}</p>
      </div>
      {service.badges?.length ? (
        <div class="flex flex-wrap justify-end gap-2">
          {service.badges.map((badge: string) => (
            <span class="rounded-full border border-[#D42B2B]/14 bg-[#FFF4F3] px-3 py-1 text-xs font-semibold text-[#D42B2B]">
              {badge}
            </span>
          ))}
        </div>
      ) : null}
    </div>
    <p class="text-base leading-8 text-[#1A1A1A]/70">{service.description}</p>
    {service.availability_note ? (
      <div class="pt-1">
        <AvailabilityBadge text={service.availability_note} />
      </div>
    ) : null}
  </div>

  {service.features?.length ? (
    <ul class="mt-6 space-y-2 text-right text-sm leading-7 text-[#1A1A1A]/72">
      {service.features.map((feature: string) => (
        <li class="rounded-[1.2rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-3">{feature}</li>
      ))}
    </ul>
  ) : null}

  <div class="mt-8 grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
    <div class="text-right">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">כולל מע״מ</p>
      <p class="mt-2 text-4xl font-semibold text-[#1A1A1A]">{formatMoney(service.price_full)}</p>
      <p class="mt-2 text-sm leading-7 text-[#1A1A1A]/64">
        {formatMoney(netPrice)} לפני מע״מ + {formatMoney(vatAmount)} מע״מ
      </p>
    </div>

    <a
      href={action.href}
      target={action.external ? "_blank" : undefined}
      rel={action.external ? "noreferrer" : undefined}
      class="inline-flex items-center justify-center rounded-full bg-[#D42B2B] px-5 py-3 text-sm font-semibold text-[#FAFAF8] transition hover:bg-[#b82424]"
    >
      {action.label}
    </a>
  </div>

  {disclaimer ? <p class="mt-8 border-t border-[#1A1A1A]/10 pt-4 text-sm leading-7 text-[#1A1A1A]/58">{disclaimer}</p> : null}
</article>
