---
import { type CollectionEntry } from "astro:content";
import ClarityAnalogy from "../ClarityAnalogy.astro";
import ConceptCallout from "../ConceptCallout.astro";
import DeepDiveInquiry from "../DeepDiveInquiry.astro";
import InlineGlossaryTerm from "../InlineGlossaryTerm.astro";
import InquirySection from "../InquirySection.astro";
import MechanismCard from "../MechanismCard.astro";
import PremiumBreak from "../PremiumBreak.astro";
import PremiumClubGate from "../PremiumClubGate.astro";
import ClubKeywordWall from "../ClubKeywordWall.astro";
import SocialParadoxes from "../SocialParadoxes.astro";
import SubscribeBanner from "../SubscribeBanner.astro";
import TruthBlock from "../TruthBlock.astro";
import ArticleYoutubeGate from "../ArticleYoutubeGate.astro";
import { glossaryConcepts } from "../../data/glossary";
import { getArticleYoutubeId, getCanonicalArticleSlug } from "../../lib/articles";
import { resolveArticleHeroImage } from "../../lib/resolve-article-hero-image";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import Layout from "../../layouts/Layout.astro";

type Props = {
  entry: CollectionEntry<"articles">;
};

const { entry } = Astro.props as Props;
const frontmatter = entry.data;
const canonicalSlug = getCanonicalArticleSlug(entry);
const { Content } = await entry.render();
const faqItems = Array.isArray(frontmatter.faq) ? frontmatter.faq : [];
const seoArticleBody = entry.body.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();
const wordCountArticle = seoArticleBody.split(/\s+/).filter(Boolean).length;
const readingMinutesArticle = Math.max(1, Math.ceil(wordCountArticle / 200));
const publishedLabel = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("he-IL", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : "";
const lastUpdatedLabel = frontmatter.updatedDate
  ? new Date(frontmatter.updatedDate).toLocaleDateString("he-IL", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : publishedLabel;
const mdxComponents = {
  ClarityAnalogy,
  ConceptCallout,
  DeepDiveInquiry,
  InlineGlossaryTerm,
  InquirySection,
  MechanismCard,
  PremiumBreak,
  SocialParadoxes,
  SubscribeBanner,
  TruthBlock,
};
const youtubeIdArticle = getArticleYoutubeId(frontmatter);
const videoSummaryPointsArticle = Array.isArray(frontmatter.videoSummaryPoints)
  ? frontmatter.videoSummaryPoints
  : [];
const hasQuestionForSchema = Boolean(String(frontmatter.questionForSchema ?? "").trim());
const articleSimpleSummary =
  typeof frontmatter.simpleSummary === "string" && frontmatter.simpleSummary.trim()
    ? frontmatter.simpleSummary.trim()
    : frontmatter.description;
const articleQuickTakeaways = Array.isArray(frontmatter.quickTakeaways)
  ? frontmatter.quickTakeaways.map((item) => String(item).trim()).filter(Boolean).slice(0, 3)
  : [];
const heroImage = resolveArticleHeroImage(canonicalSlug, frontmatter.image);
const showHeroImage = heroImage !== "/images/logo.svg";
const heroImageAlt =
  typeof frontmatter.imageAlt === "string" && frontmatter.imageAlt.trim().length > 0
    ? frontmatter.imageAlt.trim()
    : frontmatter.title;

const requestedConcepts = Array.isArray(frontmatter.relatedConcepts)
  ? frontmatter.relatedConcepts.map((item) => String(item).trim()).filter(Boolean)
  : [];

const glossaryLinks = requestedConcepts
  .map((item) => {
    const match = glossaryConcepts.find(
      (concept) => concept.slug === item || concept.title === item
    );
    return match
      ? {
          href: `/glossary/${match.slug}/`,
          title: match.title,
          description: match.summary,
        }
      : null;
  })
  .filter((item): item is { href: string; title: string; description: string } => item !== null)
  .slice(0, 2);

const explorationCards = [
  ...(glossaryLinks.length > 0
    ? glossaryLinks.map((item) => ({
        ...item,
        label: "מושג קרוב",
      }))
    : [
        {
          href: "/glossary/",
          title: "מילון המושגים",
          description: "אם משהו כאן נגע במילה או מנגנון, אפשר להמשיך משם בלי לאבד את החוט.",
          label: "מילון",
        },
      ]),
  {
    href: "/me/learning/",
    title: "לוח הלמידה",
    description: "מקום שקט לראות מה כבר קראת, מה מחכה, ואיפה נכון להמשיך.",
    label: "למידה",
  },
  {
    href: frontmatter.isPremium ? "/me/" : "/me/unlock/",
    title: frontmatter.isPremium ? "האזור האישי" : "המשך למועדון",
    description: frontmatter.isPremium
      ? "החיבור האישי נשאר מסודר גם אחרי הקריאה."
      : "יש שכבה נוספת למי שרוצה להישאר קרוב לתוכן ולעומק.",
    label: frontmatter.isPremium ? "אזור אישי" : "מועדון",
  },
];
---

<Layout
  title={frontmatter.title}
  description={frontmatter.description}
  frontmatter={frontmatter}
  faqItems={faqItems}
  hasInquirySection={faqItems.length > 0 || hasQuestionForSchema}
  seoArticleBody={seoArticleBody}
  articlePaywalled={frontmatter.isPremium}
>
  <section class="mx-auto max-w-4xl px-4 pb-20 text-right text-[var(--nm-fg)]">
    <header class="rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 px-6 py-8 shadow-[0_18px_42px_rgba(26,26,26,0.04)]">
      <p class="text-sm font-semibold text-[var(--nm-accent)]">מאמר</p>
      <h1 class="mt-3 text-[clamp(2rem,1.6rem+1.4vw,3.1rem)] font-semibold leading-tight">{frontmatter.title}</h1>
      <p class="mt-4 max-w-3xl text-[clamp(1rem,0.96rem+0.22vw,1.08rem)] leading-[1.8] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">
        {frontmatter.description}
      </p>

      <div class="mt-5 flex flex-wrap items-center justify-between gap-3 text-sm text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">
        <div class="flex flex-wrap items-center gap-3">
          <span>בערך {readingMinutesArticle} דקות קריאה</span>
          <span class="text-[color-mix(in_srgb,var(--nm-fg)_26%,transparent)]">•</span>
          <span>עודכן לאחרונה ב-{lastUpdatedLabel}</span>
        </div>
        <a href="/articles/" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-2 font-semibold text-[var(--nm-fg)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] hover:bg-[var(--nm-surface-muted)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]">
          חזרה לכל המאמרים
        </a>
      </div>
    </header>

    {articleSimpleSummary || articleQuickTakeaways.length ? (
      <section class="mt-5 rounded-[1.75rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 px-5 py-5 shadow-[0_14px_28px_rgba(26,26,26,0.03)]">
        <div class="space-y-2">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">בפשטות</p>
          <h2 class="text-xl font-semibold text-[var(--nm-fg)]">מה כדאי להבין לפני שנכנסים לעומק</h2>
          <p class="max-w-3xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
            {articleSimpleSummary}
          </p>
        </div>
        {articleQuickTakeaways.length ? (
          <ul class="mt-4 grid gap-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))] md:grid-cols-3">
            {articleQuickTakeaways.map((item) => (
              <li class="rounded-[1.1rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-3">{item}</li>
            ))}
          </ul>
        ) : null}
      </section>
    ) : null}

    {showHeroImage ? (
      <figure class="mt-5 overflow-hidden rounded-[1.75rem] border border-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] bg-[var(--nm-bg-canvas)] shadow-[0_16px_34px_rgba(26,26,26,0.04)]">
        <img
          src={heroImage}
          alt={heroImageAlt}
          width="1200"
          height="675"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </figure>
    ) : null}

    {youtubeIdArticle ? (
      <ArticleYoutubeGate
        youtubeId={youtubeIdArticle}
        title={frontmatter.title}
        isPremium={Boolean(frontmatter.isPremium)}
        videoSummaryPoints={videoSummaryPointsArticle}
      />
    ) : null}

    <div class="nm-article-shell mt-8 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_9%,transparent)] bg-[var(--nm-bg-canvas)] px-5 py-8 shadow-[0_18px_42px_rgba(26,26,26,0.03)] md:px-8">
      <ArticleLayout frontmatter={frontmatter}>
        <Content components={mdxComponents} />
      </ArticleLayout>
    </div>

    <section class="mt-6 grid gap-3 md:grid-cols-3">
      {explorationCards.map((item) => (
        <a
          href={item.href}
          class="rounded-[1.35rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 px-4 py-4 transition hover:border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] hover:bg-white"
        >
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">{item.label}</p>
          <h2 class="mt-2 text-lg font-semibold text-[var(--nm-fg)]">{item.title}</h2>
          <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">{item.description}</p>
        </a>
      ))}
    </section>

    <section class="mt-8 grid gap-4 rounded-[1.75rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/80 px-5 py-5 shadow-[0_14px_28px_rgba(26,26,26,0.03)] md:grid-cols-[minmax(0,1fr)_auto] md:items-center">
      <div class="space-y-2">
        <h2 class="text-lg font-semibold text-[var(--nm-fg)]">האתר עדיין בשלבי למידה</h2>
        <p class="max-w-2xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">
          האתר פותח ועוצב על ידי AI כפרויקט מחקר והנאה, ולכן הוא עדיין בשלבי למידה. נשמח לעזרה שלכם באיתור שגיאות כתיב, ניסוחים כבדים או קישורים שבורים. אפשר לפתוח את חלון הדיווח בלחיצה כאן.
        </p>
      </div>
      <div class="flex flex-wrap justify-end gap-3">
        <button
          type="button"
          data-open-integrity-report
          data-integrity-context="article-footer"
          class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] hover:text-[var(--nm-accent)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]"
        >
          יש לי תיקון או הערה
        </button>
        <a href="/articles/" class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_18%,transparent)] hover:bg-[var(--nm-surface-muted)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]">
          לעוד מאמרים
        </a>
      </div>
    </section>

    {frontmatter.isPremium ? (
      <section class="mt-8">
        <PremiumClubGate />
      </section>
    ) : null}

    {frontmatter.isPremium ? null : <ClubKeywordWall />}
  </section>

  <script is:inline define:vars={{ slug: canonicalSlug, title: frontmatter.title }}>
    (() => {
      try {
        const row = { slug, title, at: Date.now() };
        localStorage.setItem("nm_last_article_open", JSON.stringify(row));
        const key = "nm_article_open_log";
        const prev = JSON.parse(localStorage.getItem(key) || "[]");
        const arr = Array.isArray(prev) ? prev : [];
        const next = [row, ...arr.filter((x) => x && x.slug !== row.slug)].slice(0, 40);
        localStorage.setItem(key, JSON.stringify(next));
        const onceKey = `nm_sec_once_${slug}`;
        if (!sessionStorage.getItem(onceKey)) {
          sessionStorage.setItem(onceKey, "1");
          const sec = Math.floor(Number.parseInt(localStorage.getItem("nm_reading_seconds_local") || "0", 10) || 0);
          localStorage.setItem("nm_reading_seconds_local", String(sec + 180));
        }
      } catch {
        /* ignore */
      }
    })();
  </script>
</Layout>

<style>
  .nm-article-shell :global(.nm-article .content) {
    display: grid;
    gap: 1.35rem;
  }

  .nm-article-shell :global(.nm-article h2),
  .nm-article-shell :global(.nm-article h3) {
    color: var(--nm-fg);
    line-height: 1.45;
    scroll-margin-top: 8rem;
  }

  .nm-article-shell :global(.nm-article p),
  .nm-article-shell :global(.nm-article li) {
    line-height: 1.95;
    color: color-mix(in srgb, var(--nm-fg) 82%, var(--nm-bg));
  }

  .nm-article-shell :global(.nm-article ul),
  .nm-article-shell :global(.nm-article ol) {
    padding-inline: 1.2rem;
  }

  .nm-article-shell :global(.nm-article blockquote) {
    margin: 1.4rem 0;
    border-inline-start: 3px solid color-mix(in srgb, var(--nm-accent) 24%, transparent);
    padding-inline: 1rem;
    color: color-mix(in srgb, var(--nm-fg) 74%, var(--nm-bg));
  }

  .nm-article-shell :global(.nm-article img) {
    inline-size: 100%;
    block-size: auto;
    border-radius: 1.25rem;
  }
</style>
