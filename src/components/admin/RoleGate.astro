---
type AdminRole = "viewer" | "editor" | "admin";

interface Props {
  requiredRole?: AdminRole;
  fallback?: string;
  showIfAuthed?: boolean;
}

const {
  requiredRole = "viewer",
  fallback = "נדרשת גישת Cloudflare Access עם המייל המורשה כדי להיכנס למסך הזה",
  showIfAuthed = false,
} = Astro.props;
---

<div class="role-gate" data-role-gate data-required-role={requiredRole} data-show-if-authed={showIfAuthed}>
  <div class="gate-content hidden">
    <slot />
  </div>

  <div class="gate-fallback rounded-lg border border-yellow-200 bg-yellow-50 px-4 py-3 text-right text-sm text-yellow-800 hidden">
    <p class="font-semibold">{fallback}</p>
    <a
      href="/cdn-cgi/access/login"
      class="mt-2 inline-block text-yellow-700 underline underline-offset-2 hover:text-yellow-900"
      data-role-gate-retry
    >
      לנסות שוב דרך Access
    </a>
  </div>

  <div class="gate-loading animate-pulse rounded-lg bg-gray-200 px-4 py-3 text-right text-sm text-gray-600">
    בודק הרשאה...
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const gates = document.querySelectorAll("[data-role-gate]");
    const accessStatusUrl = new URL("./api/access-status", window.location.href);
    const defaultChallengeUrl = `/cdn-cgi/access/login?redirect_url=${encodeURIComponent(window.location.href)}`;
    const defaultSwitchIdentityUrl = `/cdn-cgi/access/logout?returnTo=${encodeURIComponent(defaultChallengeUrl)}`;

    const accessStatusPromise = fetch(accessStatusUrl, {
      headers: { accept: "application/json" },
      cache: "no-store",
      credentials: "same-origin",
    })
      .then(async (response) => {
        const payload = await response.json().catch(() => null);
        return {
          allowed: response.ok && payload?.ok === true,
          allowedEmails: Array.isArray(payload?.allowedEmails) ? payload.allowedEmails : [],
          challengeUrl:
            typeof payload?.challengeUrl === "string" && payload.challengeUrl.trim().length > 0
              ? payload.challengeUrl.trim()
              : defaultChallengeUrl,
          switchIdentityUrl:
            typeof payload?.switchIdentityUrl === "string" && payload.switchIdentityUrl.trim().length > 0
              ? payload.switchIdentityUrl.trim()
              : defaultSwitchIdentityUrl,
        };
      })
      .catch(() => ({
        allowed: false,
        allowedEmails: [],
        challengeUrl: defaultChallengeUrl,
        switchIdentityUrl: defaultSwitchIdentityUrl,
      }));

    gates.forEach((gate) => {
      const content = gate.querySelector(".gate-content");
      const fallbackNode = gate.querySelector(".gate-fallback");
      const loading = gate.querySelector(".gate-loading");
      const retryLink = gate.querySelector("[data-role-gate-retry]");

      accessStatusPromise.then(({ allowed, allowedEmails, challengeUrl, switchIdentityUrl }) => {
        loading?.classList.add("hidden");

        if (allowed) {
          content?.classList.remove("hidden");
          fallbackNode?.classList.add("hidden");
          return;
        }

        const title = fallbackNode?.querySelector(".font-semibold");
        if (title instanceof HTMLElement && allowedEmails.length > 0) {
          title.textContent = `נדרשת גישת Cloudflare Access עם ${allowedEmails.join(", ")} כדי להיכנס למסך הזה`;
        }

        if (retryLink instanceof HTMLAnchorElement) {
          retryLink.href = switchIdentityUrl;
          retryLink.setAttribute("data-access-challenge-url", challengeUrl);
        }

        fallbackNode?.classList.remove("hidden");
        content?.classList.add("hidden");
      });

      if (retryLink instanceof HTMLAnchorElement) {
        retryLink.addEventListener("click", (event) => {
          const challengeUrl = retryLink.getAttribute("data-access-challenge-url");
          if (challengeUrl == null || challengeUrl.length === 0) return;
          event.preventDefault();
          window.location.assign(retryLink.href);
        });
      }
    });
  });
</script>
