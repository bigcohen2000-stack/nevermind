---
import type { AdminRole } from "../../lib/admin-auth";

interface Props {
  requiredRole?: AdminRole;
  fallback?: string;
  showIfAuthed?: boolean;
}

const { requiredRole = "viewer", fallback = "אין לך הרשאה לתוכן זה", showIfAuthed = false } = Astro.props;
---

<div class="role-gate" data-role-gate data-required-role={requiredRole} data-show-if-authed={showIfAuthed}>
  <div class="gate-content hidden">
    <slot />
  </div>

  <div class="gate-fallback rounded-lg border border-yellow-200 bg-yellow-50 px-4 py-3 text-right text-sm text-yellow-800 hidden">
    <p class="font-semibold">{fallback}</p>
    <a href="/admin/login/" class="mt-2 inline-block text-yellow-700 underline underline-offset-2 hover:text-yellow-900">לחזור לכניסה</a>
  </div>

  <div class="gate-loading animate-pulse rounded-lg bg-gray-200 px-4 py-3 text-right text-sm text-gray-600">
    בודק הרשאה...
  </div>
</div>

<script>
  import { AdminAuth } from "../../lib/admin-auth";

  document.addEventListener("astro:page-load", () => {
    const gates = document.querySelectorAll("[data-role-gate]");

    gates.forEach((gate) => {
      const content = gate.querySelector(".gate-content");
      const fallback = gate.querySelector(".gate-fallback");
      const loading = gate.querySelector(".gate-loading");
      const requiredRole = gate instanceof HTMLElement ? gate.dataset.requiredRole || "viewer" : "viewer";
      const showIfAuthed = gate instanceof HTMLElement ? gate.dataset.showIfAuthed === "true" : false;

      const user = AdminAuth.getCurrentUser();

      loading?.classList.add("hidden");

      if (!user) {
        fallback?.classList.remove("hidden");
        content?.classList.add("hidden");
        return;
      }

      const requiredRoleSafe = (["viewer", "editor", "admin"].includes(requiredRole) ? requiredRole : "viewer") as import("../../lib/admin-auth").AdminRole;
      if (AdminAuth.hasPermission(user.role, requiredRoleSafe)) {
        content?.classList.remove("hidden");
        fallback?.classList.add("hidden");
      } else {
        fallback?.classList.remove("hidden");
        content?.classList.add("hidden");
      }
    });
  });
</script>
