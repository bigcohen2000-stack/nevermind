---
type AdminRole = "viewer" | "editor" | "admin";

interface Props {
  requiredRole?: AdminRole;
  fallback?: string;
  showIfAuthed?: boolean;
}

const { requiredRole = "viewer", fallback = "נדרשת גישת Cloudflare Access כדי להיכנס למסך הזה", showIfAuthed = false } = Astro.props;
---

<div class="role-gate" data-role-gate data-required-role={requiredRole} data-show-if-authed={showIfAuthed}>
  <div class="gate-content hidden">
    <slot />
  </div>

  <div class="gate-fallback rounded-lg border border-yellow-200 bg-yellow-50 px-4 py-3 text-right text-sm text-yellow-800 hidden">
    <p class="font-semibold">{fallback}</p>
    <a href="/admin/" class="mt-2 inline-block text-yellow-700 underline underline-offset-2 hover:text-yellow-900">לנסות שוב דרך Access</a>
  </div>

  <div class="gate-loading animate-pulse rounded-lg bg-gray-200 px-4 py-3 text-right text-sm text-gray-600">
    בודק הרשאה...
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const gates = document.querySelectorAll("[data-role-gate]");
    const accessStatusPromise = fetch("/api/admin/access-status", {
      headers: { accept: "application/json" },
      cache: "no-store",
      credentials: "same-origin",
    })
      .then(async (response) => {
        const payload = await response.json().catch(() => null);
        return response.ok && payload?.ok === true;
      })
      .catch(() => false);

    gates.forEach((gate) => {
      const content = gate.querySelector(".gate-content");
      const fallback = gate.querySelector(".gate-fallback");
      const loading = gate.querySelector(".gate-loading");
      accessStatusPromise.then((allowed) => {
        loading?.classList.add("hidden");

        if (allowed) {
          content?.classList.remove("hidden");
          fallback?.classList.add("hidden");
          return;
        }

        fallback?.classList.remove("hidden");
        content?.classList.add("hidden");
      });
    });
  });
</script>
