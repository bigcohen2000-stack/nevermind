<section
  id="club-admin"
  data-club-admin-root
  class="space-y-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 p-6 shadow-[0_24px_70px_rgba(26,26,26,0.06)]"
>
  <header class="space-y-3">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">ניהול חברים</p>
    <h2 class="text-[clamp(1.8rem,1.5rem+1vw,2.4rem)] font-semibold text-[var(--nm-fg)]">ניהול מועדון החברים</h2>
    <p class="max-w-3xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
      כאן רואים את מצב הגישה בפועל: מי נכנס עכשיו, מי נראה לאחרונה, ואיזה נתיב נפתח אחרי הכניסה.
    </p>
  </header>

  <div
    data-admin-loading
    class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-4 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]"
    aria-live="polite"
  >
    טוען נתוני מועדון...
  </div>
  <p
    data-admin-error
    class="hidden rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] bg-[var(--nm-tint)] px-4 py-3 text-sm font-semibold text-[var(--nm-fg)]"
    role="alert"
  ></p>

  <div data-admin-content class="hidden space-y-6">
    <section
      class="space-y-4 rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-accent)_14%,transparent)] bg-[var(--nm-tint)] p-5"
      data-admin-access-table-card
    >
      <header class="space-y-1">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="space-y-1">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">גישה חיה</p>
            <h3 class="text-xl font-semibold text-[var(--nm-fg)]">מי מחובר עכשיו ומי נראה לאחרונה</h3>
          </div>
          <span
            data-admin-access-count
            class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/85 px-3 py-1 text-xs font-semibold text-[var(--nm-fg)]"
          >
            0 רשומות
          </span>
        </div>
        <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_72%,var(--nm-bg))]">
          כאן רואים יחד משתמשי קוד משותף וחברי סיסמה אישית. קודם מסתכלים מי בפנים, מתי נכנס,
          ומאיזה נתיב. כל מה שמעבר לזה עבר לאזור מתקדם.
        </p>
      </header>

      <div class="overflow-x-auto rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/92">
        <table class="min-w-full divide-y divide-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)] text-right text-sm">
          <thead class="bg-[var(--nm-surface-muted)] text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]">
            <tr>
              <th scope="col" class="px-4 py-3 font-semibold">שם</th>
              <th scope="col" class="px-4 py-3 font-semibold">טלפון</th>
              <th scope="col" class="px-4 py-3 font-semibold">סוג גישה</th>
              <th scope="col" class="px-4 py-3 font-semibold">סטטוס</th>
              <th scope="col" class="px-4 py-3 font-semibold">נראה לאחרונה</th>
              <th scope="col" class="px-4 py-3 font-semibold">נתיב אחרון</th>
            </tr>
          </thead>
          <tbody data-admin-access-rows class="divide-y divide-[color-mix(in_srgb,var(--nm-fg)_8%,transparent)]"></tbody>
        </table>
      </div>

      <p data-admin-access-empty class="hidden text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">
        ברגע שמישהו יפתח גישה או ייכנס עם סיסמה, הרשומה שלו תופיע כאן.
      </p>
      <p class="text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_56%,var(--nm-bg))]">
        אם הטבלה נשארת ריקה עם שגיאת הרשאה, הבעיה בדרך כלל אינה בחבר עצמו אלא ב-Cloudflare Access.
        צריך להגן גם על <span dir="ltr">/dashboard/*</span>, גם על <span dir="ltr">/dashboard/api/*</span>, וגם על
        <span dir="ltr">/api/club-admin/*</span>.
      </p>
    </section>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-6">
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">חברים</p>
        <p data-admin-stat="members" class="mt-3 text-3xl font-semibold text-[var(--nm-fg)]">0</p>
      </article>
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">כניסות אחרונות</p>
        <p data-admin-stat="recent" class="mt-3 text-3xl font-semibold text-[var(--nm-fg)]">0</p>
      </article>
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">התראות בקרה</p>
        <p data-admin-stat="flags" class="mt-3 text-3xl font-semibold text-[var(--nm-fg)]">0</p>
      </article>
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">צפיות בתוכן</p>
        <p data-admin-stat="deep" class="mt-3 text-3xl font-semibold text-[var(--nm-fg)]">0</p>
        <p class="mt-1 text-xs text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">ביקורים במאמרים ואזורים סגורים</p>
      </article>
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">הערות דיוק</p>
        <p data-admin-stat="integrity" class="mt-3 text-3xl font-semibold text-[var(--nm-fg)]">0</p>
        <p class="mt-1 text-xs text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">דיווחים שהגיעו מתוך האתר</p>
      </article>
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">דיווח אחרון</p>
        <p data-admin-stat="last-integrity" class="mt-3 text-base font-semibold text-[var(--nm-fg)]">לא זמין</p>
      </article>
    </div>

    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_24rem]">
      <section class="space-y-4 rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5">
        <header class="space-y-1">
          <h3 class="text-xl font-semibold text-[var(--nm-fg)]">חיפוש חבר</h3>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
            כותבים טלפון או שם, בוחרים חבר מהרשימה, ורואים מיד מצב גישה, כניסות אחרונות וקיצור
            לאיפוס סיסמה.
          </p>
        </header>
        <label class="block space-y-2" for="admin-member-search">
          <span class="text-sm font-semibold text-[var(--nm-fg)]">חיפוש לפי טלפון או שם</span>
          <input
            id="admin-member-search"
            data-admin-member-search
            type="search"
            autocomplete="off"
            inputmode="search"
            class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
            placeholder="0500000000"
          />
        </label>
        <ul data-admin-member-results class="space-y-3"></ul>
        <p data-admin-member-empty class="text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_56%,var(--nm-bg))]">
          ברגע שתיטען רשימת החברים, אפשר יהיה לחפש כאן בלי לצאת מהמסך.
        </p>
      </section>

      <section class="space-y-4 rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5">
        <header class="space-y-1">
          <h3 class="text-xl font-semibold text-[var(--nm-fg)]">כרטיס חבר וציר פעילות</h3>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
            אחרי בחירת חבר רואים סטטוס נוכחי, תוקף גישה, כניסות אחרונות וקיצורי תצוגה.
          </p>
        </header>
        <div
          data-admin-member-card
          class="rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-4 py-4 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]"
        >
          בחר חבר מהרשימה כדי לראות כאן את הפרטים.
        </div>
        <div class="flex flex-wrap justify-end gap-2">
          <button
            type="button"
            data-admin-fill-reset
            class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
          >
            למלא את טופס האיפוס
          </button>
          <a
            href="/me/"
            target="_blank"
            rel="noreferrer"
            data-admin-view-member
            class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
          >
            תצוגת חבר
          </a>
          <a
            href="/me/unlock/"
            target="_blank"
            rel="noreferrer"
            data-admin-view-unlock
            class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]"
          >
            תצוגת אורח
          </a>
        </div>
        <ul data-admin-member-timeline class="space-y-3"></ul>
      </section>
    </div>

    <section class="rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5">
      <details class="group" data-admin-password-tools>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-right marker:content-none [&::-webkit-details-marker]:hidden">
          <div class="space-y-1">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">כלי סיסמה אישית</p>
            <h3 class="text-xl font-semibold text-[var(--nm-fg)]">איפוס סיסמה, הוספת חבר, והודעה מוכנה לשליחה</h3>
            <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
              הכלים האלה נשארים זמינים, אבל הם לא החלק הראשי במסך. פותחים רק כשבאמת צריך.
            </p>
          </div>
          <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] px-3 py-1 text-xs font-semibold text-[var(--nm-fg)] transition group-open:rotate-45">+</span>
        </summary>

        <div class="mt-5 grid gap-6 xl:grid-cols-[minmax(0,1fr)_24rem]">
          <section class="space-y-4 rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-5">
            <header class="space-y-1">
              <h4 class="text-lg font-semibold text-[var(--nm-fg)]">איפוס סיסמה</h4>
              <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
                בוחרים חבר, כותבים סיסמה חדשה, וה-worker מחליף את ה-hash.
              </p>
            </header>

            <form data-admin-reset-form class="space-y-4" novalidate>
              <label class="block space-y-2" for="admin-reset-phone">
                <span class="text-sm font-semibold text-[var(--nm-fg)]">טלפון חבר</span>
                <input
                  id="admin-reset-phone"
                  name="phone"
                  type="tel"
                  autocomplete="tel"
                  inputmode="numeric"
                  pattern="[0-9]*"
                  class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
                  placeholder="0500000000"
                />
              </label>

              <label class="block space-y-2" for="admin-reset-password">
                <span class="text-sm font-semibold text-[var(--nm-fg)]">סיסמה חדשה</span>
                <input
                  id="admin-reset-password"
                  name="newPassword"
                  type="password"
                  autocomplete="new-password"
                  class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
                />
              </label>

              <button
                type="submit"
                class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
              >
                לאפס סיסמה
              </button>
              <p data-admin-reset-status class="text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]" aria-live="polite"></p>
            </form>
          </section>

          <section class="space-y-4 rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/88 p-5">
            <header class="space-y-1">
              <h4 class="text-lg font-semibold text-[var(--nm-fg)]">הוספת חבר חדש</h4>
              <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
                כותבים טלפון, סיסמה, ואם רוצים גם שם מלא. החבר החדש יופיע מיד במנגנון הגישה.
              </p>
            </header>

            <form data-admin-add-member-form class="space-y-4" novalidate>
              <label class="block space-y-2" for="admin-add-fullname">
                <span class="text-sm font-semibold text-[var(--nm-fg)]">שם מלא (אופציונלי)</span>
                <input
                  id="admin-add-fullname"
                  name="fullName"
                  type="text"
                  autocomplete="name"
                  class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
                  placeholder="שם שיופיע"
                />
              </label>

              <label class="block space-y-2" for="admin-add-phone">
                <span class="text-sm font-semibold text-[var(--nm-fg)]">טלפון חבר</span>
                <input
                  id="admin-add-phone"
                  name="phone"
                  type="tel"
                  autocomplete="tel"
                  inputmode="numeric"
                  pattern="[0-9]*"
                  class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
                  placeholder="0500000000"
                  required
                />
              </label>

              <label class="block space-y-2" for="admin-add-password">
                <span class="text-sm font-semibold text-[var(--nm-fg)]">סיסמה</span>
                <input
                  id="admin-add-password"
                  name="password"
                  type="password"
                  autocomplete="new-password"
                  class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
                  placeholder="סיסמה חדשה"
                  required
                  minlength="4"
                  maxlength="128"
                />
              </label>

              <button
                type="submit"
                class="inline-flex min-h-[44px] w-full items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
              >
                הוסף חבר
              </button>

              <p data-admin-add-member-status class="text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]" aria-live="polite"></p>
            </form>
          </section>
        </div>

        <div class="mt-6 space-y-3 rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-4">
          <div class="space-y-1 text-right">
            <h4 class="text-base font-semibold text-[var(--nm-fg)]">הודעה מוכנה לחבר</h4>
            <p class="text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]">
              אחרי פתיחת חשבון או איפוס סיסמה, תופיע כאן הודעה מוכנה להעתקה עם שם המשתמש,
              הסיסמה וקישור הכניסה.
            </p>
          </div>
          <textarea
            data-admin-share-message
            readonly
            class="min-h-[140px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm leading-7 text-[var(--nm-fg)] outline-none"
            placeholder="אחרי פעולה על חבר, תופיע כאן הודעה מוכנה לשליחה."
          ></textarea>
          <div class="flex flex-wrap justify-end gap-2">
            <button
              type="button"
              data-admin-copy-login-link
              class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-white"
            >
              העתקת קישור כניסה
            </button>
            <button
              type="button"
              data-admin-copy-share
              class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-4 py-2 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]"
            >
              העתקת הודעה
            </button>
          </div>
          <p data-admin-share-status class="text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]" aria-live="polite"></p>
        </div>
      </details>
    </section>

    <details class="group rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-right marker:content-none [&::-webkit-details-marker]:hidden">
        <div class="space-y-1">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">מתקדם</p>
          <h3 class="text-xl font-semibold text-[var(--nm-fg)]">ביקורים, התראות, ודיווחים מהאתר</h3>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
