<section id="club-admin" data-club-admin-root class="space-y-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 p-6 shadow-[0_24px_70px_rgba(26,26,26,0.06)]">
  <header class="space-y-3">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">Club Admin</p>
    <h2 class="text-[clamp(1.8rem,1.5rem+1vw,2.4rem)] font-semibold text-[var(--nm-fg)]">ניהול מועדון החברים</h2>
    <p class="max-w-3xl text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
      כאן רואים את המנגנון של הגישה. כל חבר נשמר ב-CLUB_MEMBERS. כל כניסה יוצרת שורה קצרה ב-CLUB_ACTIVITY. אם אותה סיסמה מופיעה ממזהה IP שונה בחלון קצר, נוצר flag לבדיקה.
    </p>
  </header>

  <div data-admin-loading class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-4 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]" aria-live="polite">
    טוען נתוני מועדון...
  </div>
  <p data-admin-error class="hidden rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] bg-[var(--nm-tint)] px-4 py-3 text-sm font-semibold text-[var(--nm-fg)]" role="alert"></p>

  <div data-admin-content class="hidden space-y-6">
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">חברים</p>
        <p data-admin-stat="members" class="mt-3 text-3xl font-semibold text-[var(--nm-fg)]">0</p>
      </article>
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">כניסות אחרונות</p>
        <p data-admin-stat="recent" class="mt-3 text-3xl font-semibold text-[var(--nm-fg)]">0</p>
      </article>
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">Flags פתוחים</p>
        <p data-admin-stat="flags" class="mt-3 text-3xl font-semibold text-[var(--nm-fg)]">0</p>
      </article>
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">Deep File</p>
        <p data-admin-stat="deep" class="mt-3 text-3xl font-semibold text-[var(--nm-fg)]">0</p>
        <p class="mt-1 text-xs text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">ביקוני צפייה במאמרים</p>
      </article>
      <article class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] px-4 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--nm-accent)]">Flag אחרון</p>
        <p data-admin-stat="last-flag" class="mt-3 text-base font-semibold text-[var(--nm-fg)]">לא זמין</p>
      </article>
    </div>

    <section class="space-y-4 rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5">
      <header class="space-y-1">
        <h3 class="text-xl font-semibold text-[var(--nm-fg)]">Deep File — צפיות במאמרים</h3>
        <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
          אחרי כניסה פעילה של חבר, גלישה לעמוד מאמר שולחת ביקון חד-פעמי לטאב. נשמרים נתיב, זמן, וטביעת IP מקוצרת. אין טלפון בשורה הזו.
        </p>
      </header>
      <ul data-admin-page-beacons class="space-y-3"></ul>
    </section>

    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_24rem]">
      <section class="space-y-4 rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5">
        <header class="space-y-1">
          <h3 class="text-xl font-semibold text-[var(--nm-fg)]">כניסות אחרונות</h3>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">זהו רצף הכניסות האחרון שנשמר ב-CLUB_ACTIVITY.</p>
        </header>
        <ul data-admin-recent-logins class="space-y-3"></ul>
      </section>

      <section class="space-y-4 rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5">
        <header class="space-y-1">
          <h3 class="text-xl font-semibold text-[var(--nm-fg)]">איפוס סיסמה</h3>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">העובד כאן פשוט: בוחרים חבר, כותבים סיסמה חדשה, וה-worker מחליף את ה-hash.</p>
        </header>

        <form data-admin-reset-form class="space-y-4" novalidate>
          <label class="block space-y-2" for="admin-reset-phone">
            <span class="text-sm font-semibold text-[var(--nm-fg)]">טלפון חבר</span>
            <input
              id="admin-reset-phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              inputmode="tel"
              class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
              placeholder="0500000000"
            />
          </label>

          <label class="block space-y-2" for="admin-reset-password">
            <span class="text-sm font-semibold text-[var(--nm-fg)]">סיסמה חדשה</span>
            <input
              id="admin-reset-password"
              name="newPassword"
              type="password"
              autocomplete="new-password"
              class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
            />
          </label>

          <button
            type="submit"
            class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
          >
            לאפס סיסמה
          </button>
          <p data-admin-reset-status class="text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]" aria-live="polite"></p>
        </form>

        <div class="mt-8 border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pt-6">
          <header class="space-y-1">
            <h3 class="text-xl font-semibold text-[var(--nm-fg)]">הוספת חבר חדש</h3>
            <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
              כותבים טלפון וכותבים סיסמה. אם מוסיפים שם מלא הוא יופיע בהמשך בשורה של הגישה.
            </p>
          </header>

          <form data-admin-add-member-form class="mt-4 space-y-4" novalidate>
            <label class="block space-y-2" for="admin-add-fullname">
              <span class="text-sm font-semibold text-[var(--nm-fg)]">שם מלא (אופציונלי)</span>
              <input
                id="admin-add-fullname"
                name="fullName"
                type="text"
                autocomplete="name"
                class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
                placeholder="שם שיופיע"
              />
            </label>

            <label class="block space-y-2" for="admin-add-phone">
              <span class="text-sm font-semibold text-[var(--nm-fg)]">טלפון חבר</span>
              <input
                id="admin-add-phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                inputmode="tel"
                class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
                placeholder="0500000000"
                required
              />
            </label>

            <label class="block space-y-2" for="admin-add-password">
              <span class="text-sm font-semibold text-[var(--nm-fg)]">סיסמה</span>
              <input
                id="admin-add-password"
                name="password"
                type="password"
                autocomplete="new-password"
                class="min-h-[44px] w-full rounded-[1rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white px-4 py-3 text-sm text-[var(--nm-fg)] outline-none transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
                placeholder="סיסמה חדשה"
                required
                minlength="4"
                maxlength="128"
              />
            </label>

            <button
              type="submit"
              class="inline-flex min-h-[44px] w-full items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-2.5 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-red)]"
            >
              הוסף חבר
            </button>

            <p data-admin-add-member-status class="text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_60%,var(--nm-bg))]" aria-live="polite"></p>
          </form>
        </div>
      </section>
    </div>

    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_24rem]">
      <section class="space-y-4 rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5">
        <header class="space-y-1">
          <h3 class="text-xl font-semibold text-[var(--nm-fg)]">Fraud Flags</h3>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">כאן רואים איפה אותה סיסמה או אותו חבר הופיעו מכמה מזהי IP בחלון קצר.</p>
        </header>
        <ul data-admin-fraud-flags class="space-y-3"></ul>
      </section>

      <section class="space-y-4 rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-5">
        <header class="space-y-1">
          <h3 class="text-xl font-semibold text-[var(--nm-fg)]">איך זה עובד</h3>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">הסבר קצר כדי שלא תצטרך לזכור את כל החלקים בעל פה.</p>
          <a
            href="/club/"
            class="mt-1 inline-flex w-fit items-center rounded-full bg-white/70 px-3 py-1 text-sm font-semibold text-[var(--nm-accent)] underline underline-offset-4 hover:bg-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]"
          >
            גרסה ציבורית
          </a>
        </header>
        <ol class="space-y-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
          <li class="rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-4 py-3">CLUB_MEMBERS שומר את פרטי החבר, תוקף הגישה, וה-hash של הסיסמה.</li>
          <li class="rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-4 py-3">CLUB_ACTIVITY שומר שורות קצרות של כניסה: טלפון, זמן, נתיב, ודפדפן.</li>
          <li class="rounded-[1.2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-4 py-3">אם אותו hash מופיע ממזהי IP שונים מהר מדי, ה-worker יוצר flag לבקרה.</li>
        </ol>
      </section>
    </div>
  </div>

  <dialog data-admin-reset-dialog class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-bg-canvas)] p-0 text-right shadow-[0_24px_80px_rgba(26,26,26,0.18)] backdrop:bg-black/30">
    <div data-modal-panel class="w-[min(100vw-2rem,28rem)] space-y-4 p-5">
      <header class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">אישור פעולה</p>
        <h3 class="text-xl font-semibold text-[var(--nm-fg)]">איפוס סיסמה</h3>
      </header>
      <p data-admin-reset-confirm-text class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]"></p>
      <div class="flex flex-wrap justify-end gap-3">
        <button type="button" data-admin-reset-cancel class="inline-flex min-h-[44px] items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-[var(--nm-surface-muted)]">חזור</button>
        <button type="button" data-admin-reset-approve class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-[var(--nm-accent)] px-4 py-2 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">לאשר איפוס</button>
      </div>
    </div>
  </dialog>
</section>

<style>
  [data-admin-reset-dialog]::backdrop {
    background: rgb(26 26 26 / 0.3);
    backdrop-filter: blur(2px);
  }

  [data-admin-reset-dialog] [data-modal-panel] {
    opacity: 0;
    transform: scale(0.98);
    transition:
      opacity 220ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  [data-admin-reset-dialog][open] [data-modal-panel] {
    opacity: 1;
    transform: scale(1);
  }
</style>
