          <a
            href="/club/"
            class="mt-1 inline-flex w-fit items-center rounded-full bg-white/70 px-3 py-1 text-sm font-semibold text-[var(--nm-accent)] underline underline-offset-4 hover:bg-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--nm-accent)]"
