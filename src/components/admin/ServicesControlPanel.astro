---
import servicesConfig from "../../config/services.json";
import { FloatingInput } from "../ui/FloatingInput";
import { disclaimerLong, disclaimerShort, flattenVisibleServices, formatMoney } from "../../lib/services";

const services = flattenVisibleServices();
---

<form id="services-form" class="space-y-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md">
  <div class="space-y-2 text-right">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">שירותים פעילים</p>
    <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">מקור האמת של שלבי השירות</h2>
    <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">הקובץ נשען על <code>src/config/services.json</code>. משנים כאן שלבים, טקסטים, מחירים ותצורות פעולה במקום אחד.</p>
  </div>

  <details class="rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3 text-right">
    <summary class="cursor-pointer text-sm font-semibold text-[var(--nm-fg)]">שדות אופציונליים בשירות (מפת עריכה)</summary>
    <ul class="mt-3 list-inside list-disc space-y-2 text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_62%,var(--nm-bg))]">
      <li>
        <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">whatsapp_template</code> - טקסט הודעה; פלייסהולדרים{" "}
        <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">{"{title}"}</code>,{" "}
        <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">{"{price}"}</code> (מספר בלי סימן ₪). חובה מומלץ כש־<code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">action_type</code> הוא{" "}
        <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">whatsapp</code>.
      </li>
      <li>
        <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">social_proof</code> - שורת הוכחה חברתית (מוצגת בכרטיס בין כותרת משנה לתיאור).
      </li>
      <li>
        <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">availability</code> - אובייקט:{" "}
        <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">spots_left</code> (מספר),{" "}
        <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">updated_at</code> (ISO), אופציונלי{" "}
        <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">label</code> (ברירת מחדל: «נותרו»). תאימות:{" "}
        <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">availability_note</code> מחרוזת (legacy).
      </li>
      <li>גילוי נאות ארוך: <code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">trust_elements.disclaimer</code> - מקור אחד לפוטר ולמקטעים ארוכים. שורה קצרה מתחת לכפתורים: קבוע בקוד (<code class="rounded bg-[var(--nm-code-bg)] px-1 text-[var(--nm-code-fg)]">disclaimerShort</code>).</li>
    </ul>
  </details>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {services.map((service) => (
      <article class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">{service.stageName}</p>
        <p class="mt-2 text-base font-semibold text-[var(--nm-fg)]">{service.title}</p>
        <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">{service.subtitle}</p>
        <p class="mt-4 text-sm font-semibold text-[var(--nm-fg)]">{formatMoney(service.price_full)} כולל מע״מ</p>
        <p class="mt-1 text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_58%,var(--nm-bg))]">{service.action_type} · {service.id}</p>
        <div class="mt-3 flex flex-wrap justify-end gap-1.5">
          {service.social_proof?.trim() ? (
            <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] bg-[var(--nm-tint)] px-2 py-0.5 text-[10px] font-semibold text-[var(--nm-accent)]">social_proof</span>
          ) : null}
          {service.availability && typeof service.availability.spots_left === "number" ? (
            <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] bg-[var(--nm-tint)] px-2 py-0.5 text-[10px] font-semibold text-[var(--nm-accent)]">availability</span>
          ) : null}
          {service.availability_note?.trim() && !service.availability ? (
            <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-white/70 px-2 py-0.5 text-[10px] font-semibold text-[color-mix(in_srgb,var(--nm-fg)_55%,var(--nm-bg))]">availability_note</span>
          ) : null}
          {service.action_type === "whatsapp" && service.whatsapp_template?.trim() ? (
            <span class="rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] bg-[var(--nm-tint)] px-2 py-0.5 text-[10px] font-semibold text-[var(--nm-accent)]">wa תבנית</span>
          ) : null}
        </div>
      </article>
    ))}
  </div>

  <div class="space-y-2 rounded-[1.4rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-3 text-right text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">גילוי נאות (מקור: trust_elements.disclaimer)</p>
    <p class="whitespace-pre-line text-sm">{disclaimerLong}</p>
    <p class="border-t border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] pt-2 text-xs text-[color-mix(in_srgb,var(--nm-fg)_52%,var(--nm-bg))]">
      שורה קצרה בכרטיסים: <span class="font-medium text-[var(--nm-fg)]">{disclaimerShort}</span>
    </p>
  </div>

  <FloatingInput
    client:load
    id="services-json-input"
    label="services.json"
    multiline
    rows={34}
    dir="ltr"
    spellCheck={false}
    defaultValue={JSON.stringify(servicesConfig, null, 2)}
    hideValidation={true}
    className="[&_.nm-floating-control--textarea]:min-h-[36rem] [&_.nm-floating-control]:bg-[var(--nm-code-bg)] [&_.nm-floating-control]:font-mono [&_.nm-floating-control]:text-sm [&_.nm-floating-control]:leading-7 [&_.nm-floating-control]:text-[var(--nm-code-fg)]"
  />

  <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end">
    <button id="pick-services-file" type="button" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">בחר services.json</button>
    <button id="save-services-file" type="button" class="inline-flex items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">שמור לקובץ האמיתי</button>
    <button id="apply-services" type="button" class="inline-flex items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">החל מקומית</button>
    <button id="copy-services-json" type="button" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">העתק JSON</button>
    <button id="export-services-json" type="button" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">הורד services.json</button>
    <button id="reset-services" type="button" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-accent)_20%,transparent)] bg-[var(--nm-tint)] px-5 py-3 text-sm font-semibold text-[var(--nm-accent)] transition hover:bg-[var(--nm-tint-strong)]">נקה override מקומי</button>
  </div>

  <div class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">סנכרון שירותים</p>
    <p id="services-file-status" class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">עדיין לא נבחר קובץ יעד. אפשר לבחור את <code>src/config/services.json</code> ולשמור אליו ישירות מתוך Chrome.</p>
  </div>

  <div class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">בדיקות שדות (לא חוסמות שמירה)</p>
    <pre
      id="services-json-hints"
      class="mt-2 max-h-48 overflow-auto whitespace-pre-wrap break-words text-xs leading-6 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]"
    >טוען…</pre>
  </div>

  <pre class="min-h-[10rem] overflow-auto rounded-[1.6rem] bg-[var(--nm-code-bg)] p-5 text-sm leading-7 text-[var(--nm-code-fg)] shadow-inner"><code id="services-json-output">ה-JSON המעובד יופיע כאן.</code></pre>
</form>

<script is:inline define:vars={{ defaultServices: servicesConfig }}>
  document.addEventListener("astro:page-load", () => {
    const servicesStorageKey = "nm-services-overrides";
    const input = document.getElementById("services-json-input");
    const pickServicesFileButton = document.getElementById("pick-services-file");
    const saveServicesFileButton = document.getElementById("save-services-file");
    const applyServicesButton = document.getElementById("apply-services");
    const copyServicesButton = document.getElementById("copy-services-json");
    const exportServicesButton = document.getElementById("export-services-json");
    const resetServicesButton = document.getElementById("reset-services");
    const servicesFileStatus = document.getElementById("services-file-status");
    const servicesOutput = document.getElementById("services-json-output");
    const servicesHints = document.getElementById("services-json-hints");

    if (!(input instanceof HTMLTextAreaElement) ||
        !(pickServicesFileButton instanceof HTMLButtonElement) ||
        !(saveServicesFileButton instanceof HTMLButtonElement) ||
        !(applyServicesButton instanceof HTMLButtonElement) ||
        !(copyServicesButton instanceof HTMLButtonElement) ||
        !(exportServicesButton instanceof HTMLButtonElement) ||
        !(resetServicesButton instanceof HTMLButtonElement) ||
        !(servicesFileStatus instanceof HTMLElement) ||
        !(servicesOutput instanceof HTMLElement) ||
        !(servicesHints instanceof HTMLElement)) return;

    let servicesFileHandle = null;

    const pulse = (button, successText, fallbackText) => {
      button.textContent = successText;
      window.setTimeout(() => {
        button.textContent = fallbackText;
      }, 1400);
    };

    const readServices = () => {
      try {
        return JSON.parse(window.localStorage.getItem(servicesStorageKey) || "null");
      } catch {
        return null;
      }
    };

    const parseInput = () => {
      const parsed = JSON.parse(input.value);
      if (!parsed || !Array.isArray(parsed.funnel_stages) || !parsed.hero || !parsed.trust_elements) {
        throw new Error("מבנה services.json לא תקין");
      }
      return parsed;
    };

    const collectServicesHints = (parsed) => {
      const hints = [];
      if (!Array.isArray(parsed.funnel_stages)) return hints;
      for (const stage of parsed.funnel_stages) {
        const list = Array.isArray(stage.services) ? stage.services : [];
        for (const s of list) {
          const sid = s.title || s.id || "?";
          if (s.action_type === "whatsapp") {
            const tpl = s.whatsapp_template;
            if (tpl == null || String(tpl).trim() === "") {
              hints.push(`«${sid}»: whatsapp בלי whatsapp_template - תבנית ברירת-מחדל מהקוד.`);
            }
          }
          if (s.availability && typeof s.availability === "object") {
            const a = s.availability;
            if (typeof a.spots_left !== "number" || Number.isNaN(a.spots_left)) {
              hints.push(`«${sid}»: availability.spots_left חייב להיות מספר.`);
            }
            const upd = a.updated_at != null ? String(a.updated_at).trim() : "";
            if (!upd) {
              hints.push(`«${sid}»: חסר availability.updated_at (מומלץ ISO 8601).`);
            } else if (Number.isNaN(new Date(upd).getTime())) {
              hints.push(`«${sid}»: availability.updated_at לא נראה כתאריך תקין.`);
            }
          }
          if (s.availability && s.availability_note && String(s.availability_note).trim()) {
            hints.push(`«${sid}»: יש גם availability וגם availability_note - בכרטיס תוצג רק הזמינות המובנית.`);
          }
        }
      }
      const disc = parsed.trust_elements?.disclaimer;
      if (typeof disc === "string" && !disc.trim()) {
        hints.push("trust_elements.disclaimer ריק - גילוי נאות ארוך בפוטר יהיה ריק.");
      }
      return hints;
    };

    const renderHints = (parsed) => {
      const hints = collectServicesHints(parsed);
      servicesHints.textContent = hints.length
        ? hints.map((h, i) => `${i + 1}. ${h}`).join("\n")
        : "אין אזהרות מבנה לפי התוכן הנוכחי.";
    };

    const renderServicesState = (state) => {
      servicesOutput.textContent = JSON.stringify(state, null, 2);
      renderHints(state);
    };

    const updateFileStatus = (message) => {
      servicesFileStatus.textContent = message;
    };

    const current = readServices() || defaultServices;
    input.value = JSON.stringify(current, null, 2);
    renderServicesState(current);

    input.addEventListener("input", () => {
      try {
        renderHints(parseInput());
      } catch {
        servicesHints.textContent = "לא ניתן לנתח JSON - תקן תחביר לפני שמירה.";
      }
    });

    applyServicesButton.addEventListener("click", () => {
      try {
        const next = parseInput();
        window.localStorage.setItem(servicesStorageKey, JSON.stringify(next));
        renderServicesState(next);
        updateFileStatus("השינויים הוחלו מקומית. עמוד הבית, השירותים והמחולל יקראו את ה-override בדפדפן הזה.");
        pulse(applyServicesButton, "הוחל מקומית", "החל מקומית");
      } catch (error) {
        updateFileStatus(error instanceof Error ? error.message : "JSON לא תקין.");
        pulse(applyServicesButton, "JSON לא תקין", "החל מקומית");
      }
    });

    copyServicesButton.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(input.value);
        pulse(copyServicesButton, "JSON הועתק", "העתק JSON");
      } catch {
        pulse(copyServicesButton, "ההעתקה נכשלה", "העתק JSON");
      }
    });

    exportServicesButton.addEventListener("click", () => {
      const blob = new Blob([`${input.value.trim()}\n`], { type: "application/json;charset=utf-8" });
      const href = URL.createObjectURL(blob);
      const anchor = document.createElement("a");
      anchor.href = href;
      anchor.download = "services.json";
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      URL.revokeObjectURL(href);
      pulse(exportServicesButton, "הקובץ ירד", "הורד services.json");
    });

    resetServicesButton.addEventListener("click", () => {
      window.localStorage.removeItem(servicesStorageKey);
      input.value = JSON.stringify(defaultServices, null, 2);
      renderServicesState(defaultServices);
      updateFileStatus("השכבה המקומית של השירותים נוקתה. הקובץ הקנוני לא שונה.");
      pulse(resetServicesButton, "ה-reset הושלם", "נקה override מקומי");
    });

    pickServicesFileButton.addEventListener("click", async () => {
      if (typeof window.showOpenFilePicker !== "function") {
        updateFileStatus("הדפדפן הזה לא תומך בכתיבה ישירה לקובץ. השתמש בהעתקה ידנית.");
        pulse(pickServicesFileButton, "לא נתמך", "בחר services.json");
        return;
      }
      try {
        const [handle] = await window.showOpenFilePicker({
          multiple: false,
          types: [{ description: "JSON", accept: { "application/json": [".json"] } }],
        });
        servicesFileHandle = handle;
        updateFileStatus(`קובץ יעד נבחר: ${handle.name}.`);
        pulse(pickServicesFileButton, "הקובץ נבחר", "בחר services.json");
      } catch {
        updateFileStatus("בחירת הקובץ בוטלה או נכשלה.");
        pulse(pickServicesFileButton, "הבחירה בוטלה", "בחר services.json");
      }
    });

    saveServicesFileButton.addEventListener("click", async () => {
      if (!servicesFileHandle) {
        updateFileStatus("בחר קודם את src/config/services.json ואז שמור.");
        pulse(saveServicesFileButton, "חסר קובץ יעד", "שמור לקובץ האמיתי");
        return;
      }
      try {
        const saved = parseInput();
        const writable = await servicesFileHandle.createWritable();
        await writable.write(`${input.value.trim()}\n`);
        await writable.close();
        renderHints(saved);
        updateFileStatus(`הקובץ ${servicesFileHandle.name} עודכן בהצלחה.`);
        pulse(saveServicesFileButton, "נשמר לקובץ", "שמור לקובץ האמיתי");
      } catch (error) {
        updateFileStatus(error instanceof Error ? error.message : "השמירה הישירה נכשלה.");
        pulse(saveServicesFileButton, "השמירה נכשלה", "שמור לקובץ האמיתי");
      }
    });
  });
</script>

