---
interface ArticleRow {
  title: string;
  status: string;
  statusTone: string;
  premium: string;
  premiumTone: string;
  dateLabel: string;
  editHref: string;
  slug: string;
}

interface Props {
  articles: ArticleRow[];
}

const { articles } = Astro.props;
---

<section class="space-y-5 rounded-[2rem] border border-[#1A1A1A]/10 bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md">
  <div class="flex flex-col gap-3 text-right md:flex-row md:items-end md:justify-between">
    <div class="space-y-2">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">Articles Overview</p>
      <h2 class="text-2xl font-semibold text-[#1A1A1A]">כל קבצי ה־MDX במערכת</h2>
    </div>
    <a href="/admin/generator/" class="inline-flex items-center justify-center rounded-full bg-[#D42B2B] px-5 py-3 text-sm font-semibold text-[#FAFAF8] transition hover:bg-[#b82424]">מאמר חדש</a>
  </div>

  <div class="overflow-hidden rounded-[1.6rem] border border-[#1A1A1A]/10">
    <table class="min-w-full divide-y divide-[#1A1A1A]/10 text-right">
      <thead class="bg-[#FAFAF8]">
        <tr>
          <th class="px-4 py-4 text-sm font-semibold text-[#1A1A1A]">כותרת</th>
          <th class="px-4 py-4 text-sm font-semibold text-[#1A1A1A]">סטטוס</th>
          <th class="px-4 py-4 text-sm font-semibold text-[#1A1A1A]">פרימיום</th>
          <th class="px-4 py-4 text-sm font-semibold text-[#1A1A1A]">תאריך</th>
          <th class="px-4 py-4 text-sm font-semibold text-[#1A1A1A]">פעולה</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-[#1A1A1A]/8 bg-white">
        {articles.map((article) => (
          <tr>
            <td class="px-4 py-4 align-top">
              <div class="space-y-1">
                <p class="font-semibold text-[#1A1A1A]">{article.title}</p>
                <p class="text-xs text-[#1A1A1A]/54">/{article.slug}</p>
              </div>
            </td>
            <td class="px-4 py-4 align-top">
              <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${article.statusTone}`}>{article.status}</span>
            </td>
            <td class="px-4 py-4 align-top">
              <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${article.premiumTone}`}>{article.premium}</span>
            </td>
            <td class="px-4 py-4 align-top text-sm text-[#1A1A1A]/70">{article.dateLabel}</td>
            <td class="px-4 py-4 align-top">
              <a href={article.editHref} target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border border-[#1A1A1A]/10 bg-[#FAFAF8] px-4 py-2 text-sm font-semibold text-[#1A1A1A] transition hover:bg-[#ffffff]">Edit</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
