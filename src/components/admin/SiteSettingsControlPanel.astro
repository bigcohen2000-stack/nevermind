---
import siteSettings from "../../config/siteSettings.json";
import { FloatingInput } from "../ui/FloatingInput";

const summaryCards = [
  {
    label: "אינדוקס",
    value: siteSettings.seo?.allowIndexing ? "פתוח" : "חסום",
  },
  {
    label: "Whisper",
    value: siteSettings.whisperBanner?.enabled ? "מוצג" : "מוסתר",
  },
  {
    label: "מילת מועדון",
    value: siteSettings.clubKeywordWall?.enabled ? "פעיל" : "כבוי",
  },
  {
    label: "Premium Vault",
    value: siteSettings.premiumVault?.enabled ? "פעיל" : "כבוי",
  },
];
---

<form id="site-settings-form" class="space-y-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md">
  <div class="space-y-2 text-right">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">הגדרות אתר</p>
    <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">siteSettings.json</h2>
    <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">
      כאן יושבים noindex כללי, הודעות רוחב, brand, whisper, חסימות מועדון ו־premium vault. זהו מקור האמת לטקסטים רוחביים ולהתנהגות סביב מאמרים.
    </p>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    {summaryCards.map((card) => (
      <article class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right">
        <p class="text-base font-semibold text-[var(--nm-fg)]">{card.label}</p>
        <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">{card.value}</p>
      </article>
    ))}
  </div>

  <FloatingInput
    client:load
    id="site-settings-input"
    label="siteSettings.json"
    multiline
    rows={24}
    dir="ltr"
    spellCheck={false}
    defaultValue={JSON.stringify(siteSettings, null, 2)}
    hideValidation={true}
    className="[&_.nm-floating-control--textarea]:min-h-[32rem] [&_.nm-floating-control]:bg-[var(--nm-code-bg)] [&_.nm-floating-control]:font-mono [&_.nm-floating-control]:text-sm [&_.nm-floating-control]:leading-7 [&_.nm-floating-control]:text-[var(--nm-code-fg)]"
  />

  <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end">
    <button id="pick-site-settings-file" type="button" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">בחר siteSettings.json</button>
    <button id="save-site-settings-file" type="button" class="inline-flex items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">שמור לקובץ האמיתי</button>
    <button id="copy-site-settings-json" type="button" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">העתק JSON</button>
    <button id="export-site-settings-json" type="button" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">הורד siteSettings.json</button>
  </div>

  <div class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">סנכרון הגדרות</p>
    <p id="site-settings-file-status" class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
      עדיין לא נבחר קובץ יעד. אפשר לבחור את <code>src/config/siteSettings.json</code> ולשמור אליו ישירות מתוך Chrome.
    </p>
  </div>
</form>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const input = document.getElementById("site-settings-input");
    const pickButton = document.getElementById("pick-site-settings-file");
    const saveButton = document.getElementById("save-site-settings-file");
    const copyButton = document.getElementById("copy-site-settings-json");
    const exportButton = document.getElementById("export-site-settings-json");
    const status = document.getElementById("site-settings-file-status");

    if (!(input instanceof HTMLTextAreaElement)) return;
    if (!(pickButton instanceof HTMLButtonElement)) return;
    if (!(saveButton instanceof HTMLButtonElement)) return;
    if (!(copyButton instanceof HTMLButtonElement)) return;
    if (!(exportButton instanceof HTMLButtonElement)) return;
    if (!(status instanceof HTMLElement)) return;

    let fileHandle = null;

    const pulse = (button, successText, fallbackText) => {
      button.textContent = successText;
      window.setTimeout(() => {
        button.textContent = fallbackText;
      }, 1400);
    };

    const validate = () => {
      const parsed = JSON.parse(input.value);
      if (!parsed || typeof parsed !== "object") throw new Error("siteSettings.json לא אובייקט תקין.");
      if (!parsed.seo || typeof parsed.seo.allowIndexing !== "boolean") throw new Error("seo.allowIndexing חייב להיות boolean.");
      if (!parsed.brand || typeof parsed.brand.wordmarkHe !== "string") throw new Error("brand.wordmarkHe חסר.");
      if (!parsed.stagingBanner || typeof parsed.stagingBanner.enabled !== "boolean") throw new Error("stagingBanner.enabled חייב להיות boolean.");
      if (!parsed.whisperBanner || typeof parsed.whisperBanner.enabled !== "boolean") throw new Error("whisperBanner.enabled חייב להיות boolean.");
      if (!parsed.clubKeywordWall || typeof parsed.clubKeywordWall.enabled !== "boolean") throw new Error("clubKeywordWall.enabled חייב להיות boolean.");
      if (!parsed.premiumVault || typeof parsed.premiumVault.enabled !== "boolean") throw new Error("premiumVault.enabled חייב להיות boolean.");
      return parsed;
    };

    copyButton.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(input.value);
        pulse(copyButton, "JSON הועתק", "העתק JSON");
      } catch {
        pulse(copyButton, "ההעתקה נכשלה", "העתק JSON");
      }
    });

    exportButton.addEventListener("click", () => {
      const blob = new Blob([`${input.value.trim()}\n`], { type: "application/json;charset=utf-8" });
      const href = URL.createObjectURL(blob);
      const anchor = document.createElement("a");
      anchor.href = href;
      anchor.download = "siteSettings.json";
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      URL.revokeObjectURL(href);
      pulse(exportButton, "הקובץ ירד", "הורד siteSettings.json");
    });

    pickButton.addEventListener("click", async () => {
      if (typeof window.showOpenFilePicker !== "function") {
        status.textContent = "הדפדפן הזה לא תומך בכתיבה ישירה לקובץ. השתמש בהעתקה ידנית.";
        pulse(pickButton, "לא נתמך", "בחר siteSettings.json");
        return;
      }
      try {
        const [handle] = await window.showOpenFilePicker({
          multiple: false,
          types: [{ description: "JSON", accept: { "application/json": [".json"] } }],
        });
        fileHandle = handle;
        status.textContent = `קובץ יעד נבחר: ${handle.name}.`;
        pulse(pickButton, "הקובץ נבחר", "בחר siteSettings.json");
      } catch {
        status.textContent = "בחירת הקובץ בוטלה או נכשלה.";
        pulse(pickButton, "הבחירה בוטלה", "בחר siteSettings.json");
      }
    });

    saveButton.addEventListener("click", async () => {
      if (!fileHandle) {
        status.textContent = "בחר קודם את src/config/siteSettings.json ואז שמור.";
        pulse(saveButton, "חסר קובץ יעד", "שמור לקובץ האמיתי");
        return;
      }
      try {
        validate();
        const writable = await fileHandle.createWritable();
        await writable.write(`${input.value.trim()}\n`);
        await writable.close();
        status.textContent = `הקובץ ${fileHandle.name} עודכן בהצלחה.`;
        pulse(saveButton, "נשמר לקובץ", "שמור לקובץ האמיתי");
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : "השמירה הישירה נכשלה.";
        pulse(saveButton, "השמירה נכשלה", "שמור לקובץ האמיתי");
      }
    });
  });
</script>
