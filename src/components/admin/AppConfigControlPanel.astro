---
import appConfig from "../../config/appConfig.json";
---

<form id="app-config-form" class="space-y-6 rounded-[2rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/82 p-6 shadow-[0_30px_90px_rgba(26,26,26,0.08)] backdrop-blur-md">
  <div class="space-y-2 text-right">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--nm-accent)]">קונפיג מערכת</p>
    <h2 class="text-2xl font-semibold text-[var(--nm-fg)]">קונפיג מרכזי למערכת</h2>
    <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">כאן יושבים ה־repo ל־publish, מספר הוואטסאפ, והגישה לתוכן פרימיום. זה קובץ אחד שמזין כמה מודולים באתר.</p>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    <article class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right">
      <p class="text-base font-semibold text-[var(--nm-fg)]">פרסום ל־GitHub</p>
      <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">{appConfig.github.owner}/{appConfig.github.repo}</p>
    </article>
    <article class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right">
      <p class="text-base font-semibold text-[var(--nm-fg)]">WhatsApp</p>
      <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">{appConfig.contact.whatsAppNumber}</p>
    </article>
    <article class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right">
      <p class="text-base font-semibold text-[var(--nm-fg)]">גישת פרימיום</p>
      <p class="mt-2 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">{appConfig.premiumAccess.enabled ? "פעיל" : "כבוי"}</p>
    </article>
  </div>

  <label class="block space-y-2 text-right">
    <span class="text-sm font-semibold text-[var(--nm-fg)]">appConfig.json</span>
    <textarea
      id="app-config-input"
      rows="24"
      spellcheck="false"
      dir="ltr"
      class="w-full rounded-[1.6rem] border border-[color-mix(in_srgb,var(--nm-fg)_12%,transparent)] bg-[var(--nm-code-bg)] px-5 py-4 text-left text-sm leading-7 text-[var(--nm-code-fg)] outline-none transition focus:border-[color-mix(in_srgb,var(--nm-accent)_40%,transparent)] focus:ring-2 focus:ring-[color-mix(in_srgb,var(--nm-accent)_20%,transparent)]"
    >{JSON.stringify(appConfig, null, 2)}</textarea>
  </label>

  <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end">
    <button id="pick-app-config-file" type="button" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">בחר appConfig.json</button>
    <button id="save-app-config-file" type="button" class="inline-flex items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">שמור לקובץ האמיתי</button>
    <button id="copy-app-config-json" type="button" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">העתק JSON</button>
    <button id="export-app-config-json" type="button" class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white px-5 py-3 text-sm font-semibold text-[color-mix(in_srgb,var(--nm-fg)_78%,var(--nm-bg))] transition hover:bg-[var(--nm-surface-muted)]">הורד appConfig.json</button>
  </div>

  <div class="rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] p-4 text-right">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">סנכרון קונפיג</p>
    <p id="app-config-file-status" class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">עדיין לא נבחר קובץ יעד. אפשר לבחור את <code>src/config/appConfig.json</code> ולשמור אליו ישירות מתוך Chrome.</p>
  </div>
</form>

<script is:inline define:vars={{ defaultConfig: appConfig }}>
  document.addEventListener("astro:page-load", () => {
    const input = document.getElementById("app-config-input");
    const pickButton = document.getElementById("pick-app-config-file");
    const saveButton = document.getElementById("save-app-config-file");
    const copyButton = document.getElementById("copy-app-config-json");
    const exportButton = document.getElementById("export-app-config-json");
    const status = document.getElementById("app-config-file-status");

    if (!(input instanceof HTMLTextAreaElement)) return;
    if (!(pickButton instanceof HTMLButtonElement)) return;
    if (!(saveButton instanceof HTMLButtonElement)) return;
    if (!(copyButton instanceof HTMLButtonElement)) return;
    if (!(exportButton instanceof HTMLButtonElement)) return;
    if (!(status instanceof HTMLElement)) return;

    let fileHandle = null;

    const pulse = (button, successText, fallbackText) => {
      button.textContent = successText;
      window.setTimeout(() => {
        button.textContent = fallbackText;
      }, 1400);
    };

    const validate = () => {
      const parsed = JSON.parse(input.value);
      if (!parsed?.github?.owner || !parsed?.github?.repo || !parsed?.contact?.whatsAppNumber) {
        throw new Error("appConfig.json לא כולל github/contact כנדרש.");
      }
      return parsed;
    };

    copyButton.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(input.value);
        pulse(copyButton, "JSON הועתק", "העתק JSON");
      } catch {
        pulse(copyButton, "ההעתקה נכשלה", "העתק JSON");
      }
    });

    exportButton.addEventListener("click", () => {
      const blob = new Blob([`${input.value.trim()}\n`], { type: "application/json;charset=utf-8" });
      const href = URL.createObjectURL(blob);
      const anchor = document.createElement("a");
      anchor.href = href;
      anchor.download = "appConfig.json";
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      URL.revokeObjectURL(href);
      pulse(exportButton, "הקובץ ירד", "הורד appConfig.json");
    });

    pickButton.addEventListener("click", async () => {
      if (typeof window.showOpenFilePicker !== "function") {
        status.textContent = "הדפדפן הזה לא תומך בכתיבה ישירה לקובץ. השתמש בהעתקה ידנית.";
        pulse(pickButton, "לא נתמך", "בחר appConfig.json");
        return;
      }
      try {
        const [handle] = await window.showOpenFilePicker({
          multiple: false,
          types: [{ description: "JSON", accept: { "application/json": [".json"] } }],
        });
        fileHandle = handle;
        status.textContent = `קובץ יעד נבחר: ${handle.name}.`;
        pulse(pickButton, "הקובץ נבחר", "בחר appConfig.json");
      } catch {
        status.textContent = "בחירת הקובץ בוטלה או נכשלה.";
        pulse(pickButton, "הבחירה בוטלה", "בחר appConfig.json");
      }
    });

    saveButton.addEventListener("click", async () => {
      if (!fileHandle) {
        status.textContent = "בחר קודם את src/config/appConfig.json ואז שמור.";
        pulse(saveButton, "חסר קובץ יעד", "שמור לקובץ האמיתי");
        return;
      }
      try {
        validate();
        const writable = await fileHandle.createWritable();
        await writable.write(`${input.value.trim()}\n`);
        await writable.close();
        status.textContent = `הקובץ ${fileHandle.name} עודכן בהצלחה.`;
        pulse(saveButton, "נשמר לקובץ", "שמור לקובץ האמיתי");
      } catch (error) {
        status.textContent = error instanceof Error ? error.message : "השמירה הישירה נכשלה.";
        pulse(saveButton, "השמירה נכשלה", "שמור לקובץ האמיתי");
      }
    });
  });
</script>

