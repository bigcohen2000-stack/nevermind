---
interface Props {
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<aside
  data-floating-cta
  class="pointer-events-none fixed inset-x-0 bottom-4 z-[65] px-4 opacity-0 translate-y-6 transition duration-300"
>
  <div class="mx-auto flex max-w-3xl items-center justify-between gap-3 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/95 px-4 py-3 shadow-[0_22px_60px_rgba(26,26,26,0.12)] backdrop-blur-xl">
    <div class="min-w-0 text-right">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--nm-accent)]">פעולה מהירה</p>
      <p class="mt-1 text-sm leading-6 text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))]">מכאן אפשר לסגור עניין בלי לחזור לראש העמוד.</p>
    </div>
    <div class="pointer-events-auto flex shrink-0 items-center gap-2">
      {secondaryHref && secondaryLabel && (
        <a
          href={secondaryHref}
          class="inline-flex items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)] px-4 py-2 text-sm font-semibold text-[var(--nm-fg)] transition hover:bg-white"
        >
          {secondaryLabel}
        </a>
      )}
      <a
        href={primaryHref}
        class="inline-flex items-center justify-center rounded-full bg-[var(--nm-accent)] px-4 py-2 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]"
      >
        {primaryLabel}
      </a>
    </div>
  </div>
</aside>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const floatingCta = document.querySelector("[data-floating-cta]");
    if (!(floatingCta instanceof HTMLElement)) return;

    const updateVisibility = () => {
      const scrollableHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = scrollableHeight > 0 ? window.scrollY / scrollableHeight : 0;
      const isVisible = progress >= 0.6;
      floatingCta.classList.toggle("pointer-events-none", !isVisible);
      floatingCta.classList.toggle("opacity-0", !isVisible);
      floatingCta.classList.toggle("translate-y-6", !isVisible);
      floatingCta.classList.toggle("opacity-100", isVisible);
      floatingCta.classList.toggle("translate-y-0", isVisible);
    };

    window.addEventListener("scroll", updateVisibility, { passive: true });
    updateVisibility();
  });
</script>
