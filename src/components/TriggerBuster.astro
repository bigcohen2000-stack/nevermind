---
import appConfig from "../config/appConfig.json";
import { FloatingInput } from "./ui/FloatingInput";

interface Props {
  phone?: string;
  buttonLabel?: string;
  ctaLabel?: string;
}

const {
  phone = appConfig.contact.whatsAppNumber,
  buttonLabel = "עלה לי טריגר עכשיו",
  ctaLabel = "לעבור לשיחת מיקוד של 20 דקות",
} = Astro.props;

const baseMessage =
  "היי, אני בתוך טריגר ורוצה לפרק את זה דרך שיחת מיקוד של 20 דקות.";
const defaultHref = `https://wa.me/${phone}?text=${encodeURIComponent(baseMessage)}`;
---

<section
  data-trigger-buster
  data-phone={phone}
  data-base-message={baseMessage}
  class="not-prose"
  aria-label="עוצר לולאה"
>
  <button
    type="button"
    data-trigger-open
    aria-expanded="false"
    class="fixed bottom-24 left-4 z-[72] inline-flex items-center gap-2 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/94 px-4 py-3 text-sm font-semibold text-[var(--nm-fg)] shadow-[0_22px_50px_rgba(26,26,26,0.12)] transition duration-300 hover:translate-y-[-1px] hover:border-[color-mix(in_srgb,var(--nm-accent)_26%,transparent)] hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color-mix(in_srgb,var(--nm-accent)_25%,transparent)] md:bottom-28 md:left-6"
  >
    <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[var(--nm-tint)] text-[var(--nm-accent)]" aria-hidden="true">•</span>
    <span>{buttonLabel}</span>
  </button>

  <div
    data-trigger-overlay
    hidden
    class="fixed inset-0 z-[70] bg-[var(--nm-inverse)]/12 opacity-0 transition-opacity duration-[220ms] ease-[cubic-bezier(0.4,0,0.2,1)]"
  ></div>

  <aside
    data-trigger-panel
    hidden
    class="fixed bottom-24 left-4 z-[71] w-[min(92vw,26rem)] rounded-[var(--nm-radius-lg)] border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-[var(--nm-surface-muted)]/98 p-5 text-right text-[var(--nm-fg)] shadow-[var(--nm-shadow-lg)] opacity-0 translate-y-3 scale-[0.98] will-change-[opacity,transform] transition-[opacity,transform] duration-[220ms] ease-[cubic-bezier(0.4,0,0.2,1)] md:bottom-28 md:left-6"
    role="dialog"
    aria-modal="true"
    aria-labelledby="trigger-buster-title"
  >
    <div class="flex items-start justify-between gap-4">
      <button
        type="button"
        data-trigger-close
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white text-lg text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))] transition hover:border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] hover:text-[var(--nm-accent)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color-mix(in_srgb,var(--nm-accent)_25%,transparent)]"
        aria-label="סגור"
      >
        ×
      </button>
      <div class="space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">עוצרים לולאה</p>
        <h2 id="trigger-buster-title" class="text-[1.35rem] font-semibold leading-8">בוא נפריד רגע בין מה שקרה לבין מה שהמחשבה נתנה עליו.</h2>
        <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_66%,var(--nm-bg))]">שלושה צעדים קצרים. בלי לנתח חיים שלמים. רק לעצור את הלופ ולהחזיר בהירות.</p>
      </div>
    </div>

    <div class="mt-5 flex gap-2" aria-hidden="true">
      <span data-trigger-dot="1" class="h-1.5 flex-1 rounded-full bg-[var(--nm-accent)]"></span>
      <span data-trigger-dot="2" class="h-1.5 flex-1 rounded-full bg-[var(--nm-inverse)]/10"></span>
      <span data-trigger-dot="3" class="h-1.5 flex-1 rounded-full bg-[var(--nm-inverse)]/10"></span>
    </div>

    <div class="mt-6 space-y-5">
      <section data-trigger-step="1" class="space-y-4">
        <div class="space-y-2">
          <p class="text-sm font-semibold text-[var(--nm-accent)]">שלב 1 מתוך 3</p>
          <h3 class="text-xl font-semibold leading-8">מה העובדה נטו?</h3>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">בלי הסיפור שסיפרת לעצמך. רק מה קרה בפועל.</p>
        </div>
        <FloatingInput
          client:load
          id="nm-trigger-fact"
          label="דוגמה: הוא לא ענה לי מאז הבוקר"
          multiline
          rows={4}
          dataTriggerInput="fact"
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-white"
        />
        <div class="flex justify-between gap-3">
          <button type="button" data-trigger-next="2" class="inline-flex items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">להמשיך</button>
          <button type="button" data-trigger-close-inline class="text-sm font-semibold text-[var(--nm-fg)]/56 transition hover:text-[var(--nm-fg)]">לעצור כאן</button>
        </div>
      </section>

      <section data-trigger-step="2" class="hidden space-y-4">
        <div class="space-y-2">
          <p class="text-sm font-semibold text-[var(--nm-accent)]">שלב 2 מתוך 3</p>
          <h3 class="text-xl font-semibold leading-8">מה הפירוש שהילבשת על העובדה הזו?</h3>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">מה כבר החלטת שזה אומר עליך, עליו או על העתיד?</p>
        </div>
        <FloatingInput
          client:load
          id="nm-trigger-story"
          label="דוגמה: הוא מזלזל בי, אז כנראה שאני לא באמת חשוב"
          multiline
          rows={4}
          dataTriggerInput="story"
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-white"
        />
        <div class="flex justify-between gap-3">
          <button type="button" data-trigger-next="3" class="inline-flex items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]">להמשיך</button>
          <button type="button" data-trigger-back="1" class="text-sm font-semibold text-[var(--nm-fg)]/56 transition hover:text-[var(--nm-fg)]">חזרה</button>
        </div>
      </section>

      <section data-trigger-step="3" class="hidden space-y-4">
        <div class="space-y-2">
          <p class="text-sm font-semibold text-[var(--nm-accent)]">שלב 3 מתוך 3</p>
          <h3 class="text-xl font-semibold leading-8">מה הרווח הסמוי שלך מלהישאר כועס או פגוע עכשיו?</h3>
          <p class="text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_64%,var(--nm-bg))]">לפעמים הכאב מחזיק תחושת צדק, שליטה או הימנעות מהצעד הבא.</p>
        </div>
        <FloatingInput
          client:load
          id="nm-trigger-gain"
          label="דוגמה: כל עוד אני פגוע, אני לא צריך לדבר ישירות או לבדוק מה באמת קרה"
          multiline
          rows={4}
          dataTriggerInput="gain"
          hideValidation={true}
          className="[&_.nm-floating-control]:bg-white"
        />
        <div class="flex justify-between gap-3">
          <button type="button" data-trigger-finish class="inline-flex items-center justify-center rounded-full bg-[var(--nm-accent)] px-5 py-3 text-sm font-semibold text-[var(--nm-on-accent)] transition hover:bg-[var(--nm-accent-hover)]">לסיום</button>
          <button type="button" data-trigger-back="2" class="text-sm font-semibold text-[var(--nm-fg)]/56 transition hover:text-[var(--nm-fg)]">חזרה</button>
        </div>
      </section>

      <section data-trigger-result class="hidden rounded-[1.5rem] border border-[color-mix(in_srgb,var(--nm-accent)_14%,transparent)] bg-white px-4 py-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">השלב הבא</p>
        <h3 class="mt-3 text-xl font-semibold leading-8">עדיין תקוע בלופ? בוא נפרק את זה.</h3>
        <p class="mt-3 text-sm leading-7 text-[color-mix(in_srgb,var(--nm-fg)_68%,var(--nm-bg))]">
          אם גם אחרי ההפרדה הזו יש רעש, כנראה שכבר לא צריך עוד מחשבה. צריך פירוק מדויק של המנגנון עצמו.
        </p>
        <a
          data-trigger-whatsapp
          href={defaultHref}
          target="_blank"
          rel="noreferrer"
          class="mt-5 inline-flex w-full items-center justify-center rounded-full bg-[var(--nm-inverse)] px-5 py-3 text-sm font-semibold text-[var(--nm-inverse-fg)] transition hover:bg-[var(--nm-inverse-hover)]"
        >
          {ctaLabel}
        </a>
      </section>
    </div>
  </aside>
</section>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const root = document.querySelector("[data-trigger-buster]");
    if (!(root instanceof HTMLElement)) return;

    const openButton = root.querySelector("[data-trigger-open]");
    const closeButton = root.querySelector("[data-trigger-close]");
    const closeInlineButton = root.querySelector("[data-trigger-close-inline]");
    const overlay = root.querySelector("[data-trigger-overlay]");
    const panel = root.querySelector("[data-trigger-panel]");
    const nextButtons = Array.from(root.querySelectorAll("[data-trigger-next]"));
    const backButtons = Array.from(root.querySelectorAll("[data-trigger-back]"));
    const finishButton = root.querySelector("[data-trigger-finish]");
    const resultPanel = root.querySelector("[data-trigger-result]");
    const dots = Array.from(root.querySelectorAll("[data-trigger-dot]"));
    const whatsappLink = root.querySelector("[data-trigger-whatsapp]");
    const inputs = {
      fact: root.querySelector('[data-trigger-input="fact"]'),
      story: root.querySelector('[data-trigger-input="story"]'),
      gain: root.querySelector('[data-trigger-input="gain"]'),
    };

    if (!(openButton instanceof HTMLButtonElement) || !(panel instanceof HTMLElement) || !(overlay instanceof HTMLElement)) return;

    const state = {
      currentStep: 1,
      fact: "",
      story: "",
      gain: "",
    };
    let lockTimer = 0;

    const clearLockTimer = () => {
      if (lockTimer) {
        window.clearTimeout(lockTimer);
        lockTimer = 0;
      }
    };

    const triggerLockHaptic = () => {
      clearLockTimer();
      lockTimer = window.setTimeout(() => {
        try {
          if (document.hasFocus() && navigator.vibrate) {
            navigator.vibrate(10);
          }
        } catch {
        }
      }, 220);
    };

    const setDotState = (step) => {
      dots.forEach((dot, index) => {
        if (!(dot instanceof HTMLElement)) return;
        dot.classList.toggle("bg-[var(--nm-accent)]", index < step);
        dot.classList.toggle("bg-[var(--nm-inverse)]/10", index >= step);
      });
    };

    const showStep = (step) => {
      state.currentStep = step;
      const stepPanels = Array.from(root.querySelectorAll("[data-trigger-step]"));
      stepPanels.forEach((stepPanel) => {
        if (!(stepPanel instanceof HTMLElement)) return;
        stepPanel.classList.toggle("hidden", stepPanel.dataset.triggerStep !== String(step));
      });
      if (resultPanel instanceof HTMLElement) resultPanel.classList.add("hidden");
      setDotState(step);
    };

    const openPanel = () => {
      window.__nmHapticLight?.();
      overlay.hidden = false;
      panel.hidden = false;
      requestAnimationFrame(() => {
        overlay.classList.remove("opacity-0");
        panel.classList.remove("opacity-0", "translate-y-3", "scale-[0.98]");
      });
      triggerLockHaptic();
      openButton.setAttribute("aria-expanded", "true");
      showStep(1);
      const firstField = inputs.fact;
      if (firstField instanceof HTMLTextAreaElement) firstField.focus();
    };

    const closePanel = () => {
      clearLockTimer();
      overlay.classList.add("opacity-0");
      panel.classList.add("opacity-0", "translate-y-3", "scale-[0.98]");
      openButton.setAttribute("aria-expanded", "false");
      window.setTimeout(() => {
        overlay.hidden = true;
        panel.hidden = true;
      }, 250);
    };

    const buildWhatsappHref = () => {
      const phone = root.dataset.phone || "972555634035";
      const baseMessage =
        root.dataset.baseMessage ||
        "היי, אני בתוך טריגר ורוצה לפרק את זה דרך שיחת מיקוד של 20 דקות.";
      const lines = [baseMessage];
      if (state.fact.trim()) lines.push(`עובדה נטו: ${state.fact.trim()}`);
      if (state.story.trim()) lines.push(`הפירוש שהילבשתי: ${state.story.trim()}`);
      if (state.gain.trim()) lines.push(`הרווח הסמוי שאני מזהה: ${state.gain.trim()}`);
      return `https://wa.me/${phone}?text=${encodeURIComponent(lines.join("\n"))}`;
    };

    const finishFlow = () => {
      const stepPanels = Array.from(root.querySelectorAll("[data-trigger-step]"));
      stepPanels.forEach((stepPanel) => {
        if (stepPanel instanceof HTMLElement) stepPanel.classList.add("hidden");
      });
      if (resultPanel instanceof HTMLElement) resultPanel.classList.remove("hidden");
      setDotState(3);
      if (whatsappLink instanceof HTMLAnchorElement) {
        whatsappLink.href = buildWhatsappHref();
      }
    };

    openButton.addEventListener("click", openPanel);
    closeButton?.addEventListener("click", closePanel);
    closeInlineButton?.addEventListener("click", closePanel);
    overlay.addEventListener("click", closePanel);

    nextButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.addEventListener("click", () => {
        const next = Number(button.dataset.triggerNext || state.currentStep + 1);
        if (state.currentStep === 1 && inputs.fact instanceof HTMLTextAreaElement) {
          state.fact = inputs.fact.value;
        }
        if (state.currentStep === 2 && inputs.story instanceof HTMLTextAreaElement) {
          state.story = inputs.story.value;
        }
        showStep(next);
        if (next === 2 && inputs.story instanceof HTMLTextAreaElement) inputs.story.focus();
        if (next === 3 && inputs.gain instanceof HTMLTextAreaElement) inputs.gain.focus();
      });
    });

    backButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.addEventListener("click", () => {
        const prev = Number(button.dataset.triggerBack || state.currentStep - 1);
        showStep(prev);
      });
    });

    if (finishButton instanceof HTMLButtonElement) {
      finishButton.addEventListener("click", () => {
        if (inputs.gain instanceof HTMLTextAreaElement) {
          state.gain = inputs.gain.value;
        }
        finishFlow();
      });
    }

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !panel.hidden) {
        closePanel();
      }
    });
  });
</script>
