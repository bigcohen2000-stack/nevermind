<script is:inline>
  (() => {
    window.nmTrackEvent = (name, params = {}) => {
      if (!name) return;
      try {
        window.dispatchEvent(new CustomEvent("nm-analytics-event", { detail: { name, params } }));
      } catch {
      }
    };
  })();
</script>

<script>
  type NmMetric = {
    name: string;
    value: number;
    rating?: string;
    delta?: number;
    id?: string;
  };

  const reportWebVitals = (metric: NmMetric) => {
    window.nmTrackEvent?.('web_vitals', {
      name: metric.name,
      value: metric.value,
      rating: metric.rating,
      delta: metric.delta,
      id: metric.id,
    });

    if (import.meta.env.DEV) {
      console.log('Web Vital:', metric);
    }
  };

  import('web-vitals')
    .then(({ onCLS, onINP, onFCP, onLCP, onTTFB }) => {
      onCLS(reportWebVitals);
      onINP(reportWebVitals);
      onFCP(reportWebVitals);
      onLCP(reportWebVitals);
      onTTFB(reportWebVitals);
    })
    .catch((err) => {
      console.warn('Web Vitals tracking failed to load:', err);
    });

  let interactionCount = 0;
  const trackInteraction = () => {
    interactionCount++;
    if (interactionCount === 1) {
      window.nmTrackEvent?.('first_interaction');
    }
  };

  document.addEventListener('click', trackInteraction, { once: true });
  document.addEventListener('keydown', trackInteraction, { once: true });
  document.addEventListener('touchstart', trackInteraction, { once: true });

  const trackThemeChange = (theme: string) => {
    window.nmTrackEvent?.('theme_change', { theme });
  };

  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
        const theme = document.documentElement.getAttribute('data-theme') || 'light';
        trackThemeChange(theme);
      }
    });
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });

  const trackSearch = (query: string, results: number) => {
    window.nmTrackEvent?.('search', {
      query: query.slice(0, 100),
      results_count: results,
      has_results: results > 0,
    });
  };

  window.addEventListener('nm-search-performed', (event) => {
    const customEvent = event as CustomEvent<{ query?: string; results?: number }>;
    const detail = customEvent.detail ?? {};
    const query = typeof detail.query === 'string' ? detail.query : '';
    const results = typeof detail.results === 'number' ? detail.results : 0;
    trackSearch(query, results);
  });
</script>
