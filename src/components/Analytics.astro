---
const gaId = (import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "").trim();
---

{
  gaId ? (
    <script is:inline define:vars={{ gaId }}>
      (function () {
        const pending = [];
        let loaded = false;

        window.addEventListener("nm-analytics", function (e) {
          const d = e && e.detail;
          if (!d || !d.name) return;
          if (typeof window.nmTrackEvent === "function") {
            window.nmTrackEvent(d.name, d.params || {});
          } else {
            pending.push(d);
          }
        });

        function inject() {
          if (loaded) return;
          loaded = true;
          const s = document.createElement("script");
          s.async = true;
          s.src = "https://www.googletagmanager.com/gtag/js?id=" + encodeURIComponent(gaId);
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            window.dataLayer.push(arguments);
          }
          window.gtag = gtag;
          gtag("js", new Date());
          gtag("config", gaId, { anonymize_ip: true });

          window.nmTrackEvent = function (name, params) {
            if (typeof gtag !== "function") return;
            gtag("event", name, params || {});
          };

          while (pending.length) {
            const d = pending.shift();
            window.nmTrackEvent(d.name, d.params || {});
          }

          document.addEventListener("click", function (ev) {
            const t = ev.target;
            if (!(t instanceof Element)) return;
            const a = t.closest("a[href]");
            if (!a || !(a instanceof HTMLAnchorElement)) return;
            const href = a.getAttribute("href") || "";
            if (href.includes("tally.so")) {
              window.nmTrackEvent("book_session_click", { link_url: href });
            }
            if (a.hasAttribute("download") || /\.pdf($|[?#])/i.test(href)) {
              window.nmTrackEvent("digital_file_click", { link_url: href });
            }
          });
        }

        function onConsent() {
          try {
            if (localStorage.getItem("nm-cookie-consent") !== "accepted") return;
          } catch {
            return;
          }
          inject();
        }

        window.addEventListener("nm-cookie-accepted", inject);
        document.addEventListener("astro:page-load", onConsent);
        onConsent();
      })();
    </script>
  ) : null
}
