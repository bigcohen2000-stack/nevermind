---
/**
 * משל או אנלוגיה פשוטה (מאמרי beginner).
 */
interface Props {
  label?: string;
}
const { label = "משל קצר" } = Astro.props;
---

<aside
  class="mx-auto max-w-[72ch] rounded-[1.35rem] border border-[color-mix(in_srgb,var(--nm-accent)_22%,transparent)] bg-[var(--nm-tint)] px-5 py-4 text-right shadow-sm"
  aria-label={label}
>
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--nm-accent)]">{label}</p>
  <div class="mt-3 text-[clamp(1rem,0.95rem+0.2vw,1.12rem)] leading-8 text-[color-mix(in_srgb,var(--nm-fg)_88%,var(--nm-bg))]">
    <slot />
  </div>
</aside>
