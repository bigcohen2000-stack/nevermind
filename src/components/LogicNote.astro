---
interface Props {
  term: string;
  explanation: string;
}

const { term, explanation } = Astro.props as Props;
---

<details class="nm-logic-note">
  <summary>{term}</summary>
  <span class="nm-logic-note__tooltip" role="note">{explanation}</span>
</details>

<style>
  .nm-logic-note {
    position: relative;
    display: inline-block;
    margin-inline: 0.15rem;
  }

  .nm-logic-note summary {
    display: inline-flex;
    cursor: pointer;
    list-style: none;
    align-items: center;
    gap: 0.2rem;
    border-bottom: 1px dashed color-mix(in srgb, var(--nm-accent) 50%, transparent);
    color: var(--nm-fg);
    font-weight: 600;
  }

  .nm-logic-note summary::-webkit-details-marker {
    display: none;
  }

  .nm-logic-note__tooltip {
    position: absolute;
    inset-inline-end: 0;
    top: calc(100% + 0.55rem);
    z-index: 25;
    width: min(20rem, 72vw);
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--nm-fg) 10%, transparent);
    background: color-mix(in srgb, var(--nm-bg-canvas) 98%, transparent);
    padding: 0.8rem 0.95rem;
    box-shadow: 0 20px 50px color-mix(in srgb, var(--nm-fg) 8%, transparent);
    font-size: 0.95rem;
    line-height: 1.8;
    color: color-mix(in srgb, var(--nm-fg) 78%, var(--nm-bg-canvas));
  }

  .nm-logic-note:not([open]) .nm-logic-note__tooltip {
    display: none;
  }
</style>
