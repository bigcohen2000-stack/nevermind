---
const sections = [
  {
    group: "מרכז שליטה",
    items: [
      { href: "#overview", label: "סקירה", note: "מה פתוח עכשיו" },
      { href: "#access", label: "גישה וחברים", note: "מי בפנים ומתי" },
      { href: "#content-health", label: "תוכן", note: "מאמרים ומה לעדכן" },
      { href: "#system-health", label: "מערכת", note: "מה עובד ומה חסר" },
    ],
  },
  {
    group: "כלים",
    items: [
      { href: "/admin/generator/", label: "מחולל מאמרים", note: "שאלה -> מאמר" },
      { href: "/me/unlock/", label: "פתיחת גישה", note: "מה רואה אורח" },
    ],
  },
];
---

<aside class="hidden lg:block">
  <div class="sticky top-32 rounded-[28px] border border-black/8 bg-white/78 p-4 shadow-[0_18px_50px_rgba(26,26,26,0.05)] backdrop-blur-sm">
    <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#D42B2B]">ניווט</p>
    <nav class="mt-4 space-y-5" aria-label="ניווט פנימי">
      {sections.map((section) => (
        <div class="space-y-2">
          <p class="text-sm font-semibold text-[#1A1A1A]">{section.group}</p>
          <ul class="space-y-2">
            {section.items.map((item) => (
              <li>
                <a href={item.href} class="flex items-center justify-between rounded-2xl border border-black/7 bg-[#FAFAF8] px-3 py-2 text-sm text-black/70 transition hover:border-[#D42B2B]/25 hover:text-[#1A1A1A]">
                  <span>{item.label}</span>
                  <span class="text-xs text-black/45">{item.note}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>
</aside>
