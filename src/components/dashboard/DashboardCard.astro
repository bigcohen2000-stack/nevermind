---
import HelpText from "./HelpText.astro";
import MechanismCard from "./MechanismCard.astro";

const {
  title,
  eyebrow = "",
  description = "",
  sublabel = "",
  helpText = "",
  mechanismTitle = "",
  mechanismSummary = "",
  mechanismDetails = [],
  id,
} = Astro.props;
---

<article id={id} class="rounded-[28px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/84 p-5 shadow-[0_20px_60px_rgba(26,26,26,0.05)] backdrop-blur-sm dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)]">
  {eyebrow ? <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#D42B2B] dark:text-[#ff8a8a]">{eyebrow}</p> : null}
  {title ? <h2 class="mt-2 text-xl font-semibold text-[#1A1A1A] dark:text-[#FAFAF8]">{title}</h2> : null}
  {description ? <p class="mt-2 max-w-3xl text-sm leading-7 text-[#1A1A1A]/62 dark:text-[#FAFAF8]/64">{description}</p> : null}

  {(sublabel || mechanismTitle) ? (
    <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
      {sublabel ? <HelpText text={sublabel} /> : <span></span>}
      {mechanismTitle ? (
        <MechanismCard title={mechanismTitle} summary={mechanismSummary} details={mechanismDetails} icon="⌘" />
      ) : null}
    </div>
  ) : null}

  {helpText ? <div class="mt-3"><HelpText text={helpText} /></div> : null}
  <div class="mt-4">
    <slot />
  </div>
</article>
