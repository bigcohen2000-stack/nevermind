---
const {
  title,
  summary,
  details = [],
  icon = "○",
} = Astro.props as {
  title: string;
  summary: string;
  details?: string[];
  icon?: string;
};
---

<div class="group relative inline-flex max-w-full">
  <button
    type="button"
    class="inline-flex items-center gap-2 rounded-full border-[0.5px] border-[rgba(26,26,26,0.1)] bg-white/78 px-3 py-1.5 text-xs text-[#1A1A1A]/68 shadow-[0_8px_24px_rgba(26,26,26,0.04)] backdrop-blur-sm transition hover:border-[rgba(212,43,43,0.2)] hover:text-[#1A1A1A] dark:border-[rgba(250,250,248,0.12)] dark:bg-[rgba(255,255,255,0.05)] dark:text-[#FAFAF8]/68 dark:hover:border-[rgba(212,43,43,0.22)] dark:hover:text-[#FAFAF8]"
    aria-label={title}
  >
    <span class="text-[11px] text-[#D42B2B] dark:text-[#ff8a8a]">{icon}</span>
    <span>{title}</span>
  </button>

  <div class="pointer-events-none absolute right-0 top-[calc(100%+0.65rem)] z-20 w-[min(24rem,calc(100vw-2rem))] rounded-[22px] border-[0.5px] border-[rgba(26,26,26,0.1)] bg-[#FAFAF8]/96 p-4 text-right opacity-0 shadow-[0_20px_50px_rgba(26,26,26,0.08)] backdrop-blur-md transition duration-200 group-hover:pointer-events-auto group-hover:opacity-100 dark:border-[rgba(250,250,248,0.12)] dark:bg-[#1A1A1A]/94">
    <p class="text-sm font-semibold text-[#1A1A1A] dark:text-[#FAFAF8]">{title}</p>
    <p class="mt-2 text-xs leading-6 text-[#1A1A1A]/72 dark:text-[#FAFAF8]/72">{summary}</p>
    {details.length > 0 ? (
      <ul class="mt-3 space-y-2 text-xs leading-6 text-[#1A1A1A]/66 dark:text-[#FAFAF8]/68">
        {details.map((detail) => <li>{detail}</li>)}
      </ul>
    ) : null}
  </div>
</div>
