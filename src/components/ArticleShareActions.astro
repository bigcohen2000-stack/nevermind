---
interface Props {
  whatsappShareUrl: string;
  shareUrl: string;
}

const { whatsappShareUrl, shareUrl } = Astro.props as Props;
---

<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-end">
  <a
    href={whatsappShareUrl}
    target="_blank"
    rel="noreferrer"
    class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-4 py-2 text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] font-semibold text-white transition-colors duration-200 hover:bg-[#1FAE55] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#25D366]"
    aria-label="הפץ את האור בוואטסאפ"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M20 4 4 20"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        opacity="0.0"
      />
      <path
        d="M20 4L4 20"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        opacity="0.0"
      />
      <path
        d="M12 2a10 10 0 0 0-7.05 17.05L4 22l2.95-.95A10 10 0 1 0 12 2Z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linejoin="round"
        opacity="0.0"
      />
      <path
        d="M20 4L4 20"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        opacity="0.0"
      />
      <path
        d="M20 12a8 8 0 0 1-8 8c-1.2 0-2.35-.3-3.37-.86L4 20l.86-4.63A8 8 0 1 1 20 12Z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linejoin="round"
        opacity="1"
      />
      <path
        d="M10 9c.8 2 2 3 4 4"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
    הפץ את האור
  </a>

  <button
    type="button"
    data-copy-link
    data-copy-value={shareUrl}
    class="inline-flex items-center justify-center gap-2 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/70 px-4 py-2 text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] font-semibold text-[var(--nm-fg)]/75 transition-colors duration-200 hover:bg-white"
    aria-label="העתק קישור למאמר"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M9 15l-2 2a2 2 0 0 1-3-3l2-2"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        d="M15 9l2-2a2 2 0 0 1 3 3l-2 2"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        d="M7 17l10-10"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
    העתק קישור
  </button>

  <button
    type="button"
    onclick="window.print()"
    class="inline-flex items-center justify-center gap-2 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/70 px-4 py-2 text-[clamp(0.9rem,0.85rem+0.2vw,1.05rem)] font-semibold text-[var(--nm-fg)]/75 transition-colors duration-200 hover:bg-white"
    aria-label="הדפס את המאמר"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M7 7V3h10v4"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        d="M7 17h10v4H7v-4Z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        d="M6 9h12a2 2 0 0 1 2 2v3H4v-3a2 2 0 0 1 2-2Z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
    הדפס
  </button>
</div>

<div
  data-copy-toast
  class="pointer-events-none fixed bottom-6 right-6 z-50 rounded-full border border-[color-mix(in_srgb,var(--nm-fg)_10%,transparent)] bg-white/90 px-4 py-2 text-[clamp(0.85rem,0.8rem+0.2vw,1rem)] text-[color-mix(in_srgb,var(--nm-fg)_70%,var(--nm-bg))] opacity-0 transition-opacity duration-300"
>
  הועתק
</div>

