---
import type { GlossaryConcept } from "../data/glossary";

interface Props {
  concepts: GlossaryConcept[];
}

const { concepts = [] } = Astro.props as Props;
---

{concepts.length > 0 && (
  <section class="rounded-[1.8rem] border border-[#1A1A1A]/10 bg-[#FAFAF8] p-5 text-right">
    <div class="space-y-2">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#D42B2B]">Deep Dive</p>
      <h2 class="text-xl font-semibold text-[#1A1A1A]">מושגים קשורים</h2>
      <p class="text-sm leading-7 text-[#1A1A1A]/62">
        אם הנקודה הזאת כבר נגעה במשהו עמוק יותר, המשך מכאן למושגים שמחזיקים את אותה חקירה מזווית שקטה יותר.
      </p>
    </div>

    <div class="mt-4 flex flex-wrap justify-end gap-3">
      {concepts.map((concept) => (
        <a
          href={`/glossary/${concept.slug}/`}
          class="inline-flex items-center rounded-full border border-[#D42B2B]/14 bg-white px-4 py-2 text-sm font-semibold text-[#1A1A1A] transition hover:border-[#D42B2B]/28 hover:bg-[#FFF7F6]"
        >
          {concept.title}
        </a>
      ))}
    </div>
  </section>
)}
