---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="inline-flex items-center gap-2 rounded-full border border-[#D42B2B]/14 bg-[#FFF4F3] px-3 py-2 text-right text-xs font-semibold text-[#D42B2B] shadow-[0_10px_24px_rgba(212,43,43,0.08)]">
  <span class="inline-flex h-2.5 w-2.5 rounded-full bg-[#D42B2B]"></span>
  <span>{text}</span>
</div>
