{
  "name": "nevermind-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "check:text": "node scripts/check-text-integrity.mjs",
    "check": "npm run validate && astro check && npm run validate:links",
    "validate:articles": "node --experimental-strip-types scripts/validate-article-frontmatter.ts",
    "validate": "npm run check:text && npm run validate:articles && node scripts/pre-publish-check.mjs",
    "migration:report": "node scripts/migration-orphan-report.mjs",
    "validate:links": "node scripts/validate-links.mjs",
    "check:migration": "node scripts/final-migration-check.mjs",
    "update:migration-analytics": "node scripts/update-migration-from-analytics.mjs",
    "sync:redirects": "node scripts/update-migration-from-analytics.mjs --sync-redirects-only",
    "check:titles": "node scripts/check-page-titles.mjs",
    "prebuild": "npm run validate && node scripts/generate-article-paths.mjs && node scripts/generate-admin-build-report.mjs --stage=prebuild",
    "build": "astro build",
    "postbuild": "node scripts/generate-rss.mjs && node scripts/check-internal-links.mjs && node scripts/generate-admin-build-report.mjs --stage=postbuild && node scripts/postbuild-article-seo-check.mjs",
    "preview": "astro preview",
    "test": "vitest",
    "test:accessibility": "playwright test e2e/accessibility.spec.js",
    "lighthouse": "lighthouse http://localhost:4321 --output html --output-path ./lighthouse-report.html",
    "optimize:images": "node scripts/optimize-images.mjs",
    "format": "prettier --write .",
    "pagefind": "pagefind --site dist",
    "pre-deploy": "npm run verify:prod-env && node scripts/pre-deploy-check.js",
    "verify:prod-env": "node scripts/verify-production-env.mjs",
    "copy:audit": "node scripts/copy-audit-forbidden.mjs",
    "deploy": "npm run pre-deploy && npm run build",
    "deploy:cloudflare": "npm run pre-deploy && npm run build && wrangler pages deploy dist --project-name nevermind",
    "report:admin-health": "node scripts/generate-admin-build-report.mjs --stage=manual",
    "deploy:worker": "npm run pre-deploy && wrangler deploy --config workers/club-auth/wrangler.toml",
    "deploy:all": "npm run pre-deploy && npm run build && wrangler pages deploy dist --project-name nevermind && wrangler deploy --config workers/club-auth/wrangler.toml"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource-variable/assistant": "^5.2.9",
    "@fontsource/heebo": "^5.2.8",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "astro": "^5.18.1",
    "astro-pagefind": "^1.8.5",
    "csv-parse": "^5.5.2",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "lite-youtube-embed": "^0.3.4",
    "marked": "^17.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "unist-util-visit": "^5.1.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "browserslist": "^4.28.2",
    "jsdom": "^29.0.1",
    "lighthouse": "^13.0.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.4",
    "typescript": "^5.6.3",
    "unist-util-visit-parents": "^6.0.1",
    "vitest": "^4.1.2",
    "yargs-parser": "^21.1.1"
  },
  "type": "module"
}
