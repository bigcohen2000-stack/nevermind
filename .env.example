# Web3Forms — טפסים (נחשף ללקוח עם PUBLIC_)
# PUBLIC_WEB3FORMS_ACCESS_KEY=

# העתק ל-.env או הגדר בממשק הפריסה (Cloudflare Pages וכו׳)
# לוג שגיאות דפדפן (אופציונלי): POST JSON ללא נתונים רגישים
# PUBLIC_CLIENT_LOG_URL=

# וואטסאפ לכפתור DirectLink (ספרות בלבד, עם קידומת מדינה). אם ריק: נשתמש ב-appConfig או ב-PUBLIC_CONTACT_EMAIL
# PUBLIC_WHATSAPP_NUMBER=972555634035
# PUBLIC_CONTACT_EMAIL=mail@nevermind.co.il

# העתקה ל-.env.local (כלי שמחפשים שם משתנה של Next). Astro טוען רק PUBLIC_*
# NEXT_PUBLIC_WHATSAPP_NUMBER=972555634035

# Google Analytics 4 — מזהה סטרים לדפדפן (חובה PUBLIC_ כדי שיטען בלקוח אחרי הסכמת עוגיות)
# Property 343135032
# PUBLIC_GA_MEASUREMENT_ID=G-361341467

# דיווח שרתי כשמאמר פרימיום נפתח (GA4 Measurement Protocol — Admin → Data stream → Measurement Protocol API secrets)
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_API_SECRET=xxxxxxxxxxxxxxxx

# אופציונלי: POST JSON לכל פתיחת פרימיום (type, article_slug, unlock_scroll_ratio, …)
# ANALYTICS_PREMIUM_WEBHOOK_URL=https://example.com/hooks/premium-open

# חתימת fragment למאמרי פרימיום + עוגיית סשן (מינימום 16 תווים). בפרודקשן חובה ערך ייחודי.
# PREMIUM_SESSION_SECRET=

# כניסת חברי מועדון בעמוד /services/ — POST JSON { phone, password, path } ל־Worker; תגובה { ok, memberName?, expiresAt?, error? }
# PUBLIC_NM_CLUB_WEBHOOK_URL=

# לוח ניהול ב-/dashboard/ דרך פרוקסי Pages + Cloudflare Access (מומלץ במקום JWT בדפדפן)
# PUBLIC_CLUB_ADMIN_VIA_PROXY=true
