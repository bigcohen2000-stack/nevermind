# Web3Forms
# PUBLIC_WEB3FORMS_ACCESS_KEY=

# Optional client-side error log endpoint
# PUBLIC_CLIENT_LOG_URL=

# Optional contact overrides
# PUBLIC_WHATSAPP_NUMBER=972555634035
# PUBLIC_CONTACT_EMAIL=mail@nevermind.co.il

# Legacy compatibility for tools that still look for NEXT_PUBLIC_*
# NEXT_PUBLIC_WHATSAPP_NUMBER=972555634035

# Cloudflare Web Analytics is loaded from Layout.astro
# If you later move the token to env, add:
# PUBLIC_CF_WEB_ANALYTICS_TOKEN=

# Optional webhook for premium article open events
# ANALYTICS_PREMIUM_WEBHOOK_URL=https://example.com/hooks/premium-open

# Premium article session secret. Use at least 16 characters in production
# PREMIUM_SESSION_SECRET=

# Club member login endpoint used by /services/ and /club/
# PUBLIC_NM_CLUB_WEBHOOK_URL=

# Dashboard access via Pages proxy and Cloudflare Access
# PUBLIC_CLUB_ADMIN_VIA_PROXY=true

# Search gap storage is a Cloudflare Pages KV binding, not an env var
# Binding name: SEARCH_GAPS

# Optional hCaptcha public site key
# PUBLIC_HCAPTCHA_SITE_KEY=
